#!/bin/bash

# Map — insertion-ordered associative array container.
#
# Wraps a bash associative array (declare -gA) with object semantics.
# Implements the Container contract with key-value operations: get, set,
# delete, has, keys, values, and iteration via toArray.
#
# Storage: each Map instance owns a global associative array named
# __bashClass_data_${self}. Key-value data lives there, not in the
# pipe-delimited descriptor. This gives us native bash associative array
# performance for lookups while the object system handles identity,
# dispatch, and lifecycle.
#
# Key ordering: Map maintains insertion order via a companion indexed
# array __bashClass_keys_${self}. All traversal methods (keys, values,
# toArray, toString, each, iterator) walk keys in the order they were
# first inserted. Overwriting an existing key updates the value but does
# NOT change the key's position in the order. Deleting a key removes it
# from the ordered list; re-inserting it places it at the end.
#
# Composition: Map values can be any string, including object IDs.
# Storing a List's ID as a value creates a dictionary-of-lists pattern.
# Storing another Map's ID creates nested dictionaries. Same turtles,
# different shell.

# Load guard — if already registered, nothing to do
[[ -n "${__bashClass_registry[Map]+set}" ]] && return 2>/dev/null

. boop Container

# ============================================================================
# Map Class Descriptor
# ============================================================================

__bashClass_registry["Map"]="|class=Map|parent=Container|methods=new,get,set,delete,length,clear,has,keys,values,toArray,toString,each|properties=type"

# ============================================================================
# Map Implementation Functions
# ============================================================================

# Constructor — creates a new Map instance with an associative companion array
# and an indexed companion array for tracking insertion order.
#
# Usage: into=mymap Map
Map.new() {
  local -I _Class
  : "${_Class:=Map}"
  local __Map_new_self
  into=__Map_new_self __bashClass.new type=associative "$@"
  declare -gA "__bashClass_data_${__Map_new_self}"
  declare -ga "__bashClass_keys_${__Map_new_self}"
  eval "__bashClass_data_${__Map_new_self}+=()"
  eval "__bashClass_keys_${__Map_new_self}+=()"
  __bashClass.return "$__Map_new_self" ${into:-}
}

# Retrieve a value by its string key.
#
# Returns empty string if the key doesn't exist — not a crash.
#
# Usage: into=val $map.get "host"
Map.get() {
  local -I _Self _Class
  local __Map_get_key="$1"
  local -n __Map_get_arr="__bashClass_data_${_Self}"
  __bashClass.return "${__Map_get_arr[$__Map_get_key]:-}" ${into:-}
}

# Store a key-value pair in the map.
#
# If the key already exists, its value is overwritten but its position
# in the insertion order is preserved. If the key is new, it's appended
# to the ordered key list.
#
# Usage: $map.set "host" "localhost"
Map.set() {
  local -I _Self _Class
  local __Map_set_key="$1" __Map_set_val="$2"
  local -n __Map_set_arr="__bashClass_data_${_Self}"
  local -n __Map_set_keys="__bashClass_keys_${_Self}"

  # If key is new, append to ordered key list
  if [[ -z "${__Map_set_arr[$__Map_set_key]+set}" ]]; then
    __Map_set_keys+=("$__Map_set_key")
  fi

  __Map_set_arr[$__Map_set_key]="$__Map_set_val"
}

# Remove a key-value pair from the map.
#
# Removes from both the data array and the ordered key list.
# Silent no-op if the key doesn't exist.
#
# Usage: $map.delete "debug"
Map.delete() {
  local -I _Self _Class
  local __Map_del_key="$1"
  local -n __Map_del_arr="__bashClass_data_${_Self}"
  local -n __Map_del_keys="__bashClass_keys_${_Self}"

  unset "__Map_del_arr[$__Map_del_key]"

  # Remove from ordered key list and compact
  local -a __Map_del_new=()
  local __Map_del_k
  if [[ -n "${!__Map_del_keys[@]}" ]]; then
    for __Map_del_k in "${__Map_del_keys[@]}"; do
      [[ "$__Map_del_k" != "$__Map_del_key" ]] && __Map_del_new+=("$__Map_del_k")
    done
  fi
  __Map_del_keys=("${__Map_del_new[@]+"${__Map_del_new[@]}"}")
}

# Return the number of key-value pairs in the map.
#
# Usage: into=len $map.length
Map.length() {
  local -I _Self _Class
  local -n __Map_length_arr="__bashClass_data_${_Self}"
  local -i __Map_length_len=0; [[ -n "${!__Map_length_arr[@]}" ]] && __Map_length_len=${#__Map_length_arr[@]}
  __bashClass.return "$__Map_length_len" ${into:-}
}

# Remove all key-value pairs from the map.
#
# Usage: $map.clear
Map.clear() {
  local -I _Self _Class
  local -n __Map_clear_arr="__bashClass_data_${_Self}"
  local -n __Map_clear_keys="__bashClass_keys_${_Self}"
  __Map_clear_arr=()
  __Map_clear_keys=()
}

# Check whether a key exists in the map.
#
# Usage: $map.has "host" && printf "host is configured"
Map.has() {
  local -I _Self _Class
  local __Map_has_key="$1"
  local -n __Map_has_arr="__bashClass_data_${_Self}"
  [[ -n "${__Map_has_arr[$__Map_has_key]+set}" ]] && return 0 || return 1
}

# Return all keys as a newline-delimited string in insertion order.
#
# Usage: into=k $map.keys
Map.keys() {
  local -I _Self _Class
  local -n __Map_keys_keys="__bashClass_keys_${_Self}"
  local __Map_keys_out
  if ! [[ -n "${!__Map_keys_keys[@]}" ]] || (( ${#__Map_keys_keys[@]} == 0 )); then
    __bashClass.return "" ${into:-}
    return
  fi
  printf -v __Map_keys_out "%s\n" "${__Map_keys_keys[@]}"
  __Map_keys_out="${__Map_keys_out%$'\n'}"
  __bashClass.return "$__Map_keys_out" ${into:-}
}

# Return all values as a newline-delimited string in insertion order.
#
# Values appear in the same order as keys() — the Nth value line
# matches the Nth key line.
#
# Usage: into=v $map.values
Map.values() {
  local -I _Self _Class
  local -n __Map_values_arr="__bashClass_data_${_Self}"
  local -n __Map_values_keys="__bashClass_keys_${_Self}"
  local __Map_values_out=""
  if ! [[ -n "${!__Map_values_keys[@]}" ]] || (( ${#__Map_values_keys[@]} == 0 )); then
    __bashClass.return "" ${into:-}
    return
  fi
  local __Map_values_k __Map_values_first=1
  for __Map_values_k in "${__Map_values_keys[@]}"; do
    (( __Map_values_first )) || __Map_values_out="$__Map_values_out
"
    __Map_values_out="$__Map_values_out${__Map_values_arr[$__Map_values_k]}"
    __Map_values_first=0
  done
  __bashClass.return "$__Map_values_out" ${into:-}
}

# Serialize all entries as newline-delimited "key=value" lines in insertion order.
#
# Usage: into=entries $map.toArray
Map.toArray() {
  local -I _Self _Class
  local -n __Map_toArray_arr="__bashClass_data_${_Self}"
  local -n __Map_toArray_keys="__bashClass_keys_${_Self}"
  local __Map_toArray_out="" __Map_toArray_key __Map_toArray_first=1
  if [[ -n "${!__Map_toArray_keys[@]}" ]]; then
    for __Map_toArray_key in "${__Map_toArray_keys[@]}"; do
      (( __Map_toArray_first )) || __Map_toArray_out="$__Map_toArray_out
"
      __Map_toArray_out="$__Map_toArray_out$__Map_toArray_key=${__Map_toArray_arr[$__Map_toArray_key]}"
      __Map_toArray_first=0
    done
  fi
  __bashClass.return "$__Map_toArray_out" ${into:-}
}

# Human-readable representation in insertion order.
#
# Format: Map(_a1b2c3){ host="localhost", port="8080" }
#
# Usage: $map.toString
Map.toString() {
  local -I _Self _Class
  local -n __Map_ts_arr="__bashClass_data_${_Self}"
  local -n __Map_ts_keys="__bashClass_keys_${_Self}"
  local __Map_ts_out="Map($_Self){ " __Map_ts_key __Map_ts_first=1
  if [[ -n "${!__Map_ts_keys[@]}" ]]; then
    for __Map_ts_key in "${__Map_ts_keys[@]}"; do
      (( __Map_ts_first )) || __Map_ts_out="$__Map_ts_out, "
      __Map_ts_out="$__Map_ts_out$__Map_ts_key=\"${__Map_ts_arr[$__Map_ts_key]}\""
      __Map_ts_first=0
    done
  fi
  __Map_ts_out="$__Map_ts_out }"
  __bashClass.return "$__Map_ts_out" ${into:-}
}

# Iterate over all entries in insertion order, calling a user function for each.
#
# The callback receives two arguments: the key and the value.
# If the callback returns non-zero, iteration stops immediately.
#
# Usage: $map.each my_callback
Map.each() {
  local -I _Self _Class
  local __Map_each_fn="$1"
  local -n __Map_each_arr="__bashClass_data_${_Self}"
  local -n __Map_each_keys="__bashClass_keys_${_Self}"
  [[ -n "${!__Map_each_keys[@]}" ]] || return 0
  local __Map_each_key
  for __Map_each_key in "${__Map_each_keys[@]}"; do
    "$__Map_each_fn" "$__Map_each_key" "${__Map_each_arr[$__Map_each_key]}" || return
  done
}

# ============================================================================
# Register Methods & Finalize
# ============================================================================

__bashClass.registerMethod Map new Map.new
__bashClass.registerMethod Map get Map.get
__bashClass.registerMethod Map set Map.set
__bashClass.registerMethod Map delete Map.delete
__bashClass.registerMethod Map length Map.length
__bashClass.registerMethod Map clear Map.clear
__bashClass.registerMethod Map has Map.has
__bashClass.registerMethod Map keys Map.keys
__bashClass.registerMethod Map values Map.values
__bashClass.registerMethod Map toArray Map.toArray
__bashClass.registerMethod Map toString Map.toString
__bashClass.registerMethod Map each Map.each
__bashClass.registerClass Map
