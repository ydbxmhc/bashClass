#!/bin/bash
set -uo pipefail

# Math tests — TestSuite version

. boop TestSuite Math

into=t TestSuite name="Math Tests"

# Use low precision for fast tests
__Math.setPrecision 10

# ============================================================================
# Construction
# ============================================================================

$t.section "Construction"
into=m1 Math 3.14;  into=v $m1.val; $t.assert_eq "3.14" "$v" "3.14"
into=m2 Math 42;    into=v $m2.val; $t.assert_eq "integer 42" "$v" "42"
into=m3 Math -7.5;  into=v $m3.val; $t.assert_eq "-7.5" "$v" "-7.5"
into=m4 Math 0;     into=v $m4.val; $t.assert_eq "zero" "$v" "0"
into=m5 Math 0.001; into=v $m5.val; $t.assert_eq "0.001" "$v" "0.001"
into=m6 Math -0;    into=v $m6.val; $t.assert_eq "negative zero normalizes" "$v" "0"

# ============================================================================
# Addition
# ============================================================================

$t.section "Addition"
into=a1 Math 1.5; into=a2 Math 2.3
into=r $a1.add $a2; into=v $r.val; $t.assert_eq "1.5 + 2.3 = 3.8" "$v" "3.8"
into=r $a1.add -1.5; into=v $r.val; $t.assert_eq "1.5 + (-1.5) = 0" "$v" "0"
into=a5 Math -3.0; into=a6 Math -2.0
into=r $a5.add $a6; into=v $r.val; $t.assert_eq "-3 + (-2) = -5" "$v" "-5"
into=a8 Math 999; into=a9 Math 1
into=r $a8.add $a9; into=v $r.val; $t.assert_eq "999 + 1 = 1000" "$v" "1000"
into=a11 Math 0.1; into=a12 Math 0.2
into=r $a11.add $a12; into=v $r.val; $t.assert_eq "0.1 + 0.2 = 0.3 (exact)" "$v" "0.3"

# ============================================================================
# Subtraction
# ============================================================================

$t.section "Subtraction"
into=s1 Math 5.0; into=s2 Math 3.2
into=r $s1.sub $s2; into=v $r.val; $t.assert_eq "5 - 3.2 = 1.8" "$v" "1.8"
into=r $s2.sub $s1; into=v $r.val; $t.assert_eq "3.2 - 5 = -1.8" "$v" "-1.8"
into=s5 Math 100; into=s6 Math 100
into=r $s5.sub $s6; into=v $r.val; $t.assert_eq "100 - 100 = 0" "$v" "0"

# ============================================================================
# Multiplication
# ============================================================================

$t.section "Multiplication"
into=mu1 Math 2.5; into=mu2 Math 4
into=r $mu1.mul $mu2; into=v $r.val; $t.assert_eq "2.5 * 4 = 10" "$v" "10"
into=mu4 Math -3; into=mu5 Math 7
into=r $mu4.mul $mu5; into=v $r.val; $t.assert_eq "-3 * 7 = -21" "$v" "-21"
into=mu7 Math 0.1; into=mu8 Math 0.1
into=r $mu7.mul $mu8; into=v $r.val; $t.assert_eq "0.1 * 0.1 = 0.01" "$v" "0.01"
into=mu10 Math 12345; into=mu11 Math 67890
into=r $mu10.mul $mu11; into=v $r.val; $t.assert_eq "12345 * 67890 = 838102050" "$v" "838102050"

# ============================================================================
# Division
# ============================================================================

$t.section "Division"
into=d1 Math 10; into=d2 Math 4
into=r precision=10 $d1.div $d2; into=v $r.val
$t.assert_eq "10 / 4 = 2.5" "$v" "2.5"
into=d4 Math 1; into=d5 Math 3
into=r precision=10 $d4.div $d5; into=v $r.val
$t.assert_match "1 / 3 ≈ 0.333..." "$v" "0.333333333*"
into=d7 Math 22; into=d8 Math 7
into=r precision=15 $d7.div $d8; into=v $r.val
$t.assert_match "22 / 7 ≈ 3.14285714..." "$v" "3.14285714*"

# ============================================================================
# Comparisons
# ============================================================================

$t.section "Comparisons"
into=c1 Math 3.14; into=c2 Math 2.71; into=c3 Math 3.14
$t.assert_ok "3.14 eq 3.14" $c1.eq $c3
$t.assert_fail "3.14 eq 2.71" $c1.eq $c2
$t.assert_ok "3.14 gt 2.71" $c1.gt $c2
$t.assert_ok "2.71 lt 3.14" $c2.lt $c1
$t.assert_ok "3.14 ge 3.14" $c1.ge $c3
$t.assert_ok "3.14 le 3.14" $c1.le $c3
into=c4 Math -5; into=c5 Math 3
$t.assert_ok "-5 lt 3" $c4.lt $c5
$t.assert_ok "3 gt -5" $c5.gt $c4

# ============================================================================
# Utilities
# ============================================================================

$t.section "Utilities"
into=u1 Math -42.5
into=r $u1.abs; into=v $r.val; $t.assert_eq "abs(-42.5) = 42.5" "$v" "42.5"
into=u3 Math 7.7
into=r $u3.neg; into=v $r.val; $t.assert_eq "neg(7.7) = -7.7" "$v" "-7.7"
into=u5 Math 3.14159
into=u6 $u5.toInt; $t.assert_eq "toInt(3.14159) = 3" "$u6" "3"

# ============================================================================
# Pi calculation
# ============================================================================

$t.section "Pi (10 digits)"
into=pi10 Math.pi 10
into=v $pi10.val
$t.assert_match "pi(10) starts with 3.14159265" "$v" "3.14159265*"

$t.section "Pi (20 digits)"
into=pi20 Math.pi 20
into=v $pi20.val
$t.assert_match "pi(20) starts with 3.141592653589793238" "$v" "3.141592653589793238*"

$t.section "Pi (50 digits)"
into=pi50 Math.pi 50
into=v $pi50.val
$t.assert_match "pi(50) matches known value" "$v" "3.141592653589793238462643383279502884197169399375*"

# ============================================================================
# Square (loop)
# ============================================================================

$t.section "Square (loop)"
for __sq_x in 1 2 3 4 5; do
  into=__sq_m Math $__sq_x
  into=__sq_r $__sq_m.square
  into=v $__sq_r.val
  $t.assert_eq "${__sq_x}² = $(( __sq_x * __sq_x ))" "$v" "$(( __sq_x * __sq_x ))"
done

# ============================================================================
# Full-word instance methods
# ============================================================================

$t.section "Full-word instance methods"
into=fw1 Math 10; into=fw2 Math 3
into=r $fw1.subtract $fw2; into=v $r.val; $t.assert_eq "10.subtract(3) = 7" "$v" "7"
into=r $fw1.multiply $fw2; into=v $r.val; $t.assert_eq "10.multiply(3) = 30" "$v" "30"
into=r $fw1.divide $fw2; into=v $r.val
$t.assert_match "10.divide(3) ≈ 3.333..." "$v" "3.333333333*"

# ============================================================================
# Static API
# ============================================================================

$t.section "Static API"
into=v Math.add 1.5 2.3;      $t.assert_eq "Math.add 1.5 2.3 = 3.8" "$v" "3.8"
into=v Math.subtract 10 3.5;  $t.assert_eq "Math.subtract 10 3.5 = 6.5" "$v" "6.5"
into=v Math.multiply 2.5 4;   $t.assert_eq "Math.multiply 2.5 4 = 10" "$v" "10"
into=v Math.divide 10 4;      $t.assert_eq "Math.divide 10 4 = 2.5" "$v" "2.5"
into=v Math.square 7;         $t.assert_eq "Math.square 7 = 49" "$v" "49"
into=v Math.abs -42.5;        $t.assert_eq "Math.abs -42.5 = 42.5" "$v" "42.5"
into=v Math.neg 3.14;         $t.assert_eq "Math.neg 3.14 = -3.14" "$v" "-3.14"

# ============================================================================
# Symbol aliases
# ============================================================================

$t.section "Symbol aliases"
into=v Math.+ 1.5 2.3; $t.assert_eq "Math.+ = 3.8" "$v" "3.8"
into=v Math.- 10 3.5;  $t.assert_eq "Math.- = 6.5" "$v" "6.5"
into=v Math.x 2.5 4;   $t.assert_eq "Math.x = 10" "$v" "10"
into=v Math./ 10 4;    $t.assert_eq "Math./ = 2.5" "$v" "2.5"

# ============================================================================
# Math.DO (infix)
# ============================================================================

$t.section "Math.DO (infix)"
into=v Math.DO 1.5 + 2.3;                    $t.assert_eq "1.5 + 2.3 = 3.8" "$v" "3.8"
into=v Math.DO 2 + 3 x 4;                    $t.assert_eq "2 + 3 x 4 = 14 (precedence)" "$v" "14"
into=v Math.DO "( 2 + 3 ) x 4";              $t.assert_eq "(2+3) x 4 = 20 (parens)" "$v" "20"
into=v Math.DO 10 - 2 - 3;                   $t.assert_eq "10 - 2 - 3 = 5 (left assoc)" "$v" "5"
into=v Math.DO 100 / 4 / 5;                  $t.assert_eq "100 / 4 / 5 = 5" "$v" "5"
into=v Math.DO "( 1.5 + 2.5 ) x ( 3 - 1 )"; $t.assert_eq "(1.5+2.5)x(3-1) = 8" "$v" "8"
into=v Math.DO "(2+3)x4";                    $t.assert_eq "packed (2+3)x4 = 20" "$v" "20"
into=v Math.DO "10/2+3";                     $t.assert_eq "packed 10/2+3 = 8" "$v" "8"
into=v Math.DO "3 + 4" x 2;                  $t.assert_eq "mixed '3 + 4' x 2 = 11" "$v" "11"
into=v Math.DO "(-3)x4";                     $t.assert_eq "(-3)x4 = -12" "$v" "-12"
into=v Math.DO -5 + 8;                       $t.assert_eq "-5 + 8 = 3" "$v" "3"

# ============================================================================
# Math.RPN (postfix)
# ============================================================================

$t.section "Math.RPN (postfix)"
into=v Math.RPN 1.5 2.3 +;       $t.assert_eq "1.5 2.3 + = 3.8" "$v" "3.8"
into=v Math.RPN 3 4 + 2 x;       $t.assert_eq "3 4 + 2 x = 14" "$v" "14"
into=v Math.RPN "10 3 /";        $t.assert_match "10 3 / starts with 3.33" "$v" "3.33*"
into=v Math.RPN 5 3 - 2 x 1 +;  $t.assert_eq "5 3 - 2 x 1 + = 5" "$v" "5"
into=v Math.RPN "1.5 2.5" + "3" x; $t.assert_eq "mixed '1.5 2.5' + '3' x = 12" "$v" "12"

# ============================================================================
# Static square loop
# ============================================================================

$t.section "Static square loop"
for __ssq_x in 1 2 3 4 5; do
  into=v Math.square $__ssq_x
  $t.assert_eq "Math.square $__ssq_x = $(( __ssq_x * __ssq_x ))" "$v" "$(( __ssq_x * __ssq_x ))"
done

# ============================================================================
# Input validation
# ============================================================================

$t.section "Input validation — rejection"
$t.assert_fail "rejects expression as operand" bash -c '. boop Math; Math.add "(1+2)x3" "4" 2>/dev/null'
$t.assert_fail "rejects alpha string" bash -c '. boop Math; Math.add "abc" "1" 2>/dev/null'
$t.assert_fail "rejects mixed alpha-numeric" bash -c '. boop Math; Math.add "12abc" "1" 2>/dev/null'
$t.assert_fail "rejects trailing alpha" bash -c '. boop Math; Math.add "3.14abc" "1" 2>/dev/null'
$t.assert_fail "rejects special characters" bash -c '. boop Math; Math.add "1+2" "3" 2>/dev/null'
$t.assert_fail "rejects empty string" bash -c '. boop Math; Math.add "" "1" 2>/dev/null'
$t.assert_fail "rejects whitespace-only" bash -c '. boop Math; Math.add "   " "1" 2>/dev/null'
$t.assert_fail "rejects bare minus" bash -c '. boop Math; Math.add "-" "1" 2>/dev/null'
$t.assert_fail "rejects bare dot" bash -c '. boop Math; Math.add "." "1" 2>/dev/null'
$t.assert_fail "rejects minus-dot" bash -c '. boop Math; Math.add "-." "1" 2>/dev/null'
$t.assert_fail "rejects double dot" bash -c '. boop Math; Math.add "1.2.3" "1" 2>/dev/null'
$t.assert_fail "rejects double minus" bash -c '. boop Math; Math.add "--5" "1" 2>/dev/null'
$t.assert_fail "rejects minus in middle" bash -c '. boop Math; Math.add "5-3" "1" 2>/dev/null'
$t.assert_fail "rejects comma decimal" bash -c '. boop Math; Math.add "3,14" "1" 2>/dev/null'
$t.assert_fail "rejects hex notation" bash -c '. boop Math; Math.add "0xFF" "1" 2>/dev/null'
$t.assert_fail "rejects embedded newline" bash -c '. boop Math; Math.add "3
14" "1" 2>/dev/null'
$t.assert_fail "rejects unicode digits" bash -c '. boop Math; Math.add "３" "1" 2>/dev/null'
$t.assert_fail "rejects tab characters" bash -c '. boop Math; Math.add "$(printf "3\t14")" "1" 2>/dev/null'

# Scientific notation — currently rejected, will become valid (see TODO)
$t.assert_fail "rejects scientific notation (positive exp)" bash -c '. boop Math; Math.add "1.5e3" "1" 2>/dev/null'
$t.assert_fail "rejects scientific notation (negative exp)" bash -c '. boop Math; Math.add "2.7E-4" "1" 2>/dev/null'
$t.assert_fail "rejects scientific notation (uppercase)" bash -c '. boop Math; Math.add "1E10" "1" 2>/dev/null'
$t.assert_fail "rejects scientific notation (plus exp)" bash -c '. boop Math; Math.add "1.5e+3" "1" 2>/dev/null'

$t.section "Input validation — acceptance"
into=v Math.add " 3.14 " "1"; $t.assert_eq "trims whitespace" "$v" "4.14"
into=v Math.add ".5" "0";      $t.assert_eq "leading dot (.5)" "$v" "0.5"
into=v Math.add "1." "0";      $t.assert_eq "trailing dot (1.)" "$v" "1"
into=v Math.add "-0" "0";      $t.assert_eq "negative zero normalizes" "$v" "0"
into=v Math.add "-0.0" "0";    $t.assert_eq "negative zero with decimal normalizes" "$v" "0"
into=v Math.add "0777" "0";    $t.assert_eq "leading zeros treated as decimal" "$v" "777"
into=v Math.add "007.5" "0";   $t.assert_eq "leading zeros with decimal" "$v" "7.5"


# ============================================================================
# mod
# ============================================================================

$t.section "mod"
into=v Math.mod 10 3;   $t.assert_eq "10 mod 3 = 1"   "$v" "1"
into=v Math.mod 9 3;    $t.assert_eq "9 mod 3 = 0"    "$v" "0"
into=v Math.mod 7 4;    $t.assert_eq "7 mod 4 = 3"    "$v" "3"
into=v Math.mod 100 7;  $t.assert_eq "100 mod 7 = 2"  "$v" "2"
into=v Math.mod 5 5;    $t.assert_eq "5 mod 5 = 0"    "$v" "0"
# Instance method
into=m1 Math 17; into=m2 Math 5
into=r $m1.mod $m2; into=v $r.val; $t.assert_eq "17 mod 5 = 2 (instance)" "$v" "2"

# ============================================================================
# pow
# ============================================================================

$t.section "pow"
into=v Math.pow 2 10;  $t.assert_eq "2^10 = 1024"   "$v" "1024"
into=v Math.pow 3 3;   $t.assert_eq "3^3 = 27"      "$v" "27"
into=v Math.pow 5 0;   $t.assert_eq "5^0 = 1"       "$v" "1"
into=v Math.pow 7 1;   $t.assert_eq "7^1 = 7"       "$v" "7"
into=v Math.pow 10 6;  $t.assert_eq "10^6 = 1000000" "$v" "1000000"
# Instance method
into=m Math 4
into=r $m.pow 3; into=v $r.val; $t.assert_eq "4^3 = 64 (instance)" "$v" "64"

# ============================================================================
# isZero
# ============================================================================

$t.section "isZero"
into=z  Math 0;    $t.assert_ok   "0 isZero"          $z.isZero
into=nz Math 1;    $t.assert_fail "1 not isZero"       $nz.isZero
into=nz Math -1;   $t.assert_fail "-1 not isZero"      $nz.isZero
into=nz Math 0.1;  $t.assert_fail "0.1 not isZero"     $nz.isZero
into=z  Math -0;   $t.assert_ok   "-0 normalizes to 0" $z.isZero
into=z  Math 0.0;  $t.assert_ok   "0.0 isZero"         $z.isZero

# ============================================================================
# round
# ============================================================================

$t.section "round"
into=m Math 3.14159
into=r $m.round 4; into=v $r.val; $t.assert_eq "3.14159 round 4 = 3.142" "$v" "3.142"
into=r $m.round 2; into=v $r.val; $t.assert_eq "3.14159 round 2 = 3.1"   "$v" "3.1"
into=r $m.round 1; into=v $r.val; $t.assert_eq "3.14159 round 1 = 3"     "$v" "3"
# Half-up rounding
into=m Math 2.5
into=r $m.round 1; into=v $r.val; $t.assert_eq "2.5 round 1 = 3 (half-up)" "$v" "3"
into=m Math 3.5
into=r $m.round 1; into=v $r.val; $t.assert_eq "3.5 round 1 = 4 (half-up)" "$v" "4"
# Already at or below precision — no change
into=m Math 3.14
into=r $m.round 5; into=v $r.val; $t.assert_eq "3.14 round 5 = 3.14 (no change)" "$v" "3.14"

# ============================================================================
# toScale
# ============================================================================

$t.section "toScale"
into=m Math 3.14159
into=r $m.toScale 2; into=v $r.val; $t.assert_eq "3.14159 toScale 2 = 3.14" "$v" "3.14"
into=r $m.toScale 6; into=v $r.val; $t.assert_eq "3.14159 toScale 6 = 3.141590" "$v" "3.141590"
into=m Math 42
into=r $m.toScale 3; into=v $r.val; $t.assert_eq "42 toScale 3 = 42.000" "$v" "42.000"
into=r $m.toScale 0; into=v $r.val; $t.assert_eq "42 toScale 0 = 42"     "$v" "42"

# ============================================================================
# format
# ============================================================================

$t.section "format"
into=m Math 3.14159
into=v $m.format "%.2f";   $t.assert_eq "format %.2f"    "$v" "3.14"
into=v $m.format "%10.3f"; $t.assert_eq "format %10.3f"  "$v" "     3.142"
into=m Math 42
into=v $m.format "%05d";   $t.assert_eq "format %05d"    "$v" "00042"
into=m Math -7.5
into=v $m.format "%.1f";   $t.assert_eq "format negative" "$v" "-7.5"

# ============================================================================
# Division by zero
# ============================================================================

$t.section "Division by zero"
$t.assert_fail "Math.divide by zero crashes" \
  bash -c '. boop Math; Math.divide 5 0 2>/dev/null'
$t.assert_fail "instance div by zero crashes" \
  bash -c '. boop Math; into=m Math 5; into=z Math 0; $m.div $z 2>/dev/null'

# ============================================================================
# Division precision — verify digit count matches configured precision
# ============================================================================

$t.section "Division precision"
# 1/3 at precision 10 should produce exactly 10 significant digits
into=m1 Math 1; into=m2 Math 3
into=r precision=10 $m1.div $m2; into=v $r.val
# Strip "0." prefix and count digits — should be 10
__tc_digits="${v#0.}"
$t.assert_eq "1/3 at precision 10 has 10 digits" "${#__tc_digits}" "10"
$t.assert_match "1/3 starts with 0.3333333333" "$v" "0.3333333333*"

# ============================================================================
# Math.DO — precedence disambiguation
# ============================================================================

$t.section "Math.DO: operator precedence"
# x (multiply) has higher precedence than + — 2 + 3x4 = 2 + 12 = 14
into=v Math.DO 2 + 3 x 4
$t.assert_eq "2 + 3 x 4 = 14 (x binds tighter than +)" "$v" "14"
# If it were left-to-right, 2+3=5, 5x4=20. The result 14 proves x > +.
into=v Math.DO 2 x 3 + 4
$t.assert_eq "2 x 3 + 4 = 10 (x evaluated first)" "$v" "10"
# Parens override precedence
into=v Math.DO "( 2 + 3 ) x 4"
$t.assert_eq "(2+3) x 4 = 20 (parens override)" "$v" "20"

# ============================================================================
# Static API — negative inputs and edge cases
# ============================================================================

$t.section "Static API: edge cases"
into=v Math.neg -3.14;  $t.assert_eq "neg(-3.14) = 3.14 (double negation)" "$v" "3.14"
into=v Math.abs 0;      $t.assert_eq "abs(0) = 0"                          "$v" "0"
into=v Math.abs -0;     $t.assert_eq "abs(-0) = 0"                         "$v" "0"
into=v Math.neg 0;      $t.assert_eq "neg(0) = 0 (zero stays positive)"    "$v" "0"
into=v Math.add 0 0;    $t.assert_eq "0 + 0 = 0"                           "$v" "0"
into=v Math.subtract 0 0; $t.assert_eq "0 - 0 = 0"                         "$v" "0"


$t.summary
