#!/bin/bash
set -u

# Container, List, and Map tests — TestSuite version

. boop TestSuite List Map

into=t TestSuite name="Container Tests"

# ============================================================================
# LIST: Creation
# ============================================================================

$t.section "List: creation"
into=list List
$t.assert_match "valid ID" "$list" "_[0-9a-f]*"
$t.assert_ok "isa List" $list.isa List
$t.assert_ok "isa Container" $list.isa Container
$t.assert_ok "isa bashClass" $list.isa bashClass

# ============================================================================
# LIST: push/pop/length
# ============================================================================

$t.section "List: push/pop/length"
$list.push "alpha" "beta" "gamma"
into=v $list.length; $t.assert_eq "length after push 3" "$v" "3"
into=popped $list.pop
$t.assert_eq "pop returns last" "$popped" "gamma"
into=v $list.length; $t.assert_eq "length after pop" "$v" "2"

# ============================================================================
# LIST: get/set
# ============================================================================

$t.section "List: get/set"
into=v $list.get 0;  $t.assert_eq "get 0" "$v" "alpha"
into=v $list.get 1;  $t.assert_eq "get 1" "$v" "beta"
into=v $list.get -1; $t.assert_eq "get -1 (last)" "$v" "beta"
$list.set 0 "ALPHA"
into=v $list.get 0;  $t.assert_eq "get 0 after set" "$v" "ALPHA"

# ============================================================================
# LIST: shift/unshift
# ============================================================================

$t.section "List: shift/unshift"
into=shifted $list.shift
$t.assert_eq "shift returns first" "$shifted" "ALPHA"
into=v $list.length; $t.assert_eq "length after shift" "$v" "1"
$list.unshift "first" "second"
into=v $list.length; $t.assert_eq "length after unshift 2" "$v" "3"
into=v $list.get 0;  $t.assert_eq "get 0 after unshift" "$v" "first"
into=v $list.get 1;  $t.assert_eq "get 1 after unshift" "$v" "second"
into=v $list.get 2;  $t.assert_eq "get 2 after unshift" "$v" "beta"

# ============================================================================
# LIST: has
# ============================================================================

$t.section "List: has"
$t.assert_ok "has 0 (exists)" $list.has 0
$t.assert_ok "has 2 (exists)" $list.has 2
$t.assert_fail "has 3 (out of range)" $list.has 3
$t.assert_ok "has -1 (last)" $list.has -1
$t.assert_fail "has -4 (too negative)" $list.has -4

# ============================================================================
# LIST: delete
# ============================================================================

$t.section "List: delete"
$list.delete 1
into=v $list.length; $t.assert_eq "length after delete" "$v" "2"
into=v $list.get 0;  $t.assert_eq "get 0 after delete" "$v" "first"
into=v $list.get 1;  $t.assert_eq "get 1 after delete (shifted)" "$v" "beta"

# ============================================================================
# LIST: slice
# ============================================================================

$t.section "List: slice"
$list.clear
$list.push "a" "b" "c" "d" "e"
into=sl $list.slice 1 3
$t.assert_eq "slice 1..3" "$sl" "b
c"
into=sl2 $list.slice 3
$t.assert_eq "slice 3..end" "$sl2" "d
e"
into=sl3 $list.slice -2
$t.assert_eq "slice -2..end" "$sl3" "d
e"

# ============================================================================
# LIST: toArray / toString / isEmpty
# ============================================================================

$t.section "List: toArray/toString/isEmpty"
into=arr $list.toArray
$t.assert_eq "toArray" "$arr" "a
b
c
d
e"
into=s $list.toString
$t.assert_contains "toString has List(" "$s" "List("
$t.assert_fail "not empty" $list.isEmpty
$list.clear
$t.assert_ok "empty after clear" $list.isEmpty
into=v $list.length; $t.assert_eq "length after clear" "$v" "0"

# ============================================================================
# LIST: edge cases
# ============================================================================

$t.section "List: edge cases"
$t.assert_fail "pop from empty" bash -c '. boop List; into=l List; $l.pop'
$t.assert_fail "shift from empty" bash -c '. boop List; into=l List; $l.shift'
into=empty_get $list.get 99
$t.assert_eq "get out of range returns empty" "$empty_get" ""

# ============================================================================
# MAP: creation
# ============================================================================

$t.section "Map: creation"
into=map Map
$t.assert_ok "isa Map" $map.isa Map
$t.assert_ok "isa Container" $map.isa Container

# ============================================================================
# MAP: set/get/length
# ============================================================================

$t.section "Map: set/get/length"
$map.set "host" "localhost"
$map.set "port" "8080"
$map.set "debug" "true"
into=v $map.length;       $t.assert_eq "length" "$v" "3"
into=v $map.get "host";   $t.assert_eq "get host" "$v" "localhost"
into=v $map.get "port";   $t.assert_eq "get port" "$v" "8080"
into=v $map.get "nope";   $t.assert_eq "get missing key" "$v" ""

# ============================================================================
# MAP: has / delete
# ============================================================================

$t.section "Map: has/delete"
$t.assert_ok "has host" $map.has "host"
$t.assert_fail "has missing" $map.has "nope"
$map.delete "debug"
into=v $map.length; $t.assert_eq "length after delete" "$v" "2"
$t.assert_fail "has debug after delete" $map.has "debug"

# ============================================================================
# MAP: keys/values/toArray
# ============================================================================

$t.section "Map: keys/values/toArray"
into=k $map.keys
$t.assert_contains "keys has host" "$k" "host"
$t.assert_contains "keys has port" "$k" "port"
into=v $map.values
$t.assert_contains "values has localhost" "$v" "localhost"
$t.assert_contains "values has 8080" "$v" "8080"
into=entries $map.toArray
$t.assert_contains "toArray has host=localhost" "$entries" "host=localhost"
$t.assert_contains "toArray has port=8080" "$entries" "port=8080"

# ============================================================================
# MAP: toString / clear / isEmpty / overwrite
# ============================================================================

$t.section "Map: toString/clear/isEmpty/overwrite"
into=s $map.toString
$t.assert_contains "toString has Map(" "$s" "Map("
$t.assert_fail "not empty" $map.isEmpty
$map.clear
$t.assert_ok "empty after clear" $map.isEmpty
into=v $map.length; $t.assert_eq "length after clear" "$v" "0"
$map.set "key" "first"
$map.set "key" "second"
into=v $map.get "key"; $t.assert_eq "overwrite" "$v" "second"

# ============================================================================
# Container: virtual methods crash
# ============================================================================

$t.section "Container: virtual methods crash"
$t.assert_fail "Container.get crashes" bash -c '. boop Container; into=c Container; $c.get 0'
$t.assert_fail "Container.set crashes" bash -c '. boop Container; into=c Container; $c.set 0 x'
$t.assert_fail "Container.delete crashes" bash -c '. boop Container; into=c Container; $c.delete 0'
$t.assert_fail "Container.length crashes" bash -c '. boop Container; into=c Container; $c.length'
$t.assert_fail "Container.clear crashes" bash -c '. boop Container; into=c Container; $c.clear'
$t.assert_fail "Container.has crashes" bash -c '. boop Container; into=c Container; $c.has 0'
$t.assert_fail "Container.toArray crashes" bash -c '. boop Container; into=c Container; $c.toArray'

# ============================================================================
# Composition: List on Cube
# ============================================================================

$t.section "Composition: List on Cube"
. boop Cube
into=cube Cube size=4
into=tags List
$tags.push "heavy" "fragile" "this-side-up"
$cube.set tags "$tags"
into=ct $cube.get tags
into=v $ct.get 0;  $t.assert_eq "composed List.get 0" "$v" "heavy"
into=v $ct.get 2;  $t.assert_eq "composed List.get 2" "$v" "this-side-up"
into=v $ct.length; $t.assert_eq "composed List.length" "$v" "3"
__chain_val=$( $( $cube.get tags ).get 1 )
$t.assert_eq "subshell chain = fragile" "$__chain_val" "fragile"

# ============================================================================
# itemAt: nested List traversal
# ============================================================================

$t.section "itemAt: nested List"
into=matrix List
for (( __r=0; __r < 3; __r++ )); do
  into=__row List
  for (( __c=0; __c < 3; __c++ )); do
    $__row.push "$(( __r * 3 + __c + 1 ))"
  done
  $matrix.push "$__row"
done
into=v $matrix.itemAt 0 0;  $t.assert_eq "itemAt 0 0 = 1" "$v" "1"
into=v $matrix.itemAt 1 2;  $t.assert_eq "itemAt 1 2 = 6" "$v" "6"
into=v $matrix.itemAt 2 1;  $t.assert_eq "itemAt 2 1 = 8" "$v" "8"
into=v $matrix.itemAt -1 -1; $t.assert_eq "itemAt -1 -1 = 9" "$v" "9"
into=v $matrix.itemAt 99 0; $t.assert_eq "itemAt out of range = empty" "$v" ""

# ============================================================================
# itemAt: mixed List/Map
# ============================================================================

$t.section "itemAt: mixed List/Map"
into=db List
into=server1 Map
$server1.set "host" "alpha.example.com"
$server1.set "port" "5432"
into=server2 Map
$server2.set "host" "beta.example.com"
$server2.set "port" "3306"
$db.push "$server1"
$db.push "$server2"
into=v $db.itemAt 0 "host"; $t.assert_eq "db[0]['host']" "$v" "alpha.example.com"
into=v $db.itemAt 1 "port"; $t.assert_eq "db[1]['port']" "$v" "3306"
into=v $db.itemAt 0 "nope"; $t.assert_eq "missing key" "$v" ""

# ============================================================================
# setAt
# ============================================================================

$t.section "setAt"
$matrix.setAt "99" 1 1
into=v $matrix.itemAt 1 1; $t.assert_eq "setAt 1 1 = 99" "$v" "99"
into=v $matrix.itemAt 1 0; $t.assert_eq "neighbor 1 0 unchanged" "$v" "4"
into=v $matrix.itemAt 1 2; $t.assert_eq "neighbor 1 2 unchanged" "$v" "6"
$db.setAt "gamma.example.com" 0 "host"
into=v $db.itemAt 0 "host"; $t.assert_eq "setAt Map value" "$v" "gamma.example.com"
$t.assert_fail "setAt missing intermediate" bash -c '. boop List; into=l List; into=inner List; $inner.push x; $l.push "$inner"; $l.setAt val 99 0'

# ============================================================================
# itemFrom: property-rooted traversal
# ============================================================================

$t.section "itemFrom"
into=cube2 Cube size=3
into=tags2 List
$tags2.push "heavy" "fragile" "glass"
$cube2.set tags "$tags2"
into=v $cube2.itemFrom tags 0;  $t.assert_eq "itemFrom tags 0 = heavy" "$v" "heavy"
into=v $cube2.itemFrom tags -1; $t.assert_eq "itemFrom tags -1 = glass" "$v" "glass"
into=v $cube2.itemFrom nope 0;  $t.assert_eq "itemFrom missing property = empty" "$v" ""

# Deep: object with Map property containing Lists
into=obj3 Box length=1 width=1 height=1
into=inventory Map
into=fruits List
$fruits.push "apple" "banana" "cherry"
$inventory.set "fruits" "$fruits"
into=vegs List
$vegs.push "carrot" "pea"
$inventory.set "vegs" "$vegs"
$obj3.set stock "$inventory"
into=v $obj3.itemFrom stock "fruits" 1; $t.assert_eq "stock→fruits→1 = banana" "$v" "banana"
into=v $obj3.itemFrom stock "vegs" 0;   $t.assert_eq "stock→vegs→0 = carrot" "$v" "carrot"

# ============================================================================
# setOn: property-rooted write
# ============================================================================

$t.section "setOn"
$cube2.setOn tags "FRAGILE" 1
into=v $cube2.itemFrom tags 1; $t.assert_eq "setOn tags 1 = FRAGILE" "$v" "FRAGILE"
into=v $cube2.itemFrom tags 0; $t.assert_eq "neighbor 0 unchanged" "$v" "heavy"
$obj3.setOn stock "grape" "fruits" 2
into=v $obj3.itemFrom stock "fruits" 2; $t.assert_eq "setOn 3 levels = grape" "$v" "grape"
$t.assert_fail "setOn missing property" bash -c '. boop List Cube; into=c Cube size=1; $c.setOn nope val 0'

# ============================================================================
# Destroy
# ============================================================================

$t.section "Destroy"
into=dlist List
$dlist.push "a" "b" "c"
$dlist.destroy
if [[ -z "${__bashClass_registry[$dlist]:-}" ]]; then
  $t.assert_ok "destroy removes from registry" true
else
  $t.assert_ok "destroy removes from registry" false
fi

$t.summary
