boopClass Stream '
  has:fd,path,eol,eolMode,fdelim,fdelimMode,parseMode,expose,fields,readArgs,array,timeout,nchars,blockSize,buf,eof,recRe,fieldRe
  public:new,read,Read,next,field,fieldCount,eof,buffered,close,write,writeLine,putBack
'

