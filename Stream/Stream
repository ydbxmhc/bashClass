#!/bin/bash

# Stream -- record-oriented reader/writer wrapping a file descriptor.
#
# Parsing is configured once at construction; each Read call executes
# the pre-built contract with zero per-iteration overhead. Supports
# delimited mode (field splitting like bash read) and fixed-width mode
# (positional field extraction). Multi-character record delimiters are
# handled via an internal buffer-scan algorithm.
#
# Two construction forms:
#   Inline:  Stream.open PATH -d ':' user _ uid gid desc home shell
#   Schema:  Stream.open PATH '
#              [Parser]
#              delimiter = :
#              [Fields]
#              user _ uid gid desc home shell
#            '
#
# Inheritance: boop -> Stream
#
# Usage:
#   . boop Stream
#   into=s Stream.open "/etc/passwd" -d ':' user _ uid gid desc home shell
#   while $s.Read; do
#     printf "%s -> %s\n" "$user" "$shell"
#   done
#   $s.close
#
# See docs/Stream.md for the full design spec.

. boop Args

boop.init Stream || return 0

# ============================================================================
# Stream -- construction
# ============================================================================

# open -- open a file path and return a Stream configured for reading.
# The stream owns the FD and will close it on $s.close.
#
# Usage:
#   into=s Stream.open "/path/to/file" [options] [field names...]
#   into=s Stream.open "/path/to/file" 'schema string'
Stream.open() {
  local _Class="${_Class:-Stream}"
  local __Stream_open_path="${1:?Stream.open: path required}"; shift
  local __Stream_open_fd

  # Open the file for reading
  exec {__Stream_open_fd}< "$__Stream_open_path" || \
    _Crash "Stream.open: cannot open '$__Stream_open_path'"

  # Delegate to .new with the FD + ownership flag
  Stream.new fd="$__Stream_open_fd" _owned=1 _path="$__Stream_open_path" "$@"
}

# fromString -- create a Stream reading from a string via here-string FD.
# The stream owns the FD.
#
# Usage:
#   into=s Stream.fromString "$data" [options] [field names...]
Stream.fromString() {
  local _Class="${_Class:-Stream}"
  local __Stream_fs_data="${1:?Stream.fromString: data required}"; shift
  local __Stream_fs_fd

  exec {__Stream_fs_fd}<<< "$__Stream_fs_data"

  Stream.new fd="$__Stream_fs_fd" _owned=1 "$@"
}

# new -- construct a Stream from an already-open FD.
# Caller owns the FD unless _owned=1 is passed.
#
# Parses options and field names (or a schema string) to configure
# the parsing contract. All configuration is locked in at this point;
# Read executes it without re-parsing.
Stream.new() {
  local _Class="${_Class:-Stream}"
  local __Stream_new_self
  into=__Stream_new_self __boop.new "$@"
  local _Self="$__Stream_new_self"

  # Defaults from environment, then hardcoded fallbacks
  local __Stream_new_eol="${_EOL:-$'\n'}"
  local __Stream_new_delim="${_Delimiter:-}"
  local __Stream_new_fd="" __Stream_new_owned="0" __Stream_new_path=""
  local __Stream_new_mode="delimited"
  local __Stream_new_array="" __Stream_new_timeout=""
  local __Stream_new_nchars=""
  local -a __Stream_new_fields=()

  # Extract known properties that __boop.new already stored
  into=__Stream_new_fd __boop.get fd
  into=__Stream_new_owned __boop.get _owned
  into=__Stream_new_path __boop.get _path
  : "${__Stream_new_owned:=0}"

  # Remaining args: either a schema string or inline options + field names
  # Filter out the key=value args that __boop.new already consumed
  local -a __Stream_new_args=()
  local __Stream_new_arg
  for __Stream_new_arg in "$@"; do
    case "$__Stream_new_arg" in
      fd=*|_owned=*|_path=*) ;; # already handled
      *) __Stream_new_args+=("$__Stream_new_arg") ;;
    esac
  done

  if (( ${#__Stream_new_args[@]} == 1 )) && [[ "${__Stream_new_args[0]}" == *$'\n'* ]]; then
    # Schema string mode -- parse it
    __Stream._parseSchema "$__Stream_new_self" "${__Stream_new_args[0]}"
  elif (( ${#__Stream_new_args[@]} > 0 )); then
    # Inline mode -- parse options and field names
    local __Stream_new_i=0
    while (( __Stream_new_i < ${#__Stream_new_args[@]} )); do
      case "${__Stream_new_args[$__Stream_new_i]}" in
        -d)
          (( __Stream_new_i++ ))
          __Stream_new_delim="${__Stream_new_args[$__Stream_new_i]}"
          ;;
        --eol)
          (( __Stream_new_i++ ))
          __Stream_new_eol="${__Stream_new_args[$__Stream_new_i]}"
          ;;
        -a)
          (( __Stream_new_i++ ))
          __Stream_new_array="${__Stream_new_args[$__Stream_new_i]}"
          ;;
        -t)
          (( __Stream_new_i++ ))
          __Stream_new_timeout="${__Stream_new_args[$__Stream_new_i]}"
          ;;
        -n|-N)
          (( __Stream_new_i++ ))
          __Stream_new_nchars="${__Stream_new_args[$__Stream_new_i]}"
          ;;
        *)
          # Field name
          __Stream_new_fields+=("${__Stream_new_args[$__Stream_new_i]}")
          ;;
      esac
      (( __Stream_new_i++ ))
    done

    # Store the parsed config as properties
    __boop.set _eol "$__Stream_new_eol"
    __boop.set _delim "$__Stream_new_delim"
    __boop.set _mode "$__Stream_new_mode"
    __boop.set _array "$__Stream_new_array"
    __boop.set _timeout "$__Stream_new_timeout"
    __boop.set _nchars "$__Stream_new_nchars"
    __boop.set _fields "${__Stream_new_fields[*]}"
    __boop.set _buf ""
    __boop.set _eof "0"
  fi

  [[ -n "$__Stream_new_fd" ]] || _Crash "Stream.new: fd is required"
  _Info "new: Stream on fd=$__Stream_new_fd (owned=$__Stream_new_owned)"
  boop.pass "$__Stream_new_self" ${into:-}
}

# ============================================================================
# Stream -- schema parsing
# ============================================================================

__Stream._parseSchema() {
  local __Stream_ps_self="$1" __Stream_ps_schema="$2"
  local __Stream_ps_section="" __Stream_ps_line
  local __Stream_ps_eol="${_EOL:-$'\n'}"
  local __Stream_ps_delim="${_Delimiter:-}"
  local __Stream_ps_mode="delimited"
  local __Stream_ps_trim="false"
  local __Stream_ps_switch=""
  local -a __Stream_ps_fields=()

  while IFS= read -r __Stream_ps_line; do
    # Strip leading whitespace
    __Stream_ps_line="${__Stream_ps_line#"${__Stream_ps_line%%[![:space:]]*}"}"
    # Strip comments
    __Stream_ps_line="${__Stream_ps_line%%#*}"
    # Strip trailing whitespace
    __Stream_ps_line="${__Stream_ps_line%"${__Stream_ps_line##*[![:space:]]}"}"
    [[ -z "$__Stream_ps_line" ]] && continue

    # Section header
    if [[ "$__Stream_ps_line" =~ ^\[([^]]+)\]$ ]]; then
      __Stream_ps_section="${BASH_REMATCH[1]}"
      continue
    fi

    case "$__Stream_ps_section" in
      Parser)
        local __Stream_ps_key="${__Stream_ps_line%%=*}"
        local __Stream_ps_val="${__Stream_ps_line#*=}"
        __Stream_ps_key="${__Stream_ps_key%"${__Stream_ps_key##*[![:space:]]}"}"
        __Stream_ps_val="${__Stream_ps_val#"${__Stream_ps_val%%[![:space:]]*}"}"
        case "$__Stream_ps_key" in
          eol)       __Stream_ps_eol="$__Stream_ps_val" ;;
          delimiter) __Stream_ps_delim="$__Stream_ps_val" ;;
          mode)      __Stream_ps_mode="$__Stream_ps_val" ;;
          trim)      __Stream_ps_trim="$__Stream_ps_val" ;;
          switch)    __Stream_ps_switch="$__Stream_ps_val" ;;
          *) _Warn "Stream: unknown [Parser] key: $__Stream_ps_key" ;;
        esac
        ;;
      Fields)
        # Space-separated field names
        local __Stream_ps_f
        for __Stream_ps_f in $__Stream_ps_line; do
          __Stream_ps_fields+=("$__Stream_ps_f")
        done
        ;;
      *)
        # TODO: [Format NAME] sections for fixed-width mode
        ;;
    esac
  done <<< "$__Stream_ps_schema"

  # Handle escape sequences in eol
  case "$__Stream_ps_eol" in
    '\n')   __Stream_ps_eol=$'\n' ;;
    '\r\n') __Stream_ps_eol=$'\r\n' ;;
    '\t')   __Stream_ps_eol=$'\t' ;;
  esac

  # Store config
  local _Self="$__Stream_ps_self"
  __boop.set _eol "$__Stream_ps_eol"
  __boop.set _delim "$__Stream_ps_delim"
  __boop.set _mode "$__Stream_ps_mode"
  __boop.set _trim "$__Stream_ps_trim"
  __boop.set _switch "$__Stream_ps_switch"
  __boop.set _fields "${__Stream_ps_fields[*]}"
  __boop.set _buf ""
  __boop.set _eof "0"
}

# ============================================================================
# Stream -- Read
# ============================================================================

# Read -- read one record and assign fields per the construction contract.
#
# No arguments: hot path. Executes pre-built parsing logic.
# With arguments: override field names for this one read.
#
# Returns 0 on success, 1 on EOF.
Stream.Read() {
  local _Self="${_Self:-}" _Class="${_Class:-Stream}"

  # Load config from properties
  local __Stream_Read_fd __Stream_Read_eol __Stream_Read_delim
  local __Stream_Read_fields __Stream_Read_array __Stream_Read_eof
  local __Stream_Read_buf __Stream_Read_nchars
  into=__Stream_Read_fd     __boop.get fd
  into=__Stream_Read_eol    __boop.get _eol
  into=__Stream_Read_delim  __boop.get _delim
  into=__Stream_Read_fields __boop.get _fields
  into=__Stream_Read_array  __boop.get _array
  into=__Stream_Read_eof    __boop.get _eof
  into=__Stream_Read_buf    __boop.get _buf
  into=__Stream_Read_nchars __boop.get _nchars

  # Already at EOF?
  [[ "$__Stream_Read_eof" == "1" ]] && return 1

  # Override fields if args passed
  if (( $# )); then
    __Stream_Read_fields="$*"
  fi

  local __Stream_Read_record=""

  # --- Fixed-width: read exactly N chars ---
  if [[ -n "$__Stream_Read_nchars" ]]; then
    IFS= read -r -N "$__Stream_Read_nchars" -u "$__Stream_Read_fd" __Stream_Read_record
    if [[ -z "$__Stream_Read_record" ]]; then
      __boop.set _eof "1"; return 1
    fi

  # --- Fast path: single-char EOL ---
  elif [[ ${#__Stream_Read_eol} -eq 1 ]]; then
    if ! IFS= read -r -d "$__Stream_Read_eol" -u "$__Stream_Read_fd" __Stream_Read_record; then
      # read returns non-zero on EOF (even if it read partial data)
      if [[ -z "$__Stream_Read_record" ]]; then
        __boop.set _eof "1"; return 1
      fi
    fi

  # --- Slow path: multi-char EOL via buffer scan ---
  else
    while true; do
      # Scan buffer for EOL
      if [[ "$__Stream_Read_buf" == *"$__Stream_Read_eol"* ]]; then
        __Stream_Read_record="${__Stream_Read_buf%%"$__Stream_Read_eol"*}"
        __Stream_Read_buf="${__Stream_Read_buf#*"$__Stream_Read_eol"}"
        __boop.set _buf "$__Stream_Read_buf"
        break
      fi

      # Try to read more from FD. read -N returns non-zero when it hits EOF
      # even if it did read some bytes (file shorter than requested size).
      # Always add whatever was read to the buffer before checking exit code.
      local __Stream_Read_chunk="" __Stream_Read_rrc=0
      IFS= read -r -N 8192 -u "$__Stream_Read_fd" __Stream_Read_chunk || __Stream_Read_rrc=$?
      __Stream_Read_buf+="$__Stream_Read_chunk"
      if (( __Stream_Read_rrc != 0 )); then
        # FD exhausted — scan once more, then take remainder or signal EOF
        if [[ "$__Stream_Read_buf" == *"$__Stream_Read_eol"* ]]; then
          __Stream_Read_record="${__Stream_Read_buf%%"$__Stream_Read_eol"*}"
          __Stream_Read_buf="${__Stream_Read_buf#*"$__Stream_Read_eol"}"
          __boop.set _buf "$__Stream_Read_buf"
        elif [[ -n "$__Stream_Read_buf" ]]; then
          __Stream_Read_record="$__Stream_Read_buf"
          __Stream_Read_buf=""
          __boop.set _buf ""
        else
          __boop.set _eof "1"; return 1
        fi
        break
      fi
    done
  fi

  # --- Field assignment ---
  if [[ -n "$__Stream_Read_array" ]]; then
    # Array mode: split record on delimiter into named array
    local IFS="${__Stream_Read_delim:-$'\t'}"
    eval "read -ra $__Stream_Read_array <<< \"\$__Stream_Read_record\""
  elif [[ -n "$__Stream_Read_fields" ]]; then
    # Named fields: split on delimiter, last field gets the rest
    local IFS="${__Stream_Read_delim:-$'\t'}"
    eval "read -r $__Stream_Read_fields <<< \"\$__Stream_Read_record\""
  else
    # No fields configured -- return whole record via boop.pass
    boop.pass "$__Stream_Read_record" ${into:-}
  fi

  return 0
}

# ============================================================================
# Stream -- utility methods
# ============================================================================

# eof -- exit 0 if the stream is exhausted.
Stream.eof() {
  local _Self="${_Self:-}" _Class="${_Class:-Stream}"
  local __Stream_eof_val
  into=__Stream_eof_val __boop.get _eof
  [[ "$__Stream_eof_val" == "1" ]]
}

# close -- close the FD if the stream owns it.
Stream.close() {
  local _Self="${_Self:-}" _Class="${_Class:-Stream}"
  local __Stream_close_fd __Stream_close_owned
  into=__Stream_close_fd    __boop.get fd
  into=__Stream_close_owned __boop.get _owned
  if [[ "$__Stream_close_owned" == "1" && -n "$__Stream_close_fd" ]]; then
    eval "exec ${__Stream_close_fd}>&-"
    _Debug "close: fd=$__Stream_close_fd closed"
  fi
}

# readAll -- drain the FD and return everything as a single string.
Stream.readAll() {
  local _Self="${_Self:-}" _Class="${_Class:-Stream}"
  local __Stream_ra_fd __Stream_ra_buf __Stream_ra_chunk
  into=__Stream_ra_fd  __boop.get fd
  into=__Stream_ra_buf __boop.get _buf

  # Drain FD
  while IFS= read -r -N 8192 -u "$__Stream_ra_fd" __Stream_ra_chunk; do
    __Stream_ra_buf+="$__Stream_ra_chunk"
  done
  # Final partial read
  [[ -n "$__Stream_ra_chunk" ]] && __Stream_ra_buf+="$__Stream_ra_chunk"

  __boop.set _eof "1"
  __boop.set _buf ""
  boop.pass "$__Stream_ra_buf" ${into:-}
}

# write -- write a string to the stream's FD.
Stream.write() {
  local _Self="${_Self:-}" _Class="${_Class:-Stream}"
  local __Stream_write_fd
  into=__Stream_write_fd __boop.get fd
  printf '%s' "$1" >&"$__Stream_write_fd"
}

# writeLine -- write a string followed by _EOL to the stream's FD.
Stream.writeLine() {
  local _Self="${_Self:-}" _Class="${_Class:-Stream}"
  local __Stream_wl_fd __Stream_wl_eol
  into=__Stream_wl_fd  __boop.get fd
  into=__Stream_wl_eol __boop.get _eol
  printf '%s%s' "$1" "${__Stream_wl_eol:-$'\n'}" >&"$__Stream_wl_fd"
}

# ============================================================================
# Class Declaration
# ============================================================================

boopClass Stream \
  'has:fd,_owned,_path,_eol,_delim,_mode,_fields,_array,_timeout,_nchars,_buf,_eof,_trim,_switch' \
  'public:new,open,fromString,Read,eof,close,readAll,write,writeLine'

