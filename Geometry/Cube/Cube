#!/bin/bash

# Geometry.Cube class

# Load guard
[[ -n "${__boop_registry[Geometry.Cube]+set}" ]] && return 2>/dev/null

. boop Geometry::Box

# ============================================================================
# Geometry.Cube Implementation Functions
# ============================================================================

# Cube constructor - sets all dimensions equal to size
Geometry.Cube.new() {
  local _Class="${_Class:-Geometry.Cube}" __Geometry_Cube_new_size="" __Geometry_Cube_new_self

  for __Geometry_Cube_new_arg in "$@"; do [[ "$__Geometry_Cube_new_arg" =~ ^size= ]] || continue
      [[ -n "${__Geometry_Cube_new_size:-}" ]] && _Crash "repeated argument '$__Geometry_Cube_new_arg'"
      [[ "$__Geometry_Cube_new_arg" =~ ^size=([1-9][0-9]*)$ ]] ||
        _Crash "Cube: size requires a positive integer, got '$__Geometry_Cube_new_arg'"
      __Geometry_Cube_new_size="${BASH_REMATCH[1]}"
  done
  [[ -n "$__Geometry_Cube_new_size" ]] || _Crash "Cube: size is required"

  into=__Geometry_Cube_new_self _Super new "$@" length="$__Geometry_Cube_new_size" width="$__Geometry_Cube_new_size" height="$__Geometry_Cube_new_size"
  _Bless "$__Geometry_Cube_new_self" Geometry.Cube
  boop.pass "$__Geometry_Cube_new_self" ${into:-}
}

# Calculate side face area (all faces equal for cube)
Geometry.Cube.side() {
  local _Self="${_Self:-${_Class:-Geometry.Cube}}" _Class="${_Class:-Geometry.Cube}"
  local __Geometry_Cube_side_size __Geometry_Cube_side_val
  into=__Geometry_Cube_side_size $_Self.size
  into=__Geometry_Cube_side_val $_Self.area "$__Geometry_Cube_side_size" "$__Geometry_Cube_side_size"
  boop.pass "$__Geometry_Cube_side_val" ${into:-}
}

# All faces same as side for cube
Geometry.Cube.top    () { local _Self="${_Self:-${_Class:-Geometry.Cube}}" _Class="${_Class:-Geometry.Cube}"; $_Self.side; }
Geometry.Cube.end    () { local _Self="${_Self:-${_Class:-Geometry.Cube}}" _Class="${_Class:-Geometry.Cube}"; $_Self.side; }
Geometry.Cube.bottom () { local _Self="${_Self:-${_Class:-Geometry.Cube}}" _Class="${_Class:-Geometry.Cube}"; $_Self.side; }

# Calculate volume
Geometry.Cube.volume() {
  local _Self="${_Self:-${_Class:-Geometry.Cube}}" _Class="${_Class:-Geometry.Cube}"
  local __Geometry_Cube_volume_size __Geometry_Cube_volume_vol
  into=__Geometry_Cube_volume_size $_Self.size
  into=__Geometry_Cube_volume_vol required=3 $_Self.calc "$__Geometry_Cube_volume_size" "$__Geometry_Cube_volume_size" "$__Geometry_Cube_volume_size"
  boop.pass "$__Geometry_Cube_volume_vol" ${into:-}
}

# ============================================================================
# Class Declaration
# ============================================================================

boopClass Geometry.Cube isa:Geometry.Box has:size

