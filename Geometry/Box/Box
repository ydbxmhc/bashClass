#!/bin/bash

# Geometry.Box class

# Load guard
[[ -n "${__boop_registry[Geometry.Box]+set}" ]] && return 2>/dev/null

. boop

# ============================================================================
# Geometry.Box Implementation Functions
# ============================================================================

# Generic multiplication calculator
Geometry.Box.calc() {
  local _Self="${_Self:-${Class:-Geometry.Box}}" _Class="${_Class:-Geometry.Box}"
  local -i __Geometry_Box_calc_tot=1 required="${required:-0}"

  if ((required)); then
    (( required == $# )) || _Crash "$FUNCNAME requires $required INTEGER arguments to multiply"
  fi

  for __Geometry_Box_calc_arg in "$@"; do
    [[ "${__Geometry_Box_calc_arg:-}" =~ ^[0-9]+$ ]] && ((__Geometry_Box_calc_arg)) || _Crash "$FUNCNAME arguments must be nonzero integers: $*"
    (( __Geometry_Box_calc_tot *= __Geometry_Box_calc_arg ))
  done

  boop.pass "$__Geometry_Box_calc_tot" ${into:-}
}

# Calculate area (2D)
Geometry.Box.area() {
  local _Self="${_Self:-${Class:-Geometry.Box}}" _Class="${_Class:-Geometry.Box}"
  required=2 into=${into:-} Geometry.Box.calc "$@"
}

# Calculate top face area
Geometry.Box.top() {
  local _Self="${_Self:-${Class:-Geometry.Box}}" _Class="${_Class:-Geometry.Box}"
  local __Geometry_Box_top_l __Geometry_Box_top_w __Geometry_Box_top_val
  into=__Geometry_Box_top_l $_Self.length
  into=__Geometry_Box_top_w $_Self.width
  into=__Geometry_Box_top_val $_Self.area "$__Geometry_Box_top_l" "$__Geometry_Box_top_w"
  boop.pass "$__Geometry_Box_top_val" ${into:-}
}

# Calculate end face area
Geometry.Box.end() {
  local _Self="${_Self:-${Class:-Geometry.Box}}" _Class="${_Class:-Geometry.Box}"
  local __Geometry_Box_end_h __Geometry_Box_end_w __Geometry_Box_end_val
  into=__Geometry_Box_end_h $_Self.height
  into=__Geometry_Box_end_w $_Self.width
  into=__Geometry_Box_end_val $_Self.area "$__Geometry_Box_end_h" "$__Geometry_Box_end_w"
  boop.pass "$__Geometry_Box_end_val" ${into:-}
}

# Calculate side face area
Geometry.Box.side() {
  local _Self="${_Self:-${Class:-Geometry.Box}}" _Class="${_Class:-Geometry.Box}"
  local __Geometry_Box_side_h __Geometry_Box_side_l __Geometry_Box_side_val
  into=__Geometry_Box_side_h $_Self.height
  into=__Geometry_Box_side_l $_Self.length
  into=__Geometry_Box_side_val $_Self.area "$__Geometry_Box_side_h" "$__Geometry_Box_side_l"
  boop.pass "$__Geometry_Box_side_val" ${into:-}
}

# Calculate bottom face area (same as top)
Geometry.Box.bottom() {
  local _Self="${_Self:-${Class:-Geometry.Box}}" _Class="${_Class:-Geometry.Box}"
  local __Geometry_Box_bottom_val
  into=__Geometry_Box_bottom_val $_Self.top
  boop.pass "$__Geometry_Box_bottom_val" ${into:-}
}

# Calculate volume (3D)
Geometry.Box.volume() {
  local _Self="${_Self:-${Class:-Geometry.Box}}" _Class="${_Class:-Geometry.Box}"
  local __Geometry_Box_volume_l __Geometry_Box_volume_h __Geometry_Box_volume_w __Geometry_Box_volume_vol
  into=__Geometry_Box_volume_l $_Self.length
  into=__Geometry_Box_volume_h $_Self.height
  into=__Geometry_Box_volume_w $_Self.width
  into=__Geometry_Box_volume_vol required=3 $_Self.calc "$__Geometry_Box_volume_l" "$__Geometry_Box_volume_h" "$__Geometry_Box_volume_w"
  boop.pass "$__Geometry_Box_volume_vol" ${into:-}
}

# Constructor
Geometry.Box.new() {
  local _Class="${_Class:-Geometry.Box}"
  local __Geometry_Box_new_self
  into=__Geometry_Box_new_self __boop.new "$@"
  boop.pass "$__Geometry_Box_new_self" ${into:-}
}

# ============================================================================
# Class Declaration
# ============================================================================

boopClass Geometry.Box '
  has:length,width,height,unit,color
  public:calc,area,top,end,side,bottom,volume
'

