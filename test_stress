  printf "  PASS: __return in subshell = 24\n"; (( passed++ ))
else
  printf "  FAIL: __return in subshell got '%s'\n" "$__rt_sub"; (( failed++ ))
fi

# __return unset — falls through to global mode (existing behavior)
new Box length=2 width=5 height=3
__rt_fb="$__bashClass_RETURN"
$__rt_fb.volume
