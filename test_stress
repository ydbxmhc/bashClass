  bash -c '. bashClass Cube; Box.calc 5 3.5 7'

# Single valid arg works
expect_stdout "calc single arg" "42" \
  bash -c '. bashClass Cube; Box.calc 42; printf "%s" "$__bashClass_RETURN"'

# Multiple valid args multiply
expect_stdout "calc 2*3*7" "42" \
  bash -c '. bashClass Cube; Box.calc 2 3 7; printf "%s" "$__bashClass_RETURN"'

# required= typecast enforces arg count
expect_fail "calc required=3 with 2 args" \
  bash -c '. bashClass Cube; required=3 Box.calc 5 3'

expect_ok "calc required=2 with 2 args" \
  bash -c '. bashClass Cube; required=2 Box.calc 5 3'

