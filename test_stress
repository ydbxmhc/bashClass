else
  printf "  FAIL: sequential __return: top=%s side=%s\n" "$__rt_a" "$__rt_b"; (( failed++ ))
fi


# ============================================================================
# SECTION 27: Bulk benchmark (optional — pass count as $1)
# ============================================================================
if (( __bench_count > 0 )); then
  printf "\n--- bulk benchmark (%d objects) ---\n" "$__bench_count"
  __timer_start

  declare -a __bench_objs=()

  # Phase 1: Object creation
  __bench_create_start="$EPOCHREALTIME"
  for (( __bi=0; __bi < __bench_count; __bi++ )); do
    new Cube size=$(( __bi + 1 )) unit=cm
    __bench_objs+=("$__bashClass_RETURN")
  done
  __bench_create_end="$EPOCHREALTIME"
  __bcs="${__bench_create_start//.}" __bce="${__bench_create_end//.}"
  __bcd=$(( __bce - __bcs ))
  printf "  Creation:  %d.%06ds (%d objects)\n" "$(( __bcd / 1000000 ))" "$(( __bcd % 1000000 ))" "$__bench_count"

  # Phase 2: Method calls (all class methods on each object)
  __bench_method_start="$EPOCHREALTIME"
  declare -i __bench_calls=0
  for __bobj in "${__bench_objs[@]}"; do
    $__bobj.volume    >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.side      >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.top       >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.end       >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.bottom    >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.size      >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.unit      >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.isa       >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.isa Cube  >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.isa Box   >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.toString  >/dev/null 2>&1; (( __bench_calls++ ))
  done
  __bench_method_end="$EPOCHREALTIME"
  __bms="${__bench_method_start//.}" __bme="${__bench_method_end//.}"
  __bmd=$(( __bme - __bms ))
  printf "  Methods:   %d.%06ds (%d calls across %d objects)\n" \
    "$(( __bmd / 1000000 ))" "$(( __bmd % 1000000 ))" "$__bench_calls" "$__bench_count"

  # Phase 3: Second pass — should be faster (baked wrappers)
  __bench_baked_start="$EPOCHREALTIME"
  __bench_calls=0
  for __bobj in "${__bench_objs[@]}"; do
    $__bobj.volume    >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.side      >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.top       >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.end       >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.bottom    >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.size      >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.unit      >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.isa       >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.isa Cube  >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.isa Box   >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.toString  >/dev/null 2>&1; (( __bench_calls++ ))
  done
  __bench_baked_end="$EPOCHREALTIME"
  __bbs="${__bench_baked_start//.}" __bbe="${__bench_baked_end//.}"
  __bbd=$(( __bbe - __bbs ))
  printf "  Baked:     %d.%06ds (%d calls, second pass — should be faster)\n" \
    "$(( __bbd / 1000000 ))" "$(( __bbd % 1000000 ))" "$__bench_calls"

  __timer_stop
  printf "  Total:     %ss\n" "$__timer_elapsed"

  unset __bench_objs
else
  printf "\n--- bulk benchmark ---\n"
  printf "  SKIPPED (pass a number as \$1 to run, e.g. ./test_stress 100)\n"
fi

