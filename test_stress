#!/bin/bash
set -u

# Stress test / adversarial test suite for bashClass
# Tests that should FAIL (and we catch the failure), tests that should
# SUCCEED in weird conditions, and tests designed to surprise us.

__bench_count="${1:-0}"

passed=0
failed=0
errors=0

# Timing helpers — no subshells, uses EPOCHREALTIME
__timer_start() { __timer_begin="$EPOCHREALTIME"; }
__timer_stop() {
  local __end="$EPOCHREALTIME"
  local __s="${__timer_begin//.}" __e="${__end//.}"
  local -i __diff_us=$(( __e - __s ))
  local __sec=$(( __diff_us / 1000000 )) __frac=$(( __diff_us % 1000000 ))
  printf -v __timer_elapsed "%d.%06d" "$__sec" "$__frac"
}

# Run a command that SHOULD succeed. Capture output and exit code.
expect_ok() {
  local __desc="$1"; shift
  local __out __rc
  __out=$("$@" 2>&1); __rc=$?
  if (( __rc == 0 )); then
    printf "  PASS: %s\n" "$__desc"
    (( passed++ ))
  else
    printf "  FAIL: %s (exit %d)\n" "$__desc" "$__rc"
    printf "        %s\n" "$__out"
    (( failed++ ))
  fi
}

# Run a command that SHOULD fail (crash/nonzero exit).
# Must run in subshell so crash doesn't kill us.
expect_fail() {
  local __desc="$1"; shift
  local __out __rc
  __out=$("$@" 2>&1); __rc=$?
  if (( __rc != 0 )); then
    printf "  PASS: %s (correctly rejected, exit %d)\n" "$__desc" "$__rc"
    (( passed++ ))
  else
    printf "  FAIL: %s (should have failed but didn't)\n" "$__desc"
    printf "        output: %s\n" "$__out"
    (( failed++ ))
  fi
}

# Run a command, check that __bashClass_RETURN matches expected value.
# Runs in current shell so globals are visible.
expect_value() {
  local __desc="$1" __expected="$2"; shift 2
  "$@" 2>/dev/null
  if [[ "$__bashClass_RETURN" == "$__expected" ]]; then
    printf "  PASS: %s = '%s'\n" "$__desc" "$__expected"
    (( passed++ ))
  else
    printf "  FAIL: %s expected '%s' got '%s'\n" "$__desc" "$__expected" "$__bashClass_RETURN"
    (( failed++ ))
  fi
}

# Check that stdout output from a subshell matches expected value.
expect_stdout() {
  local __desc="$1" __expected="$2"; shift 2
  local __out
  __out=$("$@" 2>/dev/null)
  if [[ "$__out" == "$__expected" ]]; then
    printf "  PASS: %s = '%s'\n" "$__desc" "$__expected"
    (( passed++ ))
  else
    printf "  FAIL: %s expected '%s' got '%s'\n" "$__desc" "$__expected" "$__out"
    (( failed++ ))
  fi
}

printf "=== STRESS TEST SUITE ===\n\n"

# Section timing: stops previous section timer (if any), prints elapsed, starts new
__section() {
  if [[ -n "${__timer_begin:-}" ]]; then
    __timer_stop
    printf "  [%ss]\n" "$__timer_elapsed"
  fi
  printf "\n--- %s ---\n" "$1"
  __timer_start
}

__suite_start="$EPOCHREALTIME"

# ============================================================================
# SECTION 0a: Source class definitions (parse + load time)
# ============================================================================
__timer_start
printf "\n--- source bashClass Cube (loads bashClass → Box → Cube) ---\n"
. bashClass Cube
__timer_stop
printf "  Loaded in %ss\n" "$__timer_elapsed"
__timer_begin=""

# ============================================================================
# SECTION 0b: Object creation timing
# ============================================================================
__section "object creation"
__timer_start
new Box length=5 width=3 height=7; box="$__bashClass_RETURN"
__timer_stop
printf "  new Box:  %ss\n" "$__timer_elapsed"
__timer_start
new Cube size=4 unit=cm; cube="$__bashClass_RETURN"
__timer_stop
printf "  new Cube: %ss\n" "$__timer_elapsed"
__timer_begin=""


# ============================================================================
# SECTION 1: __bashClass.validate — input validation
# ============================================================================
__section "validate"

# Should pass
expect_ok   "valid identifier: Box"          __bashClass.validate "Box"
expect_ok   "valid identifier: _foo123"      __bashClass.validate "_foo123"
expect_ok   "valid function: Box.calc"      bash -c '. bashClass Cube; type=function __bashClass.validate "Box.calc"'
expect_ok   "valid function: a.b.c"          bash -c '. bashClass Cube; type=function __bashClass.validate "a.b.c"'

# Should fail
expect_fail "empty string"                   bash -c '. bashClass Cube; __bashClass.validate ""'
expect_fail "starts with number: 1Box"       bash -c '. bashClass Cube; __bashClass.validate "1Box"'
expect_fail "has spaces: my box"             bash -c '. bashClass Cube; __bashClass.validate "my box"'
expect_fail "has dash: my-box"               bash -c '. bashClass Cube; __bashClass.validate "my-box"'
expect_fail "dot in identifier mode"         bash -c '. bashClass Cube; __bashClass.validate "Box.new"'
expect_fail "semicolon injection: foo;ls"    bash -c '. bashClass Cube; __bashClass.validate "foo;ls"'
expect_fail "pipe injection: foo|bar"        bash -c '. bashClass Cube; __bashClass.validate "foo|bar"'
expect_fail "dollar injection"               bash -c '. bashClass Cube; __bashClass.validate "\$HOME"'
expect_fail "backtick injection"             bash -c '. bashClass Cube; __bashClass.validate "\`whoami\`"'
expect_fail "misspelled typecast: typ=func"  bash -c '. bashClass Cube; typ=function __bashClass.validate "Box.calc"'


# ============================================================================
# SECTION 2: __bashClass.return — all five modes
# ============================================================================
__section "return modes"

# Auto mode: global in main shell
__bashClass_returnMode=auto
__bashClass.return "hello_auto"
expect_value "auto mode in main shell → global" "hello_auto" true

# Auto mode: stdout in subshell (must be subshell of THIS process)
__sub_out=$( __bashClass.return "hello_sub" )
if [[ "$__sub_out" == "hello_sub" ]]; then
  printf "  PASS: auto mode in subshell → stdout\n"; (( passed++ ))
else
  printf "  FAIL: auto mode in subshell expected 'hello_sub' got '%s'\n" "$__sub_out"; (( failed++ ))
fi

# Explicit global
__bashClass_returnMode=global
__bashClass.return "hello_global"
expect_value "explicit global mode" "hello_global" true

# Explicit stdout
expect_stdout "explicit stdout mode" "hello_stdout" \
  bash -c '. bashClass Cube; __bashClass_returnMode=stdout; __bashClass.return "hello_stdout"'

# Explicit nameref
__bashClass_returnMode=auto
local_target=""
__bashClass.return "hello_nameref" local_target
if [[ "$local_target" == "hello_nameref" ]]; then
  printf "  PASS: nameref mode = 'hello_nameref'\n"; (( passed++ ))
else
  printf "  FAIL: nameref expected 'hello_nameref' got '%s'\n" "$local_target"; (( failed++ ))
fi

# Nameref with no target (should crash)
expect_fail "nameref mode, no target" \
  bash -c '. bashClass Cube; __bashClass_returnMode=nameref; __bashClass.return "boom"'

# Nameref in subshell (should work now — namerefs are local var refs)
expect_ok "nameref in subshell" \
  bash -c '. bashClass Cube; __bashClass_returnMode=nameref; __bashClass.return "boom" myvar'

# Filesystem mode
__bashClass_returnMode=filesystem
__bashClass_tmpdir="/tmp"
__bashClass.return "hello_fs"
__fs_file="/tmp/__bashClass___bashClass.return_$BASHPID"
# The file is written by the function above us, but FUNCNAME[1] in return
# is the *caller*, which is "main" in a script. Let's just check the tmpdir.
__fs_found=0
for f in /tmp/__bashClass_*; do
  [[ -f "$f" ]] && __fs_found=1 && rm -f "$f"
done
if (( __fs_found )); then
  printf "  PASS: filesystem mode wrote a file\n"; (( passed++ ))
else
  printf "  FAIL: filesystem mode — no file found\n"; (( failed++ ))
fi

# Invalid mode
expect_fail "invalid return mode: banana" \
  bash -c '. bashClass Cube; __bashClass_returnMode=banana; __bashClass.return "boom"'

# Reset
__bashClass_returnMode=auto


# ============================================================================
# SECTION 3: __bashClass.encode / decode — edge cases
# ============================================================================
__section "encode/decode"

# Empty string round-trip
__bashClass.encode "" __enc; __bashClass.decode "$__enc" __dec
if [[ "$__dec" == "" ]]; then
  printf "  PASS: empty string round-trip\n"; (( passed++ ))
else
  printf "  FAIL: empty string round-trip got '%s'\n" "$__dec"; (( failed++ ))
fi

# All special chars at once
__bashClass.encode "%|=
	" __enc
__bashClass.decode "$__enc" __dec
if [[ "$__dec" == $'%|=\n\t' ]]; then
  printf "  PASS: all special chars round-trip\n"; (( passed++ ))
else
  printf "  FAIL: all special chars round-trip got '%s'\n" "$__dec"; (( failed++ ))
fi

# Double-encode (encode an already-encoded string)
__bashClass.encode "hello%25world" __enc
__bashClass.decode "$__enc" __dec
if [[ "$__dec" == "hello%25world" ]]; then
  printf "  PASS: double-encode round-trip preserves %%25\n"; (( passed++ ))
else
  printf "  FAIL: double-encode round-trip got '%s'\n" "$__dec"; (( failed++ ))
fi

# Very long string (1000 chars)
__long_str=$(printf 'A%.0s' {1..1000})
__bashClass.encode "$__long_str" __enc
__bashClass.decode "$__enc" __dec
if [[ "$__dec" == "$__long_str" ]]; then
  printf "  PASS: 1000-char string round-trip\n"; (( passed++ ))
else
  printf "  FAIL: 1000-char string length %d vs %d\n" "${#__dec}" "${#__long_str}"; (( failed++ ))
fi

# String of only percents
__bashClass.encode "%%%" __enc
__bashClass.decode "$__enc" __dec
if [[ "$__dec" == "%%%" ]]; then
  printf "  PASS: triple percent round-trip\n"; (( passed++ ))
else
  printf "  FAIL: triple percent got '%s'\n" "$__dec"; (( failed++ ))
fi

# String of only pipes
__bashClass.encode "|||" __enc
__bashClass.decode "$__enc" __dec
if [[ "$__dec" == "|||" ]]; then
  printf "  PASS: triple pipe round-trip\n"; (( passed++ ))
else
  printf "  FAIL: triple pipe got '%s'\n" "$__dec"; (( failed++ ))
fi

# String with encoded-looking sequences (should not double-decode)
__bashClass.encode "%7C%0A%25" __enc
__bashClass.decode "$__enc" __dec
if [[ "$__dec" == "%7C%0A%25" ]]; then
  printf "  PASS: encoded-looking input preserved\n"; (( passed++ ))
else
  printf "  FAIL: encoded-looking input got '%s'\n" "$__dec"; (( failed++ ))
fi


# ============================================================================
# SECTION 4: __bashClass.parse — bad keys, missing fields, injection
# ============================================================================
__section "parse"

# Valid parse
__bashClass.parse "$box" "length" __pval
if [[ "$__pval" == "5" ]]; then
  printf "  PASS: parse existing field\n"; (( passed++ ))
else
  printf "  FAIL: parse existing field got '%s'\n" "$__pval"; (( failed++ ))
fi

# Parse nonexistent field (should return empty, not crash)
__bashClass.parse "$box" "nonexistent" __pval
if [[ "$__pval" == "" ]]; then
  printf "  PASS: parse missing field returns empty\n"; (( passed++ ))
else
  printf "  FAIL: parse missing field got '%s'\n" "$__pval"; (( failed++ ))
fi

# Parse with invalid key
expect_fail "parse with invalid key (spaces)" \
  bash -c '. bashClass Cube; __bashClass.parse "bad key" "field" x'

# Parse with empty key
expect_fail "parse with empty key" \
  bash -c '. bashClass Cube; __bashClass.parse "" "field" x'

# Parse unregistered key (valid name but not in registry)
__bashClass.parse "NoSuchThing" "field" __pval
if [[ "$__pval" == "" ]]; then
  printf "  PASS: parse unregistered key returns empty\n"; (( passed++ ))
else
  printf "  FAIL: parse unregistered key got '%s'\n" "$__pval"; (( failed++ ))
fi


# ============================================================================
# SECTION 5: __bashClass.dispatch — bad methods, bad classes, injection
# ============================================================================
__section "dispatch"

# Dispatch nonexistent method
expect_fail "dispatch nonexistent method" \
  bash -c '. bashClass Cube; new Box length=1 width=1 height=1; class=Box __bashClass.dispatch explode'

# Dispatch with invalid class name
expect_fail "dispatch with invalid class (has dash)" \
  bash -c '. bashClass Cube; class=my-class __bashClass.dispatch new'

# Dispatch with empty method
expect_fail "dispatch with empty method" \
  bash -c '. bashClass Cube; class=Box __bashClass.dispatch ""'

# Dispatch method with injection attempt
expect_fail "dispatch method injection: volume;ls" \
  bash -c '. bashClass Cube; class=Box __bashClass.dispatch "volume;ls"'

# Dispatch to unregistered class
expect_fail "dispatch to unregistered class" \
  bash -c '. bashClass Cube; class=Sphere __bashClass.dispatch new'


# ============================================================================
# SECTION 6: __bashClass.registerMethod — bad inputs
# ============================================================================
__section "registerMethod"

# Register with nonexistent function
expect_fail "register nonexistent function" \
  bash -c '. bashClass Cube; __bashClass.registerMethod Box foo __nonexistent_func'

# Register with invalid class name
expect_fail "register with invalid class" \
  bash -c '. bashClass Cube; __bashClass.registerMethod "bad class" foo Box.calc'

# Register with invalid method name
expect_fail "register with invalid method (has dot)" \
  bash -c '. bashClass Cube; __bashClass.registerMethod Box "bad.method" Box.calc'

# Register with empty args
expect_fail "register with empty class" \
  bash -c '. bashClass Cube; __bashClass.registerMethod "" foo Box.calc'


# ============================================================================
# SECTION 7: new / constructors — bad args, missing class, weird values
# ============================================================================
__section "constructors"

# new with nonexistent class
expect_fail "new nonexistent class" \
  bash -c '. bashClass Cube; new Sphere size=5'

# new with invalid class name
expect_fail "new with invalid class name" \
  bash -c '. bashClass Cube; new "bad class" size=5'

# new with no args (should still work — empty object)
new Box
__empty_box="$__bashClass_RETURN"
if [[ -n "$__empty_box" ]]; then
  printf "  PASS: new Box with no args creates object\n"; (( passed++ ))
else
  printf "  FAIL: new Box with no args returned empty\n"; (( failed++ ))
fi

# Property with special chars in value
new Box length=5 width=3 height=7 color="red|blue=green%100"
__special_box="$__bashClass_RETURN"
$__special_box.color
if [[ "$__bashClass_RETURN" == "red|blue=green%100" ]]; then
  printf "  PASS: special chars in constructor arg\n"; (( passed++ ))
else
  printf "  FAIL: special chars got '%s'\n" "$__bashClass_RETURN"; (( failed++ ))
fi

# Class-as-constructor (Box)
Box length=1 width=1 height=1
__cbox="$__bashClass_RETURN"
$__cbox.volume
if [[ "$__bashClass_RETURN" == "1" ]]; then
  printf "  PASS: Box class-as-constructor works\n"; (( passed++ ))
else
  printf "  FAIL: Box class-as-constructor volume got '%s'\n" "$__bashClass_RETURN"; (( failed++ ))
fi

# Class-as-constructor (Cube)
Cube size=3
__ccube="$__bashClass_RETURN"
$__ccube.volume
if [[ "$__bashClass_RETURN" == "27" ]]; then
  printf "  PASS: Cube class-as-constructor works\n"; (( passed++ ))
else
  printf "  FAIL: Cube class-as-constructor volume got '%s'\n" "$__bashClass_RETURN"; (( failed++ ))
fi

# Explicit dispatch constructor
class=Box __bashClass.dispatch new length=2 width=3 height=4
__dbox="$__bashClass_RETURN"
$__dbox.volume
if [[ "$__bashClass_RETURN" == "24" ]]; then
  printf "  PASS: explicit dispatch constructor works\n"; (( passed++ ))
else
  printf "  FAIL: explicit dispatch constructor volume got '%s'\n" "$__bashClass_RETURN"; (( failed++ ))
fi

# Explicit dispatch constructor (Cube)
class=Cube __bashClass.dispatch new size=5
__dcube="$__bashClass_RETURN"
$__dcube.volume
if [[ "$__bashClass_RETURN" == "125" ]]; then
  printf "  PASS: explicit dispatch constructor Cube works\n"; (( passed++ ))
else
  printf "  FAIL: explicit dispatch constructor Cube volume got '%s'\n" "$__bashClass_RETURN"; (( failed++ ))
fi

# Duplicate property in args (last one wins? or first?)
new Box length=5 width=3 height=7 length=99
__dup_box="$__bashClass_RETURN"
$__dup_box.length
printf "  INFO: duplicate prop length=5 then length=99 → '%s' (documenting behavior)\n" "$__bashClass_RETURN"
(( passed++ ))


# ============================================================================
# SECTION 8: get/set — edge cases
# ============================================================================
__section "get/set"

# Get nonexistent property (should return empty)
$box.get "nosuchprop"
if [[ "$__bashClass_RETURN" == "" ]]; then
  printf "  PASS: get nonexistent property returns empty\n"; (( passed++ ))
else
  printf "  FAIL: get nonexistent got '%s'\n" "$__bashClass_RETURN"; (( failed++ ))
fi

# Set then get empty string
$box.set "emptyval" ""
$box.get "emptyval"
if [[ "$__bashClass_RETURN" == "" ]]; then
  printf "  PASS: set/get empty string\n"; (( passed++ ))
else
  printf "  FAIL: set/get empty string got '%s'\n" "$__bashClass_RETURN"; (( failed++ ))
fi

# Set a value with newlines, tabs, pipes, equals, percents
$box.set "crazy" $'line1\nline2\t|col=100%'
$box.get "crazy"
if [[ "$__bashClass_RETURN" == $'line1\nline2\t|col=100%' ]]; then
  printf "  PASS: set/get value with all special chars\n"; (( passed++ ))
else
  printf "  FAIL: set/get special chars got '%s'\n" "$__bashClass_RETURN"; (( failed++ ))
fi

# Overwrite existing property
$box.set "length" "42"
$box.get "length"
if [[ "$__bashClass_RETURN" == "42" ]]; then
  printf "  PASS: overwrite existing property\n"; (( passed++ ))
else
  printf "  FAIL: overwrite got '%s'\n" "$__bashClass_RETURN"; (( failed++ ))
fi

# Set property via shorthand accessor
$box.length 77
$box.length
if [[ "$__bashClass_RETURN" == "77" ]]; then
  printf "  PASS: shorthand set/get\n"; (( passed++ ))
else
  printf "  FAIL: shorthand got '%s'\n" "$__bashClass_RETURN"; (( failed++ ))
fi


# ============================================================================
# SECTION 9: isa — edge cases
# ============================================================================
__section "isa"

# isa with no args returns class
$cube.isa
if [[ "$__bashClass_RETURN" == "Cube" ]]; then
  printf "  PASS: isa no-arg returns class name\n"; (( passed++ ))
else
  printf "  FAIL: isa no-arg got '%s'\n" "$__bashClass_RETURN"; (( failed++ ))
fi

# isa with nonexistent class (should return false)
$cube.isa "Sphere"
if (( $? != 0 )); then
  printf "  PASS: isa Sphere returns false\n"; (( passed++ ))
else
  printf "  FAIL: isa Sphere returned true\n"; (( failed++ ))
fi

# isa with empty string (should return class name via the empty check)
$cube.isa ""
if [[ "$__bashClass_RETURN" == "Cube" ]]; then
  printf "  PASS: isa empty string returns class name\n"; (( passed++ ))
else
  printf "  FAIL: isa empty string got '%s'\n" "$__bashClass_RETURN"; (( failed++ ))
fi

# isa walks full chain
$cube.isa bashClass && __isa_rc=0 || __isa_rc=1
if (( __isa_rc == 0 )); then
  printf "  PASS: isa bashClass from Cube (full chain)\n"; (( passed++ ))
else
  printf "  FAIL: isa bashClass from Cube returned false\n"; (( failed++ ))
fi


# ============================================================================
# SECTION 10: toString — edge cases
# ============================================================================
__section "toString"

# toString on object with no user properties
new bashClass
__bare="$__bashClass_RETURN"
$__bare.toString
printf "  INFO: bare bashClass toString: '%s'\n" "$__bashClass_RETURN"
(( passed++ ))

# toString pretty on object with special chars in values
new Box length=5 width=3 height=7 color="red|blue"
__pp_box="$__bashClass_RETURN"
prettyPrint=true $__pp_box.toString
printf "  INFO: pretty with special chars:\n%s\n" "$__bashClass_RETURN"
(( passed++ ))

# toString with misspelled typecast (should get compact, not crash)
prettyprint=true $cube.toString
if [[ "$__bashClass_RETURN" == *"{"* ]]; then
  printf "  PASS: misspelled prettyprint still works (compact)\n"; (( passed++ ))
else
  printf "  FAIL: misspelled prettyprint broke something\n"; (( failed++ ))
fi


# ============================================================================
# SECTION 11: Subshell behavior — globals don't escape
# ============================================================================
__section "subshell traps"

# Set a value in a subshell — should NOT be visible in parent
__bashClass_RETURN="before_subshell"
( new Box length=99 width=99 height=99 )
if [[ "$__bashClass_RETURN" == "before_subshell" ]]; then
  printf "  PASS: subshell new doesn't leak to parent global\n"; (( passed++ ))
else
  printf "  FAIL: subshell leaked '%s'\n" "$__bashClass_RETURN"; (( failed++ ))
fi

# Object created in subshell is invisible to parent
__sub_obj=$( new Box length=1 width=1 height=1; printf "%s" "$__bashClass_RETURN" )
if [[ -z "${__bashClass_registry[$__sub_obj]:-}" ]]; then
  printf "  PASS: subshell object not in parent registry\n"; (( passed++ ))
else
  printf "  FAIL: subshell object leaked to parent registry\n"; (( failed++ ))
fi

# Method call in subshell uses stdout (auto mode)
__sub_vol=$( $cube.volume )
# In subshell, auto→stdout, so volume prints to stdout directly.
if [[ "$__sub_vol" == "64" ]]; then
  printf "  PASS: method in subshell returns via stdout (auto mode)\n"; (( passed++ ))
else
  printf "  FAIL: method in subshell got '%s'\n" "$__sub_vol"; (( failed++ ))
fi


# ============================================================================
# SECTION 12: Lazy stubs and baking — verify behavior
# ============================================================================
__section "lazy stubs"

# Create fresh object, inspect stub before first call
new Box length=2 width=3 height=4
__stub_box="$__bashClass_RETURN"

# The stub should contain __init=true
__stub_def=$(declare -f "$__stub_box.volume")
if [[ "$__stub_def" == *"__init=true"* ]]; then
  printf "  PASS: stub contains __init=true before first call\n"; (( passed++ ))
else
  printf "  FAIL: stub doesn't contain __init=true: %s\n" "$__stub_def"; (( failed++ ))
fi

# Call it — should bake
$__stub_box.volume

# Now the baked version should NOT contain __init=true
__baked_def=$(declare -f "$__stub_box.volume")
if [[ "$__baked_def" != *"__init=true"* ]]; then
  printf "  PASS: baked wrapper does not contain __init=true\n"; (( passed++ ))
else
  printf "  FAIL: baked wrapper still has __init=true: %s\n" "$__baked_def"; (( failed++ ))
fi

# Baked wrapper should contain the resolved impl name
if [[ "$__baked_def" == *"Box.volume"* ]]; then
  printf "  PASS: baked wrapper calls Box.volume directly\n"; (( passed++ ))
else
  printf "  FAIL: baked wrapper doesn't reference Box.volume: %s\n" "$__baked_def"; (( failed++ ))
fi


# ============================================================================
# SECTION 13: Typecasting — baked wrapper fallback
# ============================================================================
__section "typecasting"

new Cube size=5
__tc="$__bashClass_RETURN"

# Bake it first
$__tc.volume
expect_value "Cube volume normal" "125" $__tc.volume

# Typecast to Box — should dispatch, not use baked Cube path
class=Box $__tc.volume
expect_value "Cube volume typecast to Box" "125" true

# Typecast to nonexistent class — should crash
expect_fail "typecast to nonexistent class" \
  bash -c ". bashClass Cube; new Cube size=5; tc=\$__bashClass_RETURN; \$tc.volume; class=Sphere \$tc.volume"

# Typecast to parent (Box) then back to normal
class=Box $__tc.side
__tc_side="$__bashClass_RETURN"
$__tc.side
__tc_side2="$__bashClass_RETURN"
if [[ "$__tc_side" == "25" && "$__tc_side2" == "25" ]]; then
  printf "  PASS: typecast to Box.side then normal Cube.side both = 25\n"; (( passed++ ))
else
  printf "  FAIL: typecast side=%s normal side=%s\n" "$__tc_side" "$__tc_side2"; (( failed++ ))
fi


# ============================================================================
# SECTION 14: super — edge cases
# ============================================================================
__section "super"

# super from bashClass (no parent — should crash)
expect_fail "super from root class" \
  bash -c '. bashClass Cube; new bashClass; obj=$__bashClass_RETURN; $obj.super volume'

# super from Box (parent is bashClass, which has no volume — should crash)
expect_fail "super volume from Box (bashClass has no volume)" \
  bash -c '. bashClass Cube; new Box length=1 width=1 height=1; obj=$__bashClass_RETURN; self=$obj class=Box __bashClass.dispatch super volume'


# ============================================================================
# SECTION 15: bencode/bdecode — bad inputs
# ============================================================================
__section "bencode/bdecode"

# bencode empty string
__bashClass.bencode ""
__bashClass.bdecode "$__bashClass_RETURN"
if [[ "$__bashClass_RETURN" == "" ]]; then
  printf "  PASS: bencode/bdecode empty string\n"; (( passed++ ))
else
  printf "  FAIL: bencode/bdecode empty got '%s'\n" "$__bashClass_RETURN"; (( failed++ ))
fi

# bencode with misspelled typecast (input vs inpt)
# Should fall through to default (string mode), not crash
__bashClass.bencode "hello"
__orig="$__bashClass_RETURN"
inpt=file __bashClass.bencode "hello"
if [[ "$__bashClass_RETURN" == "$__orig" ]]; then
  printf "  PASS: misspelled typecast falls through to string mode\n"; (( passed++ ))
else
  printf "  FAIL: misspelled typecast gave different result\n"; (( failed++ ))
fi

# bencode file mode with nonexistent file
expect_fail "bencode nonexistent file" \
