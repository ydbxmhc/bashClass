# ============================================================================
# SECTION 25: Nonzero integer validation — Box.calc
# ============================================================================
__section "nonzero validation"

# Zero should be rejected
expect_fail "calc rejects zero" \
  bash -c '. bashClass Cube; Box.calc 5 0 3'

# Negative should be rejected (not matching ^[0-9]+$)
expect_fail "calc rejects negative" \
  bash -c '. bashClass Cube; Box.calc 5 -3 7'

