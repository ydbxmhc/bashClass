# ============================================================================
# SECTION 24: __return typecast — named return through the full stack
# ============================================================================
__section "__return typecast"

new Box length=5 width=3 height=7
__rt_box="$__bashClass_RETURN"

# __return on a leaf method (calc via volume)
__rt_vol=""
__return=__rt_vol $__rt_box.volume
if [[ "$__rt_vol" == "105" ]]; then
  printf "  PASS: __return on volume = 105\n"; (( passed++ ))
else
  printf "  FAIL: __return on volume got '%s'\n" "$__rt_vol"; (( failed++ ))
fi

# __return on get (leaf, through dispatch)
__rt_len=""
__return=__rt_len $__rt_box.get length
if [[ "$__rt_len" == "5" ]]; then
  printf "  PASS: __return on get length = 5\n"; (( passed++ ))
else
  printf "  FAIL: __return on get length got '%s'\n" "$__rt_len"; (( failed++ ))
fi

# __return on property shorthand accessor
__rt_width=""
__return=__rt_width $__rt_box.width
if [[ "$__rt_width" == "3" ]]; then
  printf "  PASS: __return on shorthand width = 3\n"; (( passed++ ))
else
  printf "  FAIL: __return on shorthand width got '%s'\n" "$__rt_width"; (( failed++ ))
fi

# __return on isa (no-arg, returns class name)
__rt_class=""
__return=__rt_class $__rt_box.isa
if [[ "$__rt_class" == "Box" ]]; then
  printf "  PASS: __return on isa = Box\n"; (( passed++ ))
else
  printf "  FAIL: __return on isa got '%s'\n" "$__rt_class"; (( failed++ ))
fi

# __return on toString (compact)
__rt_str=""
__return=__rt_str $__rt_box.toString
if [[ "$__rt_str" == *"Box("* ]]; then
  printf "  PASS: __return on toString contains Box(\n"; (( passed++ ))
else
  printf "  FAIL: __return on toString got '%s'\n" "$__rt_str"; (( failed++ ))
fi

# __return on toString pretty
__rt_pretty=""
__return=__rt_pretty $__rt_box.toString pretty
if [[ "$__rt_pretty" == *$'\n'* ]]; then
  printf "  PASS: __return on toString pretty contains newlines\n"; (( passed++ ))
else
  printf "  FAIL: __return on toString pretty got '%s'\n" "$__rt_pretty"; (( failed++ ))
fi

# __return through delegation chain: Cube.top → Cube.side → Box.area → Box.calc
new Cube size=4
__rt_cube="$__bashClass_RETURN"
__rt_top=""
__return=__rt_top $__rt_cube.top
if [[ "$__rt_top" == "16" ]]; then
  printf "  PASS: __return through Cube.top chain = 16\n"; (( passed++ ))
else
  printf "  FAIL: __return through Cube.top chain got '%s'\n" "$__rt_top"; (( failed++ ))
fi

# __return on bottom (delegates to top)
__rt_bottom=""
__return=__rt_bottom $__rt_cube.bottom
