#!/bin/bash
set -uo pipefail

# Adversarial / framework integration tests
#
# Tests that should FAIL (and we catch the failure), tests that should
# SUCCEED in weird conditions, and tests designed to surprise us.
# Covers: input validation, return modes, encode/decode, parse, resolve,
# registerMethod, constructors, get/set, isa, toString, subshells,
# wrappers, typecasting, _Delegate, _Super, _Cast, serialization,
# rapid creation, _Crash, into= edge cases.
#
# Classification: INTEGRATION / ADVERSARIAL
# The benchmark section is opt-in — pass a count as $1 to enable it.

__bench_count="${1:-0}"

. boop TestSuite Cube

into=t TestSuite name="Stress Tests"

# ============================================================================
# Setup: create base objects
# ============================================================================

into=box new Box length=5 width=3 height=7
into=cube new Cube size=4 unit=cm

# ============================================================================
# SECTION 1: validate — input validation
# ============================================================================

$t.section "validate"
$t.assert_ok "valid identifier: Box" __boop.validate "Box"
$t.assert_ok "valid identifier: _foo123" __boop.validate "_foo123"
$t.assert_ok "valid function: Box.calc" bash -c '. boop Cube; type=function __boop.validate "Box.calc"'
$t.assert_ok "valid function: a.b.c" bash -c '. boop Cube; type=function __boop.validate "a.b.c"'
$t.assert_fail "empty string" bash -c '. boop Cube; __boop.validate ""'
$t.assert_fail "starts with number: 1Box" bash -c '. boop Cube; __boop.validate "1Box"'
$t.assert_fail "has spaces: my box" bash -c '. boop Cube; __boop.validate "my box"'
$t.assert_fail "has dash: my-box" bash -c '. boop Cube; __boop.validate "my-box"'
$t.assert_fail "dot in identifier mode" bash -c '. boop Cube; __boop.validate "Box.new"'
$t.assert_fail "semicolon injection" bash -c '. boop Cube; __boop.validate "foo;ls"'
$t.assert_fail "pipe injection" bash -c '. boop Cube; __boop.validate "foo|bar"'
$t.assert_fail "dollar injection" bash -c '. boop Cube; __boop.validate "\$HOME"'
$t.assert_fail "backtick injection" bash -c '. boop Cube; __boop.validate "\`whoami\`"'
$t.assert_fail "misspelled typecast" bash -c '. boop Cube; typ=function __boop.validate "Box.calc"'

# ============================================================================
# SECTION 2: return modes
# ============================================================================

$t.section "return modes"

# Auto mode: global in main shell
_OutMode=auto
boop.pass "hello_auto"
$t.assert_eq "auto mode in main shell → global" "$_Out" "hello_auto"

# Auto mode: stdout in subshell
__sub_out=$( boop.pass "hello_sub" )
$t.assert_eq "auto mode in subshell → stdout" "$__sub_out" "hello_sub"

# Explicit global
_OutMode=global
boop.pass "hello_global"
$t.assert_eq "explicit global mode" "$_Out" "hello_global"

# Explicit stdout
$t.assert_ok "explicit stdout mode" bash -c '. boop Cube; _OutMode=stdout; out=$(boop.pass "hello_stdout"); [ "$out" = "hello_stdout" ]'

# Explicit nameref
_OutMode=auto
local_target=""
boop.pass "hello_nameref" local_target
$t.assert_eq "nameref mode" "$local_target" "hello_nameref"

# Nameref with no target (should crash)
$t.assert_fail "nameref mode, no target" bash -c '. boop Cube; _OutMode=nameref; boop.pass "boom"'

# Nameref in subshell (should work)
$t.assert_ok "nameref in subshell" bash -c '. boop Cube; _OutMode=nameref; boop.pass "boom" myvar'

# Filesystem mode
_OutMode=filesystem
__boop_tmpdir="/tmp"
boop.pass "hello_fs"
__fs_found=0
for f in /tmp/__boop_*; do
  [[ -f "$f" ]] && __fs_found=1 && rm -f "$f"
done
$t.assert_ok "filesystem mode wrote a file" test "$__fs_found" -eq 1

# Invalid mode
$t.assert_fail "invalid return mode: banana" bash -c '. boop Cube; _OutMode=banana; boop.pass "boom"'

# Reset
_OutMode=auto

# ============================================================================
# SECTION 3: encode/decode — edge cases
# ============================================================================

$t.section "encode/decode"

__boop.encode "" __enc; __boop.decode "$__enc" __dec
$t.assert_eq "empty string round-trip" "$__dec" ""

__boop.encode "%|=
	" __enc; __boop.decode "$__enc" __dec
$t.assert_eq "all special chars round-trip" "$__dec" "%|=
	"

__boop.encode "hello%25world" __enc; __boop.decode "$__enc" __dec
$t.assert_eq "double-encode round-trip preserves %25" "$__dec" "hello%25world"

__long_str=$(printf 'A%.0s' {1..1000})
__boop.encode "$__long_str" __enc; __boop.decode "$__enc" __dec
$t.assert_eq "1000-char string round-trip" "$__dec" "$__long_str"

__boop.encode "%%%" __enc; __boop.decode "$__enc" __dec
$t.assert_eq "triple percent round-trip" "$__dec" "%%%"

__boop.encode "|||" __enc; __boop.decode "$__enc" __dec
$t.assert_eq "triple pipe round-trip" "$__dec" "|||"

__boop.encode "%7C%0A%25" __enc; __boop.decode "$__enc" __dec
$t.assert_eq "encoded-looking input preserved" "$__dec" "%7C%0A%25"

# ============================================================================
# SECTION 4: parse — bad keys, missing fields, injection
# ============================================================================

$t.section "parse"
__boop.parse "$box" "length" __pval
$t.assert_eq "parse existing field" "$__pval" "5"
__boop.parse "$box" "nonexistent" __pval
$t.assert_eq "parse missing field returns empty" "$__pval" ""
$t.assert_fail "parse with invalid key (spaces)" bash -c '. boop Cube; __boop.parse "bad key" "field" x'
$t.assert_fail "parse with empty key" bash -c '. boop Cube; __boop.parse "" "field" x'
__boop.parse "NoSuchThing" "field" __pval
$t.assert_eq "parse unregistered key returns empty" "$__pval" ""

# ============================================================================
# SECTION 5: resolve — bad methods, bad classes, injection
# ============================================================================

$t.section "resolve"
$t.assert_fail "resolve nonexistent method"          bash -c '. boop Cube;
   __boop.methodResolve Box explode impl'
$t.assert_fail "resolve empty method"                bash -c '. boop Cube;
   __boop.methodResolve Box "" impl'
$t.assert_fail "resolve unregistered class"          bash -c '. boop Cube;
   __boop.methodResolve Sphere new impl'
$t.assert_fail "resolve invalid class (has dash)"    bash -c '. boop Cube;
   __boop.methodResolve my-class new impl'
$t.assert_fail "resolve method injection: volume;ls" bash -c '. boop Cube;
   __boop.methodResolve Box "volume;ls" impl'

#$t.section "dispatch"
#$t.assert_fail "dispatch nonexistent method" bash -c '. boop Cube; new Box length=1 width=1 height=1; _Class=Box __boop.dispatch explode'
#$t.assert_fail "dispatch with invalid class (has dash)" bash -c '. boop Cube; _Class=my-class __boop.dispatch new'
#$t.assert_fail "dispatch with empty method" bash -c '. boop Cube; _Class=Box __boop.dispatch ""'
#$t.assert_fail "dispatch method injection: volume;ls" bash -c '. boop Cube; _Class=Box __boop.dispatch "volume;ls"'
#$t.assert_fail "dispatch to unregistered class" bash -c '. boop Cube; _Class=Sphere __boop.dispatch new'

# ============================================================================
# SECTION 6: registerMethod — bad inputs
# ============================================================================

$t.section "registerMethod"
$t.assert_fail "register nonexistent function" bash -c '. boop Cube; __boop.registerMethod Box foo __nonexistent_func'
$t.assert_fail "register with invalid class" bash -c '. boop Cube; __boop.registerMethod "bad class" foo Box.calc'
$t.assert_fail "register with invalid method (has dot)" bash -c '. boop Cube; __boop.registerMethod Box "bad.method" Box.calc'
$t.assert_fail "register with empty class" bash -c '. boop Cube; __boop.registerMethod "" foo Box.calc'

# ============================================================================
# SECTION 7: constructors — bad args, missing class, weird values
# ============================================================================

$t.section "constructors"
$t.assert_fail "new nonexistent class" bash -c '. boop Cube; new Sphere size=5'
$t.assert_fail "new with invalid class name" bash -c '. boop Cube; new "bad class" size=5'

# new with no args (should still work — empty object)
new Box; __empty_box="$_Out"
$t.assert_match "new Box with no args creates object" "$__empty_box" "_*"

# Property with special chars in value
new Box length=5 width=3 height=7 color="red|blue=green%100"
__special_box="$_Out"
$__special_box.color
$t.assert_eq "special chars in constructor arg" "$_Out" "red|blue=green%100"

# Class-as-constructor
Box length=1 width=1 height=1; __cbox="$_Out"
$__cbox.volume
$t.assert_eq "Box class-as-constructor" "$_Out" "1"

Cube size=3; __ccube="$_Out"
$__ccube.volume
$t.assert_eq "Cube class-as-constructor" "$_Out" "27"

# Explicit MRO constructor
__dbox_impl=''
__boop.methodResolve Box new __dbox_impl
_Class=Box $__dbox_impl length=2 width=3 height=4; __dbox="$_Out"
$__dbox.volume
$t.assert_eq "explicit MRO constructor Box" "$_Out" "24"
unset __dbox_impl

__dcube_impl=''
__boop.methodResolve Cube new __dcube_impl
_Class=Cube $__dcube_impl size=5; __dcube="$_Out"
$__dcube.volume
$t.assert_eq "explicit MRO constructor Cube" "$_Out" "125"
unset __dcube_impl

# Duplicate property in args: last write wins (length=99 replaces length=5)
into=__dup_box new Box length=5 width=3 height=7 length=99
into=__dup_len $__dup_box.get length
$t.assert_eq "duplicate prop: last value wins" "$__dup_len" "99"

# ============================================================================
# SECTION 8: get/set — edge cases
# ============================================================================

$t.section "get/set"
$box.get "nosuchprop"
$t.assert_eq "get nonexistent property returns empty" "$_Out" ""
$box.set "emptyval" ""
$box.get "emptyval"
$t.assert_eq "set/get empty string" "$_Out" ""
$box.set "crazy" "line1
line2	|col=100%"
$box.get "crazy"
$t.assert_eq "set/get value with all special chars" "$_Out" "line1
line2	|col=100%"
$box.set "length" "42"
$box.get "length"
$t.assert_eq "overwrite existing property" "$_Out" "42"
$box.length 77
$box.length
$t.assert_eq "shorthand set/get" "$_Out" "77"

# ============================================================================
# SECTION 9: isa — edge cases
# ============================================================================

$t.section "isa"
$cube.isa
$t.assert_eq "isa no-arg returns class name" "$_Out" "Cube"
$t.assert_fail "isa Sphere returns false" $cube.isa "Sphere"
$cube.isa ""
$t.assert_eq "isa empty string returns class name" "$_Out" "Cube"
$t.assert_ok "isa boop from Cube (full chain)" $cube.isa boop

# ============================================================================
# SECTION 10: toString — edge cases
# ============================================================================

$t.section "toString"
new boop; __bare="$_Out"
$__bare.toString
$t.assert_contains "bare boop toString" "$_Out" "boop("

new Box length=5 width=3 height=7 color="red|blue"
__pp_box="$_Out"
prettyPrint=true $__pp_box.toString
$t.info "pretty with special chars: $_Out"

# Misspelled typecast should not crash
prettyprint=true $cube.toString
$t.assert_contains "misspelled prettyprint still works (compact)" "$_Out" "{"

# ============================================================================
# SECTION 11: Subshell behavior
# ============================================================================

$t.section "subshell traps"
_Out="before_subshell"
( new Box length=99 width=99 height=99 ) > /dev/null
$t.assert_eq "subshell new doesn't leak to parent global" "$_Out" "before_subshell"

__sub_obj=$( new Box length=1 width=1 height=1; printf "%s" "$_Out" )
if [[ -z "${__boop_registry[$__sub_obj]:-}" ]]; then
  $t.assert_ok "subshell object not in parent registry" true
else
  $t.assert_ok "subshell object not in parent registry" false
fi

__sub_vol=$( $cube.volume )
$t.assert_eq "method in subshell returns via stdout" "$__sub_vol" "64"

# ============================================================================
# SECTION 12: Direct wrappers (no lazy stubs)
# ============================================================================

$t.section "direct wrappers"
into=__stub_box new Box length=2 width=3 height=4
__wrap_def=$(declare -f "$__stub_box.volume")
# Wrappers call the class function directly — no dispatch, no __init
$t.assert_contains "wrapper calls Box.volume directly" "$__wrap_def" "Box.volume"
$t.assert_ok "wrapper does not contain __init"    test -z "${__wrap_def##*${__wrap_def/__init/}}"
$t.assert_ok "wrapper does not contain dispatch"  test -z "${__wrap_def##*${__wrap_def/dispatch/}}"
$__stub_box.volume
__wrap_def2=$(declare -f "$__stub_box.volume")
$t.assert_eq "wrapper unchanged after first call" "$__wrap_def" "$__wrap_def2"

# ============================================================================
# SECTION 13: Typecasting
# ============================================================================

$t.section "typecasting"
new Cube size=5; __tc="$_Out"
$__tc.volume
$t.assert_eq "Cube volume normal" "$_Out" "125"
_Class=Box $__tc.volume
$t.assert_eq "Cube volume typecast to Box" "$_Out" "125"
# Typecast to nonexistent class — tier 3 (unrelated class) silently ignores
# the bogus class and uses the baked class instead. This is correct behavior:
# leakage/bogus typecasts don't crash, they just get ignored.
_Class=Sphere $__tc.volume
$t.assert_eq "typecast to nonexistent class uses baked class" "$_Out" "125"

_Class=Box $__tc.side; __tc_side="$_Out"
$__tc.side; __tc_side2="$_Out"
$t.assert_eq "typecast to Box.side" "$__tc_side" "25"
$t.assert_eq "normal Cube.side after typecast" "$__tc_side2" "25"

# ============================================================================
# SECTION 14: _Delegate and cross-object calls
# ============================================================================

$t.section "_Delegate and cross-object calls"

# Setup: two unrelated objects — a Cube and a Box
new Cube size=4; __del_cube="$_Out"
new Box length=2 width=3 height=5; __del_box="$_Out"
# _Delegate returns the correct value
into=__del_dval _Delegate $__del_box.volume
$t.assert_eq "_Delegate returns correct value via into" "$__del_dval" "30"

# _Delegate with isa across object boundaries
$t.assert_ok "_Delegate isa on unrelated object" _Delegate $__del_box.isa Box
$t.assert_fail "_Delegate isa wrong class" _Delegate $__del_box.isa Cube

# ============================================================================
# SECTION 15: super — edge cases
# ============================================================================
$t.section "_Super"

# Success — explicit _Super call with _Self and _Class set directly
into=c Cube size=4
into=v _Self="$c" _Class=Cube _Super side
$t.assert_eq "_Super Cube→Box.side" "$v" "16"

# Fail — no parent (boop is root)
$t.assert_fail "_Super from root class" bash -c '. boop Cube
  new boop; obj=$_Out
  _Self=$obj _Class=boop _Super toString
'
# Fail — parent exists but method not found there
$t.assert_fail "_Super method not found in parent" bash -c '. boop Cube
  new Box length=1 width=1 height=1; obj=$_Out
  _Self=$obj _Class=Box _Super volume
'
# Fail — no method name given
$t.assert_fail "_Super no method name" bash -c '. boop Cube
  new Cube size=1; obj=$_Out
  _Self=$obj _Class=Cube _Super
'

# ============================================================================
# SECTION 16: Typecasting and Delegation
# ============================================================================

$t.section "_Cast"

# Success — call Box.area directly, passing args explicitly (no property lookup)
into=c Cube size=5
into=v _Cast Box "$c" area 3 4
$t.assert_eq "_Cast Box.area with explicit args" "$v" "12"
unset c

# Fail — nonexistent class
$t.assert_fail "_Cast nonexistent class" bash -c '. boop Cube
  new Cube size=1; obj=$_Out
  _Cast Sphere "$obj" volume
'
# Fail — missing arguments
$t.assert_fail "_Cast no class" bash -c '. boop Cube
  _Cast "" "" volume
'
$t.assert_fail "_Cast no method" bash -c '. boop Cube
  new Cube size=1; obj=$_Out
  _Cast Box "$obj"
'

# ============================================================================
# SECTION 17: setDefaultMode — bad inputs
# ============================================================================

$t.section "setDefaultMode"
$t.assert_fail "setDefaultMode with garbage" bash -c '. boop Cube; __boop.setDefaultMode "garbage"'
$t.assert_fail "setDefaultMode with empty" bash -c '. boop Cube; __boop.setDefaultMode ""'
for mode in auto nameref stdout global filesystem; do
  $t.assert_ok "setDefaultMode $mode" bash -c ". boop Cube; __boop.setDefaultMode $mode"
done

# ============================================================================
# SECTION 18: registerClass — bad inputs
# ============================================================================

$t.section "registerClass"
$t.assert_fail "registerClass with invalid name" bash -c '. boop Cube; __boop.registerClass "bad class"'
$t.assert_fail "registerClass with no descriptor" bash -c '. boop Cube; __boop.registerClass "Phantom"'

# ============================================================================
# SECTION 19: refresh — re-stubbing
# ============================================================================

$t.section "refresh"
new Box length=3 width=4 height=5; __rbox="$_Out"
$__rbox.volume
$t.assert_eq "pre-refresh volume" "$_Out" "60"
__boop.refresh "$__rbox"
__rdef=$(declare -f "$__rbox.volume")
# After refresh, wrapper is regenerated — still a direct wrapper, no dispatch
$t.assert_contains "refresh re-wrapped the method" "$__rdef" "Box.volume"
$t.assert_fail "refresh wrapper has no dispatch" test "${__rdef}" != "${__rdef/dispatch/}"
$__rbox.volume
$t.assert_eq "post-refresh volume still correct" "$_Out" "60"
$t.assert_fail "refresh nonexistent object" bash -c '. boop Cube; __boop.refresh "no_such_obj"'

# ============================================================================
# SECTION 20: Return modes through the full stack
# ============================================================================

$t.section "return modes through object methods"
new Box length=6 width=7 height=8; __rm_box="$_Out"

_OutMode=auto
$__rm_box.volume
$t.assert_eq "auto/global: volume" "$_Out" "336"

_OutMode=global
$__rm_box.volume
$t.assert_eq "explicit global: volume" "$_Out" "336"

$t.assert_ok "stdout mode: volume" bash -c '. boop Cube; new Box length=6 width=7 height=8; b=$_Out; _OutMode=stdout; out=$($b.volume); [ "$out" = "336" ]'

_OutMode=auto
$__rm_box.get length
$t.assert_eq "get length via global" "$_Out" "6"

_OutMode=auto

# ============================================================================
# SECTION 21: Serialization — round-trip
# ============================================================================

$t.section "serialization"
__ser_file="/tmp/test_serialize_$$.dat"
# Create a known object to verify round-trip property values
into=__ser_box new Box length=42 width=7 height=3
__ser_box_id="$__ser_box"
__boop.serialize "$__ser_file"
$t.assert_ok "serialize wrote file" test -f "$__ser_file"
# Deserialize in a fresh shell and verify the property value survived
__ser_result=$(bash -c "
  . boop Cube
  __boop.deserialize '$__ser_file'
  __boop.parse '$__ser_box_id' 'length' val
  printf '%s' \"\$val\"
")
$t.assert_eq "deserialized property value correct" "$__ser_result" "42"
rm -f "$__ser_file"
$t.assert_fail "deserialize nonexistent file" bash -c '. boop Cube; __boop.deserialize /tmp/no_such_file_ever'
# ============================================================================
# SECTION 22: Multiple inheritance chain depth
# ============================================================================

$t.section "deep inheritance"
$cube.get "size"
$t.assert_eq "Cube.get (inherited 2 levels) = size" "$_Out" "4"
$t.assert_ok "Cube isa boop (2 levels)" $cube.isa boop

# ============================================================================
# SECTION 23: Rapid object creation — timing and uniqueness
# ============================================================================

$t.section "rapid creation"
declare -A __seen_ids
__dupes=0
for i in {1..50}; do
  new Box length=$i width=$i height=$i
  __id="$_Out"
  if [[ -n "${__seen_ids[$__id]:-}" ]]; then (( __dupes++ )); fi
  __seen_ids[$__id]=1
done
$t.assert_eq "50 rapid objects, all unique IDs" "$__dupes" "0"
unset __seen_ids

# ============================================================================
# SECTION 24: _Crash — unified crash handler
# ============================================================================

$t.section "_Crash"
$t.assert_fail "crash default exit code" bash -c '. boop Cube; _Crash "boom"'

__crash_rc=0
bash -c '. boop Cube; _Err=42 _Crash "custom code"' 2>/dev/null || __crash_rc=$?
$t.assert_eq "crash with custom exit code 42" "$__crash_rc" "42"

__crash_stdout=$(bash -c '. boop Cube; _Crash "stderr test"' 2>/dev/null)
$t.assert_eq "crash message goes to stderr, not stdout" "$__crash_stdout" ""

__crash_rc=0
bash -c '. boop Cube; _StackTrace=0 _Crash "no trace"' 2>/dev/null || __crash_rc=$?
$t.assert_eq "crash with _StackTrace=0 still exits" "$__crash_rc" "1"

# ============================================================================
# SECTION 25: into typecast — named return through the full stack
# ============================================================================

$t.section "into typecast"
new Box length=5 width=3 height=7; __rt_box="$_Out"

into=__rt_vol $__rt_box.volume
$t.assert_eq "into on volume = 105" "$__rt_vol" "105"

into=__rt_len $__rt_box.get length
$t.assert_eq "into on get length = 5" "$__rt_len" "5"

into=__rt_width $__rt_box.width
$t.assert_eq "into on shorthand width = 3" "$__rt_width" "3"

into=__rt_class $__rt_box.isa
$t.assert_eq "into on isa = Box" "$__rt_class" "Box"

into=__rt_str $__rt_box.toString
$t.assert_contains "into on toString contains Box(" "$__rt_str" "Box("

into=__rt_pretty $__rt_box.toString pretty
$t.assert_contains "into on toString pretty contains newlines" "$__rt_pretty" "
"

# into through delegation chain: Cube.top → side → Box.area → Box.calc
new Cube size=4; __rt_cube="$_Out"
into=__rt_top $__rt_cube.top
$t.assert_eq "into through Cube.top chain = 16" "$__rt_top" "16"

into=__rt_bottom $__rt_cube.bottom
$t.assert_eq "into through Cube.bottom → side = 16" "$__rt_bottom" "16"

into=__rt_newobj new Box length=1 width=1 height=1
$t.assert_match "into on new returns valid object ID" "$__rt_newobj" "_[0-9a-f]*"

# into does NOT pollute _Out when used
_Out="sentinel"
into=__rt_check $__rt_box.volume
$t.assert_eq "into bypasses _Out" "$_Out" "sentinel"

# into with typecast to parent class
into=__rt_tc _Class=Box $__rt_cube.volume
$t.assert_eq "into with typecast to Box = 64" "$__rt_tc" "64"

# ============================================================================
# SECTION 26: Nonzero integer validation — Box.calc
# ============================================================================

$t.section "nonzero validation"
$t.assert_fail "calc rejects zero" bash -c '. boop Cube; Box.calc 5 0 3'
$t.assert_fail "calc rejects negative" bash -c '. boop Cube; Box.calc 5 -3 7'
$t.assert_fail "calc rejects letters" bash -c '. boop Cube; Box.calc 5 abc 7'
$t.assert_fail "calc rejects empty arg" bash -c '. boop Cube; Box.calc 5 "" 7'
$t.assert_fail "calc rejects float" bash -c '. boop Cube; Box.calc 5 3.5 7'

$t.assert_ok "calc single arg" bash -c '. boop Cube; Box.calc 42; [ "$_Out" = "42" ]'
$t.assert_ok "calc 2*3*7" bash -c '. boop Cube; Box.calc 2 3 7; [ "$_Out" = "42" ]'

$t.assert_fail "calc required=3 with 2 args" bash -c '. boop Cube; required=3 Box.calc 5 3'
$t.assert_ok "calc required=2 with 2 args" bash -c '. boop Cube; required=2 Box.calc 5 3'

$t.assert_fail "volume after setting dimension to 0" bash -c '. boop Cube; new Box length=5 width=3 height=7; b=$_Out; $b.set height 0; $b.volume'

# ============================================================================
# SECTION 27: into edge cases
# ============================================================================

$t.section "into edge cases"

# into in a subshell
__rt_sub=$(
  __boop_rootPID=$BASHPID
  new Box length=2 width=3 height=4
  __rt_sub_b="$_Out"
  __rt_sub_vol=""
  into=__rt_sub_vol $__rt_sub_b.volume
  printf "%s" "$__rt_sub_vol"
)
$t.assert_eq "into in subshell = 24" "$__rt_sub" "24"

# into unset — falls through to global mode
new Box length=2 width=5 height=3; __rt_fb="$_Out"
$__rt_fb.volume
$t.assert_eq "no into falls through to global = 30" "$_Out" "30"

# into with same var name at two levels doesn't collide
new Cube size=3; __rt_nest="$_Out"
into=__rt_nest_vol $__rt_nest.volume
$t.assert_eq "nested into chain no collision = 27" "$__rt_nest_vol" "27"

# Multiple sequential into calls don't leak between calls
into=__rt_a $__rt_box.top
into=__rt_b $__rt_box.side
$t.assert_eq "sequential into: top=15" "$__rt_a" "15"
$t.assert_eq "sequential into: side=35" "$__rt_b" "35"

# ============================================================================
# SECTION 28: Bulk benchmark (optional — pass count as $1)
# ============================================================================

if (( __bench_count > 0 )); then
  $t.section "bulk benchmark ($__bench_count objects)"
  $t.info "Creating $__bench_count objects..."

  declare -a __bench_objs=()
  __bc_start=$EPOCHREALTIME
  for (( __bi=0; __bi < __bench_count; __bi++ )); do
    new Cube size=$(( __bi + 1 )) unit=cm
    __bench_objs+=("$_Out")
  done
  __bc_end=$EPOCHREALTIME
  $t.info "Creation: $(awk "BEGIN{printf \"%.3f\", $__bc_end - $__bc_start}")s ($__bench_count objects)"

  __bm_start=$EPOCHREALTIME
  declare -i __bench_calls=0
  for __bobj in "${__bench_objs[@]}"; do
    $__bobj.volume >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.side >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.top >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.end >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.bottom >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.size >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.unit >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.isa >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.isa Cube >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.isa Box >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.toString >/dev/null 2>&1; (( __bench_calls++ ))
  done
  __bm_end=$EPOCHREALTIME
  $t.info "Methods: $(awk "BEGIN{printf \"%.3f\", $__bm_end - $__bm_start}")s ($__bench_calls calls, first pass)"

  __bb_start=$EPOCHREALTIME
  __bench_calls=0
  for __bobj in "${__bench_objs[@]}"; do
    $__bobj.volume >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.side >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.top >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.end >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.bottom >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.size >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.unit >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.isa >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.isa Cube >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.isa Box >/dev/null 2>&1; (( __bench_calls++ ))
    $__bobj.toString >/dev/null 2>&1; (( __bench_calls++ ))
  done
  __bb_end=$EPOCHREALTIME
  $t.info "Baked: $(awk "BEGIN{printf \"%.3f\", $__bb_end - $__bb_start}")s ($__bench_calls calls, second pass)"

  unset __bench_objs
else
  $t.section "bulk benchmark"
  $t.info "SKIPPED (pass a number as \$1 to run, e.g. ./test_stress_ts 100)"
fi

$t.summary
