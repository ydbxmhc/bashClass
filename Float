# ============================================================================
# Utility methods
# ============================================================================

# Absolute value as a new Float.
Float.abs() {
  local -I self class
  local -i __Float_abs_val __Float_abs_scale
  __Float.resolve "$self" __Float_abs_val __Float_abs_scale
  (( __Float_abs_val < 0 )) && (( __Float_abs_val = -__Float_abs_val ))
  __Float.fromRaw $__Float_abs_val $__Float_abs_scale ${into:-}
}

# Negated value as a new Float.
Float.neg() {
  local -I self class
  local -i __Float_neg_val __Float_neg_scale
  __Float.resolve "$self" __Float_neg_val __Float_neg_scale
  __Float.fromRaw $(( -__Float_neg_val )) $__Float_neg_scale ${into:-}
}

# Round to N decimal places. Returns a new Float.
# Uses round-half-up: 2.345 rounded to 2 places → 2.35
Float.round() {
  local -I self class
  local -i __Float_round_places="${1:-0}"
  local -i __Float_round_val __Float_round_scale
  __Float.resolve "$self" __Float_round_val __Float_round_scale

  if (( __Float_round_places >= __Float_round_scale )); then
    local -i __Float_round_diff=$(( __Float_round_places - __Float_round_scale ))
    local -i __Float_round_mul=1 __Float_round_i
    for (( __Float_round_i=0; __Float_round_i < __Float_round_diff; __Float_round_i++ )); do
      (( __Float_round_mul *= 10 ))
    done
    __Float.fromRaw $(( __Float_round_val * __Float_round_mul )) $__Float_round_places ${into:-}
    return
  fi

  local -i __Float_round_diff=$(( __Float_round_scale - __Float_round_places ))
  local -i __Float_round_div=1 __Float_round_i
  for (( __Float_round_i=0; __Float_round_i < __Float_round_diff; __Float_round_i++ )); do
    (( __Float_round_div *= 10 ))
  done

  local -i __Float_round_sign=1
  (( __Float_round_val < 0 )) && { __Float_round_sign=-1; (( __Float_round_val = -__Float_round_val )); }

  local -i __Float_round_remainder=$(( __Float_round_val % __Float_round_div ))
  (( __Float_round_val /= __Float_round_div ))
  (( __Float_round_remainder >= (__Float_round_div / 2) )) && (( __Float_round_val++ ))
  __Float.fromRaw $(( __Float_round_val * __Float_round_sign )) $__Float_round_places ${into:-}
}

# Truncate to integer. Returns a string, not a Float.
Float.toInt() {
  local -I self class
  local -i __Float_toInt_val __Float_toInt_scale
  __Float.resolve "$self" __Float_toInt_val __Float_toInt_scale
  if (( __Float_toInt_scale > 0 )); then
    local -i __Float_toInt_div=1 __Float_toInt_i
    for (( __Float_toInt_i=0; __Float_toInt_i < __Float_toInt_scale; __Float_toInt_i++ )); do
      (( __Float_toInt_div *= 10 ))
    done
    (( __Float_toInt_val /= __Float_toInt_div ))
  fi
  __bashClass.return "$__Float_toInt_val" ${into:-}
}

# New Float with a different scale (pad or round).
Float.toScale() {
  local -I self class
  local -i __Float_toScale_val __Float_toScale_scale
  __Float.resolve "$self" __Float_toScale_val __Float_toScale_scale
  local __Float_toScale_str
  __Float.formatValue $__Float_toScale_val $__Float_toScale_scale __Float_toScale_str
  local __Float_toScale_new
  into=__Float_toScale_new Float "$__Float_toScale_str" scale=$1
  __bashClass.return "$__Float_toScale_new" ${into:-}
}

# Raw decimal string value. "3.14", "-0.5", "42", etc.
Float.val() {
  local -I self class
  local -i __Float_val_v __Float_val_s
  __Float.resolve "$self" __Float_val_v __Float_val_s
  __Float.formatValue $__Float_val_v $__Float_val_s ${into:-}
}

# Format with a printf format string. Converts to decimal string first,
# then applies printf. Useful for padding, alignment, fixed-width output.
#
# Usage: into=s $f.format "%010.4f"    # "00003.1400"
#        into=s $f.format "%.2f"       # "3.14"
Float.format() {
  local -I self class
  local __Float_format_str
  self="$self" class="$class" Float.val
  __Float_format_str="$__bashClass_RETURN"
  local __Float_format_result
  printf -v __Float_format_result "$1" "$__Float_format_str"
  __bashClass.return "$__Float_format_result" ${into:-}
}

# toString — "Float(_id){ value }"
Float.toString() {
  local -I self class
  local -i __Float_ts_val __Float_ts_scale
  __Float.resolve "$self" __Float_ts_val __Float_ts_scale
  local __Float_ts_str
  __Float.formatValue $__Float_ts_val $__Float_ts_scale __Float_ts_str
  __bashClass.return "Float($self){ $__Float_ts_str }" ${into:-}
}

