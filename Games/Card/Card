#!/bin/bash

# Games.Card — generic card base class
#
# A card is just a bag of properties. No game logic, no assumptions
# about what a card contains. Subclasses add domain-specific behavior.

[[ -n "${__boop_registry[Games.Card]+set}" ]] && return 2>/dev/null

. boop

Games.Card.new() {
  local _Class="${_Class:-Games.Card}"
  local __Games_Card_new_self
  into=__Games_Card_new_self __boop.new "$@"
  boop.pass "$__Games_Card_new_self" ${into:-}
}

Games.Card.toString() {
  local _Self="${_Self:-${Class:-Games.Card}}" _Class="${_Class:-Games.Card}"
  boop.pass "$_Self" ${into:-}
}

boopClass Games.Card public:new,toString
