#!/bin/bash

# Games.Deck — a shuffleable, drawable collection
#
# A Deck is a List you can shuffle and draw from. It has no opinion
# about what's in it — the consumer (or a card class's newDeck method)
# populates it.
#
# Inheritance: boop → Collection.Container → Collection.List → Games.Deck

[[ -n "${__boop_registry[Games.Deck]+set}" ]] && return 2>/dev/null

. boop Collection::List

# ═════════════════════════════════════════════════════════════════════
# Games.Deck extends Collection.List — shuffle, draw
# ═════════════════════════════════════════════════════════════════════

Games.Deck.new() {
  local _Class="${_Class:-Games.Deck}"
  Collection.List.new "$@"
}

# Fisher-Yates shuffle — walks the list backward, swapping each
# element with a random earlier element.
Games.Deck.shuffle() {
  local _Self="${_Self:-${Class:-Games.Deck}}" _Class="${_Class:-Games.Deck}"
  local -i __Games_Deck_shuf_len __Games_Deck_shuf_i __Games_Deck_shuf_j
  local __Games_Deck_shuf_a __Games_Deck_shuf_b
  into=__Games_Deck_shuf_len $_Self.length
  for (( __Games_Deck_shuf_i = __Games_Deck_shuf_len - 1; __Games_Deck_shuf_i > 0; __Games_Deck_shuf_i-- )); do
    __Games_Deck_shuf_j=$(( RANDOM % (__Games_Deck_shuf_i + 1) ))
    into=__Games_Deck_shuf_a $_Self.getAt $__Games_Deck_shuf_i
    into=__Games_Deck_shuf_b $_Self.getAt $__Games_Deck_shuf_j
    $_Self.setAt $__Games_Deck_shuf_i "$__Games_Deck_shuf_b"
    $_Self.setAt $__Games_Deck_shuf_j "$__Games_Deck_shuf_a"
  done
}

# Draw the top card (pop from the end of the list).
Games.Deck.draw() {
  local _Self="${_Self:-${Class:-Games.Deck}}" _Class="${_Class:-Games.Deck}"
  local __Games_Deck_draw_card; into=__Games_Deck_draw_card $_Self.pop
  boop.pass "$__Games_Deck_draw_card" ${into:-}
}

boopClass Games.Deck isa:Collection.List public:new,shuffle,draw has:type
