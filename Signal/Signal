#!/bin/bash

# Signal — managed signal/trap callback stacks
#
# Layers a LIFO callback stack on top of bash's single-slot trap, so
# multiple components can register cleanup/error handlers without stomping
# each other.
#
# All methods are class-level — no instances. Storage is one indexed bash
# array per signal, named __Signal_handlers_SIGNAME. Using plain arrays
# (not boop collection objects) keeps the trap dispatch path lightweight
# and free of global-state concerns.
#
# Callback contract: each callback is called as:
#   callback signame [extra_args...]
# where extra_args come from Signal.dispatch. Callbacks called via the
# installed trap receive only the signame. Errors in callbacks are
# suppressed so one bad handler cannot break the rest.
#
# Interface:
#   Signal.strict [0|1]           — toggle strict mode (default on)
#   Signal.on     signame callback — push callback onto the stack
#   Signal.push   signame callback — alias for on
#   Signal.off    signame callback — remove first occurrence
#   Signal.pop    signame          — remove & return last-pushed (into=)
#   Signal.shift  signame          — remove & return first-pushed (into=)
#   Signal.clear  signame          — empty stack, uninstall trap
#   Signal.list   signame          — newline-joined callback list (into=)
#   Signal.dispatch signame [args…] — fire all callbacks LIFO

. boop

boop.init Signal || return 0

# ── Global state ───────────────────────────────────────────────────────────────

# One slot per registered signal: tracks whether a trap has been installed.
declare -gA __Signal_installed=()

# Strict mode (default 1). When on:
#   - Warns if a signal name is invalid (trap returns non-zero).
#   - Warns if a callback is not a currently defined function.
# Set to 0 to suppress these warnings — useful in tests that use synthetic
# signal names or that register handlers before the function is defined.
# KILL/STOP warnings are always emitted regardless of this flag.
declare -gi __Signal_strict=1

# Signals that Signal refuses to manage. Registration is rejected with
# a clear error. These fall into two categories but the outcome is the same:
#
#   KILL, STOP (and their numeric/SIG-prefixed forms):
#     Unblockable by the OS. The kernel enforces these unconditionally.
#     A trap can be installed without error, but it will never fire.
#     Registering a handler is pointless and misleading.
#
#   DEBUG, RETURN:
#     Bash pseudo-signals that fire on every command / every function return.
#     They are incompatible with the LIFO callback-stack model -- a "stack"
#     of handlers here means N callbacks on every single command in the shell.
#     That's a profiler hook, not a signal handler. Use 'trap ... DEBUG'
#     directly if you need this behavior.
#
declare -gA __Signal_rejected=(
  [KILL]=1 [SIGKILL]=1 [9]=1
  [STOP]=1 [SIGSTOP]=1 [19]=1
  [DEBUG]=1 [RETURN]=1
)

# ── Internal helpers ───────────────────────────────────────────────────────────

# __Signal.isRejected — return 0 if sig is in the rejection list.
__Signal.isRejected() {
  [[ -n "${__Signal_rejected[${1:-}]+set}" ]]
}

# __Signal.dispatch — fire all callbacks for a signal in LIFO order.
# Called by installed traps and by Signal.dispatch. Extra args beyond
# signame are forwarded to each callback. Per-callback errors suppressed.
__Signal.dispatch() {
  local __Signal__dispatch_sig="${1:-}"; shift || true
  [[ -n "$__Signal__dispatch_sig" ]] || return 0
  local __Signal__dispatch_var="__Signal_handlers_${__Signal__dispatch_sig}"
  [[ -v "$__Signal__dispatch_var" ]] || return 0
  local -n __Signal__dispatch_arr="$__Signal__dispatch_var"
  local -i __Signal__dispatch_i
  for (( __Signal__dispatch_i=${#__Signal__dispatch_arr[@]}-1;
         __Signal__dispatch_i>=0;
         __Signal__dispatch_i-- )); do
    "${__Signal__dispatch_arr[$__Signal__dispatch_i]}" \
      "$__Signal__dispatch_sig" "$@" || true
  done
}

# __Signal.ensure — declare the per-signal array and install the trap once.
# Rejects signals in the rejection list. Warns on invalid names (when strict).
__Signal.ensure() {
  local __Signal__ensure_sig="$1"

  # Reject signals that Signal refuses to manage.
  if __Signal.isRejected "$__Signal__ensure_sig"; then
    _Error "Signal: '${__Signal__ensure_sig}' is not supported by the Signal class. KILL/STOP are unblockable by the OS (handlers never fire). DEBUG/RETURN are bash pseudo-signals that fire per-command/per-return and are incompatible with the callback-stack model. Use 'trap' directly for these."
    return 1
  fi

  local __Signal__ensure_var="__Signal_handlers_${__Signal__ensure_sig}"
  if [[ ! -v "$__Signal__ensure_var" ]]; then
    declare -ga "$__Signal__ensure_var"
  fi

  if [[ -z "${__Signal_installed[$__Signal__ensure_sig]+set}" ]]; then
    if trap "__Signal.dispatch '${__Signal__ensure_sig}'" \
       "$__Signal__ensure_sig"; then
      __Signal_installed[$__Signal__ensure_sig]=1
    else
      (( __Signal_strict )) && \
        _Warn "Signal: '${__Signal__ensure_sig}' is not a valid signal name on this platform; callbacks will be registered but no trap will be installed"
    fi
  fi
}

# __Signal.surveyExisting — internalize any traps set before Signal loaded.
#
# Reads trap -p output, wraps each pre-existing handler in a named function
# (__Signal_legacy_SIGNAME), and registers it via Signal.on at the bottom of
# the LIFO stack. New registrations added later will fire before the legacy
# handler, preserving the "last registered, first called" contract.
#
# Handler strings (possibly bare code) are preserved verbatim via eval inside
# the wrapper — safe because this code was already scheduled to run as a trap.
#
# Called once automatically at class load time.
__Signal.surveyExisting() {
  local __Signal__se_all __Signal__se_line __Signal__se_sig
  __Signal__se_all="$(trap -p)" || return 0
  [[ -z "$__Signal__se_all" ]] && return 0

  local __Signal__se_body __Signal__se_wrap
  while IFS= read -r __Signal__se_line; do
    [[ -z "$__Signal__se_line" ]] && continue

    # Format from trap -p: trap -- 'HANDLER' SIGSPEC
    # SIGSPEC is always the last whitespace-delimited token.
    __Signal__se_sig="${__Signal__se_line##* }"
    [[ -z "$__Signal__se_sig" ]] && continue

    # Skip signals already managed by Signal (shouldn't occur at load time).
    [[ -n "${__Signal_installed[$__Signal__se_sig]+set}" ]] && continue

    # Extract the quoted handler body by stripping the known prefix and suffix.
    __Signal__se_body="${__Signal__se_line#trap -- }"
    __Signal__se_body="${__Signal__se_body% "${__Signal__se_sig}"}"

    # Skip ignored signals (empty-string handler: '').
    [[ "$__Signal__se_body" == "''" || -z "$__Signal__se_body" ]] && continue

    # Create a wrapper function that evals the original handler code at dispatch
    # time. Using eval is safe: this code was already registered as a trap and
    # would have executed had Signal not loaded. The body string is in bash-
    # reusable quoting exactly as produced by trap -p.
    __Signal__se_wrap="__Signal_legacy_${__Signal__se_sig}"
    eval "${__Signal__se_wrap}() { eval ${__Signal__se_body}; }"

    # Register with strict off — the original trap was already valid.
    local __Signal__se_saved=$__Signal_strict
    __Signal_strict=0
    Signal.on "$__Signal__se_sig" "$__Signal__se_wrap"
    __Signal_strict=$__Signal__se_saved

    _Info "Signal: internalized pre-existing ${__Signal__se_sig} trap"
  done <<< "$__Signal__se_all"
}

# ── Public API ─────────────────────────────────────────────────────────────────

# Signal.strict — set strict mode on (1/on/true) or off (0/off/false).
# Strict mode on (default): warn on invalid signal names and undefined callbacks.
# Strict mode off: suppress those warnings — useful for tests with synthetic names.
# Rejected signals (KILL/STOP/DEBUG/RETURN) always error regardless of this setting.
Signal.strict() {
  local _Class="${_Class:-Signal}"
  case "${1:-}" in
    0|off|false) __Signal_strict=0 ;;
    1|on|true|"") __Signal_strict=1 ;;
    *) _Crash "Signal.strict: expected 0/off or 1/on, got '$1'" ;;
  esac
}

# Signal.on — push a callback onto the top of the LIFO stack.
# Warns (in strict mode) if the signal is invalid or the callback is not
# currently a defined function.
Signal.on() {
  local _Class="${_Class:-Signal}"
  local __Signal_on_sig="${1:-}" __Signal_on_cb="${2:-}"
  [[ -n "$__Signal_on_sig" ]] || _Crash "Signal.on: signal name required"
  [[ -n "$__Signal_on_cb"  ]] || _Crash "Signal.on: callback required"

  # Warn if the callback is not yet a defined function.
  if (( __Signal_strict )) && ! declare -f "$__Signal_on_cb" >/dev/null 2>&1; then
    _Warn "Signal.on: '${__Signal_on_cb}' is not a currently defined function — ensure it is defined before '${__Signal_on_sig}' fires"
  fi

  __Signal.ensure "$__Signal_on_sig" || return 1
  local -n __Signal_on_arr="__Signal_handlers_${__Signal_on_sig}"
  __Signal_on_arr+=( "$__Signal_on_cb" )
}

# Signal.push — alias for Signal.on.
Signal.push() {
  local _Class="${_Class:-Signal}"
  Signal.on "$@"
}

# Signal.off — remove the first occurrence of a callback from the stack.
Signal.off() {
  local _Class="${_Class:-Signal}"
  local __Signal_off_sig="${1:-}" __Signal_off_cb="${2:-}"
  [[ -n "$__Signal_off_sig" ]] || _Crash "Signal.off: signal name required"
  [[ -n "$__Signal_off_cb"  ]] || _Crash "Signal.off: callback required"
  local __Signal_off_var="__Signal_handlers_${__Signal_off_sig}"
  [[ -v "$__Signal_off_var" ]] || return 0
  local -n __Signal_off_arr="$__Signal_off_var"
  local -a __Signal_off_new=()
  local -i __Signal_off_removed=0
  local __Signal_off_entry
  if (( ${#__Signal_off_arr[@]} > 0 )); then
    for __Signal_off_entry in "${__Signal_off_arr[@]}"; do
      if [[ "$__Signal_off_entry" == "$__Signal_off_cb" && $__Signal_off_removed -eq 0 ]]; then
        __Signal_off_removed=1
      else
        __Signal_off_new+=( "$__Signal_off_entry" )
      fi
    done
  fi
  __Signal_off_arr=( "${__Signal_off_new[@]+"${__Signal_off_new[@]}"}" )
}

# Signal.pop — remove and return the last-pushed callback.
# Returns empty string if the stack is empty.
Signal.pop() {
  local _Class="${_Class:-Signal}"
  local __Signal_pop_sig="${1:-}"
  [[ -n "$__Signal_pop_sig" ]] || _Crash "Signal.pop: signal name required"
  local __Signal_pop_var="__Signal_handlers_${__Signal_pop_sig}"
  if [[ ! -v "$__Signal_pop_var" ]]; then
    boop.pass "" "${into:-}"; return 0
  fi
  local -n __Signal_pop_arr="$__Signal_pop_var"
  if (( ${#__Signal_pop_arr[@]} == 0 )); then
    boop.pass "" "${into:-}"; return 0
  fi
  local -i __Signal_pop_last=$(( ${#__Signal_pop_arr[@]} - 1 ))
  local __Signal_pop_val="${__Signal_pop_arr[$__Signal_pop_last]}"
  unset '__Signal_pop_arr[$__Signal_pop_last]'
  boop.pass "$__Signal_pop_val" "${into:-}"
}

# Signal.shift — remove and return the first-pushed callback.
# Returns empty string if the stack is empty.
Signal.shift() {
  local _Class="${_Class:-Signal}"
  local __Signal_shift_sig="${1:-}"
  [[ -n "$__Signal_shift_sig" ]] || _Crash "Signal.shift: signal name required"
  local __Signal_shift_var="__Signal_handlers_${__Signal_shift_sig}"
  if [[ ! -v "$__Signal_shift_var" ]]; then
    boop.pass "" "${into:-}"; return 0
  fi
  local -n __Signal_shift_arr="$__Signal_shift_var"
  if (( ${#__Signal_shift_arr[@]} == 0 )); then
    boop.pass "" "${into:-}"; return 0
  fi
  local __Signal_shift_val="${__Signal_shift_arr[0]}"
  __Signal_shift_arr=( "${__Signal_shift_arr[@]:1}" )
  boop.pass "$__Signal_shift_val" "${into:-}"
}

# Signal.clear — empty all callbacks for a signal and uninstall its trap.
Signal.clear() {
  local _Class="${_Class:-Signal}"
  local __Signal_clear_sig="${1:-}"
  [[ -n "$__Signal_clear_sig" ]] || _Crash "Signal.clear: signal name required"
  local __Signal_clear_var="__Signal_handlers_${__Signal_clear_sig}"
  if [[ -v "$__Signal_clear_var" ]]; then
    local -n __Signal_clear_arr="$__Signal_clear_var"
    __Signal_clear_arr=()
  fi
  if [[ -n "${__Signal_installed[$__Signal_clear_sig]+set}" ]]; then
    trap - "$__Signal_clear_sig" || true
    unset '__Signal_installed[$__Signal_clear_sig]'
  fi
}

# Signal.list — return newline-joined list of registered callbacks.
# First line is first-pushed (fires last); last line is most recently pushed.
Signal.list() {
  local _Class="${_Class:-Signal}"
  local __Signal_list_sig="${1:-}"
  [[ -n "$__Signal_list_sig" ]] || _Crash "Signal.list: signal name required"
  local __Signal_list_var="__Signal_handlers_${__Signal_list_sig}"
  if [[ ! -v "$__Signal_list_var" ]]; then
    boop.pass "" "${into:-}"; return 0
  fi
  local -n __Signal_list_arr="$__Signal_list_var"
  if (( ${#__Signal_list_arr[@]} == 0 )); then
    boop.pass "" "${into:-}"; return 0
  fi
  local __Signal_list_out
  printf -v __Signal_list_out '%s\n' "${__Signal_list_arr[@]}"
  __Signal_list_out="${__Signal_list_out%$'\n'}"
  boop.pass "$__Signal_list_out" "${into:-}"
}

# Signal.dispatch — manually fire all callbacks for a signal in LIFO order.
# Any args after signame are forwarded to each callback.
Signal.dispatch() {
  local _Class="${_Class:-Signal}"
  local __Signal_dispatch_sig="${1:-}"; shift || true
  [[ -n "$__Signal_dispatch_sig" ]] || _Crash "Signal.dispatch: signal name required"
  __Signal.dispatch "$__Signal_dispatch_sig" "$@"
}

boopClass Signal \
  'public:strict,on,push,off,pop,shift,clear,list,dispatch'

# Survey and internalize any traps that were set before Signal loaded.
__Signal.surveyExisting
