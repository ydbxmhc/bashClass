#!/bin/bash
set -uo pipefail

# Signal tests -- callback stacks, LIFO dispatch, collection API, strict mode,
# KILL/STOP warnings, undefined-callback warnings, pre-existing trap survey.
#
# Classification: UNIT (Signal)
# Covers: on/push, off, pop, shift, clear, list, dispatch, EXIT trap,
#         LIFO order, extra args, error resilience, strict mode, survey.
#
# Uses real signals (USR1, USR2) for all functional tests so that the trap
# mechanism is genuinely exercised. Synthetic names (INVALID_SIG, NOSIG) are
# used only in tests that intentionally exercise the invalid-signal path.

. boop TestSuite Signal

into=t TestSuite name="Signal Tests"

__st_boop="${__boop_root}/boop"

# -- Shared callback infrastructure --
# Callbacks write to __st_log so tests can verify call order and args.
__st_log=""
__st_reset() { __st_log=""; }

__st_a() { __st_log+="A(${1:-})"; }
__st_b() { __st_log+="B(${1:-})"; }
__st_c() { __st_log+="C(${1:-})"; }
__st_bad() { return 1; }  # always fails -- tests error resilience

# == rejected signals and strict mode ==

$t.section "rejected signals"

# Rejected signals: KILL, STOP, DEBUG, RETURN all refuse registration
# with a clear error, regardless of strict setting.
$t.assert_fail "KILL rejected" Signal.on KILL __st_a
$t.assert_fail "STOP rejected" Signal.on STOP __st_a
$t.assert_fail "DEBUG rejected" Signal.on DEBUG __st_a
$t.assert_fail "RETURN rejected" Signal.on RETURN __st_a

# The error message explains why.
__st_kill_err=$(Signal.on KILL __st_a 2>&1 || true)
$t.assert_contains "rejection error explains why" "$__st_kill_err" "not supported"

$t.section "strict mode"

# Invalid signal: warns in strict mode.
Signal.strict on
__st_inv_warn=$(Signal.on INVALID_SIG __st_a 2>&1; Signal.clear INVALID_SIG)
$t.assert_contains "invalid signal warns in strict mode" "$__st_inv_warn" "not a valid signal"

# Invalid signal: no framework warning when strict off.
Signal.strict off
__st_inv_silent=$(Signal.on INVALID_SIG __st_a 2>&1; Signal.clear INVALID_SIG)
$t.assert_ok "no framework warning when strict off" \
  test "${__st_inv_silent/\[WARN\]/}" = "$__st_inv_silent"

# Undefined callback: warns in strict mode, silent when off.
Signal.strict on
__st_undef_warn=$(Signal.on USR1 __st_undefined_fn 2>&1; Signal.clear USR1)
$t.assert_contains "undefined callback warns in strict mode" "$__st_undef_warn" "not a currently defined function"

Signal.strict off
__st_undef_silent=$(Signal.on USR1 __st_undefined_fn 2>&1; Signal.clear USR1)
$t.assert_eq "undefined callback silent when strict off" "$__st_undef_silent" ""

# Defined callback in strict mode: no warning.
Signal.strict on
__st_def_warn=$(Signal.on USR1 __st_a 2>&1; Signal.clear USR1)
$t.assert_eq "defined callback no warning in strict mode" "$__st_def_warn" ""

# == on / list / clear ==

$t.section "on and list"

Signal.on USR1 __st_a
Signal.on USR1 __st_b

into=__st_out Signal.list USR1
$t.assert_contains "list shows first callback"  "$__st_out" "__st_a"
$t.assert_contains "list shows second callback" "$__st_out" "__st_b"

Signal.clear USR1

into=__st_out Signal.list USR1
$t.assert_eq "list empty after clear" "$__st_out" ""

# == push as alias ==

$t.section "push alias"

Signal.push USR1 __st_a
Signal.push USR1 __st_b

into=__st_out Signal.list USR1
$t.assert_contains "push adds to list" "$__st_out" "__st_a"

Signal.clear USR1

# == LIFO dispatch order ==

$t.section "LIFO dispatch order"

__st_reset
Signal.on USR1 __st_a
Signal.on USR1 __st_b
Signal.on USR1 __st_c

Signal.dispatch USR1
$t.assert_eq "dispatch fires LIFO: C then B then A" \
  "$__st_log" "C(USR1)B(USR1)A(USR1)"

Signal.clear USR1

# == Extra args forwarded ==

$t.section "extra args"

__st_args_cb() { __st_log+="cb(${1:-},${2:-},${3:-})"; }
__st_reset
Signal.on USR1 __st_args_cb
Signal.dispatch USR1 foo bar
$t.assert_eq "extra args reach callback" "$__st_log" "cb(USR1,foo,bar)"

Signal.clear USR1

# == Error resilience ==

$t.section "error resilience"

__st_reset
Signal.on USR1 __st_a
Signal.on USR1 __st_bad
Signal.on USR1 __st_c

Signal.dispatch USR1
$t.assert_contains "A fires despite bad middle handler" "$__st_log" "A(USR1)"
$t.assert_contains "C fires despite bad middle handler" "$__st_log" "C(USR1)"

Signal.clear USR1

# == Signal.off ==

$t.section "off"

Signal.on USR1 __st_a
Signal.on USR1 __st_b
Signal.on USR1 __st_a   # duplicate -- only first removed by off

Signal.off USR1 __st_a

into=__st_out Signal.list USR1
# First __st_a removed; second __st_a and __st_b remain
$t.assert_contains "off removes first occurrence" "$__st_out" "__st_b"
__st_count=$(printf '%s\n' "$__st_out" | grep -c "__st_a" || true)
$t.assert_eq "second occurrence kept" "$__st_count" "1"

__st_reset
Signal.dispatch USR1
$t.assert_contains "remaining handlers still fire" "$__st_log" "A(USR1)"

Signal.clear USR1

$t.assert_ok "off on unknown signal is harmless" Signal.off NOSIG __st_a

# == Signal.pop ==

$t.section "pop"

Signal.on USR1 __st_a
Signal.on USR1 __st_b
Signal.on USR1 __st_c

into=__st_popped Signal.pop USR1
$t.assert_eq "pop returns last-pushed" "$__st_popped" "__st_c"

into=__st_out Signal.list USR1
$t.assert_contains "pop removes from list" "$__st_out" "__st_b"
$t.assert_ok "popped item gone from list" \
  test "${__st_out/__st_c/}" = "$__st_out"

__st_reset
Signal.dispatch USR1
$t.assert_eq "dispatch after pop: B then A" "$__st_log" "B(USR1)A(USR1)"

Signal.clear USR1

into=__st_popped Signal.pop USR1
$t.assert_eq "pop on empty returns empty" "$__st_popped" ""

# == Signal.shift ==

$t.section "shift"

Signal.on USR1 __st_a
Signal.on USR1 __st_b
Signal.on USR1 __st_c

into=__st_shifted Signal.shift USR1
$t.assert_eq "shift returns first-pushed" "$__st_shifted" "__st_a"

into=__st_out Signal.list USR1
$t.assert_ok "shifted item gone" \
  test "${__st_out/__st_a/}" = "$__st_out"

__st_reset
Signal.dispatch USR1
$t.assert_eq "dispatch after shift: C then B" "$__st_log" "C(USR1)B(USR1)"

Signal.clear USR1

into=__st_shifted Signal.shift USR1
$t.assert_eq "shift on empty returns empty" "$__st_shifted" ""

# == Multiple signals are independent ==

$t.section "multiple signals"

Signal.on USR1 __st_a
Signal.on USR2 __st_b

__st_reset
Signal.dispatch USR1
$t.assert_eq "USR1 fires only A" "$__st_log" "A(USR1)"

__st_reset
Signal.dispatch USR2
$t.assert_eq "USR2 fires only B" "$__st_log" "B(USR2)"

Signal.clear USR1
Signal.clear USR2

# == Dispatch on empty / unknown signal ==

$t.section "empty dispatch"

__st_reset
Signal.dispatch NOSIG
$t.assert_eq "dispatch on unknown signal is no-op" "$__st_log" ""

Signal.on USR1 __st_a
Signal.clear USR1
__st_reset
Signal.dispatch USR1
$t.assert_eq "dispatch on cleared signal is no-op" "$__st_log" ""

# == Pre-existing trap survey ==

$t.section "pre-existing trap survey"

# A pre-existing function-name trap is internalized and fires via Signal.dispatch.
__st_exit_out=$(bash -c '
  . "'"$__st_boop"'"
  __pre() { printf "pre:%s" "${1:-}"; }
  trap "__pre EXIT" EXIT          # set before Signal loads
  . "'"$__st_boop"'" Signal
  __post() { printf "post:%s" "${1:-}"; }
  Signal.on EXIT __post           # registered after load, fires FIRST (LIFO)
  exit 0
')
$t.assert_contains "pre-existing trap fires" "$__st_exit_out" "pre:EXIT"
$t.assert_contains "post-load handler fires" "$__st_exit_out" "post:EXIT"
# LIFO: post fires before pre (post was pushed later)
__st_post_pos=$(printf '%s' "$__st_exit_out" | grep -bo "post" | cut -d: -f1 | head -1)
__st_pre_pos=$(printf '%s' "$__st_exit_out" | grep -bo "pre" | cut -d: -f1 | head -1)
$t.assert_ok "post-load handler fires before pre-existing (LIFO)" \
  test "${__st_post_pos:-999}" -lt "${__st_pre_pos:-0}"

# Bare code trap (not a function name) is also internalized.
__st_bare_out=$(bash -c '
  . "'"$__st_boop"'"
  trap '\''printf "bare_fired"'\'' EXIT   # bare code on EXIT, not a function
  . "'"$__st_boop"'" Signal
  exit 0
')
$t.assert_contains "bare code trap internalized and fires" "$__st_bare_out" "bare_fired"

# == EXIT trap in a real subshell ==

$t.section "EXIT trap"

__st_exit_out=$(bash -c '
  . "'"$__st_boop"'" Signal
  __cleanup() { printf "cleaned:%s" "${1:-}"; }
  Signal.on EXIT __cleanup
  exit 0
')
$t.assert_eq "EXIT callback fires on exit" "$__st_exit_out" "cleaned:EXIT"

# Multiple EXIT handlers -- LIFO
__st_exit_out=$(bash -c '
  . "'"$__st_boop"'" Signal
  __first()  { printf "first ";  }
  __second() { printf "second "; }
  __third()  { printf "third ";  }
  Signal.on EXIT __first
  Signal.on EXIT __second
  Signal.on EXIT __third
  exit 0
')
$t.assert_eq "EXIT handlers fire LIFO" "$__st_exit_out" "third second first "

# == class identity ==

$t.section "class identity"

$t.assert_ok "Signal.isa Signal" Signal.isa Signal
$t.assert_ok "Signal.isa boop"   Signal.isa boop

# == All trappable signals: register + dispatch ==

$t.section "all trappable signals"

# Every signal that bash can trap should accept a handler and dispatch it.
# We test registration + manual dispatch (not actual signal delivery) to
# confirm the trap installs without error for each signal name.
#
# Excluded: DEBUG and RETURN are bash pseudo-signals that fire on every
# command / function-return respectively -- they trigger during our own
# dispatch/clear calls, producing spurious extra invocations. They need
# specialized testing (not the generic register+dispatch pattern).
declare -a __st_trappable=(
  HUP INT QUIT ILL TRAP ABRT BUS FPE
  USR1 SEGV USR2 PIPE ALRM TERM
  STKFLT CHLD CONT TSTP TTIN TTOU URG
  XCPU XFSZ VTALRM PROF WINCH IO PWR SYS
  EXIT ERR
)

__st_all_cb() { __st_log+="${1:-};"; }

declare -i __st_all_pass=0 __st_all_fail=0
for __st_sig in "${__st_trappable[@]}"; do
  __st_reset
  Signal.on "$__st_sig" __st_all_cb
  Signal.dispatch "$__st_sig"
  Signal.clear "$__st_sig"
  if [[ "$__st_log" == "${__st_sig};" ]]; then
    (( __st_all_pass++ ))
  else
    (( __st_all_fail++ ))
    _Warn "Signal test: $__st_sig failed (got '$__st_log')"
  fi
done

$t.assert_eq "all trappable signals register+dispatch" "$__st_all_fail" "0"
$t.info "tested ${__st_all_pass} signals successfully"

# == Real signal delivery (USR1/USR2) ==

$t.section "real signal delivery"

# Fork a subshell that registers a handler, sends itself the signal, and
# prints the result. This isolates signal delivery from the test runner --
# if anything goes wrong, only the subshell dies.
__st_usr1_out=$(bash -c '
  . "'"$__st_boop"'" Signal
  __delivered=""
  __handler() { __delivered="yes:${1:-}"; }
  Signal.on USR1 __handler
  kill -USR1 $$
  printf "%s" "$__delivered"
')
$t.assert_eq "USR1 delivered and handled" "$__st_usr1_out" "yes:USR1"

__st_usr2_out=$(bash -c '
  . "'"$__st_boop"'" Signal
  __delivered=""
  __handler() { __delivered="yes:${1:-}"; }
  Signal.on USR2 __handler
  kill -USR2 $$
  printf "%s" "$__delivered"
')
$t.assert_eq "USR2 delivered and handled" "$__st_usr2_out" "yes:USR2"

$t.summary

