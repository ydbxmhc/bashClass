#!/bin/bash
set -uo pipefail

# Args class tests
#
# Classification: UNIT (Args class)
# Covers: Args.getOpts (POSIX short opts), Args.parse (GNU long + subcommand
#         schema parser), defaults, required validation, aliases, cluster
#         short flags, --, _Action / _ArgsRemaining, object mode (into=).

. boop TestSuite Args

into=t TestSuite name="Args Tests"

# ============================================================================
# Args.getOpts — POSIX short options via getopts
# ============================================================================

$t.section "Args.getOpts: boolean and value-taking"

unset v f x
Args.getOpts ":vf:" -v -f myfile
$t.assert_eq "boolean -v sets to 1"  "${v:-}" "1"
$t.assert_eq "value -f captured"     "${f:-}" "myfile"

unset v f
Args.getOpts ":vf:" -f another
$t.assert_eq "absent boolean stays unset" "${v:-UNSET}" "UNSET"
$t.assert_eq "value option set"      "${f:-}" "another"

# __Args_orig snapshot
unset v
Args.getOpts ":v" -v positional1 positional2
$t.assert_eq "__Args_orig[0]" "${__Args_orig[0]}" "-v"
$t.assert_eq "__Args_orig[2]" "${__Args_orig[2]}" "positional2"

$t.section "Args.getOpts: error cases"

$t.assert_fail "unknown short opt crashes" \
  bash -c '. boop Args; Args.getOpts ":v" -q'
$t.assert_fail "missing value crashes" \
  bash -c '. boop Args; Args.getOpts ":f:" -f'

# ============================================================================
# Args.parse — schema, defaults, simple long options
# ============================================================================

$t.section "Args.parse: long options with values"

unset name port
Args.parse '
[Options]
name=
port = 8080
' --name alice --port 9000
$t.assert_eq "long --name value"          "$name" "alice"
$t.assert_eq "long --port overrides default" "$port" "9000"

unset name port
Args.parse '
[Options]
name=
port = 8080
' --name=bob
$t.assert_eq "long --name=value (=form)"  "$name" "bob"
$t.assert_eq "default applied when absent" "$port" "8080"

# ============================================================================
# Args.parse — short options, clusters, attached values
# ============================================================================

$t.section "Args.parse: short options"

unset verbose file
Args.parse '
[Options]
verbose | v
file | f =
' -v -f data.txt
$t.assert_eq "boolean -v"          "$verbose" "1"
$t.assert_eq "short -f value"      "$file"    "data.txt"

unset verbose file
Args.parse '
[Options]
verbose | v
file | f =
' -fdata.txt
$t.assert_eq "attached -fVALUE"    "$file"    "data.txt"

unset verbose debug quiet
Args.parse '
[Options]
verbose | v
debug   | d
quiet   | q
' -vdq
$t.assert_eq "cluster: -v"  "$verbose" "1"
$t.assert_eq "cluster: -d"  "$debug"   "1"
$t.assert_eq "cluster: -q"  "$quiet"   "1"

# ============================================================================
# Args.parse — required validation
# ============================================================================

$t.section "Args.parse: required"

unset name
Args.parse '
[Options]
:name=
' --name alice
$t.assert_eq "required when given"  "$name" "alice"

$t.assert_fail "missing required crashes" \
  bash -c '. boop Args; Args.parse "[Options]
:name=" '

$t.assert_fail "unknown long option crashes" \
  bash -c '. boop Args; Args.parse "[Options]
foo=" --bar value'

$t.assert_fail "boolean with =value crashes" \
  bash -c '. boop Args; Args.parse "[Options]
verbose | v" --verbose=yes'

$t.assert_fail "long opt missing value crashes" \
  bash -c '. boop Args; Args.parse "[Options]
name=" --name'

$t.assert_fail "hyphen in varname crashes" \
  bash -c '. boop Args; Args.parse "[Options]
my-opt=" --my-opt x'

# ============================================================================
# Args.parse — positionals, --, _Action, _ArgsRemaining
# ============================================================================

$t.section "Args.parse: remaining positionals"

unset verbose
Args.parse '
[Options]
verbose | v
' -v one two three
$t.assert_eq "remaining count"  "${#_ArgsRemaining[@]}" "3"
$t.assert_eq "remaining[0]"     "${_ArgsRemaining[0]}"  "one"
$t.assert_eq "remaining[2]"     "${_ArgsRemaining[2]}"  "three"

unset verbose
Args.parse '
[Options]
verbose | v
' -v -- --not-an-option more
$t.assert_eq "after --: count"        "${#_ArgsRemaining[@]}" "2"
$t.assert_eq "after --: dashes kept"  "${_ArgsRemaining[0]}"  "--not-an-option"

# ============================================================================
# Args.parse — subcommands and aliases
# ============================================================================

$t.section "Args.parse: subcommands"

unset verbose
Args.parse '
[Subcommands]
build | b | bld
test  | t

[Options]
verbose | v
' build -v
$t.assert_eq "subcommand canonical"  "$_Action"  "build"
$t.assert_eq "verbose set after subcmd" "$verbose" "1"

Args.parse '
[Subcommands]
build | b | bld
test  | t
' bld
$t.assert_eq "alias resolves to canonical" "$_Action" "build"

Args.parse '
[Subcommands]
build | b
test  | t
' notasubcmd extra
$t.assert_eq "non-subcmd first positional → empty action" "$_Action" ""
$t.assert_eq "non-subcmd treated as positional"  "${_ArgsRemaining[0]}" "notasubcmd"

# ============================================================================
# Args.parse — schema sections (Use, comments)
# ============================================================================

$t.section "Args.parse: schema parsing edge cases"

unset name
Args.parse '
[Use]
mytool [options] <file>

[Options]
# comment line with leading hash
name = default     # trailing comment
verbose | v
' --name override -v
$t.assert_eq "comments stripped, value parsed"  "$name"    "override"
$t.assert_eq "boolean still works"              "$verbose" "1"

unset name
Args.parse '
[Options]
name = default
'
$t.assert_eq "default applied with no args"  "$name" "default"

# ============================================================================
# Args.parse — object mode (into=)
# ============================================================================

$t.section "Args.parse: object mode (into=)"

into=cfg Args.parse '
[Subcommands]
build | b
[Options]
name=
verbose | v
' build --name alice -v rest1 rest2

$t.assert_ok    "returned a Config object"   $cfg.isa Config
into=v $cfg.get name;     $t.assert_eq "obj: name"      "$v" "alice"
into=v $cfg.get verbose;  $t.assert_eq "obj: verbose"   "$v" "1"
into=v $cfg.get _action;  $t.assert_eq "obj: _action"   "$v" "build"
into=v $cfg.get _remaining; $t.assert_eq "obj: _remaining" "$v" $'rest1\nrest2'

# Scope vars must NOT be set in object mode
$t.assert_eq "scope name unset in obj mode" "${name:-UNSET}" "UNSET"
$t.assert_eq "scope _Action unset in obj mode" "${_Action:-UNSET}" "UNSET"

# ============================================================================
# --help output
# ============================================================================

$t.section "Args.parse: --help"

__args_help_out=$(bash << 'HELPEOF'
. boop Args
Args.parse '
[Use]
  testapp [options]

[Options]
  verbose | v    # be loud
' --help
HELPEOF
)
$t.assert_contains "help includes [Use]" "$__args_help_out" "[Use]"
$t.assert_contains "help includes option line" "$__args_help_out" "verbose | v"
$t.assert_contains "help includes comment" "$__args_help_out" "be loud"

# -h also triggers help
__args_help_h=$(bash << 'HELPEOF2'
. boop Args
Args.parse '
[Use]
  testapp
[Options]
  x | X
' -h
HELPEOF2
)
$t.assert_contains "-h triggers help" "$__args_help_h" "[Use]"

# ============================================================================
# Error cases and edge cases
# ============================================================================

$t.section "Args.parse: error cases"

# Empty schema crashes
$t.assert_fail "empty schema crashes" bash << 'ERREOF'
. boop Args
Args.parse '' --verbose
ERREOF

# Unknown long option crashes
$t.assert_fail "unknown long option crashes" bash << 'ERREOF2'
. boop Args
Args.parse '
[Options]
  verbose | v
' --badopt
ERREOF2

# Unknown short option crashes
$t.assert_fail "unknown short option crashes" bash << 'ERREOF3'
. boop Args
Args.parse '
[Options]
  verbose | v
' -z
ERREOF3

# Boolean with =value crashes
$t.assert_fail "boolean with =value crashes" bash << 'ERREOF4'
. boop Args
Args.parse '
[Options]
  verbose | v
' --verbose=yes
ERREOF4

# Value option missing value crashes
$t.assert_fail "missing value crashes" bash << 'ERREOF5'
. boop Args
Args.parse '
[Options]
  output | o =
' --output
ERREOF5

# Bad variable name in schema crashes
$t.assert_fail "bad varname in schema crashes" bash << 'ERREOF6'
. boop Args
Args.parse '
[Options]
  bad-name | b
' --bad-name
ERREOF6

# No args with no required options -- should succeed
__args_noargs_rc=0
bash << 'NOARGSEOF' || __args_noargs_rc=$?
. boop Args
Args.parse '
[Options]
  verbose | v
'
NOARGSEOF
$t.assert_eq "no args with no required opts succeeds" "$__args_noargs_rc" "0"

# getOpts: unknown option crashes
$t.assert_fail "getOpts unknown option crashes" bash << 'GETEOF'
. boop Args
Args.getOpts ":vf:" -z
GETEOF

# getOpts: missing value crashes
$t.assert_fail "getOpts missing value crashes" bash << 'GETEOF2'
. boop Args
Args.getOpts ":vf:" -f
GETEOF2

# ============================================================================
# Args.parse — subcommand-scoped options
# ============================================================================

$t.section "Args.parse: subcommand-scoped options"

unset force verbose
Args.parse '
[Subcommands]
push | p
pull

[Options]
verbose | v

[push]
force | f
' push --force -v
$t.assert_eq "scoped --force accepted under push"  "$force"   "1"
$t.assert_eq "global -v accepted under push"       "$verbose" "1"

$t.assert_fail "scoped option before subcommand crashes" \
  bash -c '. boop Args; Args.parse "
[Subcommands]
push
[push]
force =" --force push'

$t.assert_fail "scoped option under wrong subcommand crashes" \
  bash -c '. boop Args; Args.parse "
[Subcommands]
push
pull
[push]
force =" pull --force'

unset force verbose
Args.parse '
[Subcommands]
push
pull

[Options]
verbose | v

[push]
: force | f =
' push --force myref
$t.assert_eq "scoped required option satisfied"  "$force" "myref"

$t.assert_ok "scoped required option not validated for other subcommand" \
  bash -c '. boop Args; Args.parse "
[Subcommands]
push
pull
[push]
: force =" pull'

# ============================================================================
# Args.parse: context-aware setVar
# ============================================================================

$t.section "Args.parse: context-aware setVar"

# Script context (no _Self, no _Class) — declare -g as before
unset _Self 2>/dev/null; unset _Class 2>/dev/null
Args.parse '
  [Options]
  ctxwidth  = 10
  ctxheight = 20
' --ctxwidth 42
$t.assert_eq "script context sets global"  "$ctxwidth"  "42"
$t.assert_eq "script context applies default" "$ctxheight" "20"

# Object context (_Self set) — values go to object properties
into=__ta_obj Config.new
_Self="$__ta_obj" Args.parse '
  [Options]
  color = red
  size  = 5
' --color blue --size 9
into=__ta_v $__ta_obj.get color; $t.assert_eq "object context value"   "$__ta_v" "blue"
into=__ta_v $__ta_obj.get size;  $t.assert_eq "object context value 2" "$__ta_v" "9"

# Default goes to object property too
into=__ta_obj2 Config.new
_Self="$__ta_obj2" Args.parse '
  [Options]
  flavor = vanilla
'
into=__ta_v $__ta_obj2.get flavor; $t.assert_eq "object context default" "$__ta_v" "vanilla"

$t.summary
