#!/bin/bash
# Run tests by layer. Smoke always runs first and gates everything else.
# Exit nonzero if any suite or check fails.
#
# Usage:
#   ./test_all                  — smoke + unit + integration + naming check
#   ./test_all smoke            — smoke only
#   ./test_all unit             — smoke + unit
#   ./test_all integration      — smoke + integration
#   TESTSUITE_VERBOSE=1 ./test_all [mode]   — verbose (every PASS line)

export TESTSUITE_VERBOSE="${TESTSUITE_VERBOSE:-1}"

__ta_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
__ta_mode="${1:-all}"
rc=0

# ============================================================================
# Smoke — always runs first; failure aborts everything
# ============================================================================
printf '\ntest_smoke...\n'
"$__ta_dir/smoke/test_smoke" || { printf '\n  SMOKE FAILED — aborting\n'; exit 1; }

[[ "$__ta_mode" == smoke ]] && exit 0

# ============================================================================
# Unit tests
# ============================================================================
if [[ "$__ta_mode" == all || "$__ta_mode" == unit ]]; then
  for f in test_testsuite_ts test_box_cube_ts test_containers_ts \
            test_logging_ts test_math_ts test_classpath_ts test_classpath_pbt; do
    printf '\n%s...\n' "$f"
    "$__ta_dir/unit/$f" || rc=1
  done
fi

[[ "$__ta_mode" == unit ]] && exit $rc

# ============================================================================
# Integration tests
# ============================================================================
if [[ "$__ta_mode" == all || "$__ta_mode" == integration ]]; then
  for f in test_stress_ts test_blackjack; do
    printf '\n%s...\n' "$f"
    "$__ta_dir/integration/$f" || rc=1
  done
fi

[[ "$__ta_mode" == integration ]] && exit $rc

# ============================================================================
# Naming convention compliance check (all mode only)
#
# Local variables in class/framework functions must use the
# __ClassName_methodName_varname convention. Catches any double-underscore-
# lowercase prefix that isn't a known class or framework name.
# ============================================================================
printf '\nnaming convention check...\n'
__nc_root="$(cd "$__ta_dir/.." && pwd)"
__nc_files="$__nc_root/boop"
__nc_files+=" $__nc_root/Geometry/Box/Box $__nc_root/Geometry/Cube/Cube"
__nc_files+=" $__nc_root/Games/Card/Card $__nc_root/Games/PlayingCard/PlayingCard $__nc_root/Games/Deck/Deck"
__nc_files+=" $__nc_root/Collection/Container/Container $__nc_root/Collection/List/List $__nc_root/Collection/Map/Map"
__nc_files+=" $__nc_root/Math/Math $__nc_root/Testing/TestSuite/TestSuite $__nc_root/blackjack"
__nc_exclude='__boop_\|__boop\.\|__Crash_\|__Container_\|__Iterator_\|__Iter_\|__List_\|__Map_\|__Math_\|__Box_\|__Cube_\|__Card_\|__Deck_\|__PlayingCard_\|__TestSuite_\|__BJ_\|__FC_\|__boopClass_\|__init'
__nc_hits=$(grep -rn '__[a-z]\+_' $__nc_files 2>/dev/null | grep -v "$__nc_exclude" | grep -v '#')
if [[ -n "$__nc_hits" ]]; then
  printf '  FAIL: non-compliant variable names found:\n%s\n' "$__nc_hits"
  rc=1
else
  printf '  PASS: all variable names follow convention\n'
fi

exit $rc
