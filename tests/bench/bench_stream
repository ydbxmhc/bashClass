#!/bin/bash

# Stream benchmarks -- comparative timing against raw read, and
# standalone benchmarks for features only Stream provides.
#
# Usage: bash tests/bench/bench_stream
#
# Each benchmark runs N iterations and reports wall-clock time.
# Results are relative -- absolute times depend on the machine.

. boop Stream
. "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/timer"

__boop.setLogLevel warn
trap __timer_cleanup EXIT
__timer_note

# --- Config ---
LINES=1000
FIELDS=5
DELIM=':'

# --- Generate test data ---
__bench_tmp=$(mktemp)
trap 'rm -f "$__bench_tmp" "$__bench_tmp2"' EXIT

# Delimited data: 1000 lines, 5 colon-separated fields
for (( i=0; i < LINES; i++ )); do
  printf 'field1%sfield2%sfield3%sfield4%sfield5\n' "$DELIM" "$DELIM" "$DELIM" "$DELIM"
done > "$__bench_tmp"

__bench_filesize=$(wc -c < "$__bench_tmp")
printf "Test data: %d lines, %d bytes, delimiter='%s'\n\n" "$LINES" "$__bench_filesize" "$DELIM"

# --- Timing helper ---
# bench_report LABEL CMD... -- run CMD via bench_time (tests/lib/timer:
# EPOCHREALTIME on bash 5+, `time` keyword/millisecond on older bash) and
# print "<label>  <elapsed>s". Many iterations average out coarser
# resolution on old bash; see tests/lib/timer.
bench_report() {
  local __bench_label="$1"; shift
  local __bench_elapsed
  bench_time __bench_elapsed "$@"
  printf "  %-50s %ss\n" "$__bench_label" "$__bench_elapsed"
}

# Drain a Stream built from the given Stream.new args. Used by most
# benchmarks below: construct, read every record, close. Uses $s.next, which
# dispatches to the correct reader for the stream's mode (direct vs buffered)
# -- the original code hardcoded $s.Read, which errored on direct-mode streams.
__bs_drain() {
  into=s Stream.new "$@"
  while $s.next; do :; done
  $s.close
}

# Raw-read baselines (no Stream) -- compared against the Stream variants.
__bs_raw_lines() { while IFS= read -r line; do :; done < "$__bench_tmp"; }
__bs_raw_split() { while IFS="$DELIM" read -r a b c d e; do :; done < "$__bench_tmp"; }
__bs_raw_delim() { while IFS= read -r -d '|' rec; do :; done < "$__bench_tmp2"; }

# ============================================================================
printf "=== COMPARATIVE: Stream vs raw read (same task) ===\n\n"
# ============================================================================

# --- Benchmark 1: read lines, no field splitting ---

bench_report "raw read: whole lines ($LINES lines)" __bs_raw_lines
bench_report "Stream direct: whole lines ($LINES lines)" __bs_drain -P "$__bench_tmp" line

printf "\n"

# --- Benchmark 2: read lines with IFS field splitting ---

bench_report "raw read: IFS split into 5 fields ($LINES lines)" __bs_raw_split
IFS="$DELIM" bench_report "Stream direct: IFS split -d newline ($LINES lines)" __bs_drain -P "$__bench_tmp" a b c d e

printf "\n"

# --- Benchmark 3: read with non-newline record delimiter ---

# Generate colon-delimited records (no newlines)
__bench_tmp2=$(mktemp)
for (( i=0; i < LINES; i++ )); do
  printf 'record_%04d|' "$i"
done > "$__bench_tmp2"

bench_report "raw read -d '|': $LINES records" __bs_raw_delim
bench_report "Stream direct -d '|': $LINES records" __bs_drain -P "$__bench_tmp2" -d '|' rec

printf "\n"

# ============================================================================
printf "=== STREAM-ONLY: features raw read can't do ===\n\n"
# ============================================================================

# --- Benchmark 4: multi-char EOL (CRLF) ---

__bench_tmp_crlf=$(mktemp)
trap 'rm -f "$__bench_tmp" "$__bench_tmp2" "$__bench_tmp_crlf"' EXIT
for (( i=0; i < LINES; i++ )); do
  printf 'line_%04d\r\n' "$i"
done > "$__bench_tmp_crlf"

bench_report "Stream -D CRLF: $LINES records (buffered pe)" __bs_drain -P "$__bench_tmp_crlf" -D $'\r\n' line

printf "\n"

# --- Benchmark 5: char-class EOL with collapsing ---

bench_report "Stream -E (collapse CR/LF): $LINES records (buffered regex)" __bs_drain -P "$__bench_tmp_crlf" -E $'\r\n' line

printf "\n"

# --- Benchmark 6: char-class field delimiter (-f) ---

bench_report "Stream -f ':' field split: $LINES records, 5 fields (buffered)" __bs_drain -P "$__bench_tmp" -f "$DELIM" a b c d e

printf "\n"

# --- Benchmark 7: exact-string field delimiter (-F) ---

# Generate data with multi-char delimiter
__bench_tmp_mc=$(mktemp)
trap 'rm -f "$__bench_tmp" "$__bench_tmp2" "$__bench_tmp_crlf" "$__bench_tmp_mc"' EXIT
for (( i=0; i < LINES; i++ )); do
  printf 'alpha<>beta<>gamma<>delta<>epsilon\n' 
done > "$__bench_tmp_mc"

bench_report "Stream -F '<>' field split: $LINES records, 5 fields (buffered pe)" __bs_drain -P "$__bench_tmp_mc" -F '<>' a b c d e

printf "\n"

# --- Benchmark 8: fixed-width reads ---

__bench_tmp_fixed=$(mktemp)
trap 'rm -f "$__bench_tmp" "$__bench_tmp2" "$__bench_tmp_crlf" "$__bench_tmp_mc" "$__bench_tmp_fixed"' EXIT
# 1000 records of 20 chars each
for (( i=0; i < LINES; i++ )); do
  printf '%020d' "$i"
done > "$__bench_tmp_fixed"

bench_report "Stream -n 20 fixed-width: $LINES records (buffered)" __bs_drain -P "$__bench_tmp_fixed" -n 20 chunk

printf "\n"

# --- Benchmark 9: small blockSize stress ---

bench_report "Stream blockSize=64: $LINES lines (many refills)" __bs_drain -P "$__bench_tmp" -D $'\n' --blockSize=64 line

bench_report "Stream blockSize=8192: $LINES lines (few refills)" __bs_drain -P "$__bench_tmp" -D $'\n' --blockSize=8192 line

printf "\n"

# --- Benchmark 10: combined -D and -f (CRLF records, colon fields) ---

__bench_tmp_combo=$(mktemp)
trap 'rm -f "$__bench_tmp" "$__bench_tmp2" "$__bench_tmp_crlf" "$__bench_tmp_mc" "$__bench_tmp_fixed" "$__bench_tmp_combo"' EXIT
for (( i=0; i < LINES; i++ )); do
  printf 'name%sage%srole%sdept%sid\r\n' "$DELIM" "$DELIM" "$DELIM" "$DELIM"
done > "$__bench_tmp_combo"

bench_report "Stream -D CRLF -f ':': $LINES records, 5 fields" __bs_drain -P "$__bench_tmp_combo" -D $'\r\n' -f "$DELIM" a b c d e

printf "\n=== DONE ===\n"

