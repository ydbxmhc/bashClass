#!/bin/bash
set -u

# Pi growth test — compute pi one additional digit at a time, leveraging
# the static cache from previous calls. Stops when a single increment
# takes more than 10 seconds. Shows the growing value and elapsed time
# after each call so you can watch pi emerge digit by digit.

. boop Math
. "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/timer"

# Timing: bench_time (tests/lib/timer) -- EPOCHREALTIME (microsecond) on bash
# 5+, the `time` keyword (millisecond) on older bash. Either way we get an
# elapsed-seconds float; the threshold check below works on both. The pi
# result persists because bench_time runs its target in the current shell.
trap __timer_cleanup EXIT
__timer_note

printf "=== PI GROWTH TEST ===\n"
printf "  Computing pi one digit at a time until a single digit takes >10s...\n\n"

# Rounding is now opt-in only (via Math.round), so no need to disable it.
# All operations truncate by default.

# Start at a reasonable base so the first few aren't trivially instant
prec=5
max_time=10

__pi_step() { into=pi Math.pi "$prec"; }

while true; do
  bench_time elapsed __pi_step
  into=v $pi.val

  printf "  pi(%3d) = %-60s  [%s sec]\n" "$prec" "$v" "$elapsed"

  # Threshold check on the elapsed float. Strip the radix point to compare as
  # integer microseconds (epoch: 6 fractional digits; time: 3 -> pad). This
  # avoids a fork to awk and works regardless of timing precision.
  __pi_frac="${elapsed#*.}"
  __pi_whole="${elapsed%.*}"
  while (( ${#__pi_frac} < 6 )); do __pi_frac+="0"; done
  __pi_us=$(( 10#${__pi_whole} * 1000000 + 10#${__pi_frac:0:6} ))
  if (( __pi_us > max_time * 1000000 )); then
    printf "\n  Stopped: pi(%d) took %s seconds (threshold: %ds)\n" "$prec" "$elapsed" "$max_time"
    break
  fi

  (( ++prec ))
done

printf "\n=== PI GROWTH COMPLETE ===\n"
