#!/bin/bash
set -u

# Matrix benchmark — create NxN grid, print, transpose, print again.
# Usage: ./test_matrix 3       (3x3 matrix)
#        ./test_matrix 5       (5x5 matrix)

. boop List
. "$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/lib/timer"

N="${1:-3}"

# Timing: bench_time (tests/lib/timer) -- EPOCHREALTIME on bash 5+, the `time`
# keyword (millisecond) on older bash. Each phase is wrapped in a function so
# the objects it builds (into= results) persist for later phases; bench_time
# runs them in the current shell. See tests/lib/timer.
trap __timer_cleanup EXIT
__timer_note

# --- Phase functions (run in current shell; set globals for later phases) ---
__mx_build() {
  into=matrix List
  for (( r=0; r < N; r++ )); do
    into=row List
    for (( c=0; c < N; c++ )); do
      $row.push "$(( r * N + c + 1 ))"
    done
    $matrix.push "$row"
  done
}

__mx_print() {
  local __mx_src="$1" __mx_label="$2"
  printf "\n%s:\n" "$__mx_label"
  for (( r=0; r < N; r++ )); do
    into=row $__mx_src.getAt "$r"
    for (( c=0; c < N; c++ )); do
      into=val $row.getAt "$c"
      printf "%4s" "$val"
    done
    printf "\n"
  done
}

__mx_transpose() {
  into=transposed List
  for (( c=0; c < N; c++ )); do
    into=new_row List
    for (( r=0; r < N; r++ )); do
      into=src_row $matrix.getAt "$r"
      into=val $src_row.getAt "$c"
      $new_row.push "$val"
    done
    $transposed.push "$new_row"
  done
}

__mx_flip() {
  into=flipped List
  for (( r=0; r < N; r++ )); do
    into=src_row $matrix.getAt "$r"
    into=new_row List
    for (( c=N-1; c >= 0; c-- )); do
      into=val $src_row.getAt "$c"
      $new_row.push "$val"
    done
    $flipped.push "$new_row"
  done
}

printf "=== Matrix Benchmark (%dx%d) ===\n\n" "$N" "$N"

# Phase 1: Build
bench_time __timer_elapsed __mx_build
printf "Build:     %ss\n" "$__timer_elapsed"

# Phase 2: Print original
bench_time __timer_elapsed __mx_print "$matrix" "Original"
printf "\nPrint:     %ss\n" "$__timer_elapsed"

# Phase 3: Transpose
bench_time __timer_elapsed __mx_transpose
printf "Transpose: %ss\n" "$__timer_elapsed"

# Phase 4: Print transposed
bench_time __timer_elapsed __mx_print "$transposed" "Transposed"
printf "\nPrint:     %ss\n" "$__timer_elapsed"

# Phase 5: Horizontal flip
bench_time __timer_elapsed __mx_flip
printf "H-Flip:    %ss\n" "$__timer_elapsed"

# Phase 6: Print flipped
bench_time __timer_elapsed __mx_print "$flipped" "H-Flipped"
printf "\nPrint:     %ss\n" "$__timer_elapsed"

# ============================================================================
# Summary
# ============================================================================
into=obj_count List
$obj_count.push "matrix rows: $N"
$obj_count.push "total List objects: $(( 1 + N + 1 + N + 1 + N ))"
printf "\n--- Stats ---\n"
into=s $obj_count.toArray
printf "%s\n" "$s"
printf "=== Done ===\n"
