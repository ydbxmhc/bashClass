#!/bin/bash
set -uo pipefail

# Smoke test — is the framework alive?
#
# Answers one question: did boop load, can it create objects, and can
# those objects respond to methods? If this fails, nothing else matters.
# Designed to run in under 2 seconds with no external dependencies.
#
# Classification: SMOKE
# Run by: test_all (first, before any unit or integration tests)

. boop TestSuite Cube

into=t TestSuite name="Smoke"

# ============================================================================
# Framework loaded
# ============================================================================

$t.section "Framework"
$t.assert_ok "boop loaded" test "${__boop_loaded:-0}" -eq 1
$t.assert_ok "registry exists" test "${#__boop_registry[@]}" -gt 0
$t.assert_ok "boop class registered" test -n "${__boop_registry[boop]+set}"
$t.assert_ok "Box class registered"  test -n "${__boop_registry[Geometry.Box]+set}"
$t.assert_ok "Cube class registered" test -n "${__boop_registry[Geometry.Cube]+set}"

# ============================================================================
# Object creation and method dispatch
# ============================================================================

$t.section "Object lifecycle"
into=c Cube size=3
$t.assert_match "object has valid ID" "$c" "__obj_*"
$t.assert_ok    "object in registry"  test -n "${__boop_registry[$c]+set}"

into=v $c.volume
$t.assert_eq "method returns correct value" "$v" "27"

$t.assert_ok "isa own class"    $c.isa Cube
$t.assert_ok "isa parent class" $c.isa Box
$t.assert_ok "isa root class"   $c.isa boop

# ── Class properties with instance fallback ──

$t.section "Class properties"

Geometry.Box.unit "cm"
into=v Geometry.Box.unit
$t.assert_eq "class property set/get" "$v" "cm"

# Instance has its own value — reads its own, not the class
into=b Box length=5 width=3 height=7
into=v $b.unit
$t.assert_eq "instance without value gets empty (no fallback)" "$v" ""

$b.unit "in"
into=v $b.unit
$t.assert_eq "instance override" "$v" "in"
into=v Geometry.Box.unit
$t.assert_eq "class unchanged after instance override" "$v" "cm"

into=b2 Box length=1 width=1 height=1 unit=""
into=v $b2.unit
$t.assert_eq "empty string is a valid explicit value" "$v" ""

# Class properties are independent — subclass doesn't inherit parent's
Geometry.Box.color "red"
into=c2 Cube size=3
into=v $c2.color
$t.assert_eq "subclass instance has no implicit inheritance" "$v" ""

# But class-level accessor on the parent still works
into=v Geometry.Box.color
$t.assert_eq "parent class property still accessible" "$v" "red"

# Clean up
Geometry.Box.unit ""
Geometry.Box.color ""

$t.summary
