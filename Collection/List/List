#!/bin/bash

# Collection.List — indexed array container.
#
# Wraps a bash indexed array (declare -ga) with object semantics.
# Implements the Container contract with standard list operations:
# push/pop (stack-end), shift/unshift (queue-end), random access by
# index, slicing, and deletion with automatic re-indexing.
#
# Storage: each List instance owns a global indexed array named
# __boop_data_${_Self}. Element data lives there, not in the
# pipe-delimited descriptor. This gives us native bash array performance
# for reads/writes while the object system handles identity and dispatch.
#
# Negative indices: get, set, delete, has, and slice all support negative
# indices (Python-style). -1 is the last element, -2 is second-to-last, etc.
#
# Composition: List elements can be any string, including object IDs.
# Storing another List's ID creates nested/multidimensional arrays.
# Storing a Map's ID creates heterogeneous structures. The framework
# doesn't care what's inside — it's turtles all the way down.

# Load guard — if already registered, nothing to do
. boop Collection::Container

boop.init Collection.List || return 0

# ============================================================================
# List Implementation Functions
# ============================================================================

# Constructor — creates a new List instance with an indexed companion array.
#
# Delegates to __boop.new for descriptor creation and stub generation,
# then declares a global indexed array (__boop_data_${_Self}) as the
# companion storage. The type=indexed argument lands in the descriptor so
# introspection (toString, Container.toString) can report the storage flavor
# without poking at the companion array directly.
#
# The _Class= default ensures subclasses that forget to set _Class still get
# a List, not a bare Container. Any extra key=value args pass through to
# __boop.new and end up in the descriptor as metadata.
#
# Usage: into=mylist Collection.List
#        into=mylist _Class=Collection.List __boop.dispatch new
Collection.List.new() {
  local _Class="${_Class:-Collection.List}"
  local __Collection_List_new_self
  into=__Collection_List_new_self __boop.new type=indexed "$@"
  declare -ga "__boop_data_${__Collection_List_new_self}=()"
  _Info "new: created $__Collection_List_new_self"
  boop.pass "$__Collection_List_new_self" ${into:-}
}

# Retrieve an element by integer index.
#
# Supports negative indices (Python-style): -1 is the last element,
# -2 is second-to-last, etc. Negative values are resolved by adding
# the array length, so -1 on a 5-element list becomes index 4.
#
# Out-of-range indices return empty string — not a crash. This is a
# deliberate design choice: get is a read operation, and returning
# nothing for a missing index is the same contract as Map.get for a
# missing key. Callers who need bounds enforcement should check has()
# first or validate the return.
#
# The nameref __Collection_List_get_arr avoids a subshell by pointing directly
# at the companion array. Combined with ${into:-} passthrough, a
# getAt-into-local is zero-copy: into=val $list.getAt 0
#
# Usage: into=val $list.getAt 0      # first element
#        into=val $list.getAt -1     # last element
#        $list.getAt 99              # empty string (no crash)
Collection.List.getAt() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local -i __Collection_List_getAt_idx="$1"
  local -n __Collection_List_getAt_arr="__boop_data_${_Self}"
  local -i __Collection_List_getAt_len=0; (( ${#__Collection_List_getAt_arr[@]} )) && __Collection_List_getAt_len=${#__Collection_List_getAt_arr[@]}
  (( __Collection_List_getAt_idx < 0 )) && (( __Collection_List_getAt_idx += __Collection_List_getAt_len ))
  if (( __Collection_List_getAt_idx < 0 || __Collection_List_getAt_idx >= __Collection_List_getAt_len )); then
    _Trace "getAt: [$1] out of range (length: $__Collection_List_getAt_len) -> ''"
    boop.pass "" ${into:-}
    return
  fi
  _Trace "getAt: [$__Collection_List_getAt_idx] -> '${__Collection_List_getAt_arr[$__Collection_List_getAt_idx]}'"
  boop.pass "${__Collection_List_getAt_arr[$__Collection_List_getAt_idx]}" ${into:-}
}

# Store a value at a specific index.
#
# Supports negative indices (resolved the same way as get). The valid
# range is 0..length inclusive — setting at index == length is an append
# (equivalent to push for a single element). Anything outside that range
# crashes with an explicit error showing both the requested index and the
# current length, because silent truncation or sparse arrays would be worse.
#
# Unlike get, set is a mutating operation, so out-of-range is a hard error.
# If you want to append without knowing the length, use push instead.
#
# Does not produce a return value — this is a void operation.
#
# Usage: $list.set 0 "new_first"    # replace first element
#        $list.set -1 "new_last"    # replace last element
#        $list.set 5 "append"       # append if length is 5
Collection.List.setAt() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local -i __Collection_List_setAt_idx="$1"
  local __Collection_List_setAt_val="$2"
  local -n __Collection_List_setAt_arr="__boop_data_${_Self}"
  local -i __Collection_List_setAt_len=0; (( ${#__Collection_List_setAt_arr[@]} )) && __Collection_List_setAt_len=${#__Collection_List_setAt_arr[@]}
  (( __Collection_List_setAt_idx < 0 )) && (( __Collection_List_setAt_idx += __Collection_List_setAt_len ))
  (( __Collection_List_setAt_idx < 0 || __Collection_List_setAt_idx > __Collection_List_setAt_len )) && {
    _Error "List index out of range: $1 (length: $__Collection_List_setAt_len)"; return 1; }
  _Trace "setAt: [$__Collection_List_setAt_idx] = '$__Collection_List_setAt_val'"
  __Collection_List_setAt_arr[$__Collection_List_setAt_idx]="$__Collection_List_setAt_val"
}

# Remove an element at a specific index and re-index the array.
#
# Supports negative indices. Out-of-range crashes (same rationale as set —
# deleting a nonexistent element is a logic error, not a no-op).
#
# Implementation detail: bash's `unset` on an indexed array element leaves
# a hole (sparse array). The re-assignment __Collection_List_del_arr=("${__Collection_List_del_arr[@]}")
# compacts the array back to contiguous indices. This is O(n) but necessary —
# sparse indexed arrays break length calculations and iteration patterns.
#
# Does not return the deleted value. If you need the value before deleting,
# call get first. This keeps delete simple and avoids the "did they want the
# value or not" ambiguity.
#
# Usage: $list.delete 0     # remove first, shift everything down
#        $list.delete -1    # remove last (same as pop, but no return)
Collection.List.delete() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local -i __Collection_List_del_idx="$1"
  local -n __Collection_List_del_arr="__boop_data_${_Self}"
  local -i __Collection_List_del_len=0; (( ${#__Collection_List_del_arr[@]} )) && __Collection_List_del_len=${#__Collection_List_del_arr[@]}
  (( __Collection_List_del_idx < 0 )) && (( __Collection_List_del_idx += __Collection_List_del_len ))
  (( __Collection_List_del_idx < 0 || __Collection_List_del_idx >= __Collection_List_del_len )) && {
    _Error "List index out of range: $1 (length: $__Collection_List_del_len)"; return 1; }
  _Debug "delete: [$__Collection_List_del_idx], length now $(( __Collection_List_del_len - 1 ))"
  unset '__Collection_List_del_arr[$__Collection_List_del_idx]'
  __Collection_List_del_arr=("${__Collection_List_del_arr[@]+"${__Collection_List_del_arr[@]}"}")
}

# Return the number of elements in the list.
#
# Uses bash's native ${#array[@]} — O(1) since bash tracks array length
# internally. Routes through boop.pass for consistent value delivery.
#
# Usage: into=len $list.length
#        $list.length; printf "%s\n" "$_Out"
Collection.List.length() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local -n __Collection_List_length_arr="__boop_data_${_Self}"
  local -i __Collection_List_length_len=0; (( ${#__Collection_List_length_arr[@]} )) && __Collection_List_length_len=${#__Collection_List_length_arr[@]}
  boop.pass "$__Collection_List_length_len" ${into:-}
}

# Remove all elements from the list.
#
# Resets the companion array to empty. The global array itself persists
# (it's not unset — that's destroy's job), just emptied. O(1) operation.
#
# Usage: $list.clear
Collection.List.clear() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local -n __Collection_List_clear_arr="__boop_data_${_Self}"
  local -i __Collection_List_clear_len=0; [[ -n "${!__Collection_List_clear_arr[@]}" ]] && __Collection_List_clear_len=${#__Collection_List_clear_arr[@]}
  _Debug "clear: $__Collection_List_clear_len element(s) removed"
  __Collection_List_clear_arr=()
}

# Check whether an index is within bounds.
#
# Supports negative indices (resolved the same way as get/set/delete).
# Returns exit code 0 (true) if the resolved index falls within
# 0..length-1, exit code 1 (false) otherwise. Uses bash boolean
# convention — no value is produced, just the exit code.
#
# Usage: $list.has 0 && printf "has first element"
#        $list.has -1 && printf "not empty"
#        $list.has 99 || printf "out of range"
Collection.List.has() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local -i __Collection_List_has_idx="$1"
  local -n __Collection_List_has_arr="__boop_data_${_Self}"
  local -i __Collection_List_has_len=0; (( ${#__Collection_List_has_arr[@]} )) && __Collection_List_has_len=${#__Collection_List_has_arr[@]}
  (( __Collection_List_has_idx < 0 )) && (( __Collection_List_has_idx += __Collection_List_has_len ))
  (( __Collection_List_has_idx >= 0 && __Collection_List_has_idx < __Collection_List_has_len )) && return 0 || return 1
}

# Append one or more elements to the end of the list.
#
# Accepts variadic arguments — all are appended in order. Uses bash's
# native += operator on the companion array, which is O(1) amortized
# per element (bash handles the internal reallocation).
#
# Does not produce a return value. If you need the new length after
# pushing, call length separately.
#
# Usage: $list.push "alpha"
#        $list.push "a" "b" "c"    # append three at once
Collection.List.push() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local -n __Collection_List_push_arr="__boop_data_${_Self}"
  __Collection_List_push_arr+=("$@")
  _Debug "push: +$# element(s), length now ${#__Collection_List_push_arr[@]}"
}

# Remove and return the last element (stack-style LIFO).
#
# Crashes on empty list — popping nothing is a logic error, not a
# silent no-op. Check isEmpty or length first if the list might be empty.
#
# Uses bash's negative index syntax (arr[-1]) to grab the last element,
# then unset it. No re-indexing needed since the removed element is
# already at the end.
#
# Usage: into=val $list.pop
#        $list.pop; printf "%s\n" "$_Out"
Collection.List.pop() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local -n __Collection_List_pop_arr="__boop_data_${_Self}"
  local -i __Collection_List_pop_len=0; (( ${#__Collection_List_pop_arr[@]} )) && __Collection_List_pop_len=${#__Collection_List_pop_arr[@]}
  (( __Collection_List_pop_len == 0 )) && { _Error "pop from empty List"; return 1; }
  local __Collection_List_pop_val="${__Collection_List_pop_arr[-1]}"
  unset '__Collection_List_pop_arr[-1]'
  _Debug "pop: -> '$__Collection_List_pop_val', length now $(( __Collection_List_pop_len - 1 ))"
  boop.pass "$__Collection_List_pop_val" ${into:-}
}

# Remove and return the first element (queue-style FIFO).
#
# Crashes on empty list (same rationale as pop). After capturing element 0,
# the array is rebuilt from index 1 onward via slice syntax, which
# re-indexes everything. This is O(n) — if you're doing heavy queue work,
# consider whether the access pattern justifies the cost.
#
# Usage: into=val $list.shift
#        $list.shift; printf "%s\n" "$_Out"
Collection.List.shift() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local -n __Collection_List_shift_arr="__boop_data_${_Self}"
  local -i __Collection_List_shift_len=0; (( ${#__Collection_List_shift_arr[@]} )) && __Collection_List_shift_len=${#__Collection_List_shift_arr[@]}
  (( __Collection_List_shift_len == 0 )) && { _Error "shift from empty List"; return 1; }
  local __Collection_List_shift_val="${__Collection_List_shift_arr[0]}"
  __Collection_List_shift_arr=("${__Collection_List_shift_arr[@]:1}")
  _Debug "shift: -> '$__Collection_List_shift_val', length now $(( __Collection_List_shift_len - 1 ))"
  boop.pass "$__Collection_List_shift_val" ${into:-}
}

# Prepend one or more elements to the beginning of the list.
#
# Accepts variadic arguments. The new elements appear in the order given,
# followed by the existing elements. Implemented by rebuilding the array
# with the new elements first — O(n) for the same reason as shift.
#
# Usage: $list.unshift "first"
#        $list.unshift "a" "b"    # "a" becomes index 0, "b" index 1
Collection.List.unshift() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local -n __Collection_List_unshift_arr="__boop_data_${_Self}"
  __Collection_List_unshift_arr=("$@" "${__Collection_List_unshift_arr[@]+"${__Collection_List_unshift_arr[@]}"}")
  _Debug "unshift: +$# element(s), length now ${#__Collection_List_unshift_arr[@]}"
}

# Extract a sub-range of elements as a newline-delimited string.
#
# Follows Python slice semantics: start is inclusive, end is exclusive.
# Both support negative indices. Omitting end means "to the end of the list".
# An empty or invalid range returns empty string (not a crash — slicing
# nothing is a valid operation).
#
# Uses bash's ${array[@]:offset:count} slice syntax for the extraction,
# then printf -v to join with newlines. The trailing newline from printf
# is stripped so the output is clean for consumption.
#
# Usage: into=s $list.slice 1 3    # elements at index 1, 2
#        into=s $list.slice 2      # index 2 through end
#        into=s $list.slice -2     # last two elements
Collection.List.slice() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local -i __Collection_List_slice_start="${1:-0}" __Collection_List_slice_end
  local -n __Collection_List_slice_arr="__boop_data_${_Self}"
  local -i __Collection_List_slice_len=0; (( ${#__Collection_List_slice_arr[@]} )) && __Collection_List_slice_len=${#__Collection_List_slice_arr[@]}
  __Collection_List_slice_end="${2:-$__Collection_List_slice_len}"
  (( __Collection_List_slice_start < 0 )) && (( __Collection_List_slice_start += __Collection_List_slice_len ))
  (( __Collection_List_slice_end < 0 )) && (( __Collection_List_slice_end += __Collection_List_slice_len ))
  local -i __Collection_List_slice_count=$(( __Collection_List_slice_end - __Collection_List_slice_start ))
  (( __Collection_List_slice_count <= 0 )) && { boop.pass "" ${into:-}; return; }
  _Debug "slice: [$__Collection_List_slice_start:$__Collection_List_slice_end] -> $__Collection_List_slice_count element(s)"
  local __Collection_List_slice_d="${_EOL:-$'\n'}"
  local __Collection_List_slice_out
  printf -v __Collection_List_slice_out "%s${__Collection_List_slice_d}" "${__Collection_List_slice_arr[@]:$__Collection_List_slice_start:$__Collection_List_slice_count}"
  __Collection_List_slice_out="${__Collection_List_slice_out%"${__Collection_List_slice_d}"}"
  boop.pass "$__Collection_List_slice_out" ${into:-}
}

# Serialize all elements to a newline-delimited string.
#
# Returns empty string for an empty list (not a newline, not nothing —
# empty string). For non-empty lists, elements are joined with newlines
# via printf -v, with the trailing newline stripped.
#
# This is the Container contract implementation. The newline delimiter
# is a convention shared with Map.toArray (which uses "key=value" lines).
# Callers can split the result with `IFS=$'\n' read -ra` or iterate
# with `while IFS= read -r`.
#
# Usage: into=all $list.toArray
Collection.List.toArray() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local -n __Collection_List_toArray_arr="__boop_data_${_Self}"
  local __Collection_List_toArray_d="${_EOL:-$'\n'}"
  local __Collection_List_toArray_out
  _Trace "toArray: ${#__Collection_List_toArray_arr[@]} element(s)"
  if ! [[ -n "${__Collection_List_toArray_arr[@]:-}" ]]; then
    boop.pass "" ${into:-}
    return
  fi
  printf -v __Collection_List_toArray_out "%s${__Collection_List_toArray_d}" "${__Collection_List_toArray_arr[@]}"
  __Collection_List_toArray_out="${__Collection_List_toArray_out%"${__Collection_List_toArray_d}"}"
  boop.pass "$__Collection_List_toArray_out" ${into:-}
}

# Human-readable representation of the list and its contents.
#
# Overrides Container.toString to show actual elements instead of just
# metadata. Format: List(_a1b2c3)[ "alpha", "beta", "gamma" ]
#
# Elements are quoted in the output for visual clarity and to make
# whitespace in values visible. This is display-only — the quotes are
# not part of the stored data.
#
# Does not support pretty-print mode (unlike the base toString). Lists
# are inherently linear, so columnar formatting doesn't add much. If
# you need formatted output, iterate with get and format yourself.
#
# Usage: $list.toString
#        into=s $list.toString; printf "%s\n" "$s"
Collection.List.toString() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local -n __Collection_List_ts_arr="__boop_data_${_Self}"
  local -i __Collection_List_ts_len=0; (( ${#__Collection_List_ts_arr[@]} )) && __Collection_List_ts_len=${#__Collection_List_ts_arr[@]}
  _Trace "toString: $__Collection_List_ts_len element(s)"
  local __Collection_List_ts_out="List($_Self)[ "
  local -i __Collection_List_ts_i
  for (( __Collection_List_ts_i=0; __Collection_List_ts_i < __Collection_List_ts_len; __Collection_List_ts_i++ )); do
    (( __Collection_List_ts_i > 0 )) && __Collection_List_ts_out="$__Collection_List_ts_out, "
    __Collection_List_ts_out="$__Collection_List_ts_out\"${__Collection_List_ts_arr[$__Collection_List_ts_i]}\""
  done
  __Collection_List_ts_out="$__Collection_List_ts_out ]"
  boop.pass "$__Collection_List_ts_out" ${into:-}
}

# Iterate over all elements, calling a user function for each.
#
# The callback receives two arguments: the index (integer) and the value.
# Iteration proceeds in index order (0, 1, 2, ...). The callback runs
# in the current shell — it can read/write variables in the caller's scope.
#
# No subshells, no forks. The callback is invoked directly via its name.
# If the callback returns non-zero, iteration stops immediately (early exit).
#
# Usage: $list.each my_callback    # calls: my_callback 0 "alpha"
#                                  #        my_callback 1 "beta"
#                                  #        ...
Collection.List.each() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local __Collection_List_each_fn="$1"
  local -n __Collection_List_each_arr="__boop_data_${_Self}"
  [[ -n "${__Collection_List_each_arr[@]:-}" ]] || return 0
  local -i __Collection_List_each_len=${#__Collection_List_each_arr[@]} __Collection_List_each_i
  _Debug "each: iterating $__Collection_List_each_len element(s) via '$__Collection_List_each_fn'"
  for (( __Collection_List_each_i=0; __Collection_List_each_i < __Collection_List_each_len; __Collection_List_each_i++ )); do
    "$__Collection_List_each_fn" "$__Collection_List_each_i" "${__Collection_List_each_arr[$__Collection_List_each_i]}" || return
  done
}

# Check whether a value exists anywhere in the list.
#
# Thin wrapper over indexOf — discards the position, returns only the
# exit code. O(n) linear scan.
#
# Usage: $list.contains "banana" && printf "found\n"
Collection.List.contains() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local __Collection_List_contains_bitbucket
  if [[ -z "${1:-}" ]]; then _Error "$_Self.contains requires a search argument"; return 1; fi
  into=__Collection_List_contains_bitbucket $_Self.indexOf "$1"
}

# Return the index of the first occurrence of a value.
#
# Linear scan — O(n). Returns the index via boop.pass and exit 0 if found.
# Returns empty string and exit 1 if not found.
#
# Usage: into=pos $list.indexOf "banana"
Collection.List.indexOf() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local __Collection_List_indexOf_val="$1"
  local -n __Collection_List_indexOf_arr="__boop_data_${_Self}"
  local -i __Collection_List_indexOf_i __Collection_List_indexOf_len=${#__Collection_List_indexOf_arr[@]}
  for (( __Collection_List_indexOf_i=0; __Collection_List_indexOf_i < __Collection_List_indexOf_len; __Collection_List_indexOf_i++ )); do
    if [[ "${__Collection_List_indexOf_arr[$__Collection_List_indexOf_i]}" == "$__Collection_List_indexOf_val" ]]; then
      boop.pass "$__Collection_List_indexOf_i" ${into:-}
      return 0
    fi
  done
  boop.pass "" ${into:-}
  return 1
}

# Return a new List containing only elements for which the callback returns 0.
#
# The callback receives one argument: the element value. It returns exit
# code 0 to keep the element, non-zero to discard it. The original List
# is not modified.
#
# On an empty list, returns a new empty List (exit 0 — not an error).
#
# Usage:
#   is_long() { (( ${#1} > 3 )); }
#   into=result $list.filter is_long
Collection.List.filter() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local __Collection_List_filter_fn="$1"
  local -n __Collection_List_filter_src="__boop_data_${_Self}"

  # Create the result List with a clean class context
  local __Collection_List_filter_result
  into=__Collection_List_filter_result _Delegate Collection.List.new

  local -n __Collection_List_filter_dst="__boop_data_${__Collection_List_filter_result}"
  local -i __Collection_List_filter_i __Collection_List_filter_len=${#__Collection_List_filter_src[@]}

  _Debug "filter: $__Collection_List_filter_len element(s) via '$__Collection_List_filter_fn'"
  for (( __Collection_List_filter_i=0; __Collection_List_filter_i < __Collection_List_filter_len; __Collection_List_filter_i++ )); do
    if "$__Collection_List_filter_fn" "${__Collection_List_filter_src[$__Collection_List_filter_i]}"; then
      __Collection_List_filter_dst+=("${__Collection_List_filter_src[$__Collection_List_filter_i]}")
    fi
  done
  _Debug "filter: kept ${#__Collection_List_filter_dst[@]} of $__Collection_List_filter_len"

  boop.pass "$__Collection_List_filter_result" ${into:-}
}

# Return a new List with each element transformed by the callback.
#
# The callback receives one argument: the element value. It writes the
# transformed value to the variable _Result. The original List is not
# modified.
#
# On an empty list, returns a new empty List (exit 0 — not an error).
#
# Usage:
#   upcase() { _Result="${1^^}"; }
#   into=result $list.map upcase
Collection.List.map() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local __Collection_List_map_fn="$1"
  local -n __Collection_List_map_src="__boop_data_${_Self}"

  # Create the result List with a clean class context
  local __Collection_List_map_result
  into=__Collection_List_map_result _Delegate Collection.List.new

  local -n __Collection_List_map_dst="__boop_data_${__Collection_List_map_result}"
  local -i __Collection_List_map_i __Collection_List_map_len=${#__Collection_List_map_src[@]}
  local _Result=""

  _Debug "map: $__Collection_List_map_len element(s) via '$__Collection_List_map_fn'"
  for (( __Collection_List_map_i=0; __Collection_List_map_i < __Collection_List_map_len; __Collection_List_map_i++ )); do
    _Result=""
    "$__Collection_List_map_fn" "${__Collection_List_map_src[$__Collection_List_map_i]}"
    __Collection_List_map_dst+=("$_Result")
  done

  boop.pass "$__Collection_List_map_result" ${into:-}
}

# Reduce the list to a single scalar value by applying a combining callback
# across all elements.
#
# The callback receives two arguments: the running total and the current
# element. It writes the new running total to _Result.
#
# The first element is used as the initial running total. The callback
# starts combining from the second element onward.
#
# On an empty list: returns empty string via boop.pass, exit code 1.
# On a single-element list: returns that element (callback never called).
#
# Usage:
#   add() { _Result=$(( $1 + $2 )); }
#   into=total $nums.reduce add
Collection.List.reduce() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"
  local __Collection_List_reduce_fn="$1"
  local -n __Collection_List_reduce_arr="__boop_data_${_Self}"
  local -i __Collection_List_reduce_len=${#__Collection_List_reduce_arr[@]}

  # Empty list: return empty, exit 1
  if (( __Collection_List_reduce_len == 0 )); then
    _Debug "reduce: empty list — returning exit 1"
    boop.pass "" ${into:-}
    return 1
  fi

  # Single element: return it directly, no callback needed
  if (( __Collection_List_reduce_len == 1 )); then
    _Debug "reduce: single element — returning directly"
    boop.pass "${__Collection_List_reduce_arr[0]}" ${into:-}
    return 0
  fi

  local _Result="${__Collection_List_reduce_arr[0]}"
  local -i __Collection_List_reduce_i

  _Debug "reduce: $__Collection_List_reduce_len element(s) via '$__Collection_List_reduce_fn'"
  for (( __Collection_List_reduce_i=1; __Collection_List_reduce_i < __Collection_List_reduce_len; __Collection_List_reduce_i++ )); do
    "$__Collection_List_reduce_fn" "$_Result" "${__Collection_List_reduce_arr[$__Collection_List_reduce_i]}"
  done

  boop.pass "$_Result" ${into:-}
}

# Apply a pipeline of operations in sequence, managing intermediates.
#
# Each operation is an op:callback pair. Operations are separated by
# whitespace, commas, or both. Spaces around colons are tolerated.
# All of these are equivalent:
#
#   $list.do "filter:is_even,map:double_it,reduce:add"
#   $list.do "filter:is_even, map:double_it, reduce:add"
#   $list.do filter:is_even map:double_it reduce:add
#   $list.do "filter : is_even" "map : double_it" "reduce : add"
#
# Recognized operations: filter, map, reduce. Each takes a callback name.
# filter and map produce new Lists (intermediates are destroyed automatically).
# reduce produces a scalar (the final value).
#
# Returns whatever the last operation produces: a List ID (filter/map) or
# a scalar string (reduce). Exit code follows the last operation's contract
# (reduce on empty returns 1).
#
# Usage:
#   into=result $list.do filter:is_even map:double_it reduce:add
Collection.List.do() {
  local _Self="${_Self:-${_Class:-Collection.List}}" _Class="${_Class:-Collection.List}"

  # --- Normalize input into op:callback tokens ---
  local IFS=' '
  local __Collection_List_do_raw="$*"
  # Commas are visual separators — replace with space
  __Collection_List_do_raw="${__Collection_List_do_raw//,/ }"
  # Collapse spaces around colons: " : " → ":", ": " → ":", " :" → ":"
  while [[ "$__Collection_List_do_raw" == *" :"* || "$__Collection_List_do_raw" == *": "* ]]; do
    __Collection_List_do_raw="${__Collection_List_do_raw// :/:}"
    __Collection_List_do_raw="${__Collection_List_do_raw//: /:}"
  done

  # Split on whitespace into tokens
  local -a __Collection_List_do_tokens
  read -ra __Collection_List_do_tokens <<< "$__Collection_List_do_raw"

  (( ${#__Collection_List_do_tokens[@]} > 0 )) ||
    _Crash "List.do: empty pipeline"

  _Debug "do: ${#__Collection_List_do_tokens[@]} operation(s)"

  # --- Execute pipeline ---
  local __Collection_List_do_current="$_Self"
  local __Collection_List_do_prev=""
  local __Collection_List_do_op __Collection_List_do_cb __Collection_List_do_tok
  local -i __Collection_List_do_rc=0

  for __Collection_List_do_tok in "${__Collection_List_do_tokens[@]}"; do
    __Collection_List_do_op="${__Collection_List_do_tok%%:*}"
    __Collection_List_do_cb="${__Collection_List_do_tok#*:}"
    [[ -n "$__Collection_List_do_op" && -n "$__Collection_List_do_cb" && "$__Collection_List_do_op" != "$__Collection_List_do_cb" ]] ||
      _Crash "List.do: malformed token '$__Collection_List_do_tok' — expected op:callback"

    _Trace "do: $__Collection_List_do_op:$__Collection_List_do_cb on $__Collection_List_do_current"

    case "$__Collection_List_do_op" in
      filter)
        __Collection_List_do_prev="$__Collection_List_do_current"
        into=__Collection_List_do_current \
          _Self="$__Collection_List_do_current" _Class=Collection.List \
          Collection.List.filter "$__Collection_List_do_cb"
        ;;
      map)
        __Collection_List_do_prev="$__Collection_List_do_current"
        into=__Collection_List_do_current \
          _Self="$__Collection_List_do_current" _Class=Collection.List \
          Collection.List.map "$__Collection_List_do_cb"
        ;;
      reduce)
        __Collection_List_do_prev="$__Collection_List_do_current"
        into=__Collection_List_do_current \
          _Self="$__Collection_List_do_current" _Class=Collection.List \
          Collection.List.reduce "$__Collection_List_do_cb" || __Collection_List_do_rc=$?
        ;;
      *) _Crash "List.do: unknown operation '$__Collection_List_do_op' (expected: filter, map, reduce)" ;;
    esac

    # Destroy the intermediate (but never the original input)
    if [[ -n "$__Collection_List_do_prev" && "$__Collection_List_do_prev" != "$_Self" &&
          -n "${__boop_registry[$__Collection_List_do_prev]+set}" ]]; then
      _Trace "do: destroying intermediate $__Collection_List_do_prev"
      _Delegate $__Collection_List_do_prev.destroy
    fi
    __Collection_List_do_prev=""
  done

  boop.pass "$__Collection_List_do_current" ${into:-}
  return $__Collection_List_do_rc
}

