#!/bin/bash

# Collection.Stack.Fast — LIFO stack via direct List inheritance.
#
# Inherits Collection.List and restricts the interface to stack semantics.
# shift/unshift are overridden with _Error stubs — convention-enforced,
# not mechanism-enforced. The tradeoff is explicit: one object instead of
# two, no delegation overhead, no cascading destroy, at the cost of a
# caller who ignores the API surface being able to call List methods.
#
# Performance advantage over composition-based Collection.Stack:
#   - No internal List object (half the objects, half the wrappers)
#   - push/pop are inherited directly — zero indirection
#   - No reference variable to manage
#   - No _destroy hook needed (Container handles the companion array)
#
# Public interface:
#   $s.push  val ...  — add one or more values to the top
#   $s.pop            — remove and return top (crashes if empty)
#   $s.peek           — return top without removing (crashes if empty)
#   $s.size           — number of elements (alias for length)
#   $s.isEmpty        — exits 0 if empty, 1 if not
#
# Inherited but intentionally available:
#   $s.length, $s.clear, $s.has, $s.toArray, $s.toString, $s.each
#
# Blocked (error stubs):
#   $s.shift, $s.unshift — not valid stack operations

. boop Collection::List

boop.init Collection.Stack.Fast || return 0

# peek — return top element without removing. Crashes on empty.
Collection.Stack.Fast.peek() {
  local _Self="${_Self:-${_Class:-Collection.Stack.Fast}}" _Class="${_Class:-Collection.Stack.Fast}"
  local -n __Collection_Stack_Fast_peek_arr="__boop_data_${_Self}"
  local -i __Collection_Stack_Fast_peek_len=${#__Collection_Stack_Fast_peek_arr[@]}
  (( __Collection_Stack_Fast_peek_len > 0 )) || _Crash "peek on empty Stack"
  boop.pass "${__Collection_Stack_Fast_peek_arr[-1]}" ${into:-}
}

# size — alias for length (stack vocabulary)
Collection.Stack.Fast.size() {
  local _Self="${_Self:-${_Class:-Collection.Stack.Fast}}" _Class="${_Class:-Collection.Stack.Fast}"
  local -n __Collection_Stack_Fast_size_arr="__boop_data_${_Self}"
  boop.pass "${#__Collection_Stack_Fast_size_arr[@]}" ${into:-}
}

# isEmpty — exit 0 if empty, 1 if not
Collection.Stack.Fast.isEmpty() {
  local _Self="${_Self:-${_Class:-Collection.Stack.Fast}}" _Class="${_Class:-Collection.Stack.Fast}"
  local -n __Collection_Stack_Fast_isEmpty_arr="__boop_data_${_Self}"
  (( ${#__Collection_Stack_Fast_isEmpty_arr[@]} == 0 ))
}

# Blocked operations — stacks don't support queue-end or random access.
Collection.Stack.Fast.shift() {
  _Error "Stack.Fast: shift is not a valid stack operation — use pop"
  return 1
}
Collection.Stack.Fast.unshift() {
  _Error "Stack.Fast: unshift is not a valid stack operation — use push"
  return 1
}
Collection.Stack.Fast.getAt() {
  _Error "Stack.Fast: random access violates LIFO — use peek or pop"
  return 1
}
Collection.Stack.Fast.setAt() {
  _Error "Stack.Fast: random access violates LIFO — use push"
  return 1
}
Collection.Stack.Fast.delete() {
  _Error "Stack.Fast: random access violates LIFO — use pop"
  return 1
}
Collection.Stack.Fast.slice() {
  _Error "Stack.Fast: random access violates LIFO — use pop in a loop"
  return 1
}

boopClass Collection.Stack.Fast isa:Collection.List version:1.0.0 '
  public:peek,size,isEmpty,shift,unshift,getAt,setAt,delete,slice
'
