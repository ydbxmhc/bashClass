#!/bin/bash

# Collection.Stack -- LIFO stack built on Collection.List.
#
# Composition: holds a List internally, exposes only the stack surface.
#
# Public interface:
#   $s.push  val ...  -- add one or more values to the top
#   $s.pop            -- remove and return top (crashes if empty)
#   $s.peek           -- return top without removing (crashes if empty)
#   $s.size           -- number of elements
#   $s.isEmpty        -- exits 0 if empty, 1 if not

. boop Collection::List
boop.init Collection.Stack || return 0

Collection.Stack.new() {
  local _Class="${_Class:-Collection.Stack}"
  local __Collection_Stack_new_self __Collection_Stack_new_list
  into=__Collection_Stack_new_self __boop.new "$@"
  into=__Collection_Stack_new_list Collection.List.new
  declare -g "__Collection_Stack_list_${__Collection_Stack_new_self}=${__Collection_Stack_new_list}"
  _Info "new: $__Collection_Stack_new_self"
  boop.pass "$__Collection_Stack_new_self" ${into:-}
}

Collection.Stack.push() {
  local _Self="${_Self:-Collection.Stack}" _Class="${_Class:-Collection.Stack}"
  local -n __Collection_Stack_push_l="__Collection_Stack_list_${_Self}"
  _Trace "push: +$# element(s)"
  _Self="$__Collection_Stack_push_l" Collection.List.push "$@"
}

Collection.Stack.pop() {
  local _Self="${_Self:-Collection.Stack}" _Class="${_Class:-Collection.Stack}"
  local -n __Collection_Stack_pop_l="__Collection_Stack_list_${_Self}"
  _Trace "pop"
  _Self="$__Collection_Stack_pop_l" Collection.List.pop
}

Collection.Stack.peek() {
  local _Self="${_Self:-Collection.Stack}" _Class="${_Class:-Collection.Stack}"
  local -n __Collection_Stack_peek_l="__Collection_Stack_list_${_Self}"
  local __Collection_Stack_peek_len
  into=__Collection_Stack_peek_len _Self="$__Collection_Stack_peek_l" Collection.List.length
  (( __Collection_Stack_peek_len > 0 )) || _Crash "peek on empty Stack"
  _Trace "peek"
  _Self="$__Collection_Stack_peek_l" Collection.List.getAt -1
}

Collection.Stack.size() {
  local _Self="${_Self:-Collection.Stack}" _Class="${_Class:-Collection.Stack}"
  local -n __Collection_Stack_size_l="__Collection_Stack_list_${_Self}"
  _Self="$__Collection_Stack_size_l" Collection.List.length
}

Collection.Stack.isEmpty() {
  local _Self="${_Self:-Collection.Stack}" _Class="${_Class:-Collection.Stack}"
  local -n __Collection_Stack_isEmpty_l="__Collection_Stack_list_${_Self}"
  local __Collection_Stack_isEmpty_len
  into=__Collection_Stack_isEmpty_len _Self="$__Collection_Stack_isEmpty_l" Collection.List.length
  (( __Collection_Stack_isEmpty_len == 0 ))
}

boopClass Collection.Stack version:1.0.0 '
  public:new,push,pop,peek,size,isEmpty
'
