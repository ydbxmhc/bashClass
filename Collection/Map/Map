#!/bin/bash

# Collection.Map — insertion-ordered associative array container.
#
# Wraps a bash associative array (declare -gA) with object semantics.
# Implements the Container contract with key-value operations: get, set,
# delete, has, keys, values, and iteration via toArray.
#
# Storage: each Map instance owns a global associative array named
# __boop_data_${_Self}. Key-value data lives there, not in the
# pipe-delimited descriptor. This gives us native bash associative array
# performance for lookups while the object system handles identity,
# dispatch, and lifecycle.
#
# Key ordering: Map maintains insertion order via a companion indexed
# array __boop_keys_${_Self}. All traversal methods (keys, values,
# toArray, toString, each, iterator) walk keys in the order they were
# first inserted. Overwriting an existing key updates the value but does
# NOT change the key's position in the order. Deleting a key removes it
# from the ordered list; re-inserting it places it at the end.
#
# Composition: Map values can be any string, including object IDs.
# Storing a List's ID as a value creates a dictionary-of-lists pattern.
# Storing another Map's ID creates nested dictionaries. Same turtles,
# different shell.

# Load guard — if already registered, nothing to do
[[ -n "${__boop_registry[Collection.Map]+set}" ]] && return 2>/dev/null

. boop Collection::Container

# ============================================================================
# Map Implementation Functions
# ============================================================================

# Constructor — creates a new Map instance with an associative companion array
# and an indexed companion array for tracking insertion order.
#
# Usage: into=mymap Collection.Map
Collection.Map.new() {
  local _Class="${_Class:-Collection.Map}"
  local __Collection_Map_new_self
  into=__Collection_Map_new_self __boop.new type=associative "$@"
  declare -gA "__boop_data_${__Collection_Map_new_self}"
  declare -ga "__boop_keys_${__Collection_Map_new_self}"
  eval "__boop_data_${__Collection_Map_new_self}+=()"
  eval "__boop_keys_${__Collection_Map_new_self}+=()"
  boop.pass "$__Collection_Map_new_self" ${into:-}
}

# Retrieve a value by its string key.
#
# Returns empty string if the key doesn't exist — not a crash.
#
# Usage: into=val $map.get "host"
Collection.Map.getAt() {
  local _Self="${_Self:-${_Class:-Collection.Map}}" _Class="${_Class:-Collection.Map}"
  local __Collection_Map_getAt_key="$1"
  local -n __Collection_Map_getAt_arr="__boop_data_${_Self}"
  boop.pass "${__Collection_Map_getAt_arr[$__Collection_Map_getAt_key]:-}" ${into:-}
}

# Store a key-value pair in the map.
#
# If the key already exists, its value is overwritten but its position
# in the insertion order is preserved. If the key is new, it's appended
# to the ordered key list.
#
# Usage: $map.set "host" "localhost"
Collection.Map.setAt() {
  local _Self="${_Self:-${_Class:-Collection.Map}}" _Class="${_Class:-Collection.Map}"
  local __Collection_Map_setAt_key="$1" __Collection_Map_setAt_val="$2"
  local -n __Collection_Map_setAt_arr="__boop_data_${_Self}"
  local -n __Collection_Map_setAt_keys="__boop_keys_${_Self}"

  # If key is new, append to ordered key list
  if [[ -z "${__Collection_Map_setAt_arr[$__Collection_Map_setAt_key]+set}" ]]; then
    __Collection_Map_setAt_keys+=("$__Collection_Map_setAt_key")
  fi

  __Collection_Map_setAt_arr[$__Collection_Map_setAt_key]="$__Collection_Map_setAt_val"
}

# Remove a key-value pair from the map.
#
# Removes from both the data array and the ordered key list.
# Silent no-op if the key doesn't exist.
#
# Usage: $map.delete "debug"
Collection.Map.delete() {
  local _Self="${_Self:-${_Class:-Collection.Map}}" _Class="${_Class:-Collection.Map}"
  local __Collection_Map_del_key="$1"
  local -n __Collection_Map_del_arr="__boop_data_${_Self}"
  local -n __Collection_Map_del_keys="__boop_keys_${_Self}"

  unset "__Collection_Map_del_arr[$__Collection_Map_del_key]"

  # Remove from ordered key list and compact
  local -a __Collection_Map_del_new=()
  local __Collection_Map_del_k
  if [[ -n "${!__Collection_Map_del_keys[@]}" ]]; then
    for __Collection_Map_del_k in "${__Collection_Map_del_keys[@]}"; do
      [[ "$__Collection_Map_del_k" != "$__Collection_Map_del_key" ]] && __Collection_Map_del_new+=("$__Collection_Map_del_k")
    done
  fi
  __Collection_Map_del_keys=("${__Collection_Map_del_new[@]+"${__Collection_Map_del_new[@]}"}")
}

# Return the number of key-value pairs in the map.
#
# Usage: into=len $map.length
Collection.Map.length() {
  local _Self="${_Self:-${_Class:-Collection.Map}}" _Class="${_Class:-Collection.Map}"
  local -n __Collection_Map_length_arr="__boop_data_${_Self}"
  local -i __Collection_Map_length_len=0; [[ -n "${!__Collection_Map_length_arr[@]}" ]] && __Collection_Map_length_len=${#__Collection_Map_length_arr[@]}
  boop.pass "$__Collection_Map_length_len" ${into:-}
}

# Remove all key-value pairs from the map.
#
# Usage: $map.clear
Collection.Map.clear() {
  local _Self="${_Self:-${_Class:-Collection.Map}}" _Class="${_Class:-Collection.Map}"
  local -n __Collection_Map_clear_arr="__boop_data_${_Self}"
  local -n __Collection_Map_clear_keys="__boop_keys_${_Self}"
  __Collection_Map_clear_arr=()
  __Collection_Map_clear_keys=()
}

# Check whether a key exists in the map.
#
# Usage: $map.has "host" && printf "host is configured"
Collection.Map.has() {
  local _Self="${_Self:-${_Class:-Collection.Map}}" _Class="${_Class:-Collection.Map}"
  local __Collection_Map_has_key="$1"
  local -n __Collection_Map_has_arr="__boop_data_${_Self}"
  [[ -n "${__Collection_Map_has_arr[$__Collection_Map_has_key]+set}" ]] && return 0 || return 1
}

# Return all keys as a newline-delimited string in insertion order.
#
# Usage: into=k $map.keys
Collection.Map.keys() {
  local _Self="${_Self:-${_Class:-Collection.Map}}" _Class="${_Class:-Collection.Map}"
  local -n __Collection_Map_keys_keys="__boop_keys_${_Self}"
  local __Collection_Map_keys_d="${_Delimiter:-$_EOL}"
  local __Collection_Map_keys_out
  if ! [[ -n "${!__Collection_Map_keys_keys[@]}" ]] || (( ${#__Collection_Map_keys_keys[@]} == 0 )); then
    boop.pass "" ${into:-}
    return
  fi
  printf -v __Collection_Map_keys_out "%s${__Collection_Map_keys_d}" "${__Collection_Map_keys_keys[@]}"
  __Collection_Map_keys_out="${__Collection_Map_keys_out%"${__Collection_Map_keys_d}"}"
  boop.pass "$__Collection_Map_keys_out" ${into:-}
}

# Return all values as a newline-delimited string in insertion order.
#
# Values appear in the same order as keys() — the Nth value line
# matches the Nth key line.
#
# Usage: into=v $map.values
Collection.Map.values() {
  local _Self="${_Self:-${_Class:-Collection.Map}}" _Class="${_Class:-Collection.Map}"
  local -n __Collection_Map_values_arr="__boop_data_${_Self}"
  local -n __Collection_Map_values_keys="__boop_keys_${_Self}"
  local __Collection_Map_values_out=""
  if ! [[ -n "${!__Collection_Map_values_keys[@]}" ]] || (( ${#__Collection_Map_values_keys[@]} == 0 )); then
    boop.pass "" ${into:-}
    return
  fi
  local __Collection_Map_values_d="${_Delimiter:-$_EOL}"
  local __Collection_Map_values_k __Collection_Map_values_first=1
  for __Collection_Map_values_k in "${__Collection_Map_values_keys[@]}"; do
    (( __Collection_Map_values_first )) || __Collection_Map_values_out="${__Collection_Map_values_out}${__Collection_Map_values_d}"
    __Collection_Map_values_out="$__Collection_Map_values_out${__Collection_Map_values_arr[$__Collection_Map_values_k]}"
    __Collection_Map_values_first=0
  done
  boop.pass "$__Collection_Map_values_out" ${into:-}
}

# Serialize all entries as newline-delimited "key=value" lines in insertion order.
#
# Usage: into=entries $map.toArray
Collection.Map.toArray() {
  local _Self="${_Self:-${_Class:-Collection.Map}}" _Class="${_Class:-Collection.Map}"
  local -n __Collection_Map_toArray_arr="__boop_data_${_Self}"
  local -n __Collection_Map_toArray_keys="__boop_keys_${_Self}"
  local __Collection_Map_toArray_d="${_Delimiter:-$_EOL}"
  local __Collection_Map_toArray_out="" __Collection_Map_toArray_key __Collection_Map_toArray_first=1
  if [[ -n "${!__Collection_Map_toArray_keys[@]}" ]]; then
    for __Collection_Map_toArray_key in "${__Collection_Map_toArray_keys[@]}"; do
      (( __Collection_Map_toArray_first )) || __Collection_Map_toArray_out="${__Collection_Map_toArray_out}${__Collection_Map_toArray_d}"
      __Collection_Map_toArray_out="$__Collection_Map_toArray_out$__Collection_Map_toArray_key=${__Collection_Map_toArray_arr[$__Collection_Map_toArray_key]}"
      __Collection_Map_toArray_first=0
    done
  fi
  boop.pass "$__Collection_Map_toArray_out" ${into:-}
}

# Human-readable representation in insertion order.
#
# Format: Map(_a1b2c3){ host="localhost", port="8080" }
#
# Usage: $map.toString
Collection.Map.toString() {
  local _Self="${_Self:-${_Class:-Collection.Map}}" _Class="${_Class:-Collection.Map}"
  local -n __Collection_Map_ts_arr="__boop_data_${_Self}"
  local -n __Collection_Map_ts_keys="__boop_keys_${_Self}"
  local __Collection_Map_ts_out="Map($_Self){ " __Collection_Map_ts_key __Collection_Map_ts_first=1
  if [[ -n "${!__Collection_Map_ts_keys[@]}" ]]; then
    for __Collection_Map_ts_key in "${__Collection_Map_ts_keys[@]}"; do
      (( __Collection_Map_ts_first )) || __Collection_Map_ts_out="$__Collection_Map_ts_out, "
      __Collection_Map_ts_out="$__Collection_Map_ts_out$__Collection_Map_ts_key=\"${__Collection_Map_ts_arr[$__Collection_Map_ts_key]}\""
      __Collection_Map_ts_first=0
    done
  fi
  __Collection_Map_ts_out="$__Collection_Map_ts_out }"
  boop.pass "$__Collection_Map_ts_out" ${into:-}
}

# Iterate over all entries in insertion order, calling a user function for each.
#
# The callback receives two arguments: the key and the value.
# If the callback returns non-zero, iteration stops immediately.
#
# Usage: $map.each my_callback
Collection.Map.each() {
  local _Self="${_Self:-${_Class:-Collection.Map}}" _Class="${_Class:-Collection.Map}"
  local __Collection_Map_each_fn="$1"
  local -n __Collection_Map_each_arr="__boop_data_${_Self}"
  local -n __Collection_Map_each_keys="__boop_keys_${_Self}"
  [[ -n "${!__Collection_Map_each_keys[@]}" ]] || return 0
  local __Collection_Map_each_key
  for __Collection_Map_each_key in "${__Collection_Map_each_keys[@]}"; do
    "$__Collection_Map_each_fn" "$__Collection_Map_each_key" "${__Collection_Map_each_arr[$__Collection_Map_each_key]}" || return
  done
}

# ============================================================================
# Class Declaration
# ============================================================================

boopClass Collection.Map isa:Collection.Container has:type '
  public:new,getAt,setAt,delete,length,clear,has,keys,values,toArray,toString,each
'
