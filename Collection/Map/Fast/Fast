#!/bin/bash

# Collection.Map.Fast -- flat compound-key store for O(1) point lookups.
#
# A purpose-built associative array with dot-delimited compound keys.
# Tuned for config data, parsed documents, lookup tables, and caches.
# All values are strings (which can be object references if needed).
#
# Fast vs Map:
#   Fast: O(1) get/set by full path. No insertion order. Enumeration
#         requires scanning all keys (slow for large stores). No
#         subtree pass-by-reference.
#   Map:  Insertion-ordered. Full iteration support. Each level is a
#         real object. More overhead per node.
#
# Use Fast when you need quick point lookups into flat or nested data.
# Use Map when you need to iterate, count, or pass subtrees around.
#
# Storage: each Fast instance owns a global associative array named
# __boop_data_${_Self}. Compound keys live there directly:
#   __boop_data_${_Self}["users.0.name"]="Alice"
#   __boop_data_${_Self}["server.port"]="8080"
#
# The separator defaults to "." and is stored as a property.
# Override per-instance: into=doc Collection.Map.Fast sep="/"

# Load guard
[[ -n "${__boop_registry[Collection.Map.Fast]+set}" ]] && return 2>/dev/null

. boop

# ============================================================================
# Constructor
# ============================================================================

Collection.Map.Fast.new() {
  local -I _Class; : "${_Class:=Collection.Map.Fast}"
  local __Collection_Map_Fast_new_self __Collection_Map_Fast_new_sep="."
  local __Collection_Map_Fast_new_arg
  for __Collection_Map_Fast_new_arg in "$@"; do
    case "$__Collection_Map_Fast_new_arg" in
      sep=*) __Collection_Map_Fast_new_sep="${__Collection_Map_Fast_new_arg#sep=}" ;;
    esac
  done
  into=__Collection_Map_Fast_new_self __boop.new sep="$__Collection_Map_Fast_new_sep"
  declare -gA "__boop_data_${__Collection_Map_Fast_new_self}"
  boop.pass "$__Collection_Map_Fast_new_self" "${into:-}"
}

# ============================================================================
# Core methods
# ============================================================================

# Get a value by compound key. Returns empty string if not set.
#
# Usage: into=val $doc.get "users.0.name"
Collection.Map.Fast.get() {
  local -I _Self _Class
  local -n __Collection_Map_Fast_get_data="__boop_data_${_Self}"
  boop.pass "${__Collection_Map_Fast_get_data[${1:-}]:-}" "${into:-}"
}

# Set a value by compound key.
#
# Usage: $doc.set "users.0.name" "Alice"
Collection.Map.Fast.set() {
  local -I _Self _Class
  local -n __Collection_Map_Fast_set_data="__boop_data_${_Self}"
  __Collection_Map_Fast_set_data["${1:-}"]="${2:-}"
}

# Check if a compound key exists. Returns exit code 0/1.
#
# Usage: $doc.has "server.port" && echo "yes"
Collection.Map.Fast.has() {
  local -I _Self _Class
  local -n __Collection_Map_Fast_has_data="__boop_data_${_Self}"
  [[ -n "${__Collection_Map_Fast_has_data[${1:-}]+set}" ]]
}

# Delete a single compound key.
#
# Usage: $doc.delete "users.0.name"
Collection.Map.Fast.delete() {
  local -I _Self _Class
  local -n __Collection_Map_Fast_delete_data="__boop_data_${_Self}"
  unset "__Collection_Map_Fast_delete_data[${1:-}]"
}

# Return the number of keys in the store.
#
# Usage: into=n $doc.length
Collection.Map.Fast.length() {
  local -I _Self _Class
  local -n __Collection_Map_Fast_length_data="__boop_data_${_Self}"
  boop.pass "${#__Collection_Map_Fast_length_data[@]}" "${into:-}"
}

# Clear all keys.
#
# Usage: $doc.clear
Collection.Map.Fast.clear() {
  local -I _Self _Class
  local -n __Collection_Map_Fast_clear_data="__boop_data_${_Self}"
  __Collection_Map_Fast_clear_data=()
}

# Return all keys, one per line.
#
# Usage: into=k $doc.keys
Collection.Map.Fast.keys() {
  local -I _Self _Class
  local -n __Collection_Map_Fast_keys_data="__boop_data_${_Self}"
  local __Collection_Map_Fast_keys_out=""
  local __Collection_Map_Fast_keys_k
  for __Collection_Map_Fast_keys_k in "${!__Collection_Map_Fast_keys_data[@]}"; do
    [[ -n "$__Collection_Map_Fast_keys_out" ]] && __Collection_Map_Fast_keys_out+="${_Delimiter}"
    __Collection_Map_Fast_keys_out+="$__Collection_Map_Fast_keys_k"
  done
  boop.pass "$__Collection_Map_Fast_keys_out" "${into:-}"
}

# Return all keys matching a prefix, one per line.
# This is the expensive operation -- scans all keys.
#
# Usage: into=k $doc.keysUnder "users"
Collection.Map.Fast.keysUnder() {
  local -I _Self _Class
  local -n __Collection_Map_Fast_ku_data="__boop_data_${_Self}"
  local __Collection_Map_Fast_ku_prefix="${1:-}"
  local __Collection_Map_Fast_ku_sep=""
  __boop.parse "$_Self" "sep" __Collection_Map_Fast_ku_sep
  local __Collection_Map_Fast_ku_out="" __Collection_Map_Fast_ku_k
  for __Collection_Map_Fast_ku_k in "${!__Collection_Map_Fast_ku_data[@]}"; do
    [[ "$__Collection_Map_Fast_ku_k" == "${__Collection_Map_Fast_ku_prefix}${__Collection_Map_Fast_ku_sep}"* ]] || continue
    [[ -n "$__Collection_Map_Fast_ku_out" ]] && __Collection_Map_Fast_ku_out+="${_Delimiter}"
    __Collection_Map_Fast_ku_out+="$__Collection_Map_Fast_ku_k"
  done
  boop.pass "$__Collection_Map_Fast_ku_out" "${into:-}"
}

# Delete all keys matching a prefix.
#
# Usage: $doc.deleteUnder "users.0"
Collection.Map.Fast.deleteUnder() {
  local -I _Self _Class
  local -n __Collection_Map_Fast_du_data="__boop_data_${_Self}"
  local __Collection_Map_Fast_du_prefix="${1:-}"
  local __Collection_Map_Fast_du_sep=""
  __boop.parse "$_Self" "sep" __Collection_Map_Fast_du_sep
  local __Collection_Map_Fast_du_k
  for __Collection_Map_Fast_du_k in "${!__Collection_Map_Fast_du_data[@]}"; do
    [[ "$__Collection_Map_Fast_du_k" == "${__Collection_Map_Fast_du_prefix}${__Collection_Map_Fast_du_sep}"* || "$__Collection_Map_Fast_du_k" == "$__Collection_Map_Fast_du_prefix" ]] &&
      unset "__Collection_Map_Fast_du_data[$__Collection_Map_Fast_du_k]"
  done
}

# Dump all key=value pairs, one per line.
#
# Usage: into=dump $doc.toString
Collection.Map.Fast.toString() {
  local -I _Self _Class
  local -n __Collection_Map_Fast_ts_data="__boop_data_${_Self}"
  local __Collection_Map_Fast_ts_out="" __Collection_Map_Fast_ts_k
  for __Collection_Map_Fast_ts_k in "${!__Collection_Map_Fast_ts_data[@]}"; do
    [[ -n "$__Collection_Map_Fast_ts_out" ]] && __Collection_Map_Fast_ts_out+="${_Delimiter}"
    __Collection_Map_Fast_ts_out+="${__Collection_Map_Fast_ts_k}=${__Collection_Map_Fast_ts_data[$__Collection_Map_Fast_ts_k]}"
  done
  boop.pass "$__Collection_Map_Fast_ts_out" "${into:-}"
}

# ============================================================================
# Registration
# ============================================================================

boopClass Collection.Map.Fast 'has:sep public:new,get,set,has,delete,length,clear,keys,keysUnder,deleteUnder,toString'
