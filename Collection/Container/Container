# ============================================================================
# Provided methods — work for all containers via delegation.
# ============================================================================

Collection.Container.isEmpty() {
  local _Self="${_Self:-${_Class:-Collection.Container}}" _Class="${_Class:-Collection.Container}"
  local __Collection_Container_isEmpty_len
  into=__Collection_Container_isEmpty_len $_Self.length
  (( __Collection_Container_isEmpty_len == 0 )) && return 0 || return 1
}

# ============================================================================
# Iterator delegation — lazy auto-creation of internal Iterator.
#
# Each Container instance can have an implicit Iterator stored in its
# _iterator descriptor property. The first call to any delegation method
# (next, prev, hasNext, etc.) creates the Iterator if it doesn't exist,
# then forwards the call. This gives every container $list.next syntax
# with zero cost if never used.
#
# For independent cursors, create Iterators explicitly via:
#   into=iter Iterator target="$list" target_class="Collection.List"
# ============================================================================

# Internal helper — ensure the lazy iterator exists, store its ID in $3.
# Uses __boop.set (descriptor property) not Container.set (data storage).
__Collection_Container._ensureIterator() {
  local __Collection_Container_ensureIterator_self="$1" __Collection_Container_ensureIterator_class="$2" __Collection_Container_ensureIterator_target="$3"
  local __Collection_Container_ensureIterator_iter
  __boop.parse "$__Collection_Container_ensureIterator_self" "_iterator" __Collection_Container_ensureIterator_iter
  if [[ -z "$__Collection_Container_ensureIterator_iter" ]]; then
    into=__Collection_Container_ensureIterator_iter Iterator target="$__Collection_Container_ensureIterator_self" target_class="$__Collection_Container_ensureIterator_class"
    # Store in descriptor, not in container data
    local __Collection_Container_ensureIterator_encoded
    __boop.encode "$__Collection_Container_ensureIterator_iter" __Collection_Container_ensureIterator_encoded
    local __Collection_Container_ensureIterator_desc="${__boop_registry[$__Collection_Container_ensureIterator_self]:-}"
    __boop_registry[$__Collection_Container_ensureIterator_self]="$__Collection_Container_ensureIterator_desc|_iterator=$__Collection_Container_ensureIterator_encoded"
  fi
  local -n __Collection_Container_ensureIterator_ref="$__Collection_Container_ensureIterator_target"
  __Collection_Container_ensureIterator_ref="$__Collection_Container_ensureIterator_iter"
}

# Create an explicit Iterator over this container.
# Returns a new Iterator object every time — independent from the
# lazy internal one. Callers manage its lifecycle.
#
# Usage: into=iter $list.iterator
#        while $iter.hasNext; do
#          into=val $iter.next
#        done
Collection.Container.iterator() {
  local _Self="${_Self:-${_Class:-Collection.Container}}" _Class="${_Class:-Collection.Container}"
  local __Collection_Container_iter_obj
  into=__Collection_Container_iter_obj Iterator target="$_Self" target_class="$_Class"
  boop.pass "$__Collection_Container_iter_obj" ${into:-}
}

# Advance the internal iterator and return the next value.
Collection.Container.next() {
  local _Self="${_Self:-${_Class:-Collection.Container}}" _Class="${_Class:-Collection.Container}" __Collection_Container_next_iter
  __Collection_Container._ensureIterator "$_Self" "$_Class" __Collection_Container_next_iter
  into=__Collection_Container_next_val _Delegate $__Collection_Container_next_iter.next
  boop.pass "$__Collection_Container_next_val" ${into:-}
}

# Move the internal iterator backward and return the value.
Collection.Container.prev() {
  local _Self="${_Self:-${_Class:-Collection.Container}}" _Class="${_Class:-Collection.Container}" __Collection_Container_prev_iter
  __Collection_Container._ensureIterator "$_Self" "$_Class" __Collection_Container_prev_iter
  into=__Collection_Container_prev_val _Delegate $__Collection_Container_prev_iter.prev
  boop.pass "$__Collection_Container_prev_val" ${into:-}
}

# Check if the internal iterator has more elements ahead.
Collection.Container.hasNext() {
  local _Self="${_Self:-${_Class:-Collection.Container}}" _Class="${_Class:-Collection.Container}" __Collection_Container_hn_iter
  __Collection_Container._ensureIterator "$_Self" "$_Class" __Collection_Container_hn_iter
  _Delegate $__Collection_Container_hn_iter.hasNext
}

# Check if the internal iterator has elements behind.
Collection.Container.hasPrev() {
  local _Self="${_Self:-${_Class:-Collection.Container}}" _Class="${_Class:-Collection.Container}" __Collection_Container_hp_iter
  __Collection_Container._ensureIterator "$_Self" "$_Class" __Collection_Container_hp_iter
  _Delegate $__Collection_Container_hp_iter.hasPrev
}

# Return the value at the internal iterator's current position.
Collection.Container.current() {
  local _Self="${_Self:-${_Class:-Collection.Container}}" _Class="${_Class:-Collection.Container}" __Collection_Container_cur_iter
  __Collection_Container._ensureIterator "$_Self" "$_Class" __Collection_Container_cur_iter
  into=__Collection_Container_cur_val _Delegate $__Collection_Container_cur_iter.current
  boop.pass "$__Collection_Container_cur_val" ${into:-}
}

# Return the key/index at the internal iterator's current position.
Collection.Container.iterIndex() {
  local _Self="${_Self:-${_Class:-Collection.Container}}" _Class="${_Class:-Collection.Container}" __Collection_Container_idx_iter
  __Collection_Container._ensureIterator "$_Self" "$_Class" __Collection_Container_idx_iter
  into=__Collection_Container_idx_val _Delegate $__Collection_Container_idx_iter.index
  boop.pass "$__Collection_Container_idx_val" ${into:-}
}

# Reset the internal iterator to before the first element.
Collection.Container.iterReset() {
  local _Self="${_Self:-${_Class:-Collection.Container}}" _Class="${_Class:-Collection.Container}" __Collection_Container_rst_iter
  __Collection_Container._ensureIterator "$_Self" "$_Class" __Collection_Container_rst_iter
  _Delegate $__Collection_Container_rst_iter.reset
}

# ============================================================================
# Constructor / Destructor / toString
# ============================================================================

Collection.Container.new() {
  local _Class="${_Class:-Collection.Container}"
  local __Collection_Container_new_self
  into=__Collection_Container_new_self __boop.new "$@"
  boop.pass "$__Collection_Container_new_self" ${into:-}
}

Collection.Container.destroy() {
  local _Self="${_Self:-${_Class:-Collection.Container}}" _Class="${_Class:-Collection.Container}"
  unset "__boop_data_${_Self}"
  unset "__boop_registry[$_Self]"
}

Collection.Container.toString() {
  local _Self="${_Self:-${_Class:-Collection.Container}}" _Class="${_Class:-Collection.Container}"
  local -l prettyPrint; : "${prettyPrint:=false}"
  [[ "${1:-}" == "pretty" ]] && prettyPrint=true
  local __Collection_Container_ts_len __Collection_Container_ts_type
  into=__Collection_Container_ts_len $_Self.length
  __boop.parse "$_Self" "type" __Collection_Container_ts_type

  if [[ "$prettyPrint" != "true" ]]; then
    boop.pass "$_Class($_Self){ type=$__Collection_Container_ts_type length=$__Collection_Container_ts_len }" ${into:-}
    return
  fi

  local __Collection_Container_ts_out
  printf -v __Collection_Container_ts_out "%s(%s) {\n  type   = %s\n  length = %s\n}" 
    "$_Class" "$_Self" "$__Collection_Container_ts_type" "$__Collection_Container_ts_len"
  boop.pass "$__Collection_Container_ts_out" ${into:-}
}

# ============================================================================
# Deep Traversal — deepGet / deepSet
# ============================================================================

Collection.Container.deepGet() {
  local _Self="${_Self:-${_Class:-Collection.Container}}" _Class="${_Class:-Collection.Container}"
  local __Collection_Container_deepGet_cursor="$_Self" __Collection_Container_deepGet_class="$_Class"
  while (( $# > 1 )); do
    into=__Collection_Container_deepGet_cursor _Delegate $__Collection_Container_deepGet_cursor.getAt "$1"
    [[ -n "$__Collection_Container_deepGet_cursor" ]] || { boop.pass "" ${into:-}; return; }
    __boop.parse "$__Collection_Container_deepGet_cursor" "class" __Collection_Container_deepGet_class
    shift
  done
  into=__Collection_Container_deepGet_cursor _Delegate $__Collection_Container_deepGet_cursor.getAt "$1"
  boop.pass "$__Collection_Container_deepGet_cursor" ${into:-}
}

Collection.Container.deepSet() {
  local _Self="${_Self:-${_Class:-Collection.Container}}" _Class="${_Class:-Collection.Container}"
  local __Collection_Container_deepSet_val="$1"; shift
  local __Collection_Container_deepSet_cursor="$_Self" __Collection_Container_deepSet_class="$_Class"
  while (( $# > 1 )); do
    into=__Collection_Container_deepSet_cursor _Delegate $__Collection_Container_deepSet_cursor.getAt "$1"
    [[ -n "$__Collection_Container_deepSet_cursor" ]] || 
      _Crash "deepSet: missing intermediate at '$1'"
    __boop.parse "$__Collection_Container_deepSet_cursor" "class" __Collection_Container_deepSet_class
    shift
  done
  _Delegate $__Collection_Container_deepSet_cursor.setAt "$1" "$__Collection_Container_deepSet_val"
}

