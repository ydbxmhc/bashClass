#!/bin/bash
# Terminal mixin — ANSI escape sequences, raw input, and named symbol constants.
#
# Mix into any class that needs terminal output capabilities.
# All style/control methods write directly to stdout.
# Query methods (width, height, char) return via into=.

. boop
boop.initMixin Terminal || return 0

# ============================================================================
# Character map — single-line box, double-line box, suits, misc
# ============================================================================

declare -gA __Terminal_chars=(
  # Single-line box drawing
  [topLeft]='┌'    [topRight]='┐'    [bottomLeft]='└'   [bottomRight]='┘'
  [horiz]='─'      [vert]='│'        [cross]='┼'
  [teeDown]='┬'    [teeUp]='┴'       [teeRight]='├'     [teeLeft]='┤'

  # Double-line box drawing
  [dTopLeft]='╔'   [dTopRight]='╗'   [dBottomLeft]='╚'  [dBottomRight]='╝'
  [dHoriz]='═'     [dVert]='║'       [dCross]='╬'
  [dTeeDown]='╦'   [dTeeUp]='╩'      [dTeeRight]='╠'    [dTeeLeft]='╣'

  # Card suits
  [spade]='♠'      [heart]='♥'       [diamond]='♦'      [club]='♣'

  # Block / shade
  [block]='█'      [darkShade]='▓'   [medShade]='▒'     [shade]='░'

  # Arrows
  [arrowLeft]='←'  [arrowRight]='→'  [arrowUp]='↑'      [arrowDown]='↓'

  # Misc
  [bullet]='•'     [ellipsis]='…'    [check]='✓'        [ballotX]='✗'
  [star]='★'       [circle]='●'      [square]='■'
)

# ============================================================================
# Color tables — ANSI codes indexed by name
# ============================================================================

declare -gA __Terminal_fg=(
  [black]=30  [red]=31  [green]=32  [yellow]=33
  [blue]=34   [magenta]=35  [cyan]=36  [white]=37
  [bright_black]=90   [bright_red]=91   [bright_green]=92  [bright_yellow]=93
  [bright_blue]=94    [bright_magenta]=95 [bright_cyan]=96  [bright_white]=97
)

declare -gA __Terminal_bg=(
  [black]=40  [red]=41  [green]=42  [yellow]=43
  [blue]=44   [magenta]=45  [cyan]=46  [white]=47
  [bright_black]=100  [bright_red]=101  [bright_green]=102 [bright_yellow]=103
  [bright_blue]=104   [bright_magenta]=105 [bright_cyan]=106 [bright_white]=107
)

# ============================================================================
# Screen control
# ============================================================================

Terminal.clear() {
  printf '\033[2J\033[H'
}

Terminal.home() {
  printf '\033[H'
}

# Move cursor to row, col (1-based).
Terminal.move() {
  printf '\033[%s;%sH' "$1" "$2"
}

Terminal.hideCursor() {
  printf '\033[?25l'
}

Terminal.showCursor() {
  printf '\033[?25h'
}

# ============================================================================
# Text style  — write escape sequence directly; combine with printf freely
# ============================================================================

Terminal.bold()      { printf '\033[1m'; }
Terminal.dim()       { printf '\033[2m'; }
Terminal.italic()    { printf '\033[3m'; }
Terminal.underline() { printf '\033[4m'; }
Terminal.reverse()   { printf '\033[7m'; }
Terminal.reset()     { printf '\033[0m'; }

# Set foreground color by name.
Terminal.fg() {
  local __Terminal_fg_code="${__Terminal_fg[${1:-}]:-}"
  [[ -n "$__Terminal_fg_code" ]] || { _Error "Terminal.fg: unknown color '${1:-}'"; return 1; }
  printf '\033[%sm' "$__Terminal_fg_code"
}

# Set background color by name.
Terminal.bg() {
  local __Terminal_bg_code="${__Terminal_bg[${1:-}]:-}"
  [[ -n "$__Terminal_bg_code" ]] || { _Error "Terminal.bg: unknown color '${1:-}'"; return 1; }
  printf '\033[%sm' "$__Terminal_bg_code"
}

# ============================================================================
# Terminal size
# ============================================================================

Terminal.width() {
  local __Terminal_width_v="${COLUMNS:-}"
  [[ -n "$__Terminal_width_v" ]] || __Terminal_width_v="$(tput cols 2>/dev/null || printf '80')"
  boop.pass "$__Terminal_width_v" ${into:-}
}

Terminal.height() {
  local __Terminal_height_v="${LINES:-}"
  [[ -n "$__Terminal_height_v" ]] || __Terminal_height_v="$(tput lines 2>/dev/null || printf '24')"
  boop.pass "$__Terminal_height_v" ${into:-}
}

# ============================================================================
# Raw mode and single-keypress input
# ============================================================================

# Switch terminal to raw mode (no echo, no line buffering).
# Caller should trap EXIT to call Terminal.restore.
Terminal.raw() {
  stty -echo raw
}

# Restore normal terminal mode.
Terminal.restore() {
  stty echo -raw
}

# Read a single keypress. Requires raw mode to work without Enter.
Terminal.readKey() {
  local __Terminal_readKey_k
  IFS= read -rn1 __Terminal_readKey_k
  boop.pass "${__Terminal_readKey_k}" ${into:-}
}

# ============================================================================
# Named character lookup
# ============================================================================

# Return a named character from the symbol table.
# Usage: into=c $obj.char topLeft
Terminal.char() {
  local __Terminal_char_v="${__Terminal_chars[${1:-}]:-}"
  [[ -n "$__Terminal_char_v" ]] || { _Error "Terminal.char: unknown symbol '${1:-}'"; return 1; }
  boop.pass "$__Terminal_char_v" ${into:-}
}

# ============================================================================
# Registration
# ============================================================================

boopMixin Terminal \
  'public:clear,move,home,hideCursor,showCursor,bold,dim,italic,underline,reverse,reset,fg,bg,width,height,raw,restore,readKey,char'
