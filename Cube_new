#!/bin/bash

# Cube class - new dispatcher implementation

. Box_new

# ============================================================================
# Cube Class Descriptor
# ============================================================================

__bashClass_registry["Cube"]="|type=class|id=Cube|parent=Box|methods=new,side,top,end,bottom,volume|properties=size,length,width,height,unit"

# ============================================================================
# Cube Implementation Functions
# ============================================================================

# Cube constructor - sets all dimensions equal to size
__Cube.new() {
  local -I class
  : "${class:=Cube}"
  local size=1

  # Extract size from arguments
  for arg in "$@"; do
    [[ "$arg" =~ ^size=([0-9]+)$ ]] && size="${BASH_REMATCH[1]}"
  done

  # Delegate to base constructor with derived dimensions
  __bashClass.new "$@" length=$size width=$size height=$size
}

# Calculate side face area (all faces equal for cube)
__Cube.side() {
  local -I self class
  local size
  __bashClass.parse "$self" "size" size
  self="$self" class=Box __bashClass.dispatch area "$size" "$size"
}

# Top face (same as side for cube)
__Cube.top() {
  local -I self class
  self="$self" class="$class" __bashClass.dispatch side
}

# End face (same as side for cube)
__Cube.end() {
  local -I self class
  self="$self" class="$class" __bashClass.dispatch side
}

# Bottom face (same as side for cube)
__Cube.bottom() {
  local -I self class
  self="$self" class="$class" __bashClass.dispatch side
}

# Calculate volume
__Cube.volume() {
  local -I self class
  local size
  __bashClass.parse "$self" "size" size
  required=3 __Box.calc "$size" "$size" "$size"
}

# ============================================================================
# Register Methods
# ============================================================================

__bashClass.registerMethod Cube new __Cube.new
__bashClass.registerMethod Cube side __Cube.side
__bashClass.registerMethod Cube top __Cube.top
__bashClass.registerMethod Cube end __Cube.end
__bashClass.registerMethod Cube bottom __Cube.bottom
__bashClass.registerMethod Cube volume __Cube.volume
