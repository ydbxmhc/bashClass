#!/bin/bash

## boop - Modern OOP dispatch system for bash
##
## Provides secure, efficient method dispatch with multiple return modes
## and proper inheritance support.
##
## Usage:
##   . boop                    # load framework only
##   . boop Box Cube           # load framework + import classes

# ============================================================================
# SOURCED MODE — Framework definitions (once only)
# ============================================================================
if (( ! ${__boop_loaded:-0} )); then

# ============================================================================
# GLOBALS - Process State
# ============================================================================

# Captured at load time so boop.pass can detect subshells later.
# If BASHPID != this value at call time, we're in a subshell and auto mode
# switches to stdout (since globals can't escape a subshell boundary).
declare -gi __boop_rootPID=$BASHPID

# ============================================================================
# GLOBALS - Registries
# ============================================================================

# Master object/class store. Keys are object IDs (_a1b2c3) or class names (Box).
# Values are pipe-delimited descriptors: |class=Box|parent=boop|length=%33|...
# Classes and objects share this registry — distinguished by context, not type field.
declare -gA __boop_registry

# Method resolution cache. Keys are "ClassName.methodName", values are the
# implementing function name (e.g., "Box.volume" → "Box.volume" the function).
# Populated on first dispatch; inherited methods get cached under the calling
# class so the MRO walk only happens once per class+method pair.
declare -gA __boop_methodRegistry

# Explicit path overrides for class file resolution. If a class is registered
# here, __boop.import skips directory and PATH searches entirely.
# Usage: __boop_classPath["MyClass"]="/opt/lib/MyClass"
declare -gA __boop_classPath

# In-progress load tracker. Set to 1 while a class file is being sourced,
# cleared when done. Prevents circular recursion when a class file sources
# boop as part of its own dependency chain (e.g., Cube sources boop Box,
# Box sources boop — without this flag, boop would try to re-import Box
# mid-load and recurse until bash gives up).
declare -gA __boop_loading

# Function-level static storage. A flat associative array for any function
# to stash values between calls — memoization, cached intermediates,
# convergence state, lookup tables, whatever. Keyed by compound strings
# so each function owns its own namespace without polluting globals.
#
# Convention: keys are "FunctionName.varName" or "ClassName.method.varName".
# Functions read/write directly — no helper needed.
#
# Usage:
#   __boop_static["Math.arctan.cache_1_5"]="0.19739555984988..."
#   local cached="${__boop_static[Math.arctan.cache_1_5]:-}"
#   __boop_static["factorial.12"]="479001600"
#
# This lives in boop (not in a class file) because it's a framework-level
# facility. Any function in any class can use it. The data persists for
# the lifetime of the shell process.
declare -gA __boop_static

# ============================================================================
# GLOBALS - Configuration
# ============================================================================

# Controls how boop.pass delivers values when no explicit nameref
# target is provided. Modes: auto (global in main shell, stdout in subshell),
# nameref (requires target — crashes without one), stdout, global, filesystem.
# Can be overridden per-call via environment: _OutMode=stdout $obj.volume
declare -g _OutMode="${_OutMode:-auto}"

# Line ending appended to stdout output in boop.pass. When _OutMode is
# "stdout" (or "auto" in a subshell), this value is printed after the
# payload. Default is newline — set to empty string for raw output.
#
# Unquoted in the printf call so an empty value vanishes entirely
# (no trailing whitespace, no extra argument).
#
# Usage:
#   _EOL=$'\n'   # default — newline after each value (CLI-friendly)
#   _EOL=""      # raw — no trailing newline (pipe-friendly)
declare -g _EOL="${_EOL:-$'\n'}"

# Absolute path to the directory containing this framework file. Used as the
# second-priority search location for class imports (after __boop_classPath,
# before PATH). Resolved once at load time via realpath so symlinks don't fool it.
declare -g  __boop_dir="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
# TODO: See TODO.md "Reserved Variable Names & Inheritance Hygiene"

# TODO: See TODO.md "Configurable Baked-Wrapper Typecast Behavior"
# TODO: See TODO.md "Argument-Parsing Object"

# ============================================================================
# GLOBALS - Log Levels
# ============================================================================

# Numeric log levels. Higher = more verbose.
# Level 0 is reserved as a crash trigger — if __boop.log receives
# level 0 (e.g., from a missing/empty argument coerced by -i), it
# prints the message and exits. This catches accidental direct calls
# to __boop.log without a level argument.
#
# silent=-1: suppress everything (even errors — use with care)
# crash=0:   reserved — triggers immediate crash (see above)
# error=1:   fatal or near-fatal conditions
# warn=2:    unexpected but recoverable situations (default)
# info=3:    notable lifecycle events (object creation, class loading)
# debug=4:   detailed internal state for troubleshooting
# trace=5:   finest grain — descriptor dumps, dispatch steps, etc.
declare -gri __boop_LOG_SILENT=-1
declare -gri __boop_LOG_CRASH=0
declare -gri __boop_LOG_ERROR=1
declare -gri __boop_LOG_WARN=2
declare -gri __boop_LOG_INFO=3
declare -gri __boop_LOG_DEBUG=4
declare -gri __boop_LOG_TRACE=5

# Global default log level. Controls what gets emitted when no per-class
# override exists. Default is warn — errors and warnings show, info and
# below are silent.
declare -gi __boop_logLevel=$__boop_LOG_WARN

# Per-class log level overrides. Keyed by class name, values are numeric
# levels. When a class has an entry here, it (and its descendants, unless
# they have their own override) use this level instead of the global.
declare -gA __boop_classLogLevel

# Resolved log level cache. Keyed by class name, values are the numeric
# level that was resolved by walking the inheritance chain. Populated on
# first log call for a given class, cleared when setLogLevel changes
# anything in the chain.
declare -gA __boop_resolvedLogLevel

# Human-readable level names for output formatting.
declare -gA __boop_logLevelName=(
  [$__boop_LOG_SILENT]="SILENT" [$__boop_LOG_CRASH]="CRASH"  [$__boop_LOG_ERROR]="ERROR"
  [$__boop_LOG_WARN]="WARN"     [$__boop_LOG_INFO]="INFO"    [$__boop_LOG_DEBUG]="DEBUG"
  [$__boop_LOG_TRACE]="TRACE"
)

# Fallback log file. If stderr is unavailable (redirected to /dev/null,
# closed, etc.), log output goes here instead. Per-process PID suffix
# prevents concurrent sessions from stomping each other.
declare -g __boop_logFile="${TMPDIR:-/tmp}/boop_$$.log"

# ============================================================================
# GLOBALS - Return Values
# ============================================================================

# Side-channel for global return mode. When boop.pass is called
# without a nameref target and the mode resolves to "global", the value
# lands here. Callers read it after the call: $obj.volume; printf "%s" "$_Out"
# Intentionally a single flat global — keeps the API simple. If you need
# to capture a value without clobbering this, use into=varname instead.
declare -g  _Out="" # no dedicated method for this; no need

# ============================================================================
# GLOBALS - Initialization Flags
# ============================================================================

# Set to 1 at the bottom of this block. The outer guard (( ! __boop_loaded ))
# checks this so re-sourcing boop (e.g., from a class file's `. boop`) skips
# all definitions and jumps straight to the import-arguments section at the end.
declare -gi __boop_loaded=0

# ============================================================================
# UTILITY
# ============================================================================

# Unified crash handler. Prints a tagged message to stderr with optional
# stack trace, then exits. All output goes to stderr via `} >&2` on the
# function body — no per-line redirection needed.
#
# Caller controls all whitespace in the message, including newlines.
# `printf '%s'` with `$@` means each argument is concatenated literally —
# add $'\n' between arguments if you want line breaks.
#
# Inherited variables (Tier 2, via `local -I`):
#   _Err        — exit code (default: 1)
#   _StackTrace — number of stack frames to show (default: 1)
#                  0 = no trace, negative = show all frames
#
# Usage:
#   _Crash "something broke"
#   _Err=42 _Crash "custom exit code"
#   _StackTrace=-1 _Crash "full trace"
#   _Crash "line one" $'\n' "line two" $'\n'
_Crash() {
  local -I _Err _StackTrace
  printf '%s' '[CRASH] ' "$@" $'\n'
  (( _StackTrace = ${_StackTrace:- 1} ))
  (( _StackTrace < 0 )) && _StackTrace=${#FUNCNAME[@]}
  if (( _StackTrace > 0 )); then
    local -i i
    for (( i=1; i <= _StackTrace && i < ${#FUNCNAME[@]}; i++ )); do
      printf "  in %s (%s:%s)\n" "${FUNCNAME[$i]}" "${BASH_SOURCE[$i]}" "${BASH_LINENO[$i-1]}"
    done
  fi
  exit ${_Err:-1}
} >&2

# Returns 0 if the current execution context is a subshell (BASHPID differs
# from the root PID captured at framework load time). Used by auto return mode.
__boop.inSubshell() { [[ $BASHPID != $__boop_rootPID ]]; }

# ============================================================================
# LOGGING
# ============================================================================

# Resolve the effective log level for a class. Walks the inheritance chain
# looking for the first class with an explicit override in
# __boop_classLogLevel, falling back to the global default.
# Result is cached in __boop_resolvedLogLevel so the walk happens
# at most once per class (until invalidated by setLogLevel).
#
# Usage: __boop.resolveLogLevel "Math" __result_var
__boop.resolveLogLevel() {
  local __rlvl_class="$1" __rlvl_target="${2:-}"
  local __rlvl_result

  # Check cache first
  if [[ -n "${__boop_resolvedLogLevel[$__rlvl_class]+set}" ]]; then
    __rlvl_result="${__boop_resolvedLogLevel[$__rlvl_class]}"
  else
    # Walk inheritance chain
    local __rlvl_cursor="$__rlvl_class"
    __rlvl_result=""
    while [[ -n "$__rlvl_cursor" ]]; do
      if [[ -n "${__boop_classLogLevel[$__rlvl_cursor]+set}" ]]; then
        __rlvl_result="${__boop_classLogLevel[$__rlvl_cursor]}"
        break
      fi
      # Move to parent
      local __rlvl_parent=""
      if [[ -n "${__boop_registry[$__rlvl_cursor]+set}" ]]; then
        [[ "${__boop_registry[$__rlvl_cursor]}" =~ \|parent=([^|]*)\| ]] && \
          __rlvl_parent="${BASH_REMATCH[1]}"
      fi
      __rlvl_cursor="$__rlvl_parent"
    done
    # Fall back to global default
    [[ -z "$__rlvl_result" ]] && __rlvl_result=$__boop_logLevel
    # Cache it
    __boop_resolvedLogLevel[$__rlvl_class]=$__rlvl_result
  fi

  if [[ -n "$__rlvl_target" ]]; then
    printf -v "$__rlvl_target" '%s' "$__rlvl_result"
  else
    printf '%s' "$__rlvl_result"
  fi
}

# Core log function. Checks the resolved level for the current class
# (via inherited _Class) and emits to stderr if the message level is
# at or below the threshold. Bails immediately on cache hit when the
# level is too verbose — the hot path is one hash lookup + one compare.
#
# Usage (internal): __boop.log 2 "something unexpected"
# Users should use the public wrappers: _Warn, _Debug, etc.
__boop.log() {
  local -i __log_level=${1:-0}; shift    # numeric level; empty/missing → 0 → crash
  (( __log_level ==  0 )) && _Crash "$@" # level 0 = Crash; die loud, right now
  (( __log_level == -1 )) && return 0    # explicit silent; nothing to do
  [[ -n "${__boop_logLevelName[$__log_level]+set}" ]] || _Crash "invalid log level: '$__log_level'"
  local -I _Class                       # inherit caller's class context

  local __log_class="${_Class:-boop}"   # fall back to "boop" if no class in scope
  local -i __log_threshold

  # Hot path: one hash lookup. If the class's effective level is already
  # cached, grab it directly. Otherwise resolve by walking the inheritance
  # chain (caches the result for next time).
  if [[ -n "${__boop_resolvedLogLevel[$__log_class]+set}" ]]; then
    __log_threshold=${__boop_resolvedLogLevel[$__log_class]}
  else
    __boop.resolveLogLevel "$__log_class" __log_threshold
  fi

  # Message level exceeds threshold — nothing to print.
  (( __log_level > __log_threshold )) && return 0

  # Identify the real caller. FUNCNAME[0] is __boop.log, [1] is the
  # wrapper (_Warn, _Debug, etc.), [2] is who actually called the wrapper.
  # If [2] is one of our public wrappers, step one more frame to [3].
  local __log_caller="${FUNCNAME[2]:-main}"
  [[ "$__log_caller" =~ ^_(Error|Warn|Info|Debug|Trace)$ ]] &&
    __log_caller="${FUNCNAME[3]:-main}"

  # Format: [LEVEL] caller: message
  local __log_label="${__boop_logLevelName[$__log_level]:-LOG}"
  printf '[%s] %s: ' "$__log_label" "$__log_caller"
  printf '%s' "$@" $'\n'
} >&2

# Set log level. With one argument, sets the global default.
# With two arguments, sets a per-class override and invalidates
# the resolved cache for that class and all its descendants.
#
# Usage: __boop.setLogLevel warn          # global
#        __boop.setLogLevel debug Math     # per-class
__boop.setLogLevel() {
  local __slvl_name="$1" __slvl_class="${2:-}"
  local -i __slvl_num

  # Resolve name to number
  case "${__slvl_name,,}" in
    silent|-1) __slvl_num=$__boop_LOG_SILENT ;; error|1)  __slvl_num=$__boop_LOG_ERROR ;;
    warn|2)    __slvl_num=$__boop_LOG_WARN   ;; info|3)   __slvl_num=$__boop_LOG_INFO  ;;
    debug|4)   __slvl_num=$__boop_LOG_DEBUG  ;; trace|5)  __slvl_num=$__boop_LOG_TRACE ;;
    *) _Crash "Invalid log level: $__slvl_name (use: silent, error, warn, info, debug, trace)" ;;
  esac

  if [[ -z "$__slvl_class" ]]; then
    # Global default — clear entire resolved cache
    __boop_logLevel=$__slvl_num
    __boop_resolvedLogLevel=()
  else
    # Per-class override — set it and invalidate cache for this class
    # and any class whose resolved level might have been inherited from it
    __boop_classLogLevel[$__slvl_class]=$__slvl_num
    # Simple invalidation: clear the whole resolved cache. The walks
    # are cheap and only happen once after a level change.
    __boop_resolvedLogLevel=()
  fi
}

# ---------------------------------------------------------------------------
# Public convenience wrappers — the user-facing API
# ---------------------------------------------------------------------------

_Trace() { __boop.log $__boop_LOG_TRACE "$@"; }
_Debug() { __boop.log $__boop_LOG_DEBUG "$@"; }
_Info()  { __boop.log $__boop_LOG_INFO  "$@"; }
_Warn()  { __boop.log $__boop_LOG_WARN  "$@"; }
_Error() { __boop.log $__boop_LOG_ERROR "$@"; }

# _LogLevel: convenience wrapper for __boop.setLogLevel
_LogLevel() { __boop.setLogLevel "$@"; }

# ============================================================================
# UNIVERSAL RETURN HANDLER
# ============================================================================

# Every function that produces a value calls this as its last act.
# This is the single choke point for all value delivery in the framework.
# Respects _OutMode globally; auto mode uses context clues.
#
# When a nameref target ($2) is provided, it ALWAYS wins — the value is
# written directly into the caller's named variable via bash nameref,
# regardless of the global mode setting. This is the zero-copy fast path
# used by into=varname delegation chains.
#
# When no target is provided, the global mode governs:
#   auto       → global in main shell, stdout in subshell (detected via BASHPID)
#   global     → writes to _Out
#   stdout     → printf to stdout (natural for $() capture)
#   nameref    → crashes (target is required — this is intentional)
#   filesystem → writes to a temp file keyed by caller function name + PID
#
# Usage:
#   boop.pass "$value"              # uses global mode (auto default)
#   boop.pass "$value" target_var   # nameref — always direct write
boop.pass() {
  local __boop_pass_val="${1:-}" __boop_pass_target="${2:-}"
  local __boop_pass_mode="${_OutMode:-auto}"

  # If a nameref target is explicitly provided, always use it.
  if [[ -n "${__boop_pass_target:-}" ]]; then
    local -n __boop_pass_ref="$__boop_pass_target"
    __boop_pass_ref="${__boop_pass_val:-}"
    return
  fi
  if [[ "$__boop_pass_mode" == "auto" ]]; then
    [[ $BASHPID == $__boop_rootPID ]] && __boop_pass_mode="global" || __boop_pass_mode="stdout"
  fi
  case "$__boop_pass_mode" in
    nameref)    _Crash "nameref mode requires target variable" ;; # wouldn't be here if it had one!
    stdout)     printf "%s" "${__boop_pass_val:-}" ${_EOL:-}   ;; # with line ending if set
    global)     _Out="$__boop_pass_val"                        ;; # the fallback default
    filesystem)
      # TODO: boop.passPath from call stack introspection
      printf "%s" "$__boop_pass_val" >| "${__boop_tmpdir:-/tmp}/__boop_${FUNCNAME[1]}_$BASHPID"
      ;;
    *) _Crash "Invalid return mode: $__boop_pass_mode" ;;
  esac
}

# _OutMode — get or set the output delivery mode for boop.pass.
#
# Controls how boop.pass delivers values when no explicit into= target
# is provided. Works as both a variable and a function — you can't
# really get it wrong:
#
#   _OutMode            # print current mode
#   _OutMode stdout     # set mode and print it
#   _OutMode=stdout     # set mode directly (no output)
#   echo "$_OutMode"    # read mode directly
#
# Modes:
#   auto        default — global in main shell, stdout in subshells
#   global      always write to _Out (the default side-channel)
#   stdout      always print to stdout (good for CLI use)
#   nameref     requires into= — crashes without one
#   filesystem  write to temp file keyed by caller + PID
#
# Validation: invalid mode crashes immediately with a clear message
# rather than failing later inside boop.pass.
#
# Typically set once at the top of a script or in ~/.bash_profile:
#   _OutMode=stdout
#   _EOL=$'\n'
_OutMode() {
  if [[ -n "${1:-}" ]]; then
    case "$1" in auto|global|stdout|nameref|filesystem) _OutMode="$1"          ;;
    *) _Crash "invalid _OutMode: '$1' (auto|global|stdout|nameref|filesystem)" ;;
    esac
  fi
  boop.pass "$_OutMode"
}

# _EOL — get or set the line ending for stdout output.
#
# Appended after the payload in boop.pass stdout mode. Default is
# newline. Set to empty string for raw output (pipe-friendly).
#
# Works as both a variable and a function:
#   _EOL              # print current value, set _EOL to itself
#   _EOL $'\n'        # set to newline
#   _EOL ""           # clear (no trailing newline)
#   _EOL=""           # clear directly (no output)
#   into=x _EOL       # read into x without side effects
#
# Uses ${1-$_EOL} (no colon) so empty string passes through as a
# valid value, while no argument falls back to the current setting.
_EOL() { boop.pass "${1-$_EOL}" ${into:-_EOL}; } 

# ============================================================================
# VALUE ENCODING/DECODING
# ============================================================================

# Fast encode: escapes the five characters that would break pipe-delimited
# descriptor storage. Uses bash parameter expansion (no subshell, no fork).
#
# ORDER MATTERS: percent must be encoded FIRST. If pipes were encoded first,
# the literal "|" becomes "%7C" — then the percent pass would re-encode the
# "%" in "%7C" to "%257C", corrupting the value. Percent-first ensures the
# escape character itself is safe before anything else touches it.
# Handles: % | = newline tab
__boop.encode() {
  local __encode_val="$1"
  __encode_val="${__encode_val//%/%25}"
  __encode_val="${__encode_val//|/%7C}"
  __encode_val="${__encode_val//=/%3D}"
  __encode_val="${__encode_val//$'\n'/%0A}"
  __encode_val="${__encode_val//$'\t'/%09}"
  boop.pass "$__encode_val" "${2:-}"
}

# Fast decode: reverses encode. Uses bash parameter expansion (no subshell).
#
# ORDER MATTERS: percent must be decoded LAST — the mirror image of encode.
# If percent were decoded first, "%257C" would become "%7C", and then the
# pipe pass would decode that to "|", producing a value that was never there.
# By decoding percent last, we guarantee that only sequences we encoded are
# restored, and user data containing literal "%7C" survives the round-trip.
__boop.decode() {
  local __decode_val="$1"
  __decode_val="${__decode_val//%09/$'\t'}"
  __decode_val="${__decode_val//%0A/$'\n'}"
  __decode_val="${__decode_val//%3D/=}"
  __decode_val="${__decode_val//%7C/|}"
  __decode_val="${__decode_val//%25/%}"
  boop.pass "$__decode_val" "${2:-}"
}

# ============================================================================
# VALIDATION
# ============================================================================

# Polymorphic input validator. Rejects anything that isn't a safe identifier
# or function name, depending on the type= typecast. This is the front door
# for every user-supplied name that touches eval, registries, or dispatch.
# Validate and reject — never sanitize and proceed.
#
# In identifier mode (default): allows [A-Za-z_][A-Za-z0-9_]* — no dots.
# In function mode: allows dots in the name (e.g., "Box.calc", "boop.pass")
# because bash functions can contain dots, and our dispatch system relies on them.
#
# The type= typecast uses `local -l` for case-insensitive matching, so
# type=Function, type=FUNCTION, and type=function all work. A misspelled
# typecast (e.g., typ=function) silently falls through to identifier mode
# because the unrecognized variable doesn't set `type` — this is correct
# behavior (strictest validation wins by default).
#
# Usage: __boop.validate "Box"                     # identifier (default)
#        type=function __boop.validate "Box.calc"  # function name (dots ok)
__boop.validate() {
  local __validate_pat; local -l type; : "${type:=identifier}"
  case $type in
    func|function) __validate_pat='^[A-Za-z_][A-Za-z0-9_.]*$' ;;
    *)             __validate_pat='^[A-Za-z_][A-Za-z0-9_]*$' ;;
  esac
  [[ "$1" =~ $__validate_pat ]] || _Crash "Invalid $type: '$1'"
}

# ============================================================================
# CONFIGURATION
# ============================================================================

# Set global default return mode. Affects all subsequent calls to
# boop.pass that don't have an explicit nameref target.
# This is a process-wide setting — use with intention.
__boop.setDefaultMode() {
  case "$1" in
    auto|nameref|stdout|global|filesystem) _OutMode="$1" ;;
    *) _Crash "Invalid mode: $1 (use: auto, nameref, stdout, global, filesystem)" ;;
  esac
}

# ============================================================================
# PARSING & DATA ACCESS
# ============================================================================

# Extract a single field from a pipe-delimited descriptor string.
# The descriptor format is: |field1=value1|field2=value2|...
# Values are stored encoded (via __boop.encode); this function
# decodes them before returning.
#
# Accepts an optional $3 nameref target for zero-copy extraction.
# If the field doesn't exist, returns empty string (not an error —
# missing properties are a normal condition, not a crash).
#
# The regex pattern anchors on the leading pipe to avoid partial matches:
# searching for "id" won't accidentally match "grid" because the pipe
# delimiter guarantees field-name boundaries.
#
# Usage:
#   value=$(__boop.parse "Box" "parent")           # stdout (subshell)
#   __boop.parse "Box" "parent" my_var             # nameref (no subshell)
#   _OutMode=global __boop.parse ... # global variable
__boop.parse() {
  local __parse_key="$1" __parse_field="$2" __parse_target="${3:-}"

  __boop.validate "$__parse_key"

  local __parse_descriptor="${__boop_registry[$__parse_key]:-}"
  local __parse_pattern="\\|${__parse_field}=([^|]*)"
  local __parse_value=""
  if [[ "$__parse_descriptor" =~ $__parse_pattern ]]; then
    __boop.decode "${BASH_REMATCH[1]}" __parse_value
  fi

  boop.pass "$__parse_value" "$__parse_target"
}

# ============================================================================
# METHOD REGISTRY
# ============================================================================

# Register a method implementation in the method registry.
# Maps "ClassName.methodName" → "implementingFunctionName" so dispatch
# can resolve calls. The implementing function must already exist (declared
# via `declare -f`) at registration time — no forward declarations.
#
# Arguments:
#   $1 — class name (identifier)
#   $2 — method name (identifier)
#   $3 — implementing function name (optional; defaults to "$1.$2")
#
# All names are validated: class as identifier, method as identifier,
# impl as function (dots allowed). This is the only way methods enter the
# registry, so validation here protects every downstream dispatch.
__boop.registerMethod() {
  local __regmethod_class="$1" __regmethod_method="$2"
  local __regmethod_impl="${3:-$1.$2}"

  __boop.validate "$__regmethod_class"
  __boop.validate "$__regmethod_method"
  type=function __boop.validate "$__regmethod_impl"

  declare -f "$__regmethod_impl" >/dev/null || _Crash "Function '$__regmethod_impl' does not exist"

  __boop_methodRegistry["$__regmethod_class.$__regmethod_method"]="$__regmethod_impl"
}

# ============================================================================
# METHOD DISPATCH
# ============================================================================

# Unified dispatcher with inheritance support, MRO caching, and lazy baking.
#
# Resolution: checks __boop_methodRegistry for "class.method" first (O(1)).
# On cache miss, walks the parent chain via descriptor "parent" fields until
# it finds a registered implementation, then caches the result under the
# original class so the walk never happens again for that pair.
#
# Lazy baking: when called with __init=true (set by stub functions), dispatch
# evals a baked wrapper onto $self that calls the resolved implementation
# directly on all future invocations — no dispatch overhead after first call.
# The baked wrapper includes a typecast guard: if the caller overrides _Class=
# (e.g., _Class=Box $cube.volume), the wrapper detects the mismatch and falls
# back to full dispatch so the typecast resolves correctly. This means normal
# calls are fast (direct function call) and typecasts always work (dispatch).
__boop.dispatch() {
  local _Self="${_Self:-${_Class:-boop}}" _Class="${_Class:-boop}"
  local -l __init; : "${__init:=false}"
  local __dispatch_method="$1"; shift

  __boop.validate "$_Self"
  __boop.validate "$_Class"
  __boop.validate "$__dispatch_method"

  # Check cache first (direct lookup — O(1) in the common case)
  local __dispatch_cachekey="$_Class.$__dispatch_method"
  local __dispatch_impl="${__boop_methodRegistry[$__dispatch_cachekey]:-}"

  # Cache miss: walk the inheritance chain (parent → grandparent → ...).
  # When found in an ancestor, cache it under the calling class so this
  # walk only happens once per class+method combination.
  if [[ -z "$__dispatch_impl" ]]; then
    local __dispatch_current="$_Class"
    while [[ -n "$__dispatch_current" ]]; do
      __dispatch_impl="${__boop_methodRegistry[$__dispatch_current.$__dispatch_method]:-}"
      if [[ -n "$__dispatch_impl" ]]; then
        [[ "$__dispatch_current" != "$_Class" ]] && __boop_methodRegistry[$__dispatch_cachekey]="$__dispatch_impl"
        break
      fi
      __boop.parse "$__dispatch_current" "parent" __dispatch_current
    done
  fi

  [[ -n "$__dispatch_impl" ]] || _Crash "Method not found: $_Class.$__dispatch_method"

  # If called from a stub (__init=true), bake a direct wrapper that replaces
  # the stub function. The baked wrapper hardcodes self, class, and the
  # resolved impl — no dispatch overhead on subsequent calls.
  #
  # TYPECAST vs LEAKAGE DETECTION (three-tier):
  #
  # The baked wrapper must handle three cases when the ambient class
  # differs from the baked class:
  #
  #   1. Exact match (common case): ambient class == baked class, or no
  #      ambient class at all. Use the fast path — direct function call
  #      with hardcoded self/class/impl. Zero dispatch overhead.
  #
  #   2. Family member: ambient class is in the baked class's inheritance
  #      chain (e.g., _Class=FaceCard on a Card object). This is a
  #      legitimate typecast — let dispatch resolve the method via MRO
  #      starting from the ambient class.
  #
  #   3. Unrelated class: ambient class is NOT in the family tree (e.g.,
  #      _Class=Hand leaking into a Card method via local -I in a Hand
  #      method). This is leakage — ignore it and use the fast path.
  #      See TODO above for future configurable behavior (warn/strict).
  #
  # EVAL ESCAPING NOTES:
  #
  # At eval time, $_Self, $_Class, $__dispatch_impl, and $__dispatch_method
  # expand to their current values and get hardcoded into the wrapper.
  # \$ and \"-quoted expansions survive eval and expand at runtime instead.
  #
  #   "${_Class:-Card}".isa Card
  #    ^^^^^^^^^^^^^^^^ — runtime expansion: ambient class, defaulting to baked
  #                    — quotes force word boundary so .isa isn't swallowed
  #                         ^^^^ — hardcoded at eval time
  if [[ "$__init" == "true" ]]; then
    eval "$_Self.$__dispatch_method() {
      # Tier 1: exact match or no ambient class — fast path (common case)
      if [[ \"\${_Class:-$_Class}\" == '$_Class' ]]; then
        _Self='$_Self' _Class='$_Class' $__dispatch_impl \"\$@\"
      # Tier 2: ambient class is in the family — legitimate typecast
      #   Check: is this object an instance of the ambient class?
      #   Covers both upcasts (_Class=Box on a Cube) and downcasts.
      #   Uses __boop.isa directly to avoid triggering dispatch
      #   recursion through the baked wrapper system.
      elif _Self='$_Self' _Class='$_Class' __boop.isa \"\${_Class:-$_Class}\"; then
        _Self='$_Self' _Class=\"\${_Class:-$_Class}\" __boop.dispatch $__dispatch_method \"\$@\"
      # Tier 3: unrelated class (leakage) — warn and use fast path
      else
        _Class='$_Class' _Warn \"class leakage: \\\"\${_Class}\\\" is unrelated to $_Class in $_Self.$__dispatch_method — using $_Class\"
        _Self='$_Self' _Class='$_Class' $__dispatch_impl \"\$@\"
      fi
    }"
  fi

  _Self="$_Self" _Class="$_Class" "$__dispatch_impl" "$@"
}

# ============================================================================
# SERIALIZATION
# ============================================================================

# Dump the entire registry to a tab-delimited file. Each line is:
#   key<TAB>descriptor
# where key is an object ID or class name and descriptor is the raw
# pipe-delimited string. This captures the full state of all objects
# and class definitions. Does NOT serialize baked wrapper functions —
# those are regenerated on next access via the stub/bake mechanism.
__boop.serialize() {
  local __serialize_file="${1:-objects.dat}"
  for __serialize_key in "${!__boop_registry[@]}"; do
    printf "%s\t%s\n" "$__serialize_key" "${__boop_registry[$__serialize_key]}"
  done > "$__serialize_file"
}

# Load a previously serialized registry from a tab-delimited file.
# Each key is validated before insertion to prevent injection from
# tampered data files. Existing registry entries with the same key
# are overwritten — last write wins.
# NOTE: This restores descriptor data only. Object wrapper functions
# (stubs/baked) are NOT recreated — call __boop.stubAll or
# __boop.refresh on each object after deserializing if you need
# to call methods on them.
__boop.deserialize() {
  local __deserialize_file="${1:-objects.dat}"
  [[ -f "$__deserialize_file" ]] || _Crash "File not found: $__deserialize_file"
  local __deserialize_key __deserialize_descriptor
  while IFS=$'\t' read -r __deserialize_key __deserialize_descriptor; do
    __boop.validate "$__deserialize_key"
    __boop_registry[$__deserialize_key]="$__deserialize_descriptor"
  done < "$__deserialize_file"
}

# ============================================================================
# STANDARD INTERFACE METHODS (inherited by all classes)
# ============================================================================

# Retrieve a property value from the object's descriptor.
# Delegates to parse, which handles decoding and return routing.
# The ${into:-} passes through the caller's nameref target (if any)
# so the value lands directly in their variable without touching the global.
__boop.get() {
  local -I _Self _Class
  __boop.parse "$_Self" "$1" ${into:-}
}

# Update a property value in the object's descriptor.
# The new value is encoded before storage (pipes, equals, percents, etc.
# are escaped so they don't corrupt the delimiter structure).
#
# If the property already exists, its value is replaced in-place via
# regex match + string substitution on the descriptor. If it doesn't
# exist, it's appended to the end. This means property order in the
# descriptor reflects insertion order, with mutations preserving position.
__boop.set() {
  local -I _Self _Class
  local __set_prop="$1" __set_encoded
  __boop.encode "$2" __set_encoded

  local __set_descriptor="${__boop_registry[$_Self]:-}"

  if [[ "$__set_descriptor" =~ \|${__set_prop}=[^|]* ]]; then
    local __set_old="${BASH_REMATCH[0]}"
    __boop_registry[$_Self]="${__set_descriptor/${__set_old}/|${__set_prop}=${__set_encoded}}"
  else
    __boop_registry[$_Self]="$__set_descriptor|$__set_prop=$__set_encoded"
  fi
}

# Type checking with ancestry walk.
# No args: returns the object's class name (via boop.pass).
# With arg: walks the inheritance chain and returns 0 (true) if the
# object's class matches or inherits from the queried class, 1 (false)
# otherwise. The walk follows "parent" fields in class descriptors
# up to the root (boop, whose parent is empty string).
#
# Note: isa with a query does NOT call boop.pass — it
# communicates via exit code only (0/1), which is the bash convention
# for boolean checks: `$obj.isa Box && printf "it's a box"`
__boop.isa() {
  local -I _Self _Class
  local __isa_query="${1:-}"

  if [[ -z "$__isa_query" ]]; then
    boop.pass "$_Class" ${into:-}
    return 0
  fi

  local __isa_current="$_Class"
  while [[ -n "$__isa_current" ]]; do
    [[ "$__isa_current" == "$__isa_query" ]] && return 0
    __boop.parse "$__isa_current" "parent" __isa_current
  done
  return 1
}

# Format an object's descriptor for human-readable display.
# Skips internal metadata fields (class, parent, methods, properties)
# and shows only user-defined properties.
#
# Compact mode (default): single-line format
#   Box(_a1b2c3){ length=5 width=3 height=7 }
#
# Pretty mode: columnar with newlines, field names right-padded for
# alignment. Two-pass: first pass measures max field name length,
# second pass formats with printf %-Ns alignment.
#
# Pretty mode is activated by either:
#   $obj.toString pretty          # positional argument
#   prettyPrint=true $obj.toString # typecast (uses local -l for case-insensitive match)
#
# Usage: $obj.toString                    # compact one-liner
#        $obj.toString pretty             # columnar with newlines
#        prettyPrint=true $obj.toString    # same, via environment
__boop.toString() {
  local -I _Self _Class
  local -l prettyPrint; : "${prettyPrint:=false}"
  [[ "${1:-}" == "pretty" ]] && prettyPrint=true
  local __ts_descriptor="${__boop_registry[$_Self]:-}"
  local __ts_field __ts_value __ts_decoded __ts_output

  # Both modes iterate the descriptor by matching "|key=value" segments,
  # then advancing past the match with ${__ts_descriptor#*"${BASH_REMATCH[0]}"}
  # to consume the string left-to-right without a second regex pass.

  if [[ "$prettyPrint" != "true" ]]; then
    __ts_output="$_Class($_Self){"
    while [[ "$__ts_descriptor" =~ \|([^=]+)=([^|]*) ]]; do
      __ts_field="${BASH_REMATCH[1]}"
      __ts_value="${BASH_REMATCH[2]}"
      case "$__ts_field" in
        class|parent|methods|properties) ;;
        *)
          __boop.decode "$__ts_value" __ts_decoded
          __ts_output="$__ts_output $__ts_field=$__ts_decoded"
          ;;
      esac
      __ts_descriptor="${__ts_descriptor#*"${BASH_REMATCH[0]}"}"
    done
    boop.pass "$__ts_output }" ${into:-}
    return
  fi

  # Pretty print: two-pass for columnar alignment
  local -i __ts_maxlen=0
  local -a __ts_keys=() __ts_vals=()
  while [[ "$__ts_descriptor" =~ \|([^=]+)=([^|]*) ]]; do
    __ts_field="${BASH_REMATCH[1]}"
    __ts_value="${BASH_REMATCH[2]}"
    case "$__ts_field" in
      class|parent|methods|properties) ;;
      *)
        __boop.decode "$__ts_value" __ts_decoded
        __ts_keys+=("$__ts_field")
        __ts_vals+=("$__ts_decoded")
        (( ${#__ts_field} > __ts_maxlen )) && __ts_maxlen=${#__ts_field} || true
        ;;
    esac
    __ts_descriptor="${__ts_descriptor#*"${BASH_REMATCH[0]}"}"
  done

  local -i __ts_i
  printf -v __ts_output "%s(%s) {\n" "$_Class" "$_Self"
  for (( __ts_i=0; __ts_i < ${#__ts_keys[@]}; __ts_i++ )); do
    printf -v __ts_field "  %-${__ts_maxlen}s = %s\n" "${__ts_keys[$__ts_i]}" "${__ts_vals[$__ts_i]}"
    __ts_output="$__ts_output$__ts_field"
  done
  __ts_output="$__ts_output}"

  boop.pass "$__ts_output" ${into:-}
}

# Object constructor. This is the beating heart of object creation.
#
# 1. Generates a unique object ID from EPOCHREALTIME (hex-encoded
#    microseconds — fast, no subshell, monotonically increasing).
# 2. Builds a pipe-delimited descriptor from the class name and any
#    key=value arguments, encoding values for safe storage.
# 3. Registers the descriptor in __boop_registry.
# 4. Generates lazy stubs for all methods and property accessors via
#    __boop.stubAll. Stubs are tiny eval'd functions that call
#    dispatch with __init=true on first use, triggering the bake
#    mechanism that replaces them with direct wrappers.
#
# Arguments are key=value pairs. Duplicate keys are allowed — both
# end up in the descriptor, but get/parse will match the first one.
# (This is documented behavior, not a bug.)
__boop.new() {
  local -I _Class; : "${_Class:=boop}"

  # Generate unique object ID
  local _Self; printf -v _Self "_%x" "${EPOCHREALTIME//.}"

  # Build descriptor
  local __new_descriptor="|class=$_Class"

  # Parse arguments and encode values.
  # If a key already exists in the descriptor (e.g., a subclass passes
  # length= after the caller already passed length=), replace in-place
  # so parse always finds the correct value. Same logic as set().
  local __new_encoded __new_prop __new_val
  for __new_arg in "$@"; do
    IFS='=' read -r __new_prop __new_val <<< "$__new_arg"
    __boop.encode "$__new_val" __new_encoded
    if [[ "$__new_descriptor" =~ \|${__new_prop}=[^|]* ]]; then
      __new_descriptor="${__new_descriptor/${BASH_REMATCH[0]}/|${__new_prop}=${__new_encoded}}"
    else
      __new_descriptor="$__new_descriptor|$__new_prop=$__new_encoded"
    fi
  done

  # Register object
  __boop_registry[$_Self]="$__new_descriptor"

  # Generate lazy stubs for all methods (walk inheritance chain)
  __boop.stubAll "$_Self" "$_Class"

  boop.pass "$_Self" ${into:-}
}

# Call a method on the parent class. Looks up the current class's parent
# from its descriptor and re-dispatches with the parent as the class context.
# Crashes if the class has no parent (you're already at the root — nowhere to go).
# Usage: _Self=$obj _Class=Cube __boop.dispatch super volume
__boop.super() {
  local -I _Self _Class
  local __super_parent; __boop.parse "$_Class" "parent" __super_parent
  [[ -n "$__super_parent" ]] || _Crash "$_Class has no parent"
  _Self="$_Self" _Class="$__super_parent" __boop.dispatch "$@"
}

# ============================================================================
# STUB GENERATION & CLASS REGISTRATION
# ============================================================================

# Generate lazy stubs for all methods and property accessors on an object.
# Walks the full inheritance chain so inherited methods get stubs too.
#
# Method stubs: tiny eval'd functions that call dispatch with __init=true.
# On first invocation, dispatch resolves the method via MRO and bakes a
# direct wrapper that replaces the stub. Cost: one eval per method at
# object creation time, one dispatch on first call, then zero overhead.
#
# Property stubs: dual-purpose get/set accessors. Called with no args,
# they dispatch to "get" with the property name. Called with one arg,
# they dispatch to "set". This gives you $obj.length (get) and
# $obj.length 42 (set) syntax.
#
# Pass "force" as $3 to overwrite existing functions — used by refresh
# to tear down baked wrappers and re-stub everything.
__boop.stubAll() {
  local __stub_self="$1" __stub_class="$2" __stub_force="${3:-}"
  local __stub_current="$__stub_class" __stub_method __stub_methods

  # Walk inheritance chain, stub all methods
  while [[ -n "$__stub_current" ]]; do
    __boop.parse "$__stub_current" "methods" __stub_methods
    IFS=',' read -ra __stub_method_list <<< "$__stub_methods"
    for __stub_method in "${__stub_method_list[@]}"; do
      [[ -n "$__stub_method" ]] || continue
      [[ "$__stub_force" != "force" ]] && declare -f "$__stub_self.$__stub_method" >/dev/null && continue
      eval "$__stub_self.$__stub_method() { __init=true _Self='$__stub_self' _Class='$__stub_class' __boop.dispatch $__stub_method \"\$@\"; }"
    done
    __boop.parse "$__stub_current" "parent" __stub_current
  done

  # Stub property accessors (get/set by property name)
  local __stub_props __stub_prop
  __boop.parse "$__stub_class" "properties" __stub_props
  IFS=',' read -ra __stub_prop_list <<< "$__stub_props"
  for __stub_prop in "${__stub_prop_list[@]}"; do
    [[ -n "$__stub_prop" ]] || continue
    [[ "$__stub_force" != "force" ]] && declare -f "$__stub_self.$__stub_prop" >/dev/null && continue
    eval "$__stub_self.$__stub_prop() {
      if ((\$#)); then _Self='$__stub_self' _Class='$__stub_class' __boop.dispatch set '$__stub_prop' \"\$1\"
      else _Self='$__stub_self' _Class='$__stub_class' __boop.dispatch get '$__stub_prop'; fi
    }"
  done
}

# Re-stub all methods on an existing object. Tears down baked wrappers
# and replaces them with fresh stubs. The next call to any method will
# re-resolve via dispatch and re-bake. Useful after modifying the method
# registry at runtime (e.g., monkey-patching a method implementation).
__boop.refresh() {
  local __refresh_self="$1"
  local __refresh_class; __boop.parse "$__refresh_self" "class" __refresh_class
  [[ -n "$__refresh_class" ]] || _Crash "Cannot refresh: no class for '$__refresh_self'"
  __boop.stubAll "$__refresh_self" "$__refresh_class" force
}

# Finalize a class definition. Call this at the bottom of a class file
# after all method functions are defined and registered.
#
# What it does:
# 1. Walks the inheritance chain collecting all method names.
# 2. For each method, creates a ClassName.method() wrapper that dispatches
#    with the class hardcoded. These wrappers let you call Box.volume()
#    as a class-level method (useful for static-style calls and as the
#    target of __boop.registerMethod).
# 3. If the class name itself isn't already a function, creates a
#    constructor shorthand: Box() { _Class=Box __boop.dispatch new "$@"; }
#    This enables the clean `Box length=5 width=3 height=7` syntax.
#
# Methods already defined by the class author (e.g., Box.calc as a real
# function) take priority — registerClass will NOT overwrite them. This
# lets class authors provide custom implementations that bypass dispatch
# when called directly.
__boop.registerClass() {
  local __regclass_class="$1"
  __boop.validate "$__regclass_class"

  [[ -n "${__boop_registry[$__regclass_class]:-}" ]] || \
    _Crash "No descriptor for class '$__regclass_class' — register it first"

  local __regclass_current="$__regclass_class" __regclass_method __regclass_methods

  # Walk inheritance chain, create ClassName.method wrappers
  while [[ -n "$__regclass_current" ]]; do
    __boop.parse "$__regclass_current" "methods" __regclass_methods
    IFS=',' read -ra __regclass_method_list <<< "${__regclass_methods:-}"
    for __regclass_method in "${__regclass_method_list[@]}"; do
      [[ -n "$__regclass_method" ]] || continue
      # Don't overwrite — class author's definitions take priority
      declare -f "$__regclass_class.$__regclass_method" >/dev/null && continue
      eval "$__regclass_class.$__regclass_method() { _Class='$__regclass_class' __boop.dispatch $__regclass_method \"\$@\"; }"
    done
    __boop.parse "$__regclass_current" "parent" __regclass_current
  done

  # Make the class name itself a constructor
  declare -f "$__regclass_class" >/dev/null || \
    eval "$__regclass_class() { _Class='$__regclass_class' __boop.dispatch new \"\$@\"; }"
}

# Global convenience constructor. Slightly friendlier than the class-as-
# constructor syntax for people who prefer explicit "new" semantics.
# Validates the class name, then delegates to dispatch.
# Usage: new Box length=5 width=3 height=7
#        into=mybox new Cube size=4
new() {
  local __new_class="$1"; shift
  __boop.validate "$__new_class"
  _Class="$__new_class" __boop.dispatch new "$@"
}

# ============================================================================
# CLASS IMPORT
# ============================================================================

# Resolve and source a class file. Iterates each argument as a class name
# and sources the corresponding file into the current shell.
#
# Resolution order (first match wins):
#   1. __boop_classPath registry — explicit path overrides set by the user
#   2. __boop_dir — the directory where boop itself lives (co-located classes)
#   3. PATH — via the . (source) builtin's native search behavior
#
# Load guards (two layers):
#   - __boop_registry[ClassName]+set — class already fully loaded, skip entirely.
#   - __boop_loading[ClassName] — class is mid-load (its file is currently being
#     sourced). This prevents circular recursion: Cube's file sources `. boop Box`,
#     Box's file sources `. boop`, boop re-enters import for Box — the loading flag
#     catches this and skips, letting the original load complete.
#
# The loading flag is unset after each successful source. If the source fails
# (exit code != 0), we crash — a half-loaded class is worse than no class.
__boop.import() {
  local __import_class
  for __import_class in "$@"; do
    # Already loaded? Skip.
    [[ -n "${__boop_registry[$__import_class]+set}" ]] && continue

    # Already loading? Skip (prevents circular recursion when a class
    # file sources boop as part of its own load sequence).
    [[ -n "${__boop_loading[$__import_class]:-}" ]] && continue
    __boop_loading[$__import_class]=1

    # Check explicit path registry first
    if [[ -n "${__boop_classPath[$__import_class]:-}" ]]; then
      . "${__boop_classPath[$__import_class]}" || \
        _Crash "Failed to load class '$__import_class' from ${__boop_classPath[$__import_class]}"
      unset '__boop_loading[$__import_class]'
      continue
    fi

    # Check __boop_dir (co-located with framework)
    if [[ -f "$__boop_dir/$__import_class" ]]; then
      . "$__boop_dir/$__import_class" || \
        _Crash "Failed to load class '$__import_class' from $__boop_dir"
      unset '__boop_loading[$__import_class]'
      continue
    fi

    # Fall through to PATH resolution
    . "$__import_class" 2>/dev/null || \
      _Crash "Class '$__import_class' not found (checked classPath, $__boop_dir, PATH)"
    unset '__boop_loading[$__import_class]'
  done
}

# ============================================================================
# REGISTER BASE CLASS
# ============================================================================

# boop is the root of all inheritance. Every class ultimately inherits
# from it (parent chain terminates at boop's empty parent field).
# The standard methods registered here (get, set, isa, toString, new, super)
# are available to all objects unless overridden by a subclass.
__boop_registry["boop"]="|class=boop|parent=|methods=new,get,set,isa,toString,super|properties="
__boop.registerMethod boop get __boop.get
__boop.registerMethod boop set __boop.set
__boop.registerMethod boop isa __boop.isa
__boop.registerMethod boop toString __boop.toString
__boop.registerMethod boop new __boop.new
__boop.registerMethod boop super __boop.super
__boop.registerClass boop

# ============================================================================
# INITIALIZATION COMPLETE
# ============================================================================
__boop_loaded=1

fi  # end of (( ! __boop_loaded ))

# ============================================================================
# IMPORT ARGUMENTS — always processed, even on subsequent sources
# ============================================================================
# This block runs OUTSIDE the __boop_loaded guard. When a class file
# does `. boop Box`, the framework definitions are skipped (already loaded),
# but this block still runs and imports Box. This is the mechanism that lets
# class files declare dependencies via their source line.
if (( $# )); then
  __boop.import "$@"
fi
