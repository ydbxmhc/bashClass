#!/bin/bash
# Run all tests in order: smoke first, then unit, then integration.
# A smoke failure short-circuits the rest — no point running unit tests
# if the framework itself is broken.
# Exit with nonzero if any suite or check fails.

rc=0

# ============================================================================
# Smoke — framework alive?
# ============================================================================
printf '\ntest_smoke...\n'
./test_smoke || { printf '\n  SMOKE FAILED — aborting remaining tests\n'; exit 1; }

# ============================================================================
# Unit tests
# ============================================================================
for f in test_testsuite_ts test_box_cube_ts test_containers_ts \
          test_logging_ts test_math_ts; do
  printf '\n%s\n' "$f..."
  "./$f" || rc=1
done

# ============================================================================
# Integration / adversarial tests
# ============================================================================
for f in test_stress_ts test_blackjack; do
  printf '\n%s\n' "$f..."
  "./$f" || rc=1
done

# ============================================================================
# Naming convention compliance check
#
# All local variables in class/framework functions must use the
# __ClassName_methodName_varname convention. This grep catches any
# double-underscore-lowercase prefix that isn't a known class or
# framework name.
#
# Excluded (compliant):
#   __boop_ __boop\. __Crash_ __Container_ __Iterator_ __Iter_
#   __List_ __Map_ __Math_ __Box_ __Cube_ __Card_ __Deck_
#   __PlayingCard_ __TestSuite_ __BJ_ __FC_ __boopClass_ __init
#   Lines starting with # (comments)
# ============================================================================
printf '\nnaming convention check...\n'
__nc_files="boop Box Cube Card PlayingCard Deck Container List Map Math TestSuite blackjack"
__nc_exclude='__boop_\|__boop\.\|__Crash_\|__Container_\|__Iterator_\|__Iter_\|__List_\|__Map_\|__Math_\|__Box_\|__Cube_\|__Card_\|__Deck_\|__PlayingCard_\|__TestSuite_\|__BJ_\|__FC_\|__boopClass_\|__init'
__nc_hits=$(grep -rn '__[a-z]\+_' $__nc_files 2>/dev/null | grep -v "$__nc_exclude" | grep -v '#')
if [[ -n "$__nc_hits" ]]; then
  printf '  FAIL: non-compliant variable names found:\n%s\n' "$__nc_hits"
  rc=1
else
  printf '  PASS: all variable names follow convention\n'
fi

exit $rc
