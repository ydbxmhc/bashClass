#!/bin/bash

# Card, FaceCard, Ace — playing card classes

[[ -n "${__boop_registry[Card]+set}" ]] && return 2>/dev/null

. boop

# ═════════════════════════════════════════════════════════════════════
# Card — base playing card
# ═════════════════════════════════════════════════════════════════════

__boop_registry["Card"]="|class=Card|parent=boop\
|methods=new,flip,val,toString\
|properties=suit,rank,faceUp"

Card.new() {
  local -I _Class; : "${_Class:=Card}"
  local __Card_new_self __Card_new_suit="" __Card_new_rank="" __Card_new_faceUp=0
  for __Card_new_arg in "$@"; do
    case "$__Card_new_arg" in
      suit=*)   __Card_new_suit="${__Card_new_arg#suit=}" ;;
      rank=*)   __Card_new_rank="${__Card_new_arg#rank=}" ;;
      faceUp=*) __Card_new_faceUp="${__Card_new_arg#faceUp=}" ;;
    esac
  done
  [[ -n "$__Card_new_suit" ]] || __boop.crash "Card: suit= is required"
  [[ -n "$__Card_new_rank" ]] || __boop.crash "Card: rank= is required"
  into=__Card_new_self __boop.new suit="$__Card_new_suit" rank="$__Card_new_rank" faceUp="$__Card_new_faceUp"
  __boop.return "$__Card_new_self" ${into:-}
}

Card.flip() {
  local -I _Self _Class
  local __Card_flip_fu; __boop.parse "$_Self" "faceUp" __Card_flip_fu
  if [[ "$__Card_flip_fu" == "1" ]]; then
    $_Self.set faceUp 0
  else
    $_Self.set faceUp 1
  fi
}

Card.val() {
  local -I _Self _Class
  local __Card_val_rank; __boop.parse "$_Self" "rank" __Card_val_rank
  case "$__Card_val_rank" in
    [2-9]) __boop.return "$__Card_val_rank" ${into:-} ;;
    10)    __boop.return "10" ${into:-} ;;
    *)     __boop.return "0" ${into:-} ;;
  esac
}

Card.toString() {
  local -I _Self _Class
  local __Card_ts_fu; __boop.parse "$_Self" "faceUp" __Card_ts_fu
  if [[ "$__Card_ts_fu" != "1" ]]; then
    __boop.return "[?]" ${into:-}
    return
  fi
  local __Card_ts_rank __Card_ts_suit
  __boop.parse "$_Self" "rank" __Card_ts_rank
  __boop.parse "$_Self" "suit" __Card_ts_suit
  __boop.return "${__Card_ts_rank}${__Card_ts_suit}" ${into:-}
}

__boop.registerMethod Card new      Card.new
__boop.registerMethod Card flip     Card.flip
__boop.registerMethod Card val      Card.val
__boop.registerMethod Card toString Card.toString
__boop.registerClass Card

# ═════════════════════════════════════════════════════════════════════
# FaceCard extends Card — J, Q, K are always worth 10
# ═════════════════════════════════════════════════════════════════════

__boop_registry["FaceCard"]="|class=FaceCard|parent=Card\
|methods=new,val\
|properties=suit,rank,faceUp"

FaceCard.new() {
  local -I _Class; _Class=FaceCard; Card.new "$@"
}

FaceCard.val() {
  local -I _Self _Class
  __boop.return "10" ${into:-}
}

__boop.registerMethod FaceCard new FaceCard.new
__boop.registerMethod FaceCard val FaceCard.val
__boop.registerClass FaceCard

# ═════════════════════════════════════════════════════════════════════
# Ace extends Card — worth 11 (Hand adjusts to 1 when bust)
# ═════════════════════════════════════════════════════════════════════

__boop_registry["Ace"]="|class=Ace|parent=Card\
|methods=new,val\
|properties=suit,rank,faceUp"

Ace.new() {
  local -I _Class; _Class=Ace; Card.new "$@"
}

Ace.val() {
  local -I _Self _Class
  __boop.return "11" ${into:-}
}

__boop.registerMethod Ace new Ace.new
__boop.registerMethod Ace val Ace.val
__boop.registerClass Ace
