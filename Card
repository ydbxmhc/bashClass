#!/bin/bash

# Card — generic card base class
#
# A card is just a bag of properties. No game logic, no assumptions
# about what a card contains. Subclasses add domain-specific behavior.

[[ -n "${__boop_registry[Card]+set}" ]] && return 2>/dev/null

. boop

Card.new() {
  local _Class="${_Class:-Card}"
  local __Card_new_self
  into=__Card_new_self __boop.new "$@"
  boop.pass "$__Card_new_self" ${into:-}
}

Card.toString() {
  local _Self="${_Self:-${Class:-Card}}" _Class="${_Class:-Card}"
  boop.pass "$_Self" ${into:-}
}

boopClass Card public:new,toString
