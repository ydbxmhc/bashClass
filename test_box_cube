#!/bin/bash
set -u

# Test the new Box and Cube implementations with full interface

. boop Cube

printf "=== Box and Cube Interface Tests ===\n\n"

# ============================================================================
# Test 1: Box creation and property access (old dispatch syntax)
# ============================================================================

printf "Test 1: Create Box with dimensions 5x3x7 (dispatch syntax)\n"
class=Box __bashClass.dispatch new length=5 width=3 height=7
box="$__bashClass_RETURN"
printf "  Created: %s\n" "$box"

# Property accessors via dotted syntax
$box.get length; printf "  Length: %s\n" "$__bashClass_RETURN"
$box.get width;  printf "  Width:  %s\n" "$__bashClass_RETURN"
$box.get height; printf "  Height: %s\n" "$__bashClass_RETURN"

# Shorthand property access (get/set by property name)
$box.length; printf "  Length (shorthand): %s\n" "$__bashClass_RETURN"

printf "\n  Calculations:\n"
$box.top;    printf "    Top area:    %s (expected: 15)\n" "$__bashClass_RETURN"
$box.end;    printf "    End area:    %s (expected: 21)\n" "$__bashClass_RETURN"
$box.side;   printf "    Side area:   %s (expected: 35)\n" "$__bashClass_RETURN"
$box.bottom; printf "    Bottom area: %s (expected: 15)\n" "$__bashClass_RETURN"
$box.volume; printf "    Volume:      %s (expected: 105)\n" "$__bashClass_RETURN"

# ============================================================================
# Test 2: Cube creation and calculations
# ============================================================================

printf "\nTest 2: Create Cube with size 4\n"
class=Cube __bashClass.dispatch new size=4 unit=cm
cube="$__bashClass_RETURN"
printf "  Created: %s\n" "$cube"

$cube.size; printf "  Size: %s\n" "$__bashClass_RETURN"
$cube.unit; printf "  Unit: %s\n" "$__bashClass_RETURN"

printf "\n  Calculations:\n"
$cube.side;   printf "    Side area: %s (expected: 16)\n" "$__bashClass_RETURN"
$cube.top;    printf "    Top area:  %s (expected: 16)\n" "$__bashClass_RETURN"
$cube.volume; printf "    Volume:    %s (expected: 64)\n" "$__bashClass_RETURN"

# ============================================================================
# Test 3: isa - type checking
# ============================================================================

printf "\nTest 3: Type checking (isa)\n"
$cube.isa;      printf "  Cube.isa:      %s (expected: Cube)\n" "$__bashClass_RETURN"
$cube.isa Cube  && printf "  isa Cube:      true\n"  || printf "  isa Cube:      false\n"
$cube.isa Box   && printf "  isa Box:       true\n"  || printf "  isa Box:       false\n"
$cube.isa bashClass && printf "  isa bashClass: true\n" || printf "  isa bashClass: false\n"
$cube.isa String && printf "  isa String:    true\n"  || printf "  isa String:    false\n"

# ============================================================================
# Test 4: set - property mutation
# ============================================================================

printf "\nTest 4: Property mutation (set)\n"
$box.length;  printf "  Box length before: %s\n" "$__bashClass_RETURN"
$box.length 10
$box.length;  printf "  Box length after:  %s (expected: 10)\n" "$__bashClass_RETURN"
$box.volume;  printf "  Box volume after:  %s (expected: 210)\n" "$__bashClass_RETURN"

# ============================================================================
# Test 5: toString (compact and pretty)
# ============================================================================

printf "\nTest 5: toString\n"
$cube.toString; printf "  Cube: %s\n" "$__bashClass_RETURN"
$box.toString;  printf "  Box:  %s\n" "$__bashClass_RETURN"
printf "\n  Pretty (arg):\n"
$cube.toString pretty; printf "%s\n" "$__bashClass_RETURN"
printf "  Pretty (env):\n"
prettyPrint=true $box.toString; printf "%s\n" "$__bashClass_RETURN"

# ============================================================================
# Test 6: Inheritance (MRO)
# ============================================================================

printf "\nTest 6: Inheritance\n"
# Cube should inherit get/set from bashClass
$cube.get size; printf "  Cube.get size: %s (expected: 4)\n" "$__bashClass_RETURN"

# ============================================================================
# Test 7: Multiple objects
# ============================================================================

printf "\nTest 7: Multiple objects\n"
class=Box __bashClass.dispatch new length=2 width=2 height=2
box1="$__bashClass_RETURN"

class=Box __bashClass.dispatch new length=10 width=5 height=3
box2="$__bashClass_RETURN"

class=Cube __bashClass.dispatch new size=3
cube1="$__bashClass_RETURN"

$box1.volume;  printf "  Box1 volume:  %s (expected: 8)\n" "$__bashClass_RETURN"
$box2.volume;  printf "  Box2 volume:  %s (expected: 150)\n" "$__bashClass_RETURN"
$cube1.volume; printf "  Cube1 volume: %s (expected: 27)\n" "$__bashClass_RETURN"

# ============================================================================
# Test 8: Typecasting
# ============================================================================

printf "\nTest 8: Typecasting\n"
$cube.volume; printf "  Cube volume (as Cube): %s (expected: 64)\n" "$__bashClass_RETURN"
class=Box $cube.volume; printf "  Cube volume (as Box):  %s (expected: 64)\n" "$__bashClass_RETURN"

# ============================================================================
# Test 9: Value encoding (special characters)
# ============================================================================

printf "\nTest 9: Value encoding\n"
class=Box __bashClass.dispatch new length=5 width=3 height=7
enc_box="$__bashClass_RETURN"
$enc_box.set color "red|green=blue"
$enc_box.get color; printf "  Pipes and equals:    '%s' (expected: 'red|green=blue')\n" "$__bashClass_RETURN"
$enc_box.set color "100%"
$enc_box.get color; printf "  Single percent:      '%s' (expected: '100%%')\n" "$__bashClass_RETURN"
$enc_box.set color "100%%"
$enc_box.get color; printf "  Double percent:      '%s' (expected: '100%%%%')\n" "$__bashClass_RETURN"
$enc_box.set color "line1
line2"
$enc_box.get color; printf "  Newlines:            '%s' (expected: 'line1\\nline2')\n" "$__bashClass_RETURN"
$enc_box.set color "col1	col2"
$enc_box.get color; printf "  Tabs:                '%s' (expected: 'col1\\tcol2')\n" "$__bashClass_RETURN"

# ============================================================================
# Test 10: Binary-safe encoding (bencode/bdecode)
# ============================================================================

printf "\nTest 10: Binary-safe encoding\n"
__bashClass.bencode "hello|world=foo%bar"
printf "  Encoded: %s\n" "$__bashClass_RETURN"
__bashClass.bdecode "$__bashClass_RETURN"
printf "  Decoded: '%s' (expected: 'hello|world=foo%%bar')\n" "$__bashClass_RETURN"

# Test file encoding via typecast
printf "binary\x00data\x01here" > /tmp/test_binary.dat
input=file __bashClass.bencode /tmp/test_binary.dat
encoded_file="$__bashClass_RETURN"
printf "  File encoded: %s\n" "$encoded_file"
__bashClass.bdecode "$encoded_file"
printf "  File round-trip: '%s' (expected: 'binary...data...here')\n" "$__bashClass_RETURN"
rm -f /tmp/test_binary.dat

# ============================================================================
# Test 11: Global `new` convenience function
# ============================================================================

printf "\nTest 11: Global new function\n"
new Box length=6 width=4 height=2
nbox="$__bashClass_RETURN"
printf "  Created: %s\n" "$nbox"
$nbox.volume; printf "  Volume: %s (expected: 48)\n" "$__bashClass_RETURN"
$nbox.length;  printf "  Length: %s (expected: 6)\n" "$__bashClass_RETURN"

new Cube size=5
ncube="$__bashClass_RETURN"
printf "  Created: %s\n" "$ncube"
$ncube.volume; printf "  Volume: %s (expected: 125)\n" "$__bashClass_RETURN"
$ncube.isa Cube && printf "  isa Cube: true\n" || printf "  isa Cube: false\n"

# ============================================================================
# Test 12: Class-as-constructor
# ============================================================================

printf "\nTest 12: Class-as-constructor\n"
Box length=8 width=2 height=3
cbox="$__bashClass_RETURN"
printf "  Created: %s\n" "$cbox"
$cbox.volume; printf "  Volume: %s (expected: 48)\n" "$__bashClass_RETURN"

Cube size=7
ccube="$__bashClass_RETURN"
printf "  Created: %s\n" "$ccube"
$ccube.volume; printf "  Volume: %s (expected: 343)\n" "$__bashClass_RETURN"
$ccube.isa Box && printf "  isa Box: true\n" || printf "  isa Box: false\n"

# ============================================================================
# Test 13: Lazy stub baking (verify stubs get replaced)
# ============================================================================

printf "\nTest 13: Lazy stub baking\n"
new Box length=3 width=3 height=3
sbox="$__bashClass_RETURN"

# First call — stub dispatches, bakes direct wrapper
$sbox.volume; printf "  First call:  %s (expected: 27)\n" "$__bashClass_RETURN"

# Second call — baked wrapper, no dispatch
$sbox.volume; printf "  Second call: %s (expected: 27)\n" "$__bashClass_RETURN"

# Verify the baked function exists and is NOT a stub anymore
declare -f "$sbox.volume" | head -1
printf "  Baked wrapper exists: %s\n" "$(declare -f "$sbox.volume" >/dev/null && printf 'yes' || printf 'no')"

# ============================================================================
# Test 14: Typecast with baked wrapper (dispatch fallback)
# ============================================================================

printf "\nTest 14: Typecast with baked wrapper\n"
new Cube size=3
tcast="$__bashClass_RETURN"

# Normal call — bakes as Cube
$tcast.volume; printf "  As Cube: %s (expected: 27)\n" "$__bashClass_RETURN"

# Typecast to Box — should fall back to dispatch
class=Box $tcast.volume; printf "  As Box:  %s (expected: 27)\n" "$__bashClass_RETURN"

# Normal call again — baked wrapper should still work
$tcast.volume; printf "  As Cube again: %s (expected: 27)\n" "$__bashClass_RETURN"

printf "\n=== All Tests Complete ===\n"
