#!/bin/bash

# Cube class

# Load guard — if already registered, nothing to do
[[ -n "${__boop_registry[Cube]+set}" ]] && return 2>/dev/null

. boop Box

# ============================================================================
# Cube Implementation Functions
# ============================================================================

# Cube constructor - sets all dimensions equal to size
Cube.new() {
  local _Class="${_Class:-Cube}"
  local __Cube_new_size="" __Cube_new_self

  # Extract size from arguments
  for __Cube_new_arg in "$@"; do
    if [[ "$__Cube_new_arg" =~ ^size= ]]; then
      [[ "$__Cube_new_arg" =~ ^size=([0-9]+)$ ]] || \
        _Crash "Cube: size requires a positive integer, got '$__Cube_new_arg'"
      __Cube_new_size="${BASH_REMATCH[1]}"
    fi
  done

  [[ -n "$__Cube_new_size" ]] || _Crash "Cube: size is required"

  # Delegate to base constructor with derived dimensions
  into=__Cube_new_self __boop.new "$@" size=$__Cube_new_size length=$__Cube_new_size width=$__Cube_new_size height=$__Cube_new_size
  boop.pass "$__Cube_new_self" ${into:-}
}

# Calculate side face area (all faces equal for cube)
Cube.side() {
  local _Self="${_Self:-${_Class:-Cube}}" _Class="${_Class:-Cube}"
  local __Cube_side_size __Cube_side_val
  into=__Cube_side_size $_Self.size
  into=__Cube_side_val $_Self.area "$__Cube_side_size" "$__Cube_side_size"
  boop.pass "$__Cube_side_val" ${into:-}
}

# all faces same as side for cube
Cube.top    () { local _Self="${_Self:-${_Class:-Cube}}" _Class="${_Class:-Cube}"; $_Self.side; }
Cube.end    () { local _Self="${_Self:-${_Class:-Cube}}" _Class="${_Class:-Cube}"; $_Self.side; }
Cube.bottom () { local _Self="${_Self:-${_Class:-Cube}}" _Class="${_Class:-Cube}"; $_Self.side; }

# Calculate volume
Cube.volume() {
  local _Self="${_Self:-${_Class:-Cube}}" _Class="${_Class:-Cube}"
  local __Cube_volume_size __Cube_volume_vol
  into=__Cube_volume_size $_Self.size
  into=__Cube_volume_vol required=3 $_Self.calc "$__Cube_volume_size" "$__Cube_volume_size" "$__Cube_volume_size"
  boop.pass "$__Cube_volume_vol" ${into:-}
}

# ============================================================================
# Class Declaration
# ============================================================================

boopClass Cube isa:Box has:size
   
