#!/bin/bash

# Cube class

# Load guard — if already registered, nothing to do
[[ -n "${__boop_registry[Cube]+set}" ]] && return 2>/dev/null

. boop Box

# ============================================================================
# Cube Class Descriptor
# ============================================================================

__boop_registry["Cube"]="|class=Cube|parent=Box|methods=new,side,top,end,bottom,volume|properties=size,length,width,height,unit"

# ============================================================================
# Cube Implementation Functions
# ============================================================================

# Cube constructor - sets all dimensions equal to size
Cube.new() {
  local -I _Class
  : "${_Class:=Cube}"
  local __Cube_new_size="" __Cube_new_self

  # Extract size from arguments
  for __Cube_new_arg in "$@"; do
    if [[ "$__Cube_new_arg" =~ ^size= ]]; then
      [[ "$__Cube_new_arg" =~ ^size=([0-9]+)$ ]] || \
        _Crash "Cube: size requires a positive integer, got '$__Cube_new_arg'"
      __Cube_new_size="${BASH_REMATCH[1]}"
    fi
  done

  [[ -n "$__Cube_new_size" ]] || _Crash "Cube: size is required"

  # Delegate to base constructor with derived dimensions
  into=__Cube_new_self __boop.new "$@" size=$__Cube_new_size length=$__Cube_new_size width=$__Cube_new_size height=$__Cube_new_size
  boop.pass "$__Cube_new_self" ${into:-}
}

# Calculate side face area (all faces equal for cube)
Cube.side() {
  local -I _Self _Class
  local __Cube_side_size __Cube_side_val
  __boop.parse "$_Self" "size" __Cube_side_size
  into=__Cube_side_val _Self="$_Self" _Class=Box __boop.dispatch area "$__Cube_side_size" "$__Cube_side_size"
  boop.pass "$__Cube_side_val" ${into:-}
}

# Top face (same as side for cube)
Cube.top() {
  local -I _Self _Class
  local __Cube_top_val
  into=__Cube_top_val _Self="$_Self" _Class="$_Class" __boop.dispatch side
  boop.pass "$__Cube_top_val" ${into:-}
}

# End face (same as side for cube)
Cube.end() {
  local -I _Self _Class
  local __Cube_end_val
  into=__Cube_end_val _Self="$_Self" _Class="$_Class" __boop.dispatch side
  boop.pass "$__Cube_end_val" ${into:-}
}

# Bottom face (same as side for cube)
Cube.bottom() {
  local -I _Self _Class
  local __Cube_bottom_val
  into=__Cube_bottom_val _Self="$_Self" _Class="$_Class" __boop.dispatch side
  boop.pass "$__Cube_bottom_val" ${into:-}
}

# Calculate volume
Cube.volume() {
  local -I _Self _Class
  local __Cube_volume_size __Cube_volume_vol
  __boop.parse "$_Self" "size" __Cube_volume_size
  into=__Cube_volume_vol required=3 Box.calc "$__Cube_volume_size" "$__Cube_volume_size" "$__Cube_volume_size"
  boop.pass "$__Cube_volume_vol" ${into:-}
}

# ============================================================================
# Register Methods & Finalize
# ============================================================================

__boop.registerMethod Cube new Cube.new
__boop.registerMethod Cube side Cube.side
__boop.registerMethod Cube top Cube.top
__boop.registerMethod Cube end Cube.end
__boop.registerMethod Cube bottom Cube.bottom
__boop.registerMethod Cube volume Cube.volume
__boop.registerClass Cube
