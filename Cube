#!/bin/bash

# Cube class

# Load guard — if already registered, nothing to do
[[ -n "${__bashClass_registry[Cube]+set}" ]] && return 2>/dev/null

. boop Box

# ============================================================================
# Cube Class Descriptor
# ============================================================================

__bashClass_registry["Cube"]="|class=Cube|parent=Box|methods=new,side,top,end,bottom,volume|properties=size,length,width,height,unit"

# ============================================================================
# Cube Implementation Functions
# ============================================================================

# Cube constructor - sets all dimensions equal to size
Cube.new() {
  local -I class
  : "${class:=Cube}"
  local __Cube_new_size=1 __Cube_new_self

  # Extract size from arguments
  for __Cube_new_arg in "$@"; do
    [[ "$__Cube_new_arg" =~ ^size=([0-9]+)$ ]] && __Cube_new_size="${BASH_REMATCH[1]}"
  done

  # Delegate to base constructor with derived dimensions
  into=__Cube_new_self __bashClass.new "$@" length=$__Cube_new_size width=$__Cube_new_size height=$__Cube_new_size
  __bashClass.return "$__Cube_new_self" ${into:-}
}

# Calculate side face area (all faces equal for cube)
Cube.side() {
  local -I self class
  local __Cube_side_size __Cube_side_val
  __bashClass.parse "$self" "size" __Cube_side_size
  into=__Cube_side_val self="$self" class=Box __bashClass.dispatch area "$__Cube_side_size" "$__Cube_side_size"
  __bashClass.return "$__Cube_side_val" ${into:-}
}

# Top face (same as side for cube)
Cube.top() {
  local -I self class
  local __Cube_top_val
  into=__Cube_top_val self="$self" class="$class" __bashClass.dispatch side
  __bashClass.return "$__Cube_top_val" ${into:-}
}

# End face (same as side for cube)
Cube.end() {
  local -I self class
  local __Cube_end_val
  into=__Cube_end_val self="$self" class="$class" __bashClass.dispatch side
  __bashClass.return "$__Cube_end_val" ${into:-}
}

# Bottom face (same as side for cube)
Cube.bottom() {
  local -I self class
  local __Cube_bottom_val
  into=__Cube_bottom_val self="$self" class="$class" __bashClass.dispatch side
  __bashClass.return "$__Cube_bottom_val" ${into:-}
}

# Calculate volume
Cube.volume() {
  local -I self class
  local __Cube_volume_size __Cube_volume_vol
  __bashClass.parse "$self" "size" __Cube_volume_size
  into=__Cube_volume_vol required=3 Box.calc "$__Cube_volume_size" "$__Cube_volume_size" "$__Cube_volume_size"
  __bashClass.return "$__Cube_volume_vol" ${into:-}
}

# ============================================================================
# Register Methods & Finalize
# ============================================================================

__bashClass.registerMethod Cube new Cube.new
__bashClass.registerMethod Cube side Cube.side
__bashClass.registerMethod Cube top Cube.top
__bashClass.registerMethod Cube end Cube.end
__bashClass.registerMethod Cube bottom Cube.bottom
__bashClass.registerMethod Cube volume Cube.volume
__bashClass.registerClass Cube
