#!/bin/bash

. Box_new

echo "Root PID: $__bashClass_rootPID"
echo "Current BASHPID: $BASHPID"

# Create box
class=Box __bashClass.dispatch new length=5 width=3 height=7
box="$__bashClass_RETURN"
echo "Box: $box"

# Check registry
echo "Registry entry: ${__bashClass_registry[$box]}"

# Try parsing with nameref
echo ""
echo "Parsing with nameref:"
__bashClass.parse "$box" "length" length
echo "Length variable: '$length'"

# Try parsing with stdout
echo ""
echo "Parsing with stdout:"
length_stdout=$(__bashClass.parse "$box" "length")
echo "Length stdout: '$length_stdout'"
