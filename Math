#!/bin/bash

# Math — arbitrary precision arithmetic via string-based digit math.
#
# Numbers are stored as strings of digits with a tracked sign and decimal
# position. All arithmetic is done digit-by-digit using bash's native
# $(( )) on small chunks. No forks, no subshells, no external tools.
# Precision is bounded only by available memory.
#
# Internal representation (in the descriptor):
#   digits = string of digits, no leading zeros (except "0" itself)
#   scale  = number of digits after the decimal point
#   neg    = 0 (positive/zero) or 1 (negative)
#
# Global precision controls how many significant digits operations like
# division produce before stopping. Overridable per-call via the
# precision= typecast. Rounding of the last digit is on by default
# but can be disabled globally or per-call via round=0.
#
# Higher-level functions (arctan, pi) are series expansions built on
# the same add/sub/mul/div primitives. They converge to the configured
# precision and return.
#
# This is grade-school math executed by a computer. Long addition with
# carry, long multiplication with partial products, long division one
# digit at a time. Anyone who can do it with pencil and paper already
# understands the algorithms.

# Load guard
[[ -n "${__boop_registry[Math]+set}" ]] && return 2>/dev/null

. boop

# ============================================================================
# Global Precision Configuration
# ============================================================================

# Default significant digits for operations that can produce infinite
# results (division, trig, pi). Exact operations (add, sub, mul) are
# not affected unless explicitly rounded via $m.round.
declare -gi __Math_precision=20

# Set global precision. Affects all subsequent inexact operations.
__Math.setPrecision() { __Math_precision=$1; }

# ============================================================================
# Math Class Descriptor
# ============================================================================

__boop_registry["Math"]="|class=Math|parent=boop|methods=new,add,sub,subtract,mul,multiply,div,divide,mod,pow,square,abs,neg,eq,lt,gt,le,ge,cmp,round,toInt,toScale,format,val,toString,isZero|properties=digits,scale,neg"


# ============================================================================
# Native integer fast path
# ============================================================================
# When both operands fit in bash's 64-bit signed integer range, we skip
# the string engine entirely and use $(( )). This is ~100x faster for
# small numbers. The string engine is the fallback for big numbers.
#
# Safe digit counts (conservative, accounting for intermediate values):
#   add/sub: both operands ≤ 18 digits (result ≤ 19, still fits)
#   mul:     combined digits ≤ 18 (product fits in 64-bit)
#   div:     dividend after scale padding ≤ 18 digits
#   mod:     same as add/sub (operands ≤ 18)
#   pow:     checked per-iteration (result can grow fast)
declare -gi __Math_FAST_DIGITS=18

# Convert a digits/scale/neg triple to a signed bash integer.
# Returns 0 (success) or 1 (too large). Result via nameref $4.
__Math.toInt64() {
  local __Math_toInt64_d="$1"
  local -i __Math_toInt64_s="$2" __Math_toInt64_n="$3"
  local -n __Math_toInt64_out="$4"
  (( ${#__Math_toInt64_d} > __Math_FAST_DIGITS )) && return 1
  # Reconstruct the scaled integer: digits IS the scaled integer
  # (e.g., digits="314" scale=2 means the integer 314 represents 3.14)
  __Math_toInt64_out=$(( __Math_toInt64_n ? -( 10#$__Math_toInt64_d ) : 10#$__Math_toInt64_d ))
  return 0
}

# Convert a signed bash integer + scale back to digits/scale/neg triple.
# Result via namerefs $3, $4, $5.
__Math.fromInt64() {
  local -i __Math_fromInt64_val="$1" __Math_fromInt64_scale="$2"
  local -n __Math_fromInt64_od="$3" __Math_fromInt64_os="$4" __Math_fromInt64_on="$5"
  __Math_fromInt64_os=$__Math_fromInt64_scale
  if (( __Math_fromInt64_val < 0 )); then
    __Math_fromInt64_on=1
    __Math_fromInt64_od="${__Math_fromInt64_val#-}"
  else
    __Math_fromInt64_on=0
    __Math_fromInt64_od="$__Math_fromInt64_val"
  fi
  # Strip leading zeros
  __Math_fromInt64_od="${__Math_fromInt64_od#"${__Math_fromInt64_od%%[!0]*}"}"
  : "${__Math_fromInt64_od:=0}"
  [[ "$__Math_fromInt64_od" == "0" ]] && __Math_fromInt64_on=0
}


# ============================================================================
# Internal string math engine
# ============================================================================
# These __Math.str* functions operate on raw digit strings (no sign, no
# decimal point). The caller is responsible for sign handling and decimal
# tracking. This keeps the core engine simple and composable.
#
# Digit strings are stored big-endian: "314159" means 3,1,4,1,5,9 from
# most significant to least significant. Leading zeros are stripped on
# output (except for the value "0" itself).
#
# CHUNKED ARITHMETIC: To minimize bash overhead, add/sub/mul process
# 9 digits at a time. Each chunk fits in a 64-bit integer, and
# chunk × chunk (up to 999999999 × 999999999 = ~9.99e17) also fits.
# This gives roughly 81x fewer $(( )) calls for multiply compared to
# single-digit processing.

# Chunk size for bulk operations. 9 digits per chunk, base 10^9.
declare -gi __Math_CHUNK=9
declare -gi __Math_BASE=1000000000

# Compare two unsigned digit strings numerically.
# Returns via exit code: 0 if equal, 1 if A > B, 2 if A < B.
__Math.strCmp() {
  local __Math_strCmp_a="$1" __Math_strCmp_b="$2"
  # Pad shorter string to match length in one shot via printf
  local -i __Math_strCmp_la=${#__Math_strCmp_a} __Math_strCmp_lb=${#__Math_strCmp_b}
  if (( __Math_strCmp_la < __Math_strCmp_lb )); then
    local -i __Math_strCmp_need=$(( __Math_strCmp_lb - __Math_strCmp_la ))
    local __Math_strCmp_pad
    printf -v __Math_strCmp_pad "%0${__Math_strCmp_need}d" 0
    __Math_strCmp_a="${__Math_strCmp_pad}${__Math_strCmp_a}"
  elif (( __Math_strCmp_lb < __Math_strCmp_la )); then
    local -i __Math_strCmp_need=$(( __Math_strCmp_la - __Math_strCmp_lb ))
    local __Math_strCmp_pad
    printf -v __Math_strCmp_pad "%0${__Math_strCmp_need}d" 0
    __Math_strCmp_b="${__Math_strCmp_pad}${__Math_strCmp_b}"
  fi
  [[ "$__Math_strCmp_a" == "$__Math_strCmp_b" ]] && return 0
  [[ "$__Math_strCmp_a" > "$__Math_strCmp_b" ]] && return 1
  return 2
}

# Add two unsigned digit strings. Chunked: processes 9 digits at a time.
__Math.strAdd() {
  local __Math_iAdd_a="$1" __Math_iAdd_b="$2"
  local -n __Math_iAdd_result="$3"

  # Pad to same length, then to chunk boundary — all in one shot
  local -i __Math_iAdd_la=${#__Math_iAdd_a} __Math_iAdd_lb=${#__Math_iAdd_b} __Math_iAdd_maxlen __Math_iAdd_padlen
  (( __Math_iAdd_maxlen = __Math_iAdd_la > __Math_iAdd_lb ? __Math_iAdd_la : __Math_iAdd_lb ))
  # Round up to next chunk boundary
  (( __Math_iAdd_padlen = (__Math_iAdd_maxlen + __Math_CHUNK - 1) / __Math_CHUNK * __Math_CHUNK ))
  if (( __Math_iAdd_la < __Math_iAdd_padlen )); then
    local -i __Math_iAdd_need=$(( __Math_iAdd_padlen - __Math_iAdd_la ))
    local __Math_iAdd_zeros
    printf -v __Math_iAdd_zeros "%0${__Math_iAdd_need}d" 0
    __Math_iAdd_a="${__Math_iAdd_zeros}${__Math_iAdd_a}"
  fi
  if (( __Math_iAdd_lb < __Math_iAdd_padlen )); then
    local -i __Math_iAdd_need=$(( __Math_iAdd_padlen - __Math_iAdd_lb ))
    local __Math_iAdd_zeros
    printf -v __Math_iAdd_zeros "%0${__Math_iAdd_need}d" 0
    __Math_iAdd_b="${__Math_iAdd_zeros}${__Math_iAdd_b}"
  fi

  local -i __Math_iAdd_carry=0 __Math_iAdd_pos __Math_iAdd_len=${#__Math_iAdd_a} __Math_iAdd_sum
  local __Math_iAdd_fmt
  __Math_iAdd_result=""
  for (( __Math_iAdd_pos = __Math_iAdd_len - __Math_CHUNK; __Math_iAdd_pos >= 0; __Math_iAdd_pos -= __Math_CHUNK )); do
    __Math_iAdd_sum=$(( 10#${__Math_iAdd_a:__Math_iAdd_pos:__Math_CHUNK} + 10#${__Math_iAdd_b:__Math_iAdd_pos:__Math_CHUNK} + __Math_iAdd_carry ))
    __Math_iAdd_carry=$(( __Math_iAdd_sum / __Math_BASE ))
    printf -v __Math_iAdd_fmt "%09d" $(( __Math_iAdd_sum % __Math_BASE ))
    __Math_iAdd_result="${__Math_iAdd_fmt}${__Math_iAdd_result}"
  done
  (( __Math_iAdd_carry )) && __Math_iAdd_result="${__Math_iAdd_carry}${__Math_iAdd_result}"
  __Math_iAdd_result="${__Math_iAdd_result#"${__Math_iAdd_result%%[!0]*}"}"
  : "${__Math_iAdd_result:=0}"
}

# Subtract two unsigned digit strings (A - B). Assumes A >= B. Chunked.
__Math.strSub() {
  local __Math_iSub_a="$1" __Math_iSub_b="$2"
  local -n __Math_iSub_result="$3"

  # Pad to same length, then to chunk boundary — all in one shot
  local -i __Math_iSub_la=${#__Math_iSub_a} __Math_iSub_lb=${#__Math_iSub_b} __Math_iSub_maxlen __Math_iSub_padlen
  (( __Math_iSub_maxlen = __Math_iSub_la > __Math_iSub_lb ? __Math_iSub_la : __Math_iSub_lb ))
  (( __Math_iSub_padlen = (__Math_iSub_maxlen + __Math_CHUNK - 1) / __Math_CHUNK * __Math_CHUNK ))
  if (( __Math_iSub_la < __Math_iSub_padlen )); then
    local -i __Math_iSub_need=$(( __Math_iSub_padlen - __Math_iSub_la ))
    local __Math_iSub_zeros
    printf -v __Math_iSub_zeros "%0${__Math_iSub_need}d" 0
    __Math_iSub_a="${__Math_iSub_zeros}${__Math_iSub_a}"
  fi
  if (( __Math_iSub_lb < __Math_iSub_padlen )); then
    local -i __Math_iSub_need=$(( __Math_iSub_padlen - __Math_iSub_lb ))
    local __Math_iSub_zeros
    printf -v __Math_iSub_zeros "%0${__Math_iSub_need}d" 0
    __Math_iSub_b="${__Math_iSub_zeros}${__Math_iSub_b}"
  fi

  local -i __Math_iSub_borrow=0 __Math_iSub_pos __Math_iSub_len=${#__Math_iSub_a} __Math_iSub_diff
  local __Math_iSub_fmt
  __Math_iSub_result=""
  for (( __Math_iSub_pos = __Math_iSub_len - __Math_CHUNK; __Math_iSub_pos >= 0; __Math_iSub_pos -= __Math_CHUNK )); do
    __Math_iSub_diff=$(( 10#${__Math_iSub_a:__Math_iSub_pos:__Math_CHUNK} - 10#${__Math_iSub_b:__Math_iSub_pos:__Math_CHUNK} - __Math_iSub_borrow ))
    if (( __Math_iSub_diff < 0 )); then
      (( __Math_iSub_diff += __Math_BASE ))
      __Math_iSub_borrow=1
    else
      __Math_iSub_borrow=0
    fi
    printf -v __Math_iSub_fmt "%09d" $__Math_iSub_diff
    __Math_iSub_result="${__Math_iSub_fmt}${__Math_iSub_result}"
  done
  __Math_iSub_result="${__Math_iSub_result#"${__Math_iSub_result%%[!0]*}"}"
  : "${__Math_iSub_result:=0}"
}

# Multiply two unsigned digit strings. Chunked grade-school method.
# Splits both operands into 9-digit chunks, multiplies chunk pairs,
# and accumulates with proper positional shifts.
__Math.strMul() {
  local __Math_iMul_a="$1" __Math_iMul_b="$2"
  local -n __Math_iMul_result="$3"

  [[ "$__Math_iMul_a" == "0" || "$__Math_iMul_b" == "0" ]] && { __Math_iMul_result="0"; return; }

  # Pad to chunk boundaries in one shot
  local -i __Math_iMul_rem_a=$(( ${#__Math_iMul_a} % __Math_CHUNK ))
  if (( __Math_iMul_rem_a )); then
    local -i __Math_iMul_need_a=$(( __Math_CHUNK - __Math_iMul_rem_a ))
    local __Math_iMul_zeros_a
    printf -v __Math_iMul_zeros_a "%0${__Math_iMul_need_a}d" 0
    __Math_iMul_a="${__Math_iMul_zeros_a}${__Math_iMul_a}"
  fi
  local -i __Math_iMul_rem_b=$(( ${#__Math_iMul_b} % __Math_CHUNK ))
  if (( __Math_iMul_rem_b )); then
    local -i __Math_iMul_need_b=$(( __Math_CHUNK - __Math_iMul_rem_b ))
    local __Math_iMul_zeros_b
    printf -v __Math_iMul_zeros_b "%0${__Math_iMul_need_b}d" 0
    __Math_iMul_b="${__Math_iMul_zeros_b}${__Math_iMul_b}"
  fi

  local -i __Math_iMul_na=$(( ${#__Math_iMul_a} / __Math_CHUNK ))
  local -i __Math_iMul_nb=$(( ${#__Math_iMul_b} / __Math_CHUNK ))
  local -i __Math_iMul_nresult=$(( __Math_iMul_na + __Math_iMul_nb ))

  # Result accumulator as array of chunks
  local -a __Math_iMul_acc=()
  local -i __Math_iMul_k
  for (( __Math_iMul_k=0; __Math_iMul_k < __Math_iMul_nresult; __Math_iMul_k++ )); do __Math_iMul_acc[$__Math_iMul_k]=0; done

  # Multiply each chunk pair and accumulate.
  # Chunks are indexed left-to-right in the string but represent
  # most-significant-first, so chunk[0] of A is the highest-order chunk.
  # In the accumulator, index 0 = highest order. We need to map:
  #   A_chunk[i] * B_chunk[j] → acc[i+j] (with carry into i+j-1)
  # But since acc is most-significant-first, the positional math works
  # out the same as standard grade-school with the shift being i+j
  # from the right... actually, let's just index from the RIGHT to
  # keep it simple and match the standard algorithm.
  local -i __Math_iMul_i __Math_iMul_j __Math_iMul_ca __Math_iMul_cb __Math_iMul_prod __Math_iMul_pos
  for (( __Math_iMul_i = __Math_iMul_na - 1; __Math_iMul_i >= 0; __Math_iMul_i-- )); do
    __Math_iMul_ca=10#${__Math_iMul_a:__Math_iMul_i*__Math_CHUNK:__Math_CHUNK}
    (( __Math_iMul_ca == 0 )) && continue
    local -i __Math_iMul_carry=0
    for (( __Math_iMul_j = __Math_iMul_nb - 1; __Math_iMul_j >= 0; __Math_iMul_j-- )); do
      __Math_iMul_cb=10#${__Math_iMul_b:__Math_iMul_j*__Math_CHUNK:__Math_CHUNK}
      # Position in result: distance from right end
      # A chunk i (0=leftmost) is at position (na-1-i) from right
      # B chunk j (0=leftmost) is at position (nb-1-j) from right
      # Result position from right = (na-1-i) + (nb-1-j)
      # Result index (0=leftmost) = nresult-1 - pos_from_right
      __Math_iMul_pos=$(( __Math_iMul_nresult - 1 - (__Math_iMul_na - 1 - __Math_iMul_i) - (__Math_iMul_nb - 1 - __Math_iMul_j) ))
      __Math_iMul_prod=$(( __Math_iMul_ca * __Math_iMul_cb + __Math_iMul_acc[__Math_iMul_pos] + __Math_iMul_carry ))
      __Math_iMul_acc[$__Math_iMul_pos]=$(( __Math_iMul_prod % __Math_BASE ))
      __Math_iMul_carry=$(( __Math_iMul_prod / __Math_BASE ))
    done
    if (( __Math_iMul_carry )); then
      (( __Math_iMul_acc[__Math_iMul_pos - 1] += __Math_iMul_carry ))
    fi
  done

  # Convert accumulator back to digit string (index 0 = most significant)
  __Math_iMul_result=""
  local __Math_iMul_chunk
  for (( __Math_iMul_k = 0; __Math_iMul_k < __Math_iMul_nresult; __Math_iMul_k++ )); do
    printf -v __Math_iMul_chunk "%09d" ${__Math_iMul_acc[$__Math_iMul_k]}
    __Math_iMul_result="${__Math_iMul_result}${__Math_iMul_chunk}"
  done
  __Math_iMul_result="${__Math_iMul_result#"${__Math_iMul_result%%[!0]*}"}"
  : "${__Math_iMul_result:=0}"
}

# Multiply an unsigned digit string by a small integer (0-999999999).
# Chunked for speed. Returns result via nameref $3.
__Math.strMulSmall() {
  local __Math_strMulSmall_a="$1"
  local -i __Math_strMulSmall_n="$2"
  local -n __Math_strMulSmall_result="$3"

  (( __Math_strMulSmall_n == 0 )) && { __Math_strMulSmall_result="0"; return; }
  (( __Math_strMulSmall_n == 1 )) && { __Math_strMulSmall_result="$__Math_strMulSmall_a"; return; }

  local -i __Math_strMulSmall_rem=$(( ${#__Math_strMulSmall_a} % __Math_CHUNK ))
  if (( __Math_strMulSmall_rem )); then
    local -i __Math_strMulSmall_need=$(( __Math_CHUNK - __Math_strMulSmall_rem ))
    local __Math_strMulSmall_zeros
    printf -v __Math_strMulSmall_zeros "%0${__Math_strMulSmall_need}d" 0
    __Math_strMulSmall_a="${__Math_strMulSmall_zeros}${__Math_strMulSmall_a}"
  fi

  local -i __Math_strMulSmall_carry=0 __Math_strMulSmall_pos __Math_strMulSmall_len=${#__Math_strMulSmall_a} __Math_strMulSmall_prod
  __Math_strMulSmall_result=""
  local __Math_strMulSmall_fmt
  for (( __Math_strMulSmall_pos = __Math_strMulSmall_len - __Math_CHUNK; __Math_strMulSmall_pos >= 0; __Math_strMulSmall_pos -= __Math_CHUNK )); do
    __Math_strMulSmall_prod=$(( 10#${__Math_strMulSmall_a:__Math_strMulSmall_pos:__Math_CHUNK} * __Math_strMulSmall_n + __Math_strMulSmall_carry ))
    __Math_strMulSmall_carry=$(( __Math_strMulSmall_prod / __Math_BASE ))
    printf -v __Math_strMulSmall_fmt "%09d" $(( __Math_strMulSmall_prod % __Math_BASE ))
    __Math_strMulSmall_result="${__Math_strMulSmall_fmt}${__Math_strMulSmall_result}"
  done
  (( __Math_strMulSmall_carry )) && __Math_strMulSmall_result="${__Math_strMulSmall_carry}${__Math_strMulSmall_result}"
  __Math_strMulSmall_result="${__Math_strMulSmall_result#"${__Math_strMulSmall_result%%[!0]*}"}"
  : "${__Math_strMulSmall_result:=0}"
}

# Divide unsigned digit string A by unsigned digit string B.
# Long division, one digit at a time. Division is inherently sequential
# (each step depends on the previous remainder), so it stays per-digit.
# The trial-multiply and subtract steps use chunked strMulSmall/strSub.
__Math.strDiv() {
  local __Math_iDiv_a="$1" __Math_iDiv_b="$2"
  local -n __Math_iDiv_quotient="$3"
  local -i __Math_iDiv_maxdigits="${4:-$__Math_precision}"
  local -n __Math_iDiv_qscale="$5"

  [[ "$__Math_iDiv_b" == "0" ]] && _Crash "Math: division by zero"
  [[ "$__Math_iDiv_a" == "0" ]] && { __Math_iDiv_quotient="0"; __Math_iDiv_qscale=0; return; }

  local __Math_iDiv_remainder="0"
  local -i __Math_iDiv_alen=${#__Math_iDiv_a} __Math_iDiv_pos=0 __Math_iDiv_qdigits=0
  local -i __Math_iDiv_past_decimal=0
  __Math_iDiv_quotient=""
  __Math_iDiv_qscale=0

  while (( __Math_iDiv_qdigits < __Math_iDiv_maxdigits )); do
    if (( __Math_iDiv_pos < __Math_iDiv_alen )); then
      __Math_iDiv_remainder="${__Math_iDiv_remainder}${__Math_iDiv_a:__Math_iDiv_pos:1}"
      (( __Math_iDiv_pos++ ))
    else
      __Math_iDiv_remainder="${__Math_iDiv_remainder}0"
      (( __Math_iDiv_past_decimal++ ))
    fi

    local __Math_iDiv_rem_stripped="${__Math_iDiv_remainder#"${__Math_iDiv_remainder%%[!0]*}"}"
    : "${__Math_iDiv_rem_stripped:=0}"
    __Math_iDiv_remainder="$__Math_iDiv_rem_stripped"

    # Binary search for quotient digit (0-9)
    local -i __Math_iDiv_lo=0 __Math_iDiv_hi=9 __Math_iDiv_mid __Math_iDiv_qd=0
    while (( __Math_iDiv_lo <= __Math_iDiv_hi )); do
      __Math_iDiv_mid=$(( (__Math_iDiv_lo + __Math_iDiv_hi) / 2 ))
      local __Math_iDiv_trial
      __Math.strMulSmall "$__Math_iDiv_b" $__Math_iDiv_mid __Math_iDiv_trial
      __Math.strCmp "$__Math_iDiv_trial" "$__Math_iDiv_remainder"
      local -i __Math_iDiv_cmprc=$?
      if (( __Math_iDiv_cmprc == 0 )); then __Math_iDiv_qd=$__Math_iDiv_mid; break
      elif (( __Math_iDiv_cmprc == 2 )); then __Math_iDiv_qd=$__Math_iDiv_mid; __Math_iDiv_lo=$(( __Math_iDiv_mid + 1 ))
      else __Math_iDiv_hi=$(( __Math_iDiv_mid - 1 ))
      fi
    done

    if (( __Math_iDiv_qd == 0 && __Math_iDiv_qdigits == 0 )); then
      # Leading zero — don't count as a quotient digit, but track
      # fractional position so the scale stays correct.
      (( __Math_iDiv_past_decimal > 0 )) && (( __Math_iDiv_qscale++ ))
    else
      __Math_iDiv_quotient="${__Math_iDiv_quotient}${__Math_iDiv_qd}"
      (( __Math_iDiv_qdigits++ ))
      (( __Math_iDiv_past_decimal > 0 )) && (( __Math_iDiv_qscale++ ))
    fi

    if (( __Math_iDiv_qd > 0 )); then
      local __Math_iDiv_sub_val
      __Math.strMulSmall "$__Math_iDiv_b" $__Math_iDiv_qd __Math_iDiv_sub_val
      __Math.strSub "$__Math_iDiv_remainder" "$__Math_iDiv_sub_val" __Math_iDiv_remainder
    fi

    [[ "$__Math_iDiv_remainder" == "0" ]] && (( __Math_iDiv_pos >= __Math_iDiv_alen )) && break
  done

  : "${__Math_iDiv_quotient:=0}"
}


# ============================================================================
# Helpers for Math objects
# ============================================================================

# Strip leading zeros from a digit string, preserving at least "0".
__Math.stripLeading() {
  local __Math_stripLeading_val="$1"
  __Math_stripLeading_val="${__Math_stripLeading_val#"${__Math_stripLeading_val%%[!0]*}"}"
  printf '%s' "${__Math_stripLeading_val:-0}"
}

# Resolve a Math argument to its digits/scale/neg triple.
#
# If the input is an object ID (starts with _ and is in the registry),
# extracts digits, scale, and neg from the object's descriptor.
# Otherwise, parses and validates the input as a literal number string.
#
# Literal parsing uses a single regex to validate and decompose the
# input in one pass. Accepts optional leading/trailing whitespace,
# optional sign, and requires at least one digit. Rejects everything
# else (letters, operators, multiple dots, etc.) with a clear error.
#
# Trailing fractional zeros are preserved — they encode precision.
# "3.14" (scale=2) and "3.140" (scale=3) are intentionally different.
#
# Arguments:
#   $1 — input value (object ID or numeric string like "3.14" or "-42")
#   $2 — nameref: receives digit string (no sign, no decimal point)
#   $3 — nameref: receives scale (integer, number of decimal places)
#   $4 — nameref: receives neg flag (0=positive, 1=negative)
#
# Returns: nothing (results via namerefs)
# Crashes: if input is not a valid number or recognized object ID
__Math.resolve() {
  local __Math_resolve_input="$1"
  local -n __Math_resolve_digits="$2" __Math_resolve_scale="$3" __Math_resolve_neg="$4"

  # Object ID — already validated, extract from descriptor
  if [[ "$__Math_resolve_input" == _* && -n "${__boop_registry[$__Math_resolve_input]:-}" ]]; then
    __boop.parse "$__Math_resolve_input" "digits" __Math_resolve_digits
    __boop.parse "$__Math_resolve_input" "scale" __Math_resolve_scale
    __boop.parse "$__Math_resolve_input" "neg" __Math_resolve_neg
    return
  fi

  # Validate and decompose literal in one pass:
  #   group 1: sign ("-" or empty)
  #   group 2: integer digits (may be empty if fraction exists)
  #   group 3: decimal point ("." or empty)
  #   group 4: fractional digits (may be empty if integer exists)
  # The -n check ensures at least one digit is present somewhere.
  if ! [[ "${__Math_resolve_input:-}" =~ ^[[:space:]]*(-?)([0-9]*)([.]*)([0-9]*)[[:space:]]*$ \
       && -n "${BASH_REMATCH[2]:-}${BASH_REMATCH[4]:-}" ]]; then
    _Crash "Math: invalid number '$1' — expected a numeric value like '3.14' or '-42'"
  fi

  __Math_resolve_neg=${#BASH_REMATCH[1]}                                  # "-" → length 1; empty → 0
  local __Math_resolve_int="${BASH_REMATCH[2]}"                           # digits before the dot
  local __Math_resolve_frac="${BASH_REMATCH[4]}"                          # digits after the dot

  # Default empty integer part to zero (e.g., ".5")
  if [[ -z "$__Math_resolve_int" ]]; then
    _Debug "__Math.resolve: no integer part in '$1', defaulting to 0"
    __Math_resolve_int=0
  fi

  # Default empty fraction to zero when a dot was present (e.g., "1.")
  if [[ -z "$__Math_resolve_frac" && -n "${BASH_REMATCH[3]}" ]]; then
    _Debug "__Math.resolve: no fraction in '$1', defaulting to 0"
    __Math_resolve_frac=0
  fi

  __Math_resolve_int="${__Math_resolve_int#"${__Math_resolve_int%%[!0]*}"}"                 # strip leading zeros
  : "${__Math_resolve_int:=0}"                                            # keep at least "0"

  __Math_resolve_digits="${__Math_resolve_int}${__Math_resolve_frac}"                       # concatenate for arithmetic
  __Math_resolve_scale=${#__Math_resolve_frac}                                     # precision = fraction length

  [[ "${__Math_resolve_digits//0/}" == "" ]] && __Math_resolve_neg=0               # no negative zero
}

# Align two numbers to the same scale by padding the shorter one with
# trailing zeros on the digit string. This makes the digit strings
# directly comparable and addable/subtractable.
__Math.alignScale() {
  local -n __Math_alignScale_dA="$1" __Math_alignScale_sA="$2" __Math_alignScale_dB="$3" __Math_alignScale_sB="$4"
  local -i __Math_alignScale_diff
  local __Math_alignScale_pad
  if (( __Math_alignScale_sA < __Math_alignScale_sB )); then
    __Math_alignScale_diff=$(( __Math_alignScale_sB - __Math_alignScale_sA ))
    printf -v __Math_alignScale_pad "%0${__Math_alignScale_diff}d" 0
    __Math_alignScale_dA="${__Math_alignScale_dA}${__Math_alignScale_pad}"
    __Math_alignScale_sA=$__Math_alignScale_sB
  elif (( __Math_alignScale_sB < __Math_alignScale_sA )); then
    __Math_alignScale_diff=$(( __Math_alignScale_sA - __Math_alignScale_sB ))
    printf -v __Math_alignScale_pad "%0${__Math_alignScale_diff}d" 0
    __Math_alignScale_dB="${__Math_alignScale_dB}${__Math_alignScale_pad}"
    __Math_alignScale_sB=$__Math_alignScale_sA
  fi
}

# Build a Math object from raw components. Strips leading zeros,
# normalizes negative zero, registers in boop.
__Math.fromParts() {
  local __Math_fromParts_digits="$1"
  local -i __Math_fromParts_scale="$2" __Math_fromParts_neg="$3"

  # Strip leading zeros (inline — no subshell)
  __Math_fromParts_digits="${__Math_fromParts_digits#"${__Math_fromParts_digits%%[!0]*}"}"
  : "${__Math_fromParts_digits:=0}"

  # Strip trailing zeros past the decimal point.
  # Uses parameter expansion to find the trailing zeros suffix,
  # then trims by length in one shot instead of one-char-at-a-time.
  if (( __Math_fromParts_scale > 0 )); then
    local __Math_fromParts_tz="${__Math_fromParts_digits%%[!0]*}"  # won't work — need trailing
    # Reverse approach: strip trailing zeros via suffix removal
    local __Math_fromParts_stripped="${__Math_fromParts_digits%"${__Math_fromParts_digits##*[!0]}"}"
    # __Math_fromParts_stripped is everything up to and including the last non-zero
    # Actually: ${var##*[!0]} gives the trailing zeros suffix
    local __Math_fromParts_tail="${__Math_fromParts_digits##*[!0]}"
    local -i __Math_fromParts_taillen=${#__Math_fromParts_tail}
    if (( __Math_fromParts_taillen > 0 && __Math_fromParts_taillen <= __Math_fromParts_scale )); then
      __Math_fromParts_digits="${__Math_fromParts_digits:0:${#__Math_fromParts_digits}-__Math_fromParts_taillen}"
      (( __Math_fromParts_scale -= __Math_fromParts_taillen ))
    elif (( __Math_fromParts_taillen > __Math_fromParts_scale )); then
      # Only strip up to scale zeros (don't eat into integer part)
      __Math_fromParts_digits="${__Math_fromParts_digits:0:${#__Math_fromParts_digits}-__Math_fromParts_scale}"
      __Math_fromParts_scale=0
    fi
    : "${__Math_fromParts_digits:=0}"
  fi

  # No negative zero
  [[ "$__Math_fromParts_digits" == "0" ]] && __Math_fromParts_neg=0

  local __Math_fromParts_self
  into=__Math_fromParts_self _Class=Math __boop.new "digits=$__Math_fromParts_digits" "scale=$__Math_fromParts_scale" "neg=$__Math_fromParts_neg"
  boop.pass "$__Math_fromParts_self" "${4:-}"
}

