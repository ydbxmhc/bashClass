# Constructor
# ============================================================================

# Create a new Math number from a string.
#
# Usage: into=m Math 3.14159
#        into=m Math -42
#        into=m Math 0.001
Math.new() {
  local _Class="${_Class:-Math}"

  local __Math_new_input="${1:-0}"
  # Skip key=value args that aren't the value itself
  [[ "$__Math_new_input" == *=* ]] && __Math_new_input="0"

  local __Math_new_digits __Math_new_neg
  local -i __Math_new_scale
  __Math.resolve "$__Math_new_input" __Math_new_digits __Math_new_scale __Math_new_neg
  __Math.fromParts "$__Math_new_digits" $__Math_new_scale $__Math_new_neg ${into:-}
}


# ============================================================================
# Arithmetic operations
# ============================================================================

# Add: self + arg. Handles sign logic, delegates to strAdd/strSub.
# Fast path: if both operands fit in 64-bit, uses native $(( )).
__Math.i_add() {
  local -I _Self; local _Class="${_Class:-Math}"
  local __Math_iAdd_dA __Math_iAdd_dB
  local -i __Math_iAdd_sA __Math_iAdd_sB __Math_iAdd_nA __Math_iAdd_nB
  __Math.resolve "$_Self" __Math_iAdd_dA __Math_iAdd_sA __Math_iAdd_nA
  __Math.resolve "$1" __Math_iAdd_dB __Math_iAdd_sB __Math_iAdd_nB

  # Fast path: native integer arithmetic
  local -i __Math_iAdd_iA __Math_iAdd_iB
  if __Math.toInt64 "$__Math_iAdd_dA" $__Math_iAdd_sA $__Math_iAdd_nA __Math_iAdd_iA \
  && __Math.toInt64 "$__Math_iAdd_dB" $__Math_iAdd_sB $__Math_iAdd_nB __Math_iAdd_iB; then
    __Math.alignScale __Math_iAdd_dA __Math_iAdd_sA __Math_iAdd_dB __Math_iAdd_sB
    __Math.toInt64 "$__Math_iAdd_dA" $__Math_iAdd_sA $__Math_iAdd_nA __Math_iAdd_iA
    __Math.toInt64 "$__Math_iAdd_dB" $__Math_iAdd_sB $__Math_iAdd_nB __Math_iAdd_iB
    local __Math_iAdd_fd; local -i __Math_iAdd_fs __Math_iAdd_fn
    __Math.fromInt64 $(( __Math_iAdd_iA + __Math_iAdd_iB )) $__Math_iAdd_sA __Math_iAdd_fd __Math_iAdd_fs __Math_iAdd_fn
    __Math.fromParts "$__Math_iAdd_fd" $__Math_iAdd_fs $__Math_iAdd_fn ${into:-}
    return
  fi

  __Math.alignScale __Math_iAdd_dA __Math_iAdd_sA __Math_iAdd_dB __Math_iAdd_sB

  local __Math_iAdd_rd
  local -i __Math_iAdd_rn

  if (( __Math_iAdd_nA == __Math_iAdd_nB )); then
    __Math.strAdd "$__Math_iAdd_dA" "$__Math_iAdd_dB" __Math_iAdd_rd
    __Math_iAdd_rn=$__Math_iAdd_nA
  else
    __Math.strCmp "$__Math_iAdd_dA" "$__Math_iAdd_dB"
    local -i __Math_iAdd_cmp=$?
    if (( __Math_iAdd_cmp == 0 )); then
      __Math.fromParts "0" $__Math_iAdd_sA 0 ${into:-}; return
    elif (( __Math_iAdd_cmp == 1 )); then
      __Math.strSub "$__Math_iAdd_dA" "$__Math_iAdd_dB" __Math_iAdd_rd
      __Math_iAdd_rn=$__Math_iAdd_nA
    else
      __Math.strSub "$__Math_iAdd_dB" "$__Math_iAdd_dA" __Math_iAdd_rd
      __Math_iAdd_rn=$__Math_iAdd_nB
    fi
  fi

  __Math.fromParts "$__Math_iAdd_rd" $__Math_iAdd_sA $__Math_iAdd_rn ${into:-}
}

# Subtract: self - arg. Flip sign of arg and add.
__Math.i_sub() {
  local -I _Self; local _Class="${_Class:-Math}"
  local __Math_iSub_dB
  local -i __Math_iSub_sB __Math_iSub_nB
  __Math.resolve "$1" __Math_iSub_dB __Math_iSub_sB __Math_iSub_nB

  # Flip sign and add
  (( __Math_iSub_nB = !__Math_iSub_nB ))
  [[ "$__Math_iSub_dB" == "0" ]] && __Math_iSub_nB=0

  # Build a temporary negated value and add
  local __Math_iSub_tmp
  __Math.fromParts "$__Math_iSub_dB" $__Math_iSub_sB $__Math_iSub_nB __Math_iSub_tmp
  _Self="$_Self" _Class=Math __Math.i_add "$__Math_iSub_tmp"
}

# Multiply: self * arg.
# Digit strings are multiplied directly. Result scale = scaleA + scaleB.
# Result sign = XOR of input signs.
# Fast path: if combined digit count ≤ 18, uses native $(( )).
__Math.i_mul() {
  local -I _Self; local _Class="${_Class:-Math}"
  local __Math_iMul_dA __Math_iMul_dB
  local -i __Math_iMul_sA __Math_iMul_sB __Math_iMul_nA __Math_iMul_nB
  __Math.resolve "$_Self" __Math_iMul_dA __Math_iMul_sA __Math_iMul_nA
  __Math.resolve "$1" __Math_iMul_dB __Math_iMul_sB __Math_iMul_nB

  # Fast path: combined digits fit in 64-bit product
  if (( ${#__Math_iMul_dA} + ${#__Math_iMul_dB} <= __Math_FAST_DIGITS )); then
    local -i __Math_iMul_iA __Math_iMul_iB
    __Math.toInt64 "$__Math_iMul_dA" $__Math_iMul_sA $__Math_iMul_nA __Math_iMul_iA
    __Math.toInt64 "$__Math_iMul_dB" $__Math_iMul_sB $__Math_iMul_nB __Math_iMul_iB
    local __Math_iMul_fd; local -i __Math_iMul_fs __Math_iMul_fn
    __Math.fromInt64 $(( __Math_iMul_iA * __Math_iMul_iB )) $(( __Math_iMul_sA + __Math_iMul_sB )) __Math_iMul_fd __Math_iMul_fs __Math_iMul_fn
    __Math.fromParts "$__Math_iMul_fd" $__Math_iMul_fs $__Math_iMul_fn ${into:-}
    return
  fi

  local __Math_iMul_rd
  __Math.strMul "$__Math_iMul_dA" "$__Math_iMul_dB" __Math_iMul_rd
  local -i __Math_iMul_rn=$(( __Math_iMul_nA != __Math_iMul_nB ? 1 : 0 ))
  __Math.fromParts "$__Math_iMul_rd" $(( __Math_iMul_sA + __Math_iMul_sB )) $__Math_iMul_rn ${into:-}
}

# Divide: self / arg.
# Respects precision= typecast or global __Math_precision.
# Always truncates to precision. Use $result.round N to round afterward.
# Fast path: if dividend (after scale padding) fits in 64-bit, uses $(( )).
__Math.i_div() {
  local -I _Self; local _Class="${_Class:-Math}"
  local -i precision; : "${precision:=$__Math_precision}"

  local __Math_iDiv_dA __Math_iDiv_dB
  local -i __Math_iDiv_sA __Math_iDiv_sB __Math_iDiv_nA __Math_iDiv_nB
  __Math.resolve "$_Self" __Math_iDiv_dA __Math_iDiv_sA __Math_iDiv_nA
  __Math.resolve "$1" __Math_iDiv_dB __Math_iDiv_sB __Math_iDiv_nB

  [[ "$__Math_iDiv_dB" == "0" ]] && _Crash "Math: division by zero"

  # Fast path: native integer division when operands are small enough.
  # After align, we multiply dividend by 10^extra for fractional digits.
  # Total digit count of (aligned_dividend * 10^extra) must fit in 64-bit.
  local -i __Math_iDiv_extra=$(( precision > 6 ? precision : 6 ))
  local -i __Math_iDiv_maxA=${#__Math_iDiv_dA} __Math_iDiv_maxB=${#__Math_iDiv_dB}
  (( __Math_iDiv_maxA < __Math_iDiv_maxB )) && __Math_iDiv_maxA=$__Math_iDiv_maxB
  if (( __Math_iDiv_maxA + __Math_iDiv_extra <= __Math_FAST_DIGITS )); then
    __Math.alignScale __Math_iDiv_dA __Math_iDiv_sA __Math_iDiv_dB __Math_iDiv_sB
    local -i __Math_iDiv_iA __Math_iDiv_iB
    __Math.toInt64 "$__Math_iDiv_dA" $__Math_iDiv_sA $__Math_iDiv_nA __Math_iDiv_iA
    __Math.toInt64 "$__Math_iDiv_dB" $__Math_iDiv_sB $__Math_iDiv_nB __Math_iDiv_iB
    local __Math_iDiv_pow
    printf -v __Math_iDiv_pow "1%0${__Math_iDiv_extra}d" 0
    local -i __Math_iDiv_mul=10#$__Math_iDiv_pow
    # Preserve sign, operate on magnitudes
    local -i __Math_iDiv_absA=${__Math_iDiv_iA#-} __Math_iDiv_absB=${__Math_iDiv_iB#-}
    local -i __Math_iDiv_raw=$(( (__Math_iDiv_absA * __Math_iDiv_mul) / __Math_iDiv_absB ))
    local -i __Math_iDiv_rn=$(( __Math_iDiv_nA != __Math_iDiv_nB ? 1 : 0 ))
    local __Math_iDiv_fd; local -i __Math_iDiv_fs __Math_iDiv_fn
    __Math.fromInt64 $__Math_iDiv_raw $__Math_iDiv_extra __Math_iDiv_fd __Math_iDiv_fs __Math_iDiv_fn
    (( __Math_iDiv_rn )) && __Math_iDiv_fn=$__Math_iDiv_rn
    [[ "$__Math_iDiv_fd" == "0" ]] && __Math_iDiv_fn=0
    __Math.fromParts "$__Math_iDiv_fd" $__Math_iDiv_fs $__Math_iDiv_fn ${into:-}
    return
  fi

  # Align scales so we're dividing integers of the same magnitude
  __Math.alignScale __Math_iDiv_dA __Math_iDiv_sA __Math_iDiv_dB __Math_iDiv_sB

  # Perform string division — operates on pure digit strings, returns
  # quotient digits and how many of them are past the decimal point
  local __Math_iDiv_q
  local -i __Math_iDiv_qs
  __Math.strDiv "$__Math_iDiv_dA" "$__Math_iDiv_dB" __Math_iDiv_q $((precision + 2)) __Math_iDiv_qs

  local -i __Math_iDiv_rn=$(( __Math_iDiv_nA != __Math_iDiv_nB ? 1 : 0 ))

  # Round or truncate to requested precision
  # Truncate to requested precision
  if (( ${#__Math_iDiv_q} > precision )); then
    local -i __Math_iDiv_removed=$(( ${#__Math_iDiv_q} - precision ))
    __Math_iDiv_q="${__Math_iDiv_q:0:precision}"
    (( __Math_iDiv_qs -= __Math_iDiv_removed ))
    (( __Math_iDiv_qs < 0 )) && __Math_iDiv_qs=0
  fi

  __Math.fromParts "$__Math_iDiv_q" $__Math_iDiv_qs $__Math_iDiv_rn ${into:-}
}

# Square: self * self. Convenience wrapper — same as mul with self as arg.
__Math.i_square() {
  local -I _Self; local _Class="${_Class:-Math}"
  _Self="$_Self" _Class="$_Class" into=${into:-} __Math.i_mul "$_Self"
}

# Modulo: self % arg. Aligns scales, computes remainder.
# Fast path only — mod on arbitrary-precision strings would need
# a full strMod implementation. For now, crashes if operands are too large.
__Math.i_mod() {
  local -I _Self; local _Class="${_Class:-Math}"
  local __Math_iMod_dA __Math_iMod_dB
  local -i __Math_iMod_sA __Math_iMod_sB __Math_iMod_nA __Math_iMod_nB
  __Math.resolve "$_Self" __Math_iMod_dA __Math_iMod_sA __Math_iMod_nA
  __Math.resolve "$1" __Math_iMod_dB __Math_iMod_sB __Math_iMod_nB

  [[ "$__Math_iMod_dB" == "0" ]] && _Crash "Math: modulo by zero"

  __Math.alignScale __Math_iMod_dA __Math_iMod_sA __Math_iMod_dB __Math_iMod_sB

  local -i __Math_iMod_iA __Math_iMod_iB
  __Math.toInt64 "$__Math_iMod_dA" $__Math_iMod_sA $__Math_iMod_nA __Math_iMod_iA \
    || _Crash "Math: mod operand too large for native arithmetic"
  __Math.toInt64 "$__Math_iMod_dB" $__Math_iMod_sB $__Math_iMod_nB __Math_iMod_iB \
    || _Crash "Math: mod operand too large for native arithmetic"

  local __Math_iMod_fd; local -i __Math_iMod_fs __Math_iMod_fn
  __Math.fromInt64 $(( __Math_iMod_iA % __Math_iMod_iB )) $__Math_iMod_sA __Math_iMod_fd __Math_iMod_fs __Math_iMod_fn
  __Math.fromParts "$__Math_iMod_fd" $__Math_iMod_fs $__Math_iMod_fn ${into:-}
}

# Power: self ^ arg (non-negative integer exponent only).
# Uses repeated multiplication via i_mul, which auto-selects fast or
# string path per iteration. This means small bases stay fast and large
# bases gracefully fall back to arbitrary precision.
__Math.i_pow() {
  local -I _Self; local _Class="${_Class:-Math}"
  local __Math_iPow_dB
  local -i __Math_iPow_sB __Math_iPow_nB
  __Math.resolve "$1" __Math_iPow_dB __Math_iPow_sB __Math_iPow_nB

  (( __Math_iPow_sB != 0 )) && _Crash "Math: fractional exponents not supported"
  (( __Math_iPow_nB )) && _Crash "Math: negative exponents not supported"

  # Exponent is a plain integer
  local -i __Math_iPow_exp=10#$__Math_iPow_dB

  # Start with 1
  local __Math_iPow_result
  into=__Math_iPow_result Math.new 1

  local -i __Math_iPow_i
  for (( __Math_iPow_i=0; __Math_iPow_i < __Math_iPow_exp; __Math_iPow_i++ )); do
    into=__Math_iPow_result _Self="$__Math_iPow_result" _Class=Math __Math.i_mul "$_Self"
  done

  boop.pass "$__Math_iPow_result" ${into:-}
}


# ============================================================================
# Comparison operations — exit codes (bash boolean convention)
# ============================================================================

# Compare self to arg. Returns 0 (equal), 1 (self > arg), 2 (self < arg).
# This is the workhorse — eq/lt/gt/le/ge are wrappers.
Math.cmp() {
  local -I _Self; local _Class="${_Class:-Math}"
  local __Math_strCmp_dA __Math_strCmp_dB
  local -i __Math_strCmp_sA __Math_strCmp_sB __Math_strCmp_nA __Math_strCmp_nB
  __Math.resolve "$_Self" __Math_strCmp_dA __Math_strCmp_sA __Math_strCmp_nA
  __Math.resolve "$1" __Math_strCmp_dB __Math_strCmp_sB __Math_strCmp_nB

  # Different signs: negative < positive
  if (( __Math_strCmp_nA != __Math_strCmp_nB )); then
    # Both zero check
    [[ "$__Math_strCmp_dA" == "0" && "$__Math_strCmp_dB" == "0" ]] && return 0
    (( __Math_strCmp_nA )) && return 2 || return 1
  fi

  __Math.alignScale __Math_strCmp_dA __Math_strCmp_sA __Math_strCmp_dB __Math_strCmp_sB
  __Math.strCmp "$__Math_strCmp_dA" "$__Math_strCmp_dB"
  local -i __Math_strCmp_rc=$?

  # If negative, flip the comparison (larger magnitude = smaller value)
  if (( __Math_strCmp_nA )); then
    (( __Math_strCmp_rc == 1 )) && return 2
    (( __Math_strCmp_rc == 2 )) && return 1
  fi
  return $__Math_strCmp_rc
}

Math.eq() { local -I _Self; local _Class="${_Class:-Math}"; _Self="$_Self" _Class="$_Class" Math.cmp "$1"; (( $? == 0 )); }
Math.lt() { local -I _Self; local _Class="${_Class:-Math}"; _Self="$_Self" _Class="$_Class" Math.cmp "$1"; (( $? == 2 )); }
Math.gt() { local -I _Self; local _Class="${_Class:-Math}"; _Self="$_Self" _Class="$_Class" Math.cmp "$1"; (( $? == 1 )); }
Math.le() { local -I _Self; local _Class="${_Class:-Math}"; _Self="$_Self" _Class="$_Class" Math.cmp "$1"; local -i rc=$?; (( rc == 0 || rc == 2 )); }
Math.ge() { local -I _Self; local _Class="${_Class:-Math}"; _Self="$_Self" _Class="$_Class" Math.cmp "$1"; local -i rc=$?; (( rc == 0 || rc == 1 )); }

