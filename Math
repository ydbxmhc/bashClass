Math.isZero() {
  local -I _Self; local _Class="${_Class:-Math}"
  local __Math_isZero_d; local -i __Math_isZero_s __Math_isZero_n
  __Math.resolve "$_Self" __Math_isZero_d __Math_isZero_s __Math_isZero_n
  [[ "$__Math_isZero_d" == "0" ]]
}

__Math.i_abs() {
  local -I _Self; local _Class="${_Class:-Math}"
  local __Math_iAbs_d; local -i __Math_iAbs_s __Math_iAbs_n
  __Math.resolve "$_Self" __Math_iAbs_d __Math_iAbs_s __Math_iAbs_n
  __Math.fromParts "$__Math_iAbs_d" $__Math_iAbs_s 0 ${into:-}
