# ============================================================================
# Static API — class-level functions that return plain value strings
# ============================================================================
# These overwrite the dispatch wrappers created by registerClass. They
# provide a dual-mode API:
#
#   Static (no self):  into=v Math.add 1.5 2.3     → v="3.8"
#   Instance (self):   into=r $obj.add 2.3          → r=object_id
#
# Static calls resolve literal arguments through the raw string engine,
# compute the result, and return a formatted decimal string — no objects
# created. Instance calls delegate to the registered __Math.i_* impl
# which returns a Math object as before.
#
# Full-word names are the primary API. Short aliases are defined below.
#
# Naming:
#   Math.add / Math.subtract / Math.multiply / Math.divide / Math.square
#   Math.abs / Math.neg
#   Math.+ / Math.- / Math.x / Math.* / Math./    (symbol aliases)
#   Math.DO   — infix expression evaluator with precedence and parens
#   Math.RPN  — reverse Polish notation evaluator

# Format a raw digit/scale/neg triple as a decimal value string.
# Same logic as Math.val but operates on raw components, no object needed.
# Strips trailing zeros past the decimal point for clean output.
__Math.formatVal() {
  local __Math_formatVal_d="$1"
  local -i __Math_formatVal_s="$2" __Math_formatVal_n="$3"

  # Strip leading zeros from digits (inline — no subshell)
  __Math_formatVal_d="${__Math_formatVal_d#"${__Math_formatVal_d%%[!0]*}"}"
  : "${__Math_formatVal_d:=0}"

  # Strip trailing zeros past decimal in one shot via suffix detection
  if (( __Math_formatVal_s > 0 )); then
    local __Math_formatVal_tail="${__Math_formatVal_d##*[!0]}"
    local -i __Math_formatVal_taillen=${#__Math_formatVal_tail}
    if (( __Math_formatVal_taillen > 0 && __Math_formatVal_taillen <= __Math_formatVal_s )); then
      __Math_formatVal_d="${__Math_formatVal_d:0:${#__Math_formatVal_d}-__Math_formatVal_taillen}"
      (( __Math_formatVal_s -= __Math_formatVal_taillen ))
    elif (( __Math_formatVal_taillen > __Math_formatVal_s )); then
      __Math_formatVal_d="${__Math_formatVal_d:0:${#__Math_formatVal_d}-__Math_formatVal_s}"
      __Math_formatVal_s=0
    fi
    : "${__Math_formatVal_d:=0}"
  fi

  local __Math_formatVal_result
  if (( __Math_formatVal_s == 0 )); then
    __Math_formatVal_result="$__Math_formatVal_d"
  elif (( __Math_formatVal_s >= ${#__Math_formatVal_d} )); then
    # Pad with leading zeros in one shot via printf
    local -i __Math_formatVal_need=$(( __Math_formatVal_s - ${#__Math_formatVal_d} ))
    local __Math_formatVal_pad
    if (( __Math_formatVal_need > 0 )); then
      printf -v __Math_formatVal_pad "%0${__Math_formatVal_need}d" 0
      __Math_formatVal_pad="${__Math_formatVal_pad}${__Math_formatVal_d}"
    else
      __Math_formatVal_pad="$__Math_formatVal_d"
    fi
    __Math_formatVal_result="0.${__Math_formatVal_pad}"
  else
    local -i __Math_formatVal_split=$(( ${#__Math_formatVal_d} - __Math_formatVal_s ))
    __Math_formatVal_result="${__Math_formatVal_d:0:__Math_formatVal_split}.${__Math_formatVal_d:__Math_formatVal_split}"
  fi

  (( __Math_formatVal_n )) && [[ "$__Math_formatVal_result" != "0" ]] && __Math_formatVal_result="-${__Math_formatVal_result}"
  boop.pass "$__Math_formatVal_result" "${4:-}"
}

# Internal: static binary op. Returns plain value string via boop.pass.
# Uses native $(( )) fast path when operands fit in 64-bit.
__Math.staticBinOp() {
  local __Math_staticBinOp_op="$1"
  local __Math_staticBinOp_dA __Math_staticBinOp_dB
  local -i __Math_staticBinOp_sA __Math_staticBinOp_sB __Math_staticBinOp_nA __Math_staticBinOp_nB
  __Math.resolve "$2" __Math_staticBinOp_dA __Math_staticBinOp_sA __Math_staticBinOp_nA
  __Math.resolve "$3" __Math_staticBinOp_dB __Math_staticBinOp_sB __Math_staticBinOp_nB

  local __Math_staticBinOp_rd
  local -i __Math_staticBinOp_rs __Math_staticBinOp_rn

  # Fast path for add/sub/mul/mod when operands fit in 64-bit
  case "$__Math_staticBinOp_op" in
    add|sub|mod)
      if (( ${#__Math_staticBinOp_dA} <= __Math_FAST_DIGITS && ${#__Math_staticBinOp_dB} <= __Math_FAST_DIGITS )); then
        __Math.alignScale __Math_staticBinOp_dA __Math_staticBinOp_sA __Math_staticBinOp_dB __Math_staticBinOp_sB
        if (( ${#__Math_staticBinOp_dA} <= __Math_FAST_DIGITS )); then
          local -i __Math_staticBinOp_iA __Math_staticBinOp_iB
          __Math.toInt64 "$__Math_staticBinOp_dA" $__Math_staticBinOp_sA $__Math_staticBinOp_nA __Math_staticBinOp_iA
          __Math.toInt64 "$__Math_staticBinOp_dB" $__Math_staticBinOp_sB $__Math_staticBinOp_nB __Math_staticBinOp_iB
          case "$__Math_staticBinOp_op" in
            add) __Math.fromInt64 $(( __Math_staticBinOp_iA + __Math_staticBinOp_iB )) $__Math_staticBinOp_sA __Math_staticBinOp_rd __Math_staticBinOp_rs __Math_staticBinOp_rn ;;
            sub) __Math.fromInt64 $(( __Math_staticBinOp_iA - __Math_staticBinOp_iB )) $__Math_staticBinOp_sA __Math_staticBinOp_rd __Math_staticBinOp_rs __Math_staticBinOp_rn ;;
            mod) [[ "$__Math_staticBinOp_dB" == "0" ]] && _Crash "Math: modulo by zero"
                 __Math.fromInt64 $(( __Math_staticBinOp_iA % __Math_staticBinOp_iB )) $__Math_staticBinOp_sA __Math_staticBinOp_rd __Math_staticBinOp_rs __Math_staticBinOp_rn ;;
          esac
          __Math.formatVal "$__Math_staticBinOp_rd" $__Math_staticBinOp_rs $__Math_staticBinOp_rn ${into:-}
          return
        fi
      fi ;;
    mul)
      if (( ${#__Math_staticBinOp_dA} + ${#__Math_staticBinOp_dB} <= __Math_FAST_DIGITS )); then
        local -i __Math_staticBinOp_iA __Math_staticBinOp_iB
        __Math.toInt64 "$__Math_staticBinOp_dA" $__Math_staticBinOp_sA $__Math_staticBinOp_nA __Math_staticBinOp_iA
        __Math.toInt64 "$__Math_staticBinOp_dB" $__Math_staticBinOp_sB $__Math_staticBinOp_nB __Math_staticBinOp_iB
        __Math.fromInt64 $(( __Math_staticBinOp_iA * __Math_staticBinOp_iB )) $(( __Math_staticBinOp_sA + __Math_staticBinOp_sB )) __Math_staticBinOp_rd __Math_staticBinOp_rs __Math_staticBinOp_rn
        __Math.formatVal "$__Math_staticBinOp_rd" $__Math_staticBinOp_rs $__Math_staticBinOp_rn ${into:-}
        return
      fi ;;
  esac

  # Slow path: arbitrary precision string engine
  case "$__Math_staticBinOp_op" in
    add) __Math.alignScale __Math_staticBinOp_dA __Math_staticBinOp_sA __Math_staticBinOp_dB __Math_staticBinOp_sB
         __Math.rawAdd "$__Math_staticBinOp_dA" $__Math_staticBinOp_sA $__Math_staticBinOp_nA "$__Math_staticBinOp_dB" $__Math_staticBinOp_sB $__Math_staticBinOp_nB __Math_staticBinOp_rd __Math_staticBinOp_rs __Math_staticBinOp_rn ;;
    sub) __Math.alignScale __Math_staticBinOp_dA __Math_staticBinOp_sA __Math_staticBinOp_dB __Math_staticBinOp_sB
         __Math.rawSub "$__Math_staticBinOp_dA" $__Math_staticBinOp_sA $__Math_staticBinOp_nA "$__Math_staticBinOp_dB" $__Math_staticBinOp_sB $__Math_staticBinOp_nB __Math_staticBinOp_rd __Math_staticBinOp_rs __Math_staticBinOp_rn ;;
    mul) __Math.rawMul "$__Math_staticBinOp_dA" $__Math_staticBinOp_sA $__Math_staticBinOp_nA "$__Math_staticBinOp_dB" $__Math_staticBinOp_sB $__Math_staticBinOp_nB __Math_staticBinOp_rd __Math_staticBinOp_rs __Math_staticBinOp_rn ;;
    div) local -i __Math_staticBinOp_prec=${precision:-$__Math_precision}
         __Math.rawDiv "$__Math_staticBinOp_dA" $__Math_staticBinOp_sA $__Math_staticBinOp_nA "$__Math_staticBinOp_dB" $__Math_staticBinOp_sB $__Math_staticBinOp_nB __Math_staticBinOp_rd __Math_staticBinOp_rs __Math_staticBinOp_rn $__Math_staticBinOp_prec ;;
    mod) [[ "$__Math_staticBinOp_dB" == "0" ]] && _Crash "Math: modulo by zero"
         __Math.alignScale __Math_staticBinOp_dA __Math_staticBinOp_sA __Math_staticBinOp_dB __Math_staticBinOp_sB
         local -i __Math_staticBinOp_iA __Math_staticBinOp_iB
         __Math.toInt64 "$__Math_staticBinOp_dA" $__Math_staticBinOp_sA $__Math_staticBinOp_nA __Math_staticBinOp_iA \
           || _Crash "Math: mod operand too large for native arithmetic"
         __Math.toInt64 "$__Math_staticBinOp_dB" $__Math_staticBinOp_sB $__Math_staticBinOp_nB __Math_staticBinOp_iB \
           || _Crash "Math: mod operand too large for native arithmetic"
         __Math.fromInt64 $(( __Math_staticBinOp_iA % __Math_staticBinOp_iB )) $__Math_staticBinOp_sA __Math_staticBinOp_rd __Math_staticBinOp_rs __Math_staticBinOp_rn ;;
  esac

  __Math.formatVal "$__Math_staticBinOp_rd" $__Math_staticBinOp_rs $__Math_staticBinOp_rn ${into:-}
}

# Internal: static unary op. Returns plain value string.
__Math.staticUnaryOp() {
  local __Math_staticUnaryOp_op="$1"
  local __Math_staticUnaryOp_d
  local -i __Math_staticUnaryOp_s __Math_staticUnaryOp_n
  __Math.resolve "$2" __Math_staticUnaryOp_d __Math_staticUnaryOp_s __Math_staticUnaryOp_n

  case "$__Math_staticUnaryOp_op" in
    abs)    __Math_staticUnaryOp_n=0 ;;
    neg)    [[ "$__Math_staticUnaryOp_d" == "0" ]] && __Math_staticUnaryOp_n=0 || (( __Math_staticUnaryOp_n = !__Math_staticUnaryOp_n )) ;;
    square) local __Math_staticUnaryOp_rd; local -i __Math_staticUnaryOp_rs __Math_staticUnaryOp_rn
            __Math.rawMul "$__Math_staticUnaryOp_d" $__Math_staticUnaryOp_s $__Math_staticUnaryOp_n "$__Math_staticUnaryOp_d" $__Math_staticUnaryOp_s $__Math_staticUnaryOp_n __Math_staticUnaryOp_rd __Math_staticUnaryOp_rs __Math_staticUnaryOp_rn
            __Math.formatVal "$__Math_staticUnaryOp_rd" $__Math_staticUnaryOp_rs 0 ${into:-}
            return ;;
  esac

  __Math.formatVal "$__Math_staticUnaryOp_d" $__Math_staticUnaryOp_s $__Math_staticUnaryOp_n ${into:-}
}

# Dual-mode wrappers: static (no self) returns value string,
# instance (self set) delegates to __Math.i_* which returns object.

Math.add()      { if [[ -n "${_Self:-}" ]]; then local -I _Self; local _Class="${_Class:-Math}"; __Math.i_add "$@"; else __Math.staticBinOp add "$@"; fi; }
Math.subtract() { if [[ -n "${_Self:-}" ]]; then local -I _Self; local _Class="${_Class:-Math}"; __Math.i_sub "$@"; else __Math.staticBinOp sub "$@"; fi; }
Math.multiply() { if [[ -n "${_Self:-}" ]]; then local -I _Self; local _Class="${_Class:-Math}"; __Math.i_mul "$@"; else __Math.staticBinOp mul "$@"; fi; }
Math.divide()   { if [[ -n "${_Self:-}" ]]; then local -I _Self; local _Class="${_Class:-Math}"; __Math.i_div "$@"; else __Math.staticBinOp div "$@"; fi; }
Math.square()   { if [[ -n "${_Self:-}" ]]; then local -I _Self; local _Class="${_Class:-Math}"; __Math.i_square "$@"; else __Math.staticUnaryOp square "$1"; fi; }
Math.abs()      { if [[ -n "${_Self:-}" ]]; then local -I _Self; local _Class="${_Class:-Math}"; __Math.i_abs "$@"; else __Math.staticUnaryOp abs "$1"; fi; }
Math.neg()      { if [[ -n "${_Self:-}" ]]; then local -I _Self; local _Class="${_Class:-Math}"; __Math.i_neg "$@"; else __Math.staticUnaryOp neg "$1"; fi; }
Math.mod()      { if [[ -n "${_Self:-}" ]]; then local -I _Self; local _Class="${_Class:-Math}"; __Math.i_mod "$@"; else __Math.staticBinOp mod "$@"; fi; }
Math.pow()      { if [[ -n "${_Self:-}" ]]; then local -I _Self; local _Class="${_Class:-Math}"; __Math.i_pow "$@"; else
  # Static pow: create temp object, call i_pow, extract value
  local __Math_staticPow_tmp; into=__Math_staticPow_tmp Math.new "$1"
  local __Math_staticPow_result; into=__Math_staticPow_result _Self="$__Math_staticPow_tmp" _Class=Math __Math.i_pow "$2"
  local __Math_staticPow_val; into=__Math_staticPow_val _Self="$__Math_staticPow_result" _Class=Math Math.val
  boop.pass "$__Math_staticPow_val" ${into:-}; fi; }

# Symbol aliases — same functions, shorter names.
# The +, *, / characters require the `function` keyword form inside eval.
# Bash's shorthand name() syntax rejects special chars even in eval;
# `function name` is more permissive about what constitutes a valid name.
Math.x() { Math.multiply "$@"; }
eval 'function Math.+  { Math.add "$@"; }'
eval 'function Math.-  { Math.subtract "$@"; }'
eval 'function Math.* { Math.multiply "$@"; }'
eval 'function Math./  { Math.divide "$@"; }'
eval 'function Math.%  { Math.mod "$@"; }'
eval 'function Math.^  { Math.pow "$@"; }'

# ============================================================================
# Expression Evaluators — Math.DO (infix) and Math.RPN (postfix)
# ============================================================================

# Classify a token as operator, paren, or operand.
# Sets the nameref $2 to: "op", "lparen", "rparen", or "num".
__Math.tokenType() {
  local -n __Math_tokenType_out="$2"
  case "$1" in
    +|-|x|'*'|/) __Math_tokenType_out="op" ;;
    '(') __Math_tokenType_out="lparen" ;;
    ')') __Math_tokenType_out="rparen" ;;
    *) __Math_tokenType_out="num" ;;
  esac
}

# Operator precedence: + and - are 1, x and / are 2.
# Sets nameref $2 to the precedence level.
__Math.precedence() {
  local -n __Math_precedence_out="$2"
  case "$1" in
    +|-) __Math_precedence_out=1 ;;
    x|'*'|/) __Math_precedence_out=2 ;;
    *) __Math_precedence_out=0 ;;
  esac
}

# Apply a binary operator to two value strings. Returns value string via nameref $4.
__Math.applyOp() {
  local __Math_applyOp_op="$1" __Math_applyOp_a="$2" __Math_applyOp_b="$3"
  local -n __Math_applyOp_out="$4"
  case "$__Math_applyOp_op" in
    +)     into=__Math_applyOp_out __Math.staticBinOp add "$__Math_applyOp_a" "$__Math_applyOp_b" ;;
    -)     into=__Math_applyOp_out __Math.staticBinOp sub "$__Math_applyOp_a" "$__Math_applyOp_b" ;;
    x|'*') into=__Math_applyOp_out __Math.staticBinOp mul "$__Math_applyOp_a" "$__Math_applyOp_b" ;;
    /)     into=__Math_applyOp_out __Math.staticBinOp div "$__Math_applyOp_a" "$__Math_applyOp_b" ;;
  esac
}

# Tokenize an expression string into an array of tokens.
#
# Uses BASH_REMATCH to chomp whole tokens at once — a number (possibly
# multi-digit with decimals) is one match, not one iteration per char.
# Splits on operator and paren boundaries. Whitespace is skipped.
#
# Leading minus is treated as part of a number (negative sign) when it
# appears at the start of the expression, after an operator, or after
# an open paren. Otherwise it's the subtraction operator.
#
# $1 = input string
# $2 = nameref to output array
__Math.tokenize() {
  local __Math_tokenize_str="$1"
  local -n __Math_tokenize_out="$2"
  __Math_tokenize_out=()
  local -i __Math_tokenize_osp=0
  local __Math_tokenize_prev=""

  while [[ -n "$__Math_tokenize_str" ]]; do
    # Skip whitespace
    if [[ "$__Math_tokenize_str" =~ ^[[:space:]]+ ]]; then
      __Math_tokenize_str="${__Math_tokenize_str:${#BASH_REMATCH[0]}}"
      continue
    fi

    # Number with leading minus (negative) — only when prev is empty, op, or (
    if [[ ( -z "$__Math_tokenize_prev" || "$__Math_tokenize_prev" == "op" || "$__Math_tokenize_prev" == "(" ) \
          && "$__Math_tokenize_str" =~ ^-[0-9.]+ ]]; then
      __Math_tokenize_out[$__Math_tokenize_osp]="${BASH_REMATCH[0]}"; (( __Math_tokenize_osp++ ))
      __Math_tokenize_str="${__Math_tokenize_str:${#BASH_REMATCH[0]}}"
      __Math_tokenize_prev="num"

    # Positive number
    elif [[ "$__Math_tokenize_str" =~ ^[0-9.]+ ]]; then
      __Math_tokenize_out[$__Math_tokenize_osp]="${BASH_REMATCH[0]}"; (( __Math_tokenize_osp++ ))
      __Math_tokenize_str="${__Math_tokenize_str:${#BASH_REMATCH[0]}}"
      __Math_tokenize_prev="num"

    # Open paren
    elif [[ "${__Math_tokenize_str:0:1}" == "(" ]]; then
      __Math_tokenize_out[$__Math_tokenize_osp]="("; (( __Math_tokenize_osp++ ))
      __Math_tokenize_str="${__Math_tokenize_str:1}"
      __Math_tokenize_prev="("

    # Close paren
    elif [[ "${__Math_tokenize_str:0:1}" == ")" ]]; then
      __Math_tokenize_out[$__Math_tokenize_osp]=")"; (( __Math_tokenize_osp++ ))
      __Math_tokenize_str="${__Math_tokenize_str:1}"
      __Math_tokenize_prev=")"

    # Operator: + - x * /
    elif [[ "$__Math_tokenize_str" =~ ^[+x*/-] ]]; then
      __Math_tokenize_out[$__Math_tokenize_osp]="${BASH_REMATCH[0]}"; (( __Math_tokenize_osp++ ))
      __Math_tokenize_str="${__Math_tokenize_str:1}"
      __Math_tokenize_prev="op"

    # Unknown character — skip it
    else
      __Math_tokenize_str="${__Math_tokenize_str:1}"
    fi
  done
}

# Math.RPN — reverse Polish notation evaluator.
#
# The single evaluation engine for all expression evaluation. Math.DO
# converts infix to RPN tokens, then delegates here. Calling Math.RPN
# directly skips the precedence pass — you supply the order.
#
# All arguments are collapsed via "$*" into a single string, then split
# on whitespace. This handles separate args, quoted strings, or any mix:
#   Math.RPN 1.5 2.3 +          # separate args
#   Math.RPN "1.5 2.3 +"        # single string
#   Math.RPN "1.5 2.3" +        # mixed
#
# Operands are pushed onto a stack. When an operator is encountered,
# it pops two operands, applies the operation, and pushes the result.
# Uses plain bash arrays as stacks — no Stack class dependency.
#
# Usage:
#   into=v Math.RPN 1.5 2.3 +                   # 3.8
#   into=v Math.RPN 1.5 2.3 + 4 x               # 15.2
#   into=v Math.RPN "3 4 + 2 x"                  # 14
#   into=v Math.RPN 10 3 /                        # 3.33333...
Math.RPN() {
  local IFS=' '
  local -a __Math_RPN_tokens
  read -ra __Math_RPN_tokens <<< "$*"

  local -a __Math_RPN_stack=()
  local -i __Math_RPN_sp=0
  local __Math_RPN_tok __Math_RPN_type

  for __Math_RPN_tok in "${__Math_RPN_tokens[@]}"; do
    __Math.tokenType "$__Math_RPN_tok" __Math_RPN_type

    if [[ "$__Math_RPN_type" == "num" ]]; then
      __Math_RPN_stack[$__Math_RPN_sp]="$__Math_RPN_tok"
      (( __Math_RPN_sp++ ))
    elif [[ "$__Math_RPN_type" == "op" ]]; then
      (( __Math_RPN_sp < 2 )) && _Crash "Math.RPN: not enough operands for '$__Math_RPN_tok'"
      (( __Math_RPN_sp-- ))
      local __Math_RPN_b="${__Math_RPN_stack[$__Math_RPN_sp]}"
      (( __Math_RPN_sp-- ))
      local __Math_RPN_a="${__Math_RPN_stack[$__Math_RPN_sp]}"
      local __Math_RPN_r
      __Math.applyOp "$__Math_RPN_tok" "$__Math_RPN_a" "$__Math_RPN_b" __Math_RPN_r
      __Math_RPN_stack[$__Math_RPN_sp]="$__Math_RPN_r"
      (( __Math_RPN_sp++ ))
    fi
  done

  (( __Math_RPN_sp != 1 )) && _Crash "Math.RPN: invalid expression (${__Math_RPN_sp} values remain)"
  boop.pass "${__Math_RPN_stack[0]}" ${into:-}
}

# Math.DO — infix expression evaluator with operator precedence and parens.
#
# All arguments are collapsed via "$*" into a single string, then run
# through __Math.tokenize which splits on operator/paren boundaries.
# This handles any input style:
#   Math.DO 1.5 + 2.3              # separate args
#   Math.DO "1.5 + 2.3"            # single string
#   Math.DO "(1.5+2.3)x4"          # packed, no whitespace
#   Math.DO "( 1.5 + 2.3 )" x 4   # mixed
#
# Implements the shunting-yard algorithm (Dijkstra) to convert the
# tokenized infix expression into RPN, then delegates to Math.RPN
# for evaluation. One evaluation engine, one precedence pass.
#
# Handles +, -, x (or *), /, and parentheses. Standard precedence:
# x and / bind tighter than + and -. Left-to-right associativity for
# equal precedence. Leading minus is recognized as negative sign when
# it appears at the start, after an operator, or after an open paren.
#
# Usage:
#   into=v Math.DO 1.5 + 2.3                    # 3.8
#   into=v Math.DO 2 + 3 x 4                    # 14 (precedence)
#   into=v Math.DO '(' 2 + 3 ')' x 4            # 20 (parens)
#   into=v Math.DO "(2+3)x4"                    # 20 (packed)
#   into=v Math.DO "( 1.5 + 2.5 ) x 4"         # 16 (string mode)
Math.DO() {
  # Collapse all args into one string, tokenize with boundary splitting
  local IFS=' '
  local -a __Math_DO_tokens
  __Math.tokenize "$*" __Math_DO_tokens

  # Shunting-yard: convert infix tokens to RPN token array
  local -a __Math_DO_ops=() __Math_DO_rpn=()
  local -i __Math_DO_osp=0 __Math_DO_rsp=0
  local __Math_DO_tok __Math_DO_type __Math_DO_prec __Math_DO_top_prec

  for __Math_DO_tok in "${__Math_DO_tokens[@]}"; do
    __Math.tokenType "$__Math_DO_tok" __Math_DO_type

    case "$__Math_DO_type" in
      num)
        __Math_DO_rpn[$__Math_DO_rsp]="$__Math_DO_tok"
        (( __Math_DO_rsp++ ))
        ;;
      op)
        __Math.precedence "$__Math_DO_tok" __Math_DO_prec
        while (( __Math_DO_osp > 0 )); do
          local __Math_DO_top="${__Math_DO_ops[$(( __Math_DO_osp - 1 ))]}"
          [[ "$__Math_DO_top" == "(" ]] && break
          __Math.precedence "$__Math_DO_top" __Math_DO_top_prec
          (( __Math_DO_top_prec < __Math_DO_prec )) && break
          (( __Math_DO_osp-- ))
          __Math_DO_rpn[$__Math_DO_rsp]="$__Math_DO_top"
          (( __Math_DO_rsp++ ))
        done
        __Math_DO_ops[$__Math_DO_osp]="$__Math_DO_tok"
        (( __Math_DO_osp++ ))
        ;;
      lparen)
        __Math_DO_ops[$__Math_DO_osp]="("
        (( __Math_DO_osp++ ))
        ;;
      rparen)
        while (( __Math_DO_osp > 0 )) && [[ "${__Math_DO_ops[$(( __Math_DO_osp - 1 ))]}" != "(" ]]; do
          (( __Math_DO_osp-- ))
          __Math_DO_rpn[$__Math_DO_rsp]="${__Math_DO_ops[$__Math_DO_osp]}"
          (( __Math_DO_rsp++ ))
        done
        (( __Math_DO_osp > 0 )) && (( __Math_DO_osp-- ))  # discard the "("
        ;;
    esac
  done

  # Drain remaining operators onto the RPN output
  while (( __Math_DO_osp > 0 )); do
    (( __Math_DO_osp-- ))
    __Math_DO_rpn[$__Math_DO_rsp]="${__Math_DO_ops[$__Math_DO_osp]}"
    (( __Math_DO_rsp++ ))
  done

  # Evaluate via the shared RPN engine
  Math.RPN "${__Math_DO_rpn[@]}"
}
