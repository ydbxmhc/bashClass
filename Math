# ============================================================================
# Static API — class-level functions that return plain value strings
# ============================================================================
# These overwrite the dispatch wrappers created by registerClass. They
# provide a dual-mode API:
#
#   Static (no self):  into=v Math.add 1.5 2.3     → v="3.8"
#   Instance (self):   into=r $obj.add 2.3          → r=object_id
#
# Static calls resolve literal arguments through the raw string engine,
# compute the result, and return a formatted decimal string — no objects
# created. Instance calls delegate to the registered __Math.i_* impl
# which returns a Math object as before.
#
# Full-word names are the primary API. Short aliases are defined below.
#
# Naming:
#   Math.add / Math.subtract / Math.multiply / Math.divide / Math.square
#   Math.abs / Math.neg
#   Math.+ / Math.- / Math.x / Math.* / Math./    (symbol aliases)
#   Math.DO   — infix expression evaluator with precedence and parens
#   Math.RPN  — reverse Polish notation evaluator

# Format a raw digit/scale/neg triple as a decimal value string.
# Same logic as Math.val but operates on raw components, no object needed.
# Strips trailing zeros past the decimal point for clean output.
__Math.formatVal() {
  local __fv_d="$1"
  local -i __fv_s="$2" __fv_n="$3"

  # Strip leading zeros from digits (inline — no subshell)
  __fv_d="${__fv_d#"${__fv_d%%[!0]*}"}"
  : "${__fv_d:=0}"

  # Strip trailing zeros past decimal in one shot via suffix detection
  if (( __fv_s > 0 )); then
    local __fv_tail="${__fv_d##*[!0]}"
    local -i __fv_taillen=${#__fv_tail}
    if (( __fv_taillen > 0 && __fv_taillen <= __fv_s )); then
      __fv_d="${__fv_d:0:${#__fv_d}-__fv_taillen}"
      (( __fv_s -= __fv_taillen ))
    elif (( __fv_taillen > __fv_s )); then
      __fv_d="${__fv_d:0:${#__fv_d}-__fv_s}"
      __fv_s=0
    fi
    : "${__fv_d:=0}"
  fi

  local __fv_result
  if (( __fv_s == 0 )); then
    __fv_result="$__fv_d"
  elif (( __fv_s >= ${#__fv_d} )); then
    # Pad with leading zeros in one shot via printf
    local -i __fv_need=$(( __fv_s - ${#__fv_d} ))
    local __fv_pad
    if (( __fv_need > 0 )); then
      printf -v __fv_pad "%0${__fv_need}d" 0
      __fv_pad="${__fv_pad}${__fv_d}"
    else
      __fv_pad="$__fv_d"
    fi
    __fv_result="0.${__fv_pad}"
  else
    local -i __fv_split=$(( ${#__fv_d} - __fv_s ))
    __fv_result="${__fv_d:0:__fv_split}.${__fv_d:__fv_split}"
  fi

  (( __fv_n )) && [[ "$__fv_result" != "0" ]] && __fv_result="-${__fv_result}"
  __boop.return "$__fv_result" "${4:-}"
}

# Internal: static binary op. Returns plain value string via __boop.return.
# Uses native $(( )) fast path when operands fit in 64-bit.
__Math.staticBinOp() {
  local __sbo_op="$1"
  local __sbo_dA __sbo_dB
  local -i __sbo_sA __sbo_sB __sbo_nA __sbo_nB
  __Math.resolve "$2" __sbo_dA __sbo_sA __sbo_nA
  __Math.resolve "$3" __sbo_dB __sbo_sB __sbo_nB

  local __sbo_rd
  local -i __sbo_rs __sbo_rn

  # Fast path for add/sub/mul/mod when operands fit in 64-bit
  case "$__sbo_op" in
    add|sub|mod)
      if (( ${#__sbo_dA} <= __Math_FAST_DIGITS && ${#__sbo_dB} <= __Math_FAST_DIGITS )); then
        __Math.alignScale __sbo_dA __sbo_sA __sbo_dB __sbo_sB
        if (( ${#__sbo_dA} <= __Math_FAST_DIGITS )); then
          local -i __sbo_iA __sbo_iB
          __Math.toInt64 "$__sbo_dA" $__sbo_sA $__sbo_nA __sbo_iA
          __Math.toInt64 "$__sbo_dB" $__sbo_sB $__sbo_nB __sbo_iB
          case "$__sbo_op" in
            add) __Math.fromInt64 $(( __sbo_iA + __sbo_iB )) $__sbo_sA __sbo_rd __sbo_rs __sbo_rn ;;
            sub) __Math.fromInt64 $(( __sbo_iA - __sbo_iB )) $__sbo_sA __sbo_rd __sbo_rs __sbo_rn ;;
            mod) [[ "$__sbo_dB" == "0" ]] && __boop.crash "Math: modulo by zero"
                 __Math.fromInt64 $(( __sbo_iA % __sbo_iB )) $__sbo_sA __sbo_rd __sbo_rs __sbo_rn ;;
          esac
          __Math.formatVal "$__sbo_rd" $__sbo_rs $__sbo_rn ${into:-}
          return
        fi
      fi ;;
    mul)
      if (( ${#__sbo_dA} + ${#__sbo_dB} <= __Math_FAST_DIGITS )); then
        local -i __sbo_iA __sbo_iB
        __Math.toInt64 "$__sbo_dA" $__sbo_sA $__sbo_nA __sbo_iA
        __Math.toInt64 "$__sbo_dB" $__sbo_sB $__sbo_nB __sbo_iB
        __Math.fromInt64 $(( __sbo_iA * __sbo_iB )) $(( __sbo_sA + __sbo_sB )) __sbo_rd __sbo_rs __sbo_rn
        __Math.formatVal "$__sbo_rd" $__sbo_rs $__sbo_rn ${into:-}
        return
      fi ;;
  esac

  # Slow path: arbitrary precision string engine
  case "$__sbo_op" in
    add) __Math.alignScale __sbo_dA __sbo_sA __sbo_dB __sbo_sB
         __Math.rawAdd "$__sbo_dA" $__sbo_sA $__sbo_nA "$__sbo_dB" $__sbo_sB $__sbo_nB __sbo_rd __sbo_rs __sbo_rn ;;
    sub) __Math.alignScale __sbo_dA __sbo_sA __sbo_dB __sbo_sB
         __Math.rawSub "$__sbo_dA" $__sbo_sA $__sbo_nA "$__sbo_dB" $__sbo_sB $__sbo_nB __sbo_rd __sbo_rs __sbo_rn ;;
    mul) __Math.rawMul "$__sbo_dA" $__sbo_sA $__sbo_nA "$__sbo_dB" $__sbo_sB $__sbo_nB __sbo_rd __sbo_rs __sbo_rn ;;
    div) local -i __sbo_prec=${precision:-$__Math_precision}
         __Math.rawDiv "$__sbo_dA" $__sbo_sA $__sbo_nA "$__sbo_dB" $__sbo_sB $__sbo_nB __sbo_rd __sbo_rs __sbo_rn $__sbo_prec ;;
    mod) [[ "$__sbo_dB" == "0" ]] && __boop.crash "Math: modulo by zero"
         __Math.alignScale __sbo_dA __sbo_sA __sbo_dB __sbo_sB
         local -i __sbo_iA __sbo_iB
         __Math.toInt64 "$__sbo_dA" $__sbo_sA $__sbo_nA __sbo_iA \
           || __boop.crash "Math: mod operand too large for native arithmetic"
         __Math.toInt64 "$__sbo_dB" $__sbo_sB $__sbo_nB __sbo_iB \
           || __boop.crash "Math: mod operand too large for native arithmetic"
         __Math.fromInt64 $(( __sbo_iA % __sbo_iB )) $__sbo_sA __sbo_rd __sbo_rs __sbo_rn ;;
  esac

  __Math.formatVal "$__sbo_rd" $__sbo_rs $__sbo_rn ${into:-}
}

# Internal: static unary op. Returns plain value string.
__Math.staticUnaryOp() {
  local __suo_op="$1"
  local __suo_d
  local -i __suo_s __suo_n
  __Math.resolve "$2" __suo_d __suo_s __suo_n

  case "$__suo_op" in
    abs)    __suo_n=0 ;;
    neg)    [[ "$__suo_d" == "0" ]] && __suo_n=0 || (( __suo_n = !__suo_n )) ;;
    square) local __suo_rd; local -i __suo_rs __suo_rn
            __Math.rawMul "$__suo_d" $__suo_s $__suo_n "$__suo_d" $__suo_s $__suo_n __suo_rd __suo_rs __suo_rn
            __Math.formatVal "$__suo_rd" $__suo_rs 0 ${into:-}
            return ;;
  esac

  __Math.formatVal "$__suo_d" $__suo_s $__suo_n ${into:-}
}

# Dual-mode wrappers: static (no self) returns value string,
# instance (self set) delegates to __Math.i_* which returns object.

Math.add()      { if [[ -n "${_Self:-}" ]]; then local -I _Self _Class; __Math.i_add "$@"; else __Math.staticBinOp add "$@"; fi; }
Math.subtract() { if [[ -n "${_Self:-}" ]]; then local -I _Self _Class; __Math.i_sub "$@"; else __Math.staticBinOp sub "$@"; fi; }
Math.multiply() { if [[ -n "${_Self:-}" ]]; then local -I _Self _Class; __Math.i_mul "$@"; else __Math.staticBinOp mul "$@"; fi; }
Math.divide()   { if [[ -n "${_Self:-}" ]]; then local -I _Self _Class; __Math.i_div "$@"; else __Math.staticBinOp div "$@"; fi; }
Math.square()   { if [[ -n "${_Self:-}" ]]; then local -I _Self _Class; __Math.i_square "$@"; else __Math.staticUnaryOp square "$1"; fi; }
Math.abs()      { if [[ -n "${_Self:-}" ]]; then local -I _Self _Class; __Math.i_abs "$@"; else __Math.staticUnaryOp abs "$1"; fi; }
Math.neg()      { if [[ -n "${_Self:-}" ]]; then local -I _Self _Class; __Math.i_neg "$@"; else __Math.staticUnaryOp neg "$1"; fi; }
Math.mod()      { if [[ -n "${_Self:-}" ]]; then local -I _Self _Class; __Math.i_mod "$@"; else __Math.staticBinOp mod "$@"; fi; }
Math.pow()      { if [[ -n "${_Self:-}" ]]; then local -I _Self _Class; __Math.i_pow "$@"; else
  # Static pow: create temp object, call i_pow, extract value
  local __spow_tmp; into=__spow_tmp Math.new "$1"
  local __spow_result; into=__spow_result _Self="$__spow_tmp" _Class=Math __Math.i_pow "$2"
  local __spow_val; into=__spow_val _Self="$__spow_result" _Class=Math Math.val
  __boop.return "$__spow_val" ${into:-}; fi; }

# Symbol aliases — same functions, shorter names.
# The +, *, / characters require the `function` keyword form inside eval.
# Bash's shorthand name() syntax rejects special chars even in eval;
# `function name` is more permissive about what constitutes a valid name.
Math.x() { Math.multiply "$@"; }
eval 'function Math.+  { Math.add "$@"; }'
eval 'function Math.-  { Math.subtract "$@"; }'
eval 'function Math.* { Math.multiply "$@"; }'
eval 'function Math./  { Math.divide "$@"; }'
eval 'function Math.%  { Math.mod "$@"; }'
eval 'function Math.^  { Math.pow "$@"; }'

# ============================================================================
# Expression Evaluators — Math.DO (infix) and Math.RPN (postfix)
# ============================================================================

# Classify a token as operator, paren, or operand.
# Sets the nameref $2 to: "op", "lparen", "rparen", or "num".
__Math.tokenType() {
  local -n __tt_out="$2"
  case "$1" in
    +|-|x|'*'|/) __tt_out="op" ;;
    '(') __tt_out="lparen" ;;
    ')') __tt_out="rparen" ;;
    *) __tt_out="num" ;;
  esac
}

# Operator precedence: + and - are 1, x and / are 2.
# Sets nameref $2 to the precedence level.
__Math.precedence() {
  local -n __prec_out="$2"
  case "$1" in
    +|-) __prec_out=1 ;;
    x|'*'|/) __prec_out=2 ;;
    *) __prec_out=0 ;;
  esac
}

# Apply a binary operator to two value strings. Returns value string via nameref $4.
__Math.applyOp() {
  local __ao_op="$1" __ao_a="$2" __ao_b="$3"
  local -n __ao_out="$4"
  case "$__ao_op" in
    +)     into=__ao_out __Math.staticBinOp add "$__ao_a" "$__ao_b" ;;
    -)     into=__ao_out __Math.staticBinOp sub "$__ao_a" "$__ao_b" ;;
    x|'*') into=__ao_out __Math.staticBinOp mul "$__ao_a" "$__ao_b" ;;
    /)     into=__ao_out __Math.staticBinOp div "$__ao_a" "$__ao_b" ;;
  esac
}

# Tokenize an expression string into an array of tokens.
#
# Uses BASH_REMATCH to chomp whole tokens at once — a number (possibly
# multi-digit with decimals) is one match, not one iteration per char.
# Splits on operator and paren boundaries. Whitespace is skipped.
#
# Leading minus is treated as part of a number (negative sign) when it
# appears at the start of the expression, after an operator, or after
# an open paren. Otherwise it's the subtraction operator.
#
# $1 = input string
# $2 = nameref to output array
__Math.tokenize() {
  local __tz_str="$1"
  local -n __tz_out="$2"
  __tz_out=()
  local -i __tz_osp=0
  local __tz_prev=""

  while [[ -n "$__tz_str" ]]; do
    # Skip whitespace
    if [[ "$__tz_str" =~ ^[[:space:]]+ ]]; then
      __tz_str="${__tz_str:${#BASH_REMATCH[0]}}"
      continue
    fi

    # Number with leading minus (negative) — only when prev is empty, op, or (
    if [[ ( -z "$__tz_prev" || "$__tz_prev" == "op" || "$__tz_prev" == "(" ) \
          && "$__tz_str" =~ ^-[0-9.]+ ]]; then
      __tz_out[$__tz_osp]="${BASH_REMATCH[0]}"; (( __tz_osp++ ))
      __tz_str="${__tz_str:${#BASH_REMATCH[0]}}"
      __tz_prev="num"

    # Positive number
    elif [[ "$__tz_str" =~ ^[0-9.]+ ]]; then
      __tz_out[$__tz_osp]="${BASH_REMATCH[0]}"; (( __tz_osp++ ))
      __tz_str="${__tz_str:${#BASH_REMATCH[0]}}"
      __tz_prev="num"

    # Open paren
    elif [[ "${__tz_str:0:1}" == "(" ]]; then
      __tz_out[$__tz_osp]="("; (( __tz_osp++ ))
      __tz_str="${__tz_str:1}"
      __tz_prev="("

    # Close paren
    elif [[ "${__tz_str:0:1}" == ")" ]]; then
      __tz_out[$__tz_osp]=")"; (( __tz_osp++ ))
      __tz_str="${__tz_str:1}"
      __tz_prev=")"

    # Operator: + - x * /
    elif [[ "$__tz_str" =~ ^[+x*/-] ]]; then
      __tz_out[$__tz_osp]="${BASH_REMATCH[0]}"; (( __tz_osp++ ))
      __tz_str="${__tz_str:1}"
      __tz_prev="op"

    # Unknown character — skip it
    else
      __tz_str="${__tz_str:1}"
    fi
  done
}

# Math.RPN — reverse Polish notation evaluator.
#
# The single evaluation engine for all expression evaluation. Math.DO
# converts infix to RPN tokens, then delegates here. Calling Math.RPN
# directly skips the precedence pass — you supply the order.
#
# All arguments are collapsed via "$*" into a single string, then split
# on whitespace. This handles separate args, quoted strings, or any mix:
#   Math.RPN 1.5 2.3 +          # separate args
#   Math.RPN "1.5 2.3 +"        # single string
#   Math.RPN "1.5 2.3" +        # mixed
#
# Operands are pushed onto a stack. When an operator is encountered,
# it pops two operands, applies the operation, and pushes the result.
# Uses plain bash arrays as stacks — no Stack class dependency.
#
# Usage:
#   into=v Math.RPN 1.5 2.3 +                   # 3.8
#   into=v Math.RPN 1.5 2.3 + 4 x               # 15.2
#   into=v Math.RPN "3 4 + 2 x"                  # 14
#   into=v Math.RPN 10 3 /                        # 3.33333...
Math.RPN() {
  local IFS=' '
  local -a __rpn_tokens
  read -ra __rpn_tokens <<< "$*"

  local -a __rpn_stack=()
  local -i __rpn_sp=0
  local __rpn_tok __rpn_type

  for __rpn_tok in "${__rpn_tokens[@]}"; do
    __Math.tokenType "$__rpn_tok" __rpn_type

    if [[ "$__rpn_type" == "num" ]]; then
      __rpn_stack[$__rpn_sp]="$__rpn_tok"
      (( __rpn_sp++ ))
    elif [[ "$__rpn_type" == "op" ]]; then
      (( __rpn_sp < 2 )) && __boop.crash "Math.RPN: not enough operands for '$__rpn_tok'"
      (( __rpn_sp-- ))
      local __rpn_b="${__rpn_stack[$__rpn_sp]}"
      (( __rpn_sp-- ))
      local __rpn_a="${__rpn_stack[$__rpn_sp]}"
      local __rpn_r
      __Math.applyOp "$__rpn_tok" "$__rpn_a" "$__rpn_b" __rpn_r
      __rpn_stack[$__rpn_sp]="$__rpn_r"
      (( __rpn_sp++ ))
    fi
  done

  (( __rpn_sp != 1 )) && __boop.crash "Math.RPN: invalid expression (${__rpn_sp} values remain)"
  __boop.return "${__rpn_stack[0]}" ${into:-}
}

# Math.DO — infix expression evaluator with operator precedence and parens.
#
# All arguments are collapsed via "$*" into a single string, then run
# through __Math.tokenize which splits on operator/paren boundaries.
# This handles any input style:
#   Math.DO 1.5 + 2.3              # separate args
#   Math.DO "1.5 + 2.3"            # single string
#   Math.DO "(1.5+2.3)x4"          # packed, no whitespace
#   Math.DO "( 1.5 + 2.3 )" x 4   # mixed
#
# Implements the shunting-yard algorithm (Dijkstra) to convert the
# tokenized infix expression into RPN, then delegates to Math.RPN
# for evaluation. One evaluation engine, one precedence pass.
#
# Handles +, -, x (or *), /, and parentheses. Standard precedence:
# x and / bind tighter than + and -. Left-to-right associativity for
# equal precedence. Leading minus is recognized as negative sign when
# it appears at the start, after an operator, or after an open paren.
#
# Usage:
#   into=v Math.DO 1.5 + 2.3                    # 3.8
#   into=v Math.DO 2 + 3 x 4                    # 14 (precedence)
#   into=v Math.DO '(' 2 + 3 ')' x 4            # 20 (parens)
#   into=v Math.DO "(2+3)x4"                    # 20 (packed)
#   into=v Math.DO "( 1.5 + 2.5 ) x 4"         # 16 (string mode)
Math.DO() {
  # Collapse all args into one string, tokenize with boundary splitting
  local IFS=' '
  local -a __do_tokens
  __Math.tokenize "$*" __do_tokens

  # Shunting-yard: convert infix tokens to RPN token array
  local -a __do_ops=() __do_rpn=()
  local -i __do_osp=0 __do_rsp=0
  local __do_tok __do_type __do_prec __do_top_prec

  for __do_tok in "${__do_tokens[@]}"; do
    __Math.tokenType "$__do_tok" __do_type

    case "$__do_type" in
      num)
        __do_rpn[$__do_rsp]="$__do_tok"
        (( __do_rsp++ ))
        ;;
      op)
        __Math.precedence "$__do_tok" __do_prec
        while (( __do_osp > 0 )); do
          local __do_top="${__do_ops[$(( __do_osp - 1 ))]}"
          [[ "$__do_top" == "(" ]] && break
          __Math.precedence "$__do_top" __do_top_prec
          (( __do_top_prec < __do_prec )) && break
          (( __do_osp-- ))
          __do_rpn[$__do_rsp]="$__do_top"
          (( __do_rsp++ ))
        done
        __do_ops[$__do_osp]="$__do_tok"
        (( __do_osp++ ))
        ;;
      lparen)
        __do_ops[$__do_osp]="("
        (( __do_osp++ ))
        ;;
      rparen)
        while (( __do_osp > 0 )) && [[ "${__do_ops[$(( __do_osp - 1 ))]}" != "(" ]]; do
          (( __do_osp-- ))
          __do_rpn[$__do_rsp]="${__do_ops[$__do_osp]}"
          (( __do_rsp++ ))
        done
        (( __do_osp > 0 )) && (( __do_osp-- ))  # discard the "("
        ;;
    esac
  done

  # Drain remaining operators onto the RPN output
  while (( __do_osp > 0 )); do
    (( __do_osp-- ))
    __do_rpn[$__do_rsp]="${__do_ops[$__do_osp]}"
    (( __do_rsp++ ))
  done

  # Evaluate via the shared RPN engine
  Math.RPN "${__do_rpn[@]}"
}
