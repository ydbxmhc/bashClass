__Math.i_neg() {
  local -I _Self; local _Class="${_Class:-Math}"
  local __Math_iNeg_d; local -i __Math_iNeg_s __Math_iNeg_n
  __Math.resolve "$_Self" __Math_iNeg_d __Math_iNeg_s __Math_iNeg_n
  [[ "$__Math_iNeg_d" == "0" ]] && __Math_iNeg_n=0 || (( __Math_iNeg_n = !__Math_iNeg_n ))
  __Math.fromParts "$__Math_iNeg_d" $__Math_iNeg_s $__Math_iNeg_n ${into:-}
}

# Round to N significant digits. Returns a new Math object.
# Uses round-half-up: if the digit past the cut point is >= 5, bump up.
Math.round() {
  local -I _Self; local _Class="${_Class:-Math}"
  local -i __Math_round_prec="${1:-$__Math_precision}"
  local __Math_round_d; local -i __Math_round_s __Math_round_n
  __Math.resolve "$_Self" __Math_round_d __Math_round_s __Math_round_n

  local -i __Math_round_len=${#__Math_round_d}
  (( __Math_round_len <= __Math_round_prec )) && { __Math.fromParts "$__Math_round_d" $__Math_round_s $__Math_round_n ${into:-}; return; }

  # Digit just past the cut point decides rounding
  local -i __Math_round_check=${__Math_round_d:__Math_round_prec:1}
  __Math_round_d="${__Math_round_d:0:__Math_round_prec}"

  if (( __Math_round_check >= 5 )); then
    # Increment the last kept digit. If it's 9, carry propagates.
    local -i __Math_round_last=${__Math_round_d: -1}
    if (( __Math_round_last < 9 )); then
      # Simple case: just bump the last digit
      __Math_round_d="${__Math_round_d:0:${#__Math_round_d}-1}$(( __Math_round_last + 1 ))"
    else
      # Last digit is 9 — need to propagate carry through trailing 9s
      __Math_round_d="${__Math_round_d:0:${#__Math_round_d}-1}"
      if [[ "$__Math_round_d" == *[!9]* ]]; then
        local __Math_round_nines="${__Math_round_d##*[!9]}"
        local -i __Math_round_hlen=$(( ${#__Math_round_d} - ${#__Math_round_nines} ))
        local -i __Math_round_bump=$(( ${__Math_round_d:__Math_round_hlen-1:1} + 1 ))
        printf -v __Math_round_d '%s%d%0*d' "${__Math_round_d:0:__Math_round_hlen-1}" $__Math_round_bump ${#__Math_round_nines} 0
      else
        # Entire prefix is 9s — carry extends the number
        printf -v __Math_round_d '1%0*d' ${#__Math_round_d} 0
      fi
      __Math_round_d="${__Math_round_d}0"
    fi
  fi

  # Adjust scale: we removed (__Math_round_len - __Math_round_prec) digits from the end
  local -i __Math_round_removed=$(( __Math_round_len - __Math_round_prec ))
  (( __Math_round_s = __Math_round_s - __Math_round_removed ))
  (( __Math_round_s < 0 )) && __Math_round_s=0

  __Math.fromParts "$__Math_round_d" $__Math_round_s $__Math_round_n ${into:-}
}

# Truncate to integer string.
Math.toInt() {
  local -I _Self; local _Class="${_Class:-Math}"
  local __Math_toInt64_d; local -i __Math_toInt64_s __Math_toInt64_n
  __Math.resolve "$_Self" __Math_toInt64_d __Math_toInt64_s __Math_toInt64_n

  if (( __Math_toInt64_s >= ${#__Math_toInt64_d} )); then
    boop.pass "0" ${into:-}; return
  fi

  local __Math_toInt64_int="${__Math_toInt64_d:0:${#__Math_toInt64_d}-__Math_toInt64_s}"
  # Inline stripLeading — no subshell
  __Math_toInt64_int="${__Math_toInt64_int#"${__Math_toInt64_int%%[!0]*}"}"
  : "${__Math_toInt64_int:=0}"
  (( __Math_toInt64_n )) && [[ "$__Math_toInt64_int" != "0" ]] && __Math_toInt64_int="-${__Math_toInt64_int}"
  boop.pass "$__Math_toInt64_int" ${into:-}
}

# Return the decimal string representation. "3.14", "-0.5", "42", etc.
Math.val() {
  local -I _Self; local _Class="${_Class:-Math}"
  local __Math_val_d; local -i __Math_val_s __Math_val_n
  __Math.resolve "$_Self" __Math_val_d __Math_val_s __Math_val_n

  local __Math_val_result
  if (( __Math_val_s == 0 )); then
    __Math_val_result="$__Math_val_d"
  elif (( __Math_val_s >= ${#__Math_val_d} )); then
    # All digits are fractional — pad with leading zeros in one shot
    local -i __Math_val_need=$(( __Math_val_s - ${#__Math_val_d} ))
    local __Math_val_pad
    if (( __Math_val_need > 0 )); then
      printf -v __Math_val_pad "%0${__Math_val_need}d" 0
      __Math_val_pad="${__Math_val_pad}${__Math_val_d}"
    else
      __Math_val_pad="$__Math_val_d"
    fi
    __Math_val_result="0.${__Math_val_pad}"
  else
    local -i __Math_val_split=$(( ${#__Math_val_d} - __Math_val_s ))
    __Math_val_result="${__Math_val_d:0:__Math_val_split}.${__Math_val_d:__Math_val_split}"
  fi

  (( __Math_val_n )) && [[ "$__Math_val_result" != "0" ]] && __Math_val_result="-${__Math_val_result}"
  boop.pass "$__Math_val_result" ${into:-}
}

Math.toString() {
  local -I _Self; local _Class="${_Class:-Math}"
  local __Math_toString_val
  into=__Math_toString_val _Self="$_Self" _Class="$_Class" Math.val
  boop.pass "Math($_Self){ $__Math_toString_val }" ${into:-}
}

# Change scale (decimal places). Pads with zeros or rounds to fit.
# Returns a new Math object at the requested scale.
#
# Usage: into=r $m.toScale 4    # force 4 decimal places
Math.toScale() {
  local -I _Self; local _Class="${_Class:-Math}"
  local -i __Math_toScale_target="${1:-0}"
  local __Math_toScale_d; local -i __Math_toScale_s __Math_toScale_n
  __Math.resolve "$_Self" __Math_toScale_d __Math_toScale_s __Math_toScale_n

  if (( __Math_toScale_target > __Math_toScale_s )); then
    # Pad with trailing zeros
    local -i __Math_toScale_diff=$(( __Math_toScale_target - __Math_toScale_s ))
    local __Math_toScale_pad
    printf -v __Math_toScale_pad "%0${__Math_toScale_diff}d" 0
    __Math_toScale_d="${__Math_toScale_d}${__Math_toScale_pad}"
    # Bypass fromParts to preserve trailing zeros
    local __Math_toScale_self
    into=__Math_toScale_self _Class=Math __boop.new "digits=$__Math_toScale_d" "scale=$__Math_toScale_target" "neg=$__Math_toScale_n"
    boop.pass "$__Math_toScale_self" ${into:-}
  elif (( __Math_toScale_target < __Math_toScale_s )); then
    local -i __Math_toScale_sigdigits=$(( ${#__Math_toScale_d} - (__Math_toScale_s - __Math_toScale_target) ))
    (( __Math_toScale_sigdigits < 1 )) && __Math_toScale_sigdigits=1
    local __Math_toScale_tmp
    __Math.fromParts "$__Math_toScale_d" $__Math_toScale_s $__Math_toScale_n __Math_toScale_tmp
    local __Math_toScale_rounded
    into=__Math_toScale_rounded _Self="$__Math_toScale_tmp" _Class=Math Math.round $__Math_toScale_sigdigits
    # Rounding carry (e.g., 999.999 → 1000) can reduce scale below target.
    # If that happened, pad back up to the requested scale.
    local __Math_toScale_rd; local -i __Math_toScale_rs __Math_toScale_rn
    __Math.resolve "$__Math_toScale_rounded" __Math_toScale_rd __Math_toScale_rs __Math_toScale_rn
    if (( __Math_toScale_rs < __Math_toScale_target )); then
      local -i __Math_toScale_pad2=$(( __Math_toScale_target - __Math_toScale_rs ))
      local __Math_toScale_zeros2
      printf -v __Math_toScale_zeros2 "%0${__Math_toScale_pad2}d" 0
      __Math_toScale_rd="${__Math_toScale_rd}${__Math_toScale_zeros2}"
      into=${into:-} _Class=Math __boop.new "digits=$__Math_toScale_rd" "scale=$__Math_toScale_target" "neg=$__Math_toScale_rn"
    else
      boop.pass "$__Math_toScale_rounded" ${into:-}
    fi
  else
    __Math.fromParts "$__Math_toScale_d" $__Math_toScale_s $__Math_toScale_n ${into:-}
  fi
}

# Format with a printf format string. Converts to decimal string first,
# then applies printf. Useful for padding, alignment, fixed-width output.
#
# Usage: into=s $m.format "%010.4f"    # "00003.1400"
#        into=s $m.format "%.2f"       # "3.14"
Math.format() {
  local -I _Self; local _Class="${_Class:-Math}"
  local __Math_format_str
  into=__Math_format_str _Self="$_Self" _Class="$_Class" Math.val
  local __Math_format_result
  printf -v __Math_format_result "$1" "$__Math_format_str"
  boop.pass "$__Math_format_result" ${into:-}
}


