#!/bin/bash

# Math — arbitrary precision arithmetic via string-based digit math.
#
# Numbers are stored as strings of digits with a tracked sign and decimal
# position. All arithmetic is done digit-by-digit using bash's native
# $(( )) on small chunks. No forks, no subshells, no external tools.
# Precision is bounded only by available memory.
#
# Internal representation (in the descriptor):
#   digits = string of digits, no leading zeros (except "0" itself)
#   scale  = number of digits after the decimal point
#   neg    = 0 (positive/zero) or 1 (negative)
#
# Global precision controls how many significant digits operations like
# division produce before stopping. Overridable per-call via the
# precision= typecast. Rounding of the last digit is on by default
# but can be disabled globally or per-call via round=0.
#
# Higher-level functions (arctan, pi) are series expansions built on
# the same add/sub/mul/div primitives. They converge to the configured
# precision and return.
#
# This is grade-school math executed by a computer. Long addition with
# carry, long multiplication with partial products, long division one
# digit at a time. Anyone who can do it with pencil and paper already
# understands the algorithms.

# Load guard
[[ -n "${__boop_registry[Math]+set}" ]] && return 2>/dev/null

. boop

# ============================================================================
# Global Precision Configuration
# ============================================================================

# Default significant digits for operations that can produce infinite
# results (division, trig, pi). Exact operations (add, sub, mul) are
# not affected unless explicitly rounded via $m.round.
declare -gi __Math_precision=20

# Set global precision. Affects all subsequent inexact operations.
__Math.setPrecision() { __Math_precision=$1; }

# ============================================================================
# Math Class Descriptor
# ============================================================================

__boop_registry["Math"]="|class=Math|parent=boop|methods=new,add,sub,subtract,mul,multiply,div,divide,mod,pow,square,abs,neg,eq,lt,gt,le,ge,cmp,round,toInt,toScale,format,val,toString,isZero|properties=digits,scale,neg"


# ============================================================================
# Native integer fast path
# ============================================================================
# When both operands fit in bash's 64-bit signed integer range, we skip
# the string engine entirely and use $(( )). This is ~100x faster for
# small numbers. The string engine is the fallback for big numbers.
#
# Safe digit counts (conservative, accounting for intermediate values):
#   add/sub: both operands ≤ 18 digits (result ≤ 19, still fits)
#   mul:     combined digits ≤ 18 (product fits in 64-bit)
#   div:     dividend after scale padding ≤ 18 digits
#   mod:     same as add/sub (operands ≤ 18)
#   pow:     checked per-iteration (result can grow fast)
declare -gi __Math_FAST_DIGITS=18

# Convert a digits/scale/neg triple to a signed bash integer.
# Returns 0 (success) or 1 (too large). Result via nameref $4.
__Math.toInt64() {
  local __ti_d="$1"
  local -i __ti_s="$2" __ti_n="$3"
  local -n __ti_out="$4"
  (( ${#__ti_d} > __Math_FAST_DIGITS )) && return 1
  # Reconstruct the scaled integer: digits IS the scaled integer
  # (e.g., digits="314" scale=2 means the integer 314 represents 3.14)
  __ti_out=$(( __ti_n ? -( 10#$__ti_d ) : 10#$__ti_d ))
  return 0
}

# Convert a signed bash integer + scale back to digits/scale/neg triple.
# Result via namerefs $3, $4, $5.
__Math.fromInt64() {
  local -i __fi_val="$1" __fi_scale="$2"
  local -n __fi_od="$3" __fi_os="$4" __fi_on="$5"
  __fi_os=$__fi_scale
  if (( __fi_val < 0 )); then
    __fi_on=1
    __fi_od="${__fi_val#-}"
  else
    __fi_on=0
    __fi_od="$__fi_val"
  fi
  # Strip leading zeros
  __fi_od="${__fi_od#"${__fi_od%%[!0]*}"}"
  : "${__fi_od:=0}"
  [[ "$__fi_od" == "0" ]] && __fi_on=0
}


# ============================================================================
# Internal string math engine
# ============================================================================
# These __Math.str* functions operate on raw digit strings (no sign, no
# decimal point). The caller is responsible for sign handling and decimal
# tracking. This keeps the core engine simple and composable.
#
# Digit strings are stored big-endian: "314159" means 3,1,4,1,5,9 from
# most significant to least significant. Leading zeros are stripped on
# output (except for the value "0" itself).
#
# CHUNKED ARITHMETIC: To minimize bash overhead, add/sub/mul process
# 9 digits at a time. Each chunk fits in a 64-bit integer, and
# chunk × chunk (up to 999999999 × 999999999 = ~9.99e17) also fits.
# This gives roughly 81x fewer $(( )) calls for multiply compared to
# single-digit processing.

# Chunk size for bulk operations. 9 digits per chunk, base 10^9.
declare -gi __Math_CHUNK=9
declare -gi __Math_BASE=1000000000

# Compare two unsigned digit strings numerically.
# Returns via exit code: 0 if equal, 1 if A > B, 2 if A < B.
__Math.strCmp() {
  local __cmp_a="$1" __cmp_b="$2"
  # Pad shorter string to match length in one shot via printf
  local -i __cmp_la=${#__cmp_a} __cmp_lb=${#__cmp_b}
  if (( __cmp_la < __cmp_lb )); then
    local -i __cmp_need=$(( __cmp_lb - __cmp_la ))
    local __cmp_pad
    printf -v __cmp_pad "%0${__cmp_need}d" 0
    __cmp_a="${__cmp_pad}${__cmp_a}"
  elif (( __cmp_lb < __cmp_la )); then
    local -i __cmp_need=$(( __cmp_la - __cmp_lb ))
    local __cmp_pad
    printf -v __cmp_pad "%0${__cmp_need}d" 0
    __cmp_b="${__cmp_pad}${__cmp_b}"
  fi
  [[ "$__cmp_a" == "$__cmp_b" ]] && return 0
  [[ "$__cmp_a" > "$__cmp_b" ]] && return 1
  return 2
}

# Add two unsigned digit strings. Chunked: processes 9 digits at a time.
__Math.strAdd() {
  local __add_a="$1" __add_b="$2"
  local -n __add_result="$3"

  # Pad to same length, then to chunk boundary — all in one shot
  local -i __add_la=${#__add_a} __add_lb=${#__add_b} __add_maxlen __add_padlen
  (( __add_maxlen = __add_la > __add_lb ? __add_la : __add_lb ))
  # Round up to next chunk boundary
  (( __add_padlen = (__add_maxlen + __Math_CHUNK - 1) / __Math_CHUNK * __Math_CHUNK ))
  if (( __add_la < __add_padlen )); then
    local -i __add_need=$(( __add_padlen - __add_la ))
    local __add_zeros
    printf -v __add_zeros "%0${__add_need}d" 0
    __add_a="${__add_zeros}${__add_a}"
  fi
  if (( __add_lb < __add_padlen )); then
    local -i __add_need=$(( __add_padlen - __add_lb ))
    local __add_zeros
    printf -v __add_zeros "%0${__add_need}d" 0
    __add_b="${__add_zeros}${__add_b}"
  fi

  local -i __add_carry=0 __add_pos __add_len=${#__add_a} __add_sum
  local __add_fmt
  __add_result=""
  for (( __add_pos = __add_len - __Math_CHUNK; __add_pos >= 0; __add_pos -= __Math_CHUNK )); do
    __add_sum=$(( 10#${__add_a:__add_pos:__Math_CHUNK} + 10#${__add_b:__add_pos:__Math_CHUNK} + __add_carry ))
    __add_carry=$(( __add_sum / __Math_BASE ))
    printf -v __add_fmt "%09d" $(( __add_sum % __Math_BASE ))
    __add_result="${__add_fmt}${__add_result}"
  done
  (( __add_carry )) && __add_result="${__add_carry}${__add_result}"
  __add_result="${__add_result#"${__add_result%%[!0]*}"}"
  : "${__add_result:=0}"
}

# Subtract two unsigned digit strings (A - B). Assumes A >= B. Chunked.
__Math.strSub() {
  local __sub_a="$1" __sub_b="$2"
  local -n __sub_result="$3"

  # Pad to same length, then to chunk boundary — all in one shot
  local -i __sub_la=${#__sub_a} __sub_lb=${#__sub_b} __sub_maxlen __sub_padlen
  (( __sub_maxlen = __sub_la > __sub_lb ? __sub_la : __sub_lb ))
  (( __sub_padlen = (__sub_maxlen + __Math_CHUNK - 1) / __Math_CHUNK * __Math_CHUNK ))
  if (( __sub_la < __sub_padlen )); then
    local -i __sub_need=$(( __sub_padlen - __sub_la ))
    local __sub_zeros
    printf -v __sub_zeros "%0${__sub_need}d" 0
    __sub_a="${__sub_zeros}${__sub_a}"
  fi
  if (( __sub_lb < __sub_padlen )); then
    local -i __sub_need=$(( __sub_padlen - __sub_lb ))
    local __sub_zeros
    printf -v __sub_zeros "%0${__sub_need}d" 0
    __sub_b="${__sub_zeros}${__sub_b}"
  fi

  local -i __sub_borrow=0 __sub_pos __sub_len=${#__sub_a} __sub_diff
  local __sub_fmt
  __sub_result=""
  for (( __sub_pos = __sub_len - __Math_CHUNK; __sub_pos >= 0; __sub_pos -= __Math_CHUNK )); do
    __sub_diff=$(( 10#${__sub_a:__sub_pos:__Math_CHUNK} - 10#${__sub_b:__sub_pos:__Math_CHUNK} - __sub_borrow ))
    if (( __sub_diff < 0 )); then
      (( __sub_diff += __Math_BASE ))
      __sub_borrow=1
    else
      __sub_borrow=0
    fi
    printf -v __sub_fmt "%09d" $__sub_diff
    __sub_result="${__sub_fmt}${__sub_result}"
  done
  __sub_result="${__sub_result#"${__sub_result%%[!0]*}"}"
  : "${__sub_result:=0}"
}

# Multiply two unsigned digit strings. Chunked grade-school method.
# Splits both operands into 9-digit chunks, multiplies chunk pairs,
# and accumulates with proper positional shifts.
__Math.strMul() {
  local __mul_a="$1" __mul_b="$2"
  local -n __mul_result="$3"

  [[ "$__mul_a" == "0" || "$__mul_b" == "0" ]] && { __mul_result="0"; return; }

  # Pad to chunk boundaries in one shot
  local -i __mul_rem_a=$(( ${#__mul_a} % __Math_CHUNK ))
  if (( __mul_rem_a )); then
    local -i __mul_need_a=$(( __Math_CHUNK - __mul_rem_a ))
    local __mul_zeros_a
    printf -v __mul_zeros_a "%0${__mul_need_a}d" 0
    __mul_a="${__mul_zeros_a}${__mul_a}"
  fi
  local -i __mul_rem_b=$(( ${#__mul_b} % __Math_CHUNK ))
  if (( __mul_rem_b )); then
    local -i __mul_need_b=$(( __Math_CHUNK - __mul_rem_b ))
    local __mul_zeros_b
    printf -v __mul_zeros_b "%0${__mul_need_b}d" 0
    __mul_b="${__mul_zeros_b}${__mul_b}"
  fi

  local -i __mul_na=$(( ${#__mul_a} / __Math_CHUNK ))
  local -i __mul_nb=$(( ${#__mul_b} / __Math_CHUNK ))
  local -i __mul_nresult=$(( __mul_na + __mul_nb ))

  # Result accumulator as array of chunks
  local -a __mul_acc=()
  local -i __mul_k
  for (( __mul_k=0; __mul_k < __mul_nresult; __mul_k++ )); do __mul_acc[$__mul_k]=0; done

  # Multiply each chunk pair and accumulate.
  # Chunks are indexed left-to-right in the string but represent
  # most-significant-first, so chunk[0] of A is the highest-order chunk.
  # In the accumulator, index 0 = highest order. We need to map:
  #   A_chunk[i] * B_chunk[j] → acc[i+j] (with carry into i+j-1)
  # But since acc is most-significant-first, the positional math works
  # out the same as standard grade-school with the shift being i+j
  # from the right... actually, let's just index from the RIGHT to
  # keep it simple and match the standard algorithm.
  local -i __mul_i __mul_j __mul_ca __mul_cb __mul_prod __mul_pos
  for (( __mul_i = __mul_na - 1; __mul_i >= 0; __mul_i-- )); do
    __mul_ca=10#${__mul_a:__mul_i*__Math_CHUNK:__Math_CHUNK}
    (( __mul_ca == 0 )) && continue
    local -i __mul_carry=0
    for (( __mul_j = __mul_nb - 1; __mul_j >= 0; __mul_j-- )); do
      __mul_cb=10#${__mul_b:__mul_j*__Math_CHUNK:__Math_CHUNK}
      # Position in result: distance from right end
      # A chunk i (0=leftmost) is at position (na-1-i) from right
      # B chunk j (0=leftmost) is at position (nb-1-j) from right
      # Result position from right = (na-1-i) + (nb-1-j)
      # Result index (0=leftmost) = nresult-1 - pos_from_right
      __mul_pos=$(( __mul_nresult - 1 - (__mul_na - 1 - __mul_i) - (__mul_nb - 1 - __mul_j) ))
      __mul_prod=$(( __mul_ca * __mul_cb + __mul_acc[__mul_pos] + __mul_carry ))
      __mul_acc[$__mul_pos]=$(( __mul_prod % __Math_BASE ))
      __mul_carry=$(( __mul_prod / __Math_BASE ))
    done
    if (( __mul_carry )); then
      (( __mul_acc[__mul_pos - 1] += __mul_carry ))
    fi
  done

  # Convert accumulator back to digit string (index 0 = most significant)
  __mul_result=""
  local __mul_chunk
  for (( __mul_k = 0; __mul_k < __mul_nresult; __mul_k++ )); do
    printf -v __mul_chunk "%09d" ${__mul_acc[$__mul_k]}
    __mul_result="${__mul_result}${__mul_chunk}"
  done
  __mul_result="${__mul_result#"${__mul_result%%[!0]*}"}"
  : "${__mul_result:=0}"
}

# Multiply an unsigned digit string by a small integer (0-999999999).
# Chunked for speed. Returns result via nameref $3.
__Math.strMulSmall() {
  local __muls_a="$1"
  local -i __muls_n="$2"
  local -n __muls_result="$3"

  (( __muls_n == 0 )) && { __muls_result="0"; return; }
  (( __muls_n == 1 )) && { __muls_result="$__muls_a"; return; }

  local -i __muls_rem=$(( ${#__muls_a} % __Math_CHUNK ))
  if (( __muls_rem )); then
    local -i __muls_need=$(( __Math_CHUNK - __muls_rem ))
    local __muls_zeros
    printf -v __muls_zeros "%0${__muls_need}d" 0
    __muls_a="${__muls_zeros}${__muls_a}"
  fi

  local -i __muls_carry=0 __muls_pos __muls_len=${#__muls_a} __muls_prod
  __muls_result=""
  local __muls_fmt
  for (( __muls_pos = __muls_len - __Math_CHUNK; __muls_pos >= 0; __muls_pos -= __Math_CHUNK )); do
    __muls_prod=$(( 10#${__muls_a:__muls_pos:__Math_CHUNK} * __muls_n + __muls_carry ))
    __muls_carry=$(( __muls_prod / __Math_BASE ))
    printf -v __muls_fmt "%09d" $(( __muls_prod % __Math_BASE ))
    __muls_result="${__muls_fmt}${__muls_result}"
  done
  (( __muls_carry )) && __muls_result="${__muls_carry}${__muls_result}"
  __muls_result="${__muls_result#"${__muls_result%%[!0]*}"}"
  : "${__muls_result:=0}"
}

# Divide unsigned digit string A by unsigned digit string B.
# Long division, one digit at a time. Division is inherently sequential
# (each step depends on the previous remainder), so it stays per-digit.
# The trial-multiply and subtract steps use chunked strMulSmall/strSub.
__Math.strDiv() {
  local __div_a="$1" __div_b="$2"
  local -n __div_quotient="$3"
  local -i __div_maxdigits="${4:-$__Math_precision}"
  local -n __div_qscale="$5"

  [[ "$__div_b" == "0" ]] && __boop.crash "Math: division by zero"
  [[ "$__div_a" == "0" ]] && { __div_quotient="0"; __div_qscale=0; return; }

  local __div_remainder="0"
  local -i __div_alen=${#__div_a} __div_pos=0 __div_qdigits=0
  local -i __div_past_decimal=0
  __div_quotient=""
  __div_qscale=0

  while (( __div_qdigits < __div_maxdigits )); do
    if (( __div_pos < __div_alen )); then
      __div_remainder="${__div_remainder}${__div_a:__div_pos:1}"
      (( __div_pos++ ))
    else
      __div_remainder="${__div_remainder}0"
      (( __div_past_decimal++ ))
    fi

    local __div_rem_stripped="${__div_remainder#"${__div_remainder%%[!0]*}"}"
    : "${__div_rem_stripped:=0}"
    __div_remainder="$__div_rem_stripped"

    # Binary search for quotient digit (0-9)
    local -i __div_lo=0 __div_hi=9 __div_mid __div_qd=0
    while (( __div_lo <= __div_hi )); do
      __div_mid=$(( (__div_lo + __div_hi) / 2 ))
      local __div_trial
      __Math.strMulSmall "$__div_b" $__div_mid __div_trial
      __Math.strCmp "$__div_trial" "$__div_remainder"
      local -i __div_cmprc=$?
      if (( __div_cmprc == 0 )); then __div_qd=$__div_mid; break
      elif (( __div_cmprc == 2 )); then __div_qd=$__div_mid; __div_lo=$(( __div_mid + 1 ))
      else __div_hi=$(( __div_mid - 1 ))
      fi
    done

    if (( __div_qd == 0 && __div_qdigits == 0 )); then
      # Leading zero — don't count as a quotient digit, but track
      # fractional position so the scale stays correct.
      (( __div_past_decimal > 0 )) && (( __div_qscale++ ))
    else
      __div_quotient="${__div_quotient}${__div_qd}"
      (( __div_qdigits++ ))
      (( __div_past_decimal > 0 )) && (( __div_qscale++ ))
    fi

    if (( __div_qd > 0 )); then
      local __div_sub_val
      __Math.strMulSmall "$__div_b" $__div_qd __div_sub_val
      __Math.strSub "$__div_remainder" "$__div_sub_val" __div_remainder
    fi

    [[ "$__div_remainder" == "0" ]] && (( __div_pos >= __div_alen )) && break
  done

  : "${__div_quotient:=0}"
}


# ============================================================================
# Helpers for Math objects
# ============================================================================

# Strip leading zeros from a digit string, preserving at least "0".
__Math.stripLeading() {
  local __sl_val="$1"
  __sl_val="${__sl_val#"${__sl_val%%[!0]*}"}"
  printf '%s' "${__sl_val:-0}"
}

# Resolve a Math argument to its digits/scale/neg triple.
#
# If the input is an object ID (starts with _ and is in the registry),
# extracts digits, scale, and neg from the object's descriptor.
# Otherwise, parses and validates the input as a literal number string.
#
# Literal parsing uses a single regex to validate and decompose the
# input in one pass. Accepts optional leading/trailing whitespace,
# optional sign, and requires at least one digit. Rejects everything
# else (letters, operators, multiple dots, etc.) with a clear error.
#
# Trailing fractional zeros are preserved — they encode precision.
# "3.14" (scale=2) and "3.140" (scale=3) are intentionally different.
#
# Arguments:
#   $1 — input value (object ID or numeric string like "3.14" or "-42")
#   $2 — nameref: receives digit string (no sign, no decimal point)
#   $3 — nameref: receives scale (integer, number of decimal places)
#   $4 — nameref: receives neg flag (0=positive, 1=negative)
#
# Returns: nothing (results via namerefs)
# Crashes: if input is not a valid number or recognized object ID
__Math.resolve() {
  local __res_input="$1"
  local -n __res_digits="$2" __res_scale="$3" __res_neg="$4"

  # Object ID — already validated, extract from descriptor
  if [[ "$__res_input" == _* && -n "${__boop_registry[$__res_input]:-}" ]]; then
    __boop.parse "$__res_input" "digits" __res_digits
    __boop.parse "$__res_input" "scale" __res_scale
    __boop.parse "$__res_input" "neg" __res_neg
    return
  fi

  # Validate and decompose literal in one pass:
  #   group 1: sign ("-" or empty)
  #   group 2: integer digits (may be empty if fraction exists)
  #   group 3: decimal point ("." or empty)
  #   group 4: fractional digits (may be empty if integer exists)
  # The -n check ensures at least one digit is present somewhere.
  if ! [[ "${__res_input:-}" =~ ^[[:space:]]*(-?)([0-9]*)([.]*)([0-9]*)[[:space:]]*$ \
       && -n "${BASH_REMATCH[2]:-}${BASH_REMATCH[4]:-}" ]]; then
    __boop.crash "Math: invalid number '$1' — expected a numeric value like '3.14' or '-42'"
  fi

  __res_neg=${#BASH_REMATCH[1]}                                  # "-" → length 1; empty → 0
  local __res_int="${BASH_REMATCH[2]}"                           # digits before the dot
  local __res_frac="${BASH_REMATCH[4]}"                          # digits after the dot

  # Default empty integer part to zero (e.g., ".5")
  if [[ -z "$__res_int" ]]; then
    _Debug "__Math.resolve: no integer part in '$1', defaulting to 0"
    __res_int=0
  fi

  # Default empty fraction to zero when a dot was present (e.g., "1.")
  if [[ -z "$__res_frac" && -n "${BASH_REMATCH[3]}" ]]; then
    _Debug "__Math.resolve: no fraction in '$1', defaulting to 0"
    __res_frac=0
  fi

  __res_int="${__res_int#"${__res_int%%[!0]*}"}"                 # strip leading zeros
  : "${__res_int:=0}"                                            # keep at least "0"

  __res_digits="${__res_int}${__res_frac}"                       # concatenate for arithmetic
  __res_scale=${#__res_frac}                                     # precision = fraction length

  [[ "${__res_digits//0/}" == "" ]] && __res_neg=0               # no negative zero
}

# Align two numbers to the same scale by padding the shorter one with
# trailing zeros on the digit string. This makes the digit strings
# directly comparable and addable/subtractable.
__Math.alignScale() {
  local -n __as_dA="$1" __as_sA="$2" __as_dB="$3" __as_sB="$4"
  local -i __as_diff
  local __as_pad
  if (( __as_sA < __as_sB )); then
    __as_diff=$(( __as_sB - __as_sA ))
    printf -v __as_pad "%0${__as_diff}d" 0
    __as_dA="${__as_dA}${__as_pad}"
    __as_sA=$__as_sB
  elif (( __as_sB < __as_sA )); then
    __as_diff=$(( __as_sA - __as_sB ))
    printf -v __as_pad "%0${__as_diff}d" 0
    __as_dB="${__as_dB}${__as_pad}"
    __as_sB=$__as_sA
  fi
}

# Build a Math object from raw components. Strips leading zeros,
# normalizes negative zero, registers in boop.
__Math.fromParts() {
  local __fp_digits="$1"
  local -i __fp_scale="$2" __fp_neg="$3"

  # Strip leading zeros (inline — no subshell)
  __fp_digits="${__fp_digits#"${__fp_digits%%[!0]*}"}"
  : "${__fp_digits:=0}"

  # Strip trailing zeros past the decimal point.
  # Uses parameter expansion to find the trailing zeros suffix,
  # then trims by length in one shot instead of one-char-at-a-time.
  if (( __fp_scale > 0 )); then
    local __fp_tz="${__fp_digits%%[!0]*}"  # won't work — need trailing
    # Reverse approach: strip trailing zeros via suffix removal
    local __fp_stripped="${__fp_digits%"${__fp_digits##*[!0]}"}"
    # __fp_stripped is everything up to and including the last non-zero
    # Actually: ${var##*[!0]} gives the trailing zeros suffix
    local __fp_tail="${__fp_digits##*[!0]}"
    local -i __fp_taillen=${#__fp_tail}
    if (( __fp_taillen > 0 && __fp_taillen <= __fp_scale )); then
      __fp_digits="${__fp_digits:0:${#__fp_digits}-__fp_taillen}"
      (( __fp_scale -= __fp_taillen ))
    elif (( __fp_taillen > __fp_scale )); then
      # Only strip up to scale zeros (don't eat into integer part)
      __fp_digits="${__fp_digits:0:${#__fp_digits}-__fp_scale}"
      __fp_scale=0
    fi
    : "${__fp_digits:=0}"
  fi

  # No negative zero
  [[ "$__fp_digits" == "0" ]] && __fp_neg=0

  local __fp_self
  into=__fp_self _Class=Math __boop.new "digits=$__fp_digits" "scale=$__fp_scale" "neg=$__fp_neg"
  __boop.return "$__fp_self" "${4:-}"
}

# ============================================================================
# Constructor
# ============================================================================

# Create a new Math number from a string.
#
# Usage: into=m Math 3.14159
#        into=m Math -42
#        into=m Math 0.001
Math.new() {
  local -I _Class
  : "${_Class:=Math}"

  local __Math_new_input="${1:-0}"
  # Skip key=value args that aren't the value itself
  [[ "$__Math_new_input" == *=* ]] && __Math_new_input="0"

  local __Math_new_digits __Math_new_neg
  local -i __Math_new_scale
  __Math.resolve "$__Math_new_input" __Math_new_digits __Math_new_scale __Math_new_neg
  __Math.fromParts "$__Math_new_digits" $__Math_new_scale $__Math_new_neg ${into:-}
}


# ============================================================================
# Arithmetic operations
# ============================================================================

# Add: self + arg. Handles sign logic, delegates to strAdd/strSub.
# Fast path: if both operands fit in 64-bit, uses native $(( )).
__Math.i_add() {
  local -I _Self _Class
  local __add_dA __add_dB
  local -i __add_sA __add_sB __add_nA __add_nB
  __Math.resolve "$_Self" __add_dA __add_sA __add_nA
  __Math.resolve "$1" __add_dB __add_sB __add_nB

  # Fast path: native integer arithmetic
  local -i __add_iA __add_iB
  if __Math.toInt64 "$__add_dA" $__add_sA $__add_nA __add_iA \
  && __Math.toInt64 "$__add_dB" $__add_sB $__add_nB __add_iB; then
    __Math.alignScale __add_dA __add_sA __add_dB __add_sB
    __Math.toInt64 "$__add_dA" $__add_sA $__add_nA __add_iA
    __Math.toInt64 "$__add_dB" $__add_sB $__add_nB __add_iB
    local __add_fd; local -i __add_fs __add_fn
    __Math.fromInt64 $(( __add_iA + __add_iB )) $__add_sA __add_fd __add_fs __add_fn
    __Math.fromParts "$__add_fd" $__add_fs $__add_fn ${into:-}
    return
  fi

  __Math.alignScale __add_dA __add_sA __add_dB __add_sB

  local __add_rd
  local -i __add_rn

  if (( __add_nA == __add_nB )); then
    __Math.strAdd "$__add_dA" "$__add_dB" __add_rd
    __add_rn=$__add_nA
  else
    __Math.strCmp "$__add_dA" "$__add_dB"
    local -i __add_cmp=$?
    if (( __add_cmp == 0 )); then
      __Math.fromParts "0" $__add_sA 0 ${into:-}; return
    elif (( __add_cmp == 1 )); then
      __Math.strSub "$__add_dA" "$__add_dB" __add_rd
      __add_rn=$__add_nA
    else
      __Math.strSub "$__add_dB" "$__add_dA" __add_rd
      __add_rn=$__add_nB
    fi
  fi

  __Math.fromParts "$__add_rd" $__add_sA $__add_rn ${into:-}
}

# Subtract: self - arg. Flip sign of arg and add.
__Math.i_sub() {
  local -I _Self _Class
  local __sub_dB
  local -i __sub_sB __sub_nB
  __Math.resolve "$1" __sub_dB __sub_sB __sub_nB

  # Flip sign and add
  (( __sub_nB = !__sub_nB ))
  [[ "$__sub_dB" == "0" ]] && __sub_nB=0

  # Build a temporary negated value and add
  local __sub_tmp
  __Math.fromParts "$__sub_dB" $__sub_sB $__sub_nB __sub_tmp
  _Self="$_Self" _Class=Math __Math.i_add "$__sub_tmp"
}

# Multiply: self * arg.
# Digit strings are multiplied directly. Result scale = scaleA + scaleB.
# Result sign = XOR of input signs.
# Fast path: if combined digit count ≤ 18, uses native $(( )).
__Math.i_mul() {
  local -I _Self _Class
  local __mul_dA __mul_dB
  local -i __mul_sA __mul_sB __mul_nA __mul_nB
  __Math.resolve "$_Self" __mul_dA __mul_sA __mul_nA
  __Math.resolve "$1" __mul_dB __mul_sB __mul_nB

  # Fast path: combined digits fit in 64-bit product
  if (( ${#__mul_dA} + ${#__mul_dB} <= __Math_FAST_DIGITS )); then
    local -i __mul_iA __mul_iB
    __Math.toInt64 "$__mul_dA" $__mul_sA $__mul_nA __mul_iA
    __Math.toInt64 "$__mul_dB" $__mul_sB $__mul_nB __mul_iB
    local __mul_fd; local -i __mul_fs __mul_fn
    __Math.fromInt64 $(( __mul_iA * __mul_iB )) $(( __mul_sA + __mul_sB )) __mul_fd __mul_fs __mul_fn
    __Math.fromParts "$__mul_fd" $__mul_fs $__mul_fn ${into:-}
    return
  fi

  local __mul_rd
  __Math.strMul "$__mul_dA" "$__mul_dB" __mul_rd
  local -i __mul_rn=$(( __mul_nA != __mul_nB ? 1 : 0 ))
  __Math.fromParts "$__mul_rd" $(( __mul_sA + __mul_sB )) $__mul_rn ${into:-}
}

# Divide: self / arg.
# Respects precision= typecast or global __Math_precision.
# Always truncates to precision. Use $result.round N to round afterward.
# Fast path: if dividend (after scale padding) fits in 64-bit, uses $(( )).
__Math.i_div() {
  local -I _Self _Class
  local -i precision; : "${precision:=$__Math_precision}"

  local __div_dA __div_dB
  local -i __div_sA __div_sB __div_nA __div_nB
  __Math.resolve "$_Self" __div_dA __div_sA __div_nA
  __Math.resolve "$1" __div_dB __div_sB __div_nB

  [[ "$__div_dB" == "0" ]] && __boop.crash "Math: division by zero"

  # Fast path: native integer division when operands are small enough.
  # After align, we multiply dividend by 10^extra for fractional digits.
  # Total digit count of (aligned_dividend * 10^extra) must fit in 64-bit.
  local -i __div_extra=$(( precision > 6 ? precision : 6 ))
  local -i __div_maxA=${#__div_dA} __div_maxB=${#__div_dB}
  (( __div_maxA < __div_maxB )) && __div_maxA=$__div_maxB
  if (( __div_maxA + __div_extra <= __Math_FAST_DIGITS )); then
    __Math.alignScale __div_dA __div_sA __div_dB __div_sB
    local -i __div_iA __div_iB
    __Math.toInt64 "$__div_dA" $__div_sA $__div_nA __div_iA
    __Math.toInt64 "$__div_dB" $__div_sB $__div_nB __div_iB
    local __div_pow
    printf -v __div_pow "1%0${__div_extra}d" 0
    local -i __div_mul=10#$__div_pow
    # Preserve sign, operate on magnitudes
    local -i __div_absA=${__div_iA#-} __div_absB=${__div_iB#-}
    local -i __div_raw=$(( (__div_absA * __div_mul) / __div_absB ))
    local -i __div_rn=$(( __div_nA != __div_nB ? 1 : 0 ))
    local __div_fd; local -i __div_fs __div_fn
    __Math.fromInt64 $__div_raw $__div_extra __div_fd __div_fs __div_fn
    (( __div_rn )) && __div_fn=$__div_rn
    [[ "$__div_fd" == "0" ]] && __div_fn=0
    __Math.fromParts "$__div_fd" $__div_fs $__div_fn ${into:-}
    return
  fi

  # Align scales so we're dividing integers of the same magnitude
  __Math.alignScale __div_dA __div_sA __div_dB __div_sB

  # Perform string division — operates on pure digit strings, returns
  # quotient digits and how many of them are past the decimal point
  local __div_q
  local -i __div_qs
  __Math.strDiv "$__div_dA" "$__div_dB" __div_q $((precision + 2)) __div_qs

  local -i __div_rn=$(( __div_nA != __div_nB ? 1 : 0 ))

  # Round or truncate to requested precision
  # Truncate to requested precision
  if (( ${#__div_q} > precision )); then
    local -i __div_removed=$(( ${#__div_q} - precision ))
    __div_q="${__div_q:0:precision}"
    (( __div_qs -= __div_removed ))
    (( __div_qs < 0 )) && __div_qs=0
  fi

  __Math.fromParts "$__div_q" $__div_qs $__div_rn ${into:-}
}

# Square: self * self. Convenience wrapper — same as mul with self as arg.
__Math.i_square() {
  local -I _Self _Class
  _Self="$_Self" _Class="$_Class" into=${into:-} __Math.i_mul "$_Self"
}

# Modulo: self % arg. Aligns scales, computes remainder.
# Fast path only — mod on arbitrary-precision strings would need
# a full strMod implementation. For now, crashes if operands are too large.
__Math.i_mod() {
  local -I _Self _Class
  local __mod_dA __mod_dB
  local -i __mod_sA __mod_sB __mod_nA __mod_nB
  __Math.resolve "$_Self" __mod_dA __mod_sA __mod_nA
  __Math.resolve "$1" __mod_dB __mod_sB __mod_nB

  [[ "$__mod_dB" == "0" ]] && __boop.crash "Math: modulo by zero"

  __Math.alignScale __mod_dA __mod_sA __mod_dB __mod_sB

  local -i __mod_iA __mod_iB
  __Math.toInt64 "$__mod_dA" $__mod_sA $__mod_nA __mod_iA \
    || __boop.crash "Math: mod operand too large for native arithmetic"
  __Math.toInt64 "$__mod_dB" $__mod_sB $__mod_nB __mod_iB \
    || __boop.crash "Math: mod operand too large for native arithmetic"

  local __mod_fd; local -i __mod_fs __mod_fn
  __Math.fromInt64 $(( __mod_iA % __mod_iB )) $__mod_sA __mod_fd __mod_fs __mod_fn
  __Math.fromParts "$__mod_fd" $__mod_fs $__mod_fn ${into:-}
}

# Power: self ^ arg (non-negative integer exponent only).
# Uses repeated multiplication via i_mul, which auto-selects fast or
# string path per iteration. This means small bases stay fast and large
# bases gracefully fall back to arbitrary precision.
__Math.i_pow() {
  local -I _Self _Class
  local __pow_dB
  local -i __pow_sB __pow_nB
  __Math.resolve "$1" __pow_dB __pow_sB __pow_nB

  (( __pow_sB != 0 )) && __boop.crash "Math: fractional exponents not supported"
  (( __pow_nB )) && __boop.crash "Math: negative exponents not supported"

  # Exponent is a plain integer
  local -i __pow_exp=10#$__pow_dB

  # Start with 1
  local __pow_result
  into=__pow_result Math.new 1

  local -i __pow_i
  for (( __pow_i=0; __pow_i < __pow_exp; __pow_i++ )); do
    into=__pow_result _Self="$__pow_result" _Class=Math __Math.i_mul "$_Self"
  done

  __boop.return "$__pow_result" ${into:-}
}


# ============================================================================
# Comparison operations — exit codes (bash boolean convention)
# ============================================================================

# Compare self to arg. Returns 0 (equal), 1 (self > arg), 2 (self < arg).
# This is the workhorse — eq/lt/gt/le/ge are wrappers.
Math.cmp() {
  local -I _Self _Class
  local __cmp_dA __cmp_dB
  local -i __cmp_sA __cmp_sB __cmp_nA __cmp_nB
  __Math.resolve "$_Self" __cmp_dA __cmp_sA __cmp_nA
  __Math.resolve "$1" __cmp_dB __cmp_sB __cmp_nB

  # Different signs: negative < positive
  if (( __cmp_nA != __cmp_nB )); then
    # Both zero check
    [[ "$__cmp_dA" == "0" && "$__cmp_dB" == "0" ]] && return 0
    (( __cmp_nA )) && return 2 || return 1
  fi

  __Math.alignScale __cmp_dA __cmp_sA __cmp_dB __cmp_sB
  __Math.strCmp "$__cmp_dA" "$__cmp_dB"
  local -i __cmp_rc=$?

  # If negative, flip the comparison (larger magnitude = smaller value)
  if (( __cmp_nA )); then
    (( __cmp_rc == 1 )) && return 2
    (( __cmp_rc == 2 )) && return 1
  fi
  return $__cmp_rc
}

Math.eq() { local -I _Self _Class; _Self="$_Self" _Class="$_Class" Math.cmp "$1"; (( $? == 0 )); }
Math.lt() { local -I _Self _Class; _Self="$_Self" _Class="$_Class" Math.cmp "$1"; (( $? == 2 )); }
Math.gt() { local -I _Self _Class; _Self="$_Self" _Class="$_Class" Math.cmp "$1"; (( $? == 1 )); }
Math.le() { local -I _Self _Class; _Self="$_Self" _Class="$_Class" Math.cmp "$1"; local -i rc=$?; (( rc == 0 || rc == 2 )); }
Math.ge() { local -I _Self _Class; _Self="$_Self" _Class="$_Class" Math.cmp "$1"; local -i rc=$?; (( rc == 0 || rc == 1 )); }

# ============================================================================
# Utility methods
# ============================================================================

Math.isZero() {
  local -I _Self _Class
  local __iz_d; local -i __iz_s __iz_n
  __Math.resolve "$_Self" __iz_d __iz_s __iz_n
  [[ "$__iz_d" == "0" ]]
}

__Math.i_abs() {
  local -I _Self _Class
  local __abs_d; local -i __abs_s __abs_n
  __Math.resolve "$_Self" __abs_d __abs_s __abs_n
  __Math.fromParts "$__abs_d" $__abs_s 0 ${into:-}
}

__Math.i_neg() {
  local -I _Self _Class
  local __neg_d; local -i __neg_s __neg_n
  __Math.resolve "$_Self" __neg_d __neg_s __neg_n
  [[ "$__neg_d" == "0" ]] && __neg_n=0 || (( __neg_n = !__neg_n ))
  __Math.fromParts "$__neg_d" $__neg_s $__neg_n ${into:-}
}

# Round to N significant digits. Returns a new Math object.
# Uses round-half-up: if the digit past the cut point is >= 5, bump up.
Math.round() {
  local -I _Self _Class
  local -i __rnd_prec="${1:-$__Math_precision}"
  local __rnd_d; local -i __rnd_s __rnd_n
  __Math.resolve "$_Self" __rnd_d __rnd_s __rnd_n

  local -i __rnd_len=${#__rnd_d}
  (( __rnd_len <= __rnd_prec )) && { __Math.fromParts "$__rnd_d" $__rnd_s $__rnd_n ${into:-}; return; }

  # Digit just past the cut point decides rounding
  local -i __rnd_check=${__rnd_d:__rnd_prec:1}
  __rnd_d="${__rnd_d:0:__rnd_prec}"

  if (( __rnd_check >= 5 )); then
    # Increment the last kept digit. If it's 9, carry propagates.
    local -i __rnd_last=${__rnd_d: -1}
    if (( __rnd_last < 9 )); then
      # Simple case: just bump the last digit
      __rnd_d="${__rnd_d:0:${#__rnd_d}-1}$(( __rnd_last + 1 ))"
    else
      # Last digit is 9 — need to propagate carry through trailing 9s
      __rnd_d="${__rnd_d:0:${#__rnd_d}-1}"
      if [[ "$__rnd_d" == *[!9]* ]]; then
        local __rnd_nines="${__rnd_d##*[!9]}"
        local -i __rnd_hlen=$(( ${#__rnd_d} - ${#__rnd_nines} ))
        local -i __rnd_bump=$(( ${__rnd_d:__rnd_hlen-1:1} + 1 ))
        printf -v __rnd_d '%s%d%0*d' "${__rnd_d:0:__rnd_hlen-1}" $__rnd_bump ${#__rnd_nines} 0
      else
        # Entire prefix is 9s — carry extends the number
        printf -v __rnd_d '1%0*d' ${#__rnd_d} 0
      fi
      __rnd_d="${__rnd_d}0"
    fi
  fi

  # Adjust scale: we removed (__rnd_len - __rnd_prec) digits from the end
  local -i __rnd_removed=$(( __rnd_len - __rnd_prec ))
  (( __rnd_s = __rnd_s - __rnd_removed ))
  (( __rnd_s < 0 )) && __rnd_s=0

  __Math.fromParts "$__rnd_d" $__rnd_s $__rnd_n ${into:-}
}

# Truncate to integer string.
Math.toInt() {
  local -I _Self _Class
  local __ti_d; local -i __ti_s __ti_n
  __Math.resolve "$_Self" __ti_d __ti_s __ti_n

  if (( __ti_s >= ${#__ti_d} )); then
    __boop.return "0" ${into:-}; return
  fi

  local __ti_int="${__ti_d:0:${#__ti_d}-__ti_s}"
  # Inline stripLeading — no subshell
  __ti_int="${__ti_int#"${__ti_int%%[!0]*}"}"
  : "${__ti_int:=0}"
  (( __ti_n )) && [[ "$__ti_int" != "0" ]] && __ti_int="-${__ti_int}"
  __boop.return "$__ti_int" ${into:-}
}

# Return the decimal string representation. "3.14", "-0.5", "42", etc.
Math.val() {
  local -I _Self _Class
  local __val_d; local -i __val_s __val_n
  __Math.resolve "$_Self" __val_d __val_s __val_n

  local __val_result
  if (( __val_s == 0 )); then
    __val_result="$__val_d"
  elif (( __val_s >= ${#__val_d} )); then
    # All digits are fractional — pad with leading zeros in one shot
    local -i __val_need=$(( __val_s - ${#__val_d} ))
    local __val_pad
    if (( __val_need > 0 )); then
      printf -v __val_pad "%0${__val_need}d" 0
      __val_pad="${__val_pad}${__val_d}"
    else
      __val_pad="$__val_d"
    fi
    __val_result="0.${__val_pad}"
  else
    local -i __val_split=$(( ${#__val_d} - __val_s ))
    __val_result="${__val_d:0:__val_split}.${__val_d:__val_split}"
  fi

  (( __val_n )) && [[ "$__val_result" != "0" ]] && __val_result="-${__val_result}"
  __boop.return "$__val_result" ${into:-}
}

Math.toString() {
  local -I _Self _Class
  local __ts_val
  into=__ts_val _Self="$_Self" _Class="$_Class" Math.val
  __boop.return "Math($_Self){ $__ts_val }" ${into:-}
}

# Change scale (decimal places). Pads with zeros or rounds to fit.
# Returns a new Math object at the requested scale.
#
# Usage: into=r $m.toScale 4    # force 4 decimal places
Math.toScale() {
  local -I _Self _Class
  local -i __tsc_target="${1:-0}"
  local __tsc_d; local -i __tsc_s __tsc_n
  __Math.resolve "$_Self" __tsc_d __tsc_s __tsc_n

  if (( __tsc_target > __tsc_s )); then
    # Pad with trailing zeros
    local -i __tsc_diff=$(( __tsc_target - __tsc_s ))
    local __tsc_pad
    printf -v __tsc_pad "%0${__tsc_diff}d" 0
    __tsc_d="${__tsc_d}${__tsc_pad}"
    # Bypass fromParts to preserve trailing zeros
    local __tsc_self
    into=__tsc_self _Class=Math __boop.new "digits=$__tsc_d" "scale=$__tsc_target" "neg=$__tsc_n"
    __boop.return "$__tsc_self" ${into:-}
  elif (( __tsc_target < __tsc_s )); then
    local -i __tsc_sigdigits=$(( ${#__tsc_d} - (__tsc_s - __tsc_target) ))
    (( __tsc_sigdigits < 1 )) && __tsc_sigdigits=1
    local __tsc_tmp
    __Math.fromParts "$__tsc_d" $__tsc_s $__tsc_n __tsc_tmp
    local __tsc_rounded
    into=__tsc_rounded _Self="$__tsc_tmp" _Class=Math Math.round $__tsc_sigdigits
    # Rounding carry (e.g., 999.999 → 1000) can reduce scale below target.
    # If that happened, pad back up to the requested scale.
    local __tsc_rd; local -i __tsc_rs __tsc_rn
    __Math.resolve "$__tsc_rounded" __tsc_rd __tsc_rs __tsc_rn
    if (( __tsc_rs < __tsc_target )); then
      local -i __tsc_pad2=$(( __tsc_target - __tsc_rs ))
      local __tsc_zeros2
      printf -v __tsc_zeros2 "%0${__tsc_pad2}d" 0
      __tsc_rd="${__tsc_rd}${__tsc_zeros2}"
      into=${into:-} _Class=Math __boop.new "digits=$__tsc_rd" "scale=$__tsc_target" "neg=$__tsc_rn"
    else
      __boop.return "$__tsc_rounded" ${into:-}
    fi
  else
    __Math.fromParts "$__tsc_d" $__tsc_s $__tsc_n ${into:-}
  fi
}

# Format with a printf format string. Converts to decimal string first,
# then applies printf. Useful for padding, alignment, fixed-width output.
#
# Usage: into=s $m.format "%010.4f"    # "00003.1400"
#        into=s $m.format "%.2f"       # "3.14"
Math.format() {
  local -I _Self _Class
  local __fmt_str
  into=__fmt_str _Self="$_Self" _Class="$_Class" Math.val
  local __fmt_result
  printf -v __fmt_result "$1" "$__fmt_str"
  __boop.return "$__fmt_result" ${into:-}
}


# ============================================================================
# Higher-level math functions
# ============================================================================

# ============================================================================
# Raw arithmetic on digit/scale/neg triples
# ============================================================================
# These bypass the object system entirely. No IDs, no descriptors, no
# registry, no stubs, no encoding. Just local variables in, local
# variables out. Used by the hot inner loops of series expansions
# (arctan, pi) where object overhead dominates runtime.
#
# Convention: result is returned via three namerefs passed as the last
# three arguments: out_digits, out_scale, out_neg.

# Raw add: (dA,sA,nA) + (dB,sB,nB) → (dR,sR,nR)
# Aligns scales, then delegates to strAdd or strSub based on sign.
# Same logic as Math.add but without object creation or resolution.
__Math.rawAdd() {
  local __ra_dA="$1" __ra_dB="$4"
  local -i __ra_sA="$2" __ra_nA="$3" __ra_sB="$5" __ra_nB="$6"
  local -n __ra_od="$7" __ra_os="$8" __ra_on="$9"

  __Math.alignScale __ra_dA __ra_sA __ra_dB __ra_sB

  if (( __ra_nA == __ra_nB )); then
    __Math.strAdd "$__ra_dA" "$__ra_dB" __ra_od
    __ra_on=$__ra_nA
  else
    __Math.strCmp "$__ra_dA" "$__ra_dB"
    local -i __ra_cmp=$?
    if (( __ra_cmp == 0 )); then
      __ra_od="0"; __ra_os=$__ra_sA; __ra_on=0; return
    elif (( __ra_cmp == 1 )); then
      __Math.strSub "$__ra_dA" "$__ra_dB" __ra_od
      __ra_on=$__ra_nA
    else
      __Math.strSub "$__ra_dB" "$__ra_dA" __ra_od
      __ra_on=$__ra_nB
    fi
  fi
  __ra_os=$__ra_sA
  # Strip leading zeros
  __ra_od="${__ra_od#"${__ra_od%%[!0]*}"}"
  : "${__ra_od:=0}"
  [[ "$__ra_od" == "0" ]] && __ra_on=0
}

# Raw sub: (dA,sA,nA) - (dB,sB,nB) → flip sign of B and rawAdd.
__Math.rawSub() {
  local -i __rs_nB="$6"
  (( __rs_nB = !__rs_nB ))
  [[ "$4" == "0" ]] && __rs_nB=0
  __Math.rawAdd "$1" "$2" "$3" "$4" "$5" $__rs_nB "$7" "$8" "$9"
}

# Raw mul: (dA,sA,nA) * (dB,sB,nB) → (dR,sR,nR)
# Result scale = scaleA + scaleB. Sign = XOR of input signs.
__Math.rawMul() {
  local __rm_dA="$1" __rm_dB="$4"
  local -i __rm_sA="$2" __rm_nA="$3" __rm_sB="$5" __rm_nB="$6"
  local -n __rm_od="$7" __rm_os="$8" __rm_on="$9"

  __Math.strMul "$__rm_dA" "$__rm_dB" __rm_od
  __rm_os=$(( __rm_sA + __rm_sB ))
  __rm_on=$(( __rm_nA != __rm_nB ? 1 : 0 ))
  [[ "$__rm_od" == "0" ]] && __rm_on=0
}

# Raw mul by small integer: (dA,sA,nA) * int → (dR,sR,nR)
# Handles negative multiplier by splitting sign from magnitude.
__Math.rawMulSmall() {
  local __rms_dA="$1"
  local -i __rms_sA="$2" __rms_nA="$3" __rms_n="$4"
  local -n __rms_od="$5" __rms_os="$6" __rms_on="$7"

  local -i __rms_abs_n=${__rms_n#-}
  __Math.strMulSmall "$__rms_dA" $__rms_abs_n __rms_od
  __rms_os=$__rms_sA
  __rms_on=$(( (__rms_n < 0) != __rms_nA ? 1 : 0 ))
  [[ "$__rms_od" == "0" ]] && __rms_on=0
}

# Raw div: (dA,sA,nA) / (dB,sB,nB) → (dR,sR,nR)
# Aligns scales, performs string division, then truncates to
# the requested precision. Same logic as Math.div but without objects.
# $10 = precision (default __Math_precision).
__Math.rawDiv() {
  local __rd_dA="$1" __rd_dB="$4"
  local -i __rd_sA="$2" __rd_nA="$3" __rd_sB="$5" __rd_nB="$6"
  local -n __rd_od="${7}" __rd_os="${8}" __rd_on="${9}"
  local -i __rd_prec="${10:-$__Math_precision}"

  [[ "$__rd_dB" == "0" ]] && __boop.crash "Math: division by zero"

  __Math.alignScale __rd_dA __rd_sA __rd_dB __rd_sB

  local -i __rd_qs
  __Math.strDiv "$__rd_dA" "$__rd_dB" __rd_od $((__rd_prec + 2)) __rd_qs

  __rd_on=$(( __rd_nA != __rd_nB ? 1 : 0 ))

  # Truncate to requested precision
  if (( ${#__rd_od} > __rd_prec )); then
    local -i __rd_removed=$(( ${#__rd_od} - __rd_prec ))
    __rd_od="${__rd_od:0:__rd_prec}"
    (( __rd_qs -= __rd_removed ))
    (( __rd_qs < 0 )) && __rd_qs=0
  fi

  __rd_os=$__rd_qs
  [[ "$__rd_od" == "0" ]] && __rd_on=0
}

# Raw div by small integer: (dA,sA,nA) / int → (dR,sR,nR)
# Converts the small int to a triple and delegates to rawDiv.
# $8 = precision override.
__Math.rawDivSmall() {
  local -i __rds_n="${4}"
  local -i __rds_nB=0
  (( __rds_n < 0 )) && { __rds_nB=1; __rds_n=$(( -__rds_n )); }
  __Math.rawDiv "$1" "$2" "$3" "$__rds_n" 0 $__rds_nB "$5" "$6" "$7" "${8:-}"
}

# ============================================================================
# Higher-level math functions
# ============================================================================

# arctan(1/n) via Taylor series: 1/n - 1/(3n³) + 1/(5n⁵) - 1/(7n⁷) + ...
#
# This is the building block for Machin-like pi formulas. We compute
# arctan of the reciprocal of a small integer, which keeps the series
# converging fast (each term shrinks by a factor of n²).
#
# PERFORMANCE: operates entirely on raw digit/scale/neg triples. No Math
# objects are created during the loop — only one object is built at the
# end to wrap the result. This eliminates all object overhead (ID gen,
# descriptor encoding, registry writes, stub eval) from the hot path.
#
# Uses __boop_static to cache results at a given precision so
# repeated calls (e.g., from pi at the same precision) don't recompute.
#
# $1 = integer n (compute arctan(1/n))
# $2 = optional precision override
# $3 = optional nameref target for result (object ID)
__Math.arctan_recip() {
  local -i __at_n="$1"
  local -i __at_prec="${2:-$__Math_precision}"
  local -i __at_workprec=$(( __at_prec + 15 ))

  # Check cache
  local __at_cachekey="Math.arctan_recip.${__at_n}.${__at_prec}"
  if [[ -n "${__boop_static[$__at_cachekey]:-}" ]]; then
    __boop.return "${__boop_static[$__at_cachekey]}" "${3:-}"
    return
  fi

  # All work done on raw triples: digits, scale, neg
  # term = power = 1/n
  local __at_pd __at_td __at_sd __at_dd
  local -i __at_ps __at_ts __at_ss __at_ds
  local -i __at_pn __at_tn __at_sn __at_dn

  # 1/n → power triple
  __Math.rawDiv "1" 0 0 "$__at_n" 0 0 __at_pd __at_ps __at_pn $__at_workprec

  # Pad to working precision — exact divisions like 1/5 = 0.2 return
  # minimal digit strings. Without padding, the power accumulator
  # carries only 1 significant digit through every multiply, and
  # precision is lost catastrophically.
  if (( ${#__at_pd} < __at_workprec )); then
    local -i __at_padneed=$(( __at_workprec - ${#__at_pd} ))
    local __at_padzeros
    printf -v __at_padzeros "%0${__at_padneed}d" 0
    __at_pd="${__at_pd}${__at_padzeros}"
    (( __at_ps += __at_padneed ))
  fi

  # sum = power (copy)
  __at_sd="$__at_pd"; __at_ss=$__at_ps; __at_sn=$__at_pn

  # inv_nsq = 1/n² — precomputed multiplier for stepping power
  local __at_id
  local -i __at_is __at_in
  local -i __at_nsq=$(( __at_n * __at_n ))
  __Math.rawDiv "1" 0 0 "$__at_nsq" 0 0 __at_id __at_is __at_in $__at_workprec

  # Same padding for inv_nsq
  if (( ${#__at_id} < __at_workprec )); then
    local -i __at_idpadneed=$(( __at_workprec - ${#__at_id} ))
    local __at_idpadzeros
    printf -v __at_idpadzeros "%0${__at_idpadneed}d" 0
    __at_id="${__at_id}${__at_idpadzeros}"
    (( __at_is += __at_idpadneed ))
  fi

  local -i __at_k=1 __at_sign=-1

  while true; do
    # power *= inv_nsq
    __Math.rawMul "$__at_pd" $__at_ps $__at_pn "$__at_id" $__at_is $__at_in __at_pd __at_ps __at_pn

    # Trim power to working precision to prevent digit string bloat.
    # Multiplication doubles the digit count each time; without trimming,
    # strings grow without bound and strMul becomes O(n²) on length.
    if (( ${#__at_pd} > __at_workprec )); then
      local -i __at_trim=$(( ${#__at_pd} - __at_workprec ))
      __at_pd="${__at_pd:0:__at_workprec}"
      (( __at_ps -= __at_trim ))
      (( __at_ps < 0 )) && __at_ps=0
    fi

    # term = power / (2k+1)
    local -i __at_divisor=$(( 2 * __at_k + 1 ))
    __Math.rawDivSmall "$__at_pd" $__at_ps $__at_pn $__at_divisor __at_td __at_ts __at_tn $__at_workprec

    # Convergence check: if all significant digits of term are beyond
    # our precision, the term won't affect the sum. Check by comparing
    # the number of leading zeros in the fractional part.
    local -i __at_intdigits=$(( ${#__at_td} - __at_ts ))
    (( __at_intdigits < 0 )) && __at_intdigits=0
    # If the term has no integer part and enough leading fractional zeros, stop
    if (( __at_intdigits == 0 )); then
      # Count leading zeros: pad digits to scale length, count prefix zeros
      local __at_padded="$__at_td"
      if (( ${#__at_padded} < __at_ts )); then
        local -i __at_pneed=$(( __at_ts - ${#__at_padded} ))
        local __at_pz
        printf -v __at_pz "%0${__at_pneed}d" 0
        __at_padded="${__at_pz}${__at_padded}"
      fi
      local __at_lz="${__at_padded%%[!0]*}"
      if (( ${#__at_lz} >= __at_prec )); then
        break
      fi
    fi

    # Alternating sign: subtract odd terms, add even terms
    if (( __at_sign < 0 )); then
      __Math.rawSub "$__at_sd" $__at_ss $__at_sn "$__at_td" $__at_ts $__at_tn __at_sd __at_ss __at_sn
    else
      __Math.rawAdd "$__at_sd" $__at_ss $__at_sn "$__at_td" $__at_ts $__at_tn __at_sd __at_ss __at_sn
    fi

    (( __at_sign = -__at_sign ))
    (( __at_k++ ))
  done

  # Wrap final result in a Math object for the public API
  local __at_result
  __Math.fromParts "$__at_sd" $__at_ss $__at_sn __at_result

  __boop_static[$__at_cachekey]="$__at_result"
  __boop.return "$__at_result" "${3:-}"
}

# Calculate pi to the specified precision using Machin's formula:
#   π/4 = 4·arctan(1/5) - arctan(1/239)
#   π = 16·arctan(1/5) - 4·arctan(1/239)
#
# This converges fast — arctan(1/5) needs about N/1.4 terms for N digits,
# and arctan(1/239) needs about N/4.8 terms. For 1000 digits, that's
# roughly 700 + 200 = 900 iterations total.
#
# The arctan calls use raw triple arithmetic internally (no object churn).
# Only the final multiply/subtract/round steps create objects, since
# there are only a handful of those.
#
# Usage: into=pi Math.pi           # default precision
#        into=pi Math.pi 100       # 100 significant digits
#        into=pi Math.pi 1000      # go big
Math.pi() {
  local -i __pi_prec="${1:-$__Math_precision}"

  # Check cache
  local __pi_cachekey="Math.pi.${__pi_prec}"
  if [[ -n "${__boop_static[$__pi_cachekey]:-}" ]]; then
    __boop.return "${__boop_static[$__pi_cachekey]}" ${into:-}
    return
  fi

  local -i __pi_workprec=$(( __pi_prec + 15 ))

  # arctan(1/5) and arctan(1/239) — raw triple loops internally
  local __pi_at5 __pi_at239
  __Math.arctan_recip 5 $__pi_workprec __pi_at5
  __Math.arctan_recip 239 $__pi_workprec __pi_at239

  # Extract raw triples from the arctan results for final arithmetic
  local __pi_d5 __pi_d239
  local -i __pi_s5 __pi_n5 __pi_s239 __pi_n239
  __Math.resolve "$__pi_at5" __pi_d5 __pi_s5 __pi_n5
  __Math.resolve "$__pi_at239" __pi_d239 __pi_s239 __pi_n239

  # 16 * arctan(1/5)
  local __pi_rd1
  local -i __pi_rs1 __pi_rn1
  __Math.rawMulSmall "$__pi_d5" $__pi_s5 $__pi_n5 16 __pi_rd1 __pi_rs1 __pi_rn1

  # 4 * arctan(1/239)
  local __pi_rd2
  local -i __pi_rs2 __pi_rn2
  __Math.rawMulSmall "$__pi_d239" $__pi_s239 $__pi_n239 4 __pi_rd2 __pi_rs2 __pi_rn2

  # pi = 16*arctan(1/5) - 4*arctan(1/239)
  local __pi_rd
  local -i __pi_rs __pi_rn
  __Math.rawSub "$__pi_rd1" $__pi_rs1 $__pi_rn1 "$__pi_rd2" $__pi_rs2 $__pi_rn2 __pi_rd __pi_rs __pi_rn

  # Build object, truncate to requested precision
  local __pi_result
  __Math.fromParts "$__pi_rd" $__pi_rs $__pi_rn __pi_result

  local __pi_td; local -i __pi_ts __pi_tn
  __Math.resolve "$__pi_result" __pi_td __pi_ts __pi_tn
  if (( ${#__pi_td} > __pi_prec )); then
    local -i __pi_cut=$(( ${#__pi_td} - __pi_prec ))
    __pi_td="${__pi_td:0:__pi_prec}"
    (( __pi_ts -= __pi_cut ))
    (( __pi_ts < 0 )) && __pi_ts=0
  fi
  __Math.fromParts "$__pi_td" $__pi_ts $__pi_tn __pi_result

  __boop_static[$__pi_cachekey]="$__pi_result"
  __boop.return "$__pi_result" ${into:-}
}


