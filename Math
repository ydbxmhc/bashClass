# Higher-level math functions
# ============================================================================

# ============================================================================
# Raw arithmetic on digit/scale/neg triples
# ============================================================================
# These bypass the object system entirely. No IDs, no descriptors, no
# registry, no stubs, no encoding. Just local variables in, local
# variables out. Used by the hot inner loops of series expansions
# (arctan, pi) where object overhead dominates runtime.
#
# Convention: result is returned via three namerefs passed as the last
# three arguments: out_digits, out_scale, out_neg.

# Raw add: (dA,sA,nA) + (dB,sB,nB) → (dR,sR,nR)
# Aligns scales, then delegates to strAdd or strSub based on sign.
# Same logic as Math.add but without object creation or resolution.
__Math.rawAdd() {
  local __Math_rawAdd_dA="$1" __Math_rawAdd_dB="$4"
  local -i __Math_rawAdd_sA="$2" __Math_rawAdd_nA="$3" __Math_rawAdd_sB="$5" __Math_rawAdd_nB="$6"
  local -n __Math_rawAdd_od="$7" __Math_rawAdd_os="$8" __Math_rawAdd_on="$9"

  __Math.alignScale __Math_rawAdd_dA __Math_rawAdd_sA __Math_rawAdd_dB __Math_rawAdd_sB

  if (( __Math_rawAdd_nA == __Math_rawAdd_nB )); then
    __Math.strAdd "$__Math_rawAdd_dA" "$__Math_rawAdd_dB" __Math_rawAdd_od
    __Math_rawAdd_on=$__Math_rawAdd_nA
  else
    __Math.strCmp "$__Math_rawAdd_dA" "$__Math_rawAdd_dB"
    local -i __Math_rawAdd_cmp=$?
    if (( __Math_rawAdd_cmp == 0 )); then
      __Math_rawAdd_od="0"; __Math_rawAdd_os=$__Math_rawAdd_sA; __Math_rawAdd_on=0; return
    elif (( __Math_rawAdd_cmp == 1 )); then
      __Math.strSub "$__Math_rawAdd_dA" "$__Math_rawAdd_dB" __Math_rawAdd_od
      __Math_rawAdd_on=$__Math_rawAdd_nA
    else
      __Math.strSub "$__Math_rawAdd_dB" "$__Math_rawAdd_dA" __Math_rawAdd_od
      __Math_rawAdd_on=$__Math_rawAdd_nB
    fi
  fi
  __Math_rawAdd_os=$__Math_rawAdd_sA
  # Strip leading zeros
  __Math_rawAdd_od="${__Math_rawAdd_od#"${__Math_rawAdd_od%%[!0]*}"}"
  : "${__Math_rawAdd_od:=0}"
  [[ "$__Math_rawAdd_od" == "0" ]] && __Math_rawAdd_on=0
}

# Raw sub: (dA,sA,nA) - (dB,sB,nB) → flip sign of B and rawAdd.
__Math.rawSub() {
  local -i __Math_rawSub_nB="$6"
  (( __Math_rawSub_nB = !__Math_rawSub_nB ))
  [[ "$4" == "0" ]] && __Math_rawSub_nB=0
  __Math.rawAdd "$1" "$2" "$3" "$4" "$5" $__Math_rawSub_nB "$7" "$8" "$9"
}

# Raw mul: (dA,sA,nA) * (dB,sB,nB) → (dR,sR,nR)
# Result scale = scaleA + scaleB. Sign = XOR of input signs.
__Math.rawMul() {
  local __Math_rawMul_dA="$1" __Math_rawMul_dB="$4"
  local -i __Math_rawMul_sA="$2" __Math_rawMul_nA="$3" __Math_rawMul_sB="$5" __Math_rawMul_nB="$6"
  local -n __Math_rawMul_od="$7" __Math_rawMul_os="$8" __Math_rawMul_on="$9"

  __Math.strMul "$__Math_rawMul_dA" "$__Math_rawMul_dB" __Math_rawMul_od
  __Math_rawMul_os=$(( __Math_rawMul_sA + __Math_rawMul_sB ))
  __Math_rawMul_on=$(( __Math_rawMul_nA != __Math_rawMul_nB ? 1 : 0 ))
  [[ "$__Math_rawMul_od" == "0" ]] && __Math_rawMul_on=0
}

# Raw mul by small integer: (dA,sA,nA) * int → (dR,sR,nR)
# Handles negative multiplier by splitting sign from magnitude.
__Math.rawMulSmall() {
  local __Math_rawMulSmall_dA="$1"
  local -i __Math_rawMulSmall_sA="$2" __Math_rawMulSmall_nA="$3" __Math_rawMulSmall_n="$4"
  local -n __Math_rawMulSmall_od="$5" __Math_rawMulSmall_os="$6" __Math_rawMulSmall_on="$7"

  local -i __Math_rawMulSmall_abs_n=${__Math_rawMulSmall_n#-}
  __Math.strMulSmall "$__Math_rawMulSmall_dA" $__Math_rawMulSmall_abs_n __Math_rawMulSmall_od
  __Math_rawMulSmall_os=$__Math_rawMulSmall_sA
  __Math_rawMulSmall_on=$(( (__Math_rawMulSmall_n < 0) != __Math_rawMulSmall_nA ? 1 : 0 ))
  [[ "$__Math_rawMulSmall_od" == "0" ]] && __Math_rawMulSmall_on=0
}

# Raw div: (dA,sA,nA) / (dB,sB,nB) → (dR,sR,nR)
# Aligns scales, performs string division, then truncates to
# the requested precision. Same logic as Math.div but without objects.
# $10 = precision (default __Math_precision).
__Math.rawDiv() {
  local __Math_rawDiv_dA="$1" __Math_rawDiv_dB="$4"
  local -i __Math_rawDiv_sA="$2" __Math_rawDiv_nA="$3" __Math_rawDiv_sB="$5" __Math_rawDiv_nB="$6"
  local -n __Math_rawDiv_od="${7}" __Math_rawDiv_os="${8}" __Math_rawDiv_on="${9}"
  local -i __Math_rawDiv_prec="${10:-$__Math_precision}"

  [[ "$__Math_rawDiv_dB" == "0" ]] && _Crash "Math: division by zero"

  __Math.alignScale __Math_rawDiv_dA __Math_rawDiv_sA __Math_rawDiv_dB __Math_rawDiv_sB

  local -i __Math_rawDiv_qs
  __Math.strDiv "$__Math_rawDiv_dA" "$__Math_rawDiv_dB" __Math_rawDiv_od $((__Math_rawDiv_prec + 2)) __Math_rawDiv_qs

  __Math_rawDiv_on=$(( __Math_rawDiv_nA != __Math_rawDiv_nB ? 1 : 0 ))

  # Truncate to requested precision
  if (( ${#__Math_rawDiv_od} > __Math_rawDiv_prec )); then
    local -i __Math_rawDiv_removed=$(( ${#__Math_rawDiv_od} - __Math_rawDiv_prec ))
    __Math_rawDiv_od="${__Math_rawDiv_od:0:__Math_rawDiv_prec}"
    (( __Math_rawDiv_qs -= __Math_rawDiv_removed ))
    (( __Math_rawDiv_qs < 0 )) && __Math_rawDiv_qs=0
  fi

  __Math_rawDiv_os=$__Math_rawDiv_qs
  [[ "$__Math_rawDiv_od" == "0" ]] && __Math_rawDiv_on=0
}

# Raw div by small integer: (dA,sA,nA) / int → (dR,sR,nR)
# Converts the small int to a triple and delegates to rawDiv.
# $8 = precision override.
__Math.rawDivSmall() {
  local -i __Math_rawDivSmall_n="${4}"
  local -i __Math_rawDivSmall_nB=0
  (( __Math_rawDivSmall_n < 0 )) && { __Math_rawDivSmall_nB=1; __Math_rawDivSmall_n=$(( -__Math_rawDivSmall_n )); }
  __Math.rawDiv "$1" "$2" "$3" "$__Math_rawDivSmall_n" 0 $__Math_rawDivSmall_nB "$5" "$6" "$7" "${8:-}"
}

# ============================================================================
# Higher-level math functions
# ============================================================================

# arctan(1/n) via Taylor series: 1/n - 1/(3n³) + 1/(5n⁵) - 1/(7n⁷) + ...
#
# This is the building block for Machin-like pi formulas. We compute
# arctan of the reciprocal of a small integer, which keeps the series
# converging fast (each term shrinks by a factor of n²).
#
# PERFORMANCE: operates entirely on raw digit/scale/neg triples. No Math
# objects are created during the loop — only one object is built at the
# end to wrap the result. This eliminates all object overhead (ID gen,
# descriptor encoding, registry writes, stub eval) from the hot path.
#
# Uses __boop_static to cache results at a given precision so
# repeated calls (e.g., from pi at the same precision) don't recompute.
#
# $1 = integer n (compute arctan(1/n))
# $2 = optional precision override
# $3 = optional nameref target for result (object ID)
__Math.arctan_recip() {
  local -i __Math_arctan_n="$1"
  local -i __Math_arctan_prec="${2:-$__Math_precision}"
  local -i __Math_arctan_workprec=$(( __Math_arctan_prec + 15 ))

  # Check cache
  local __Math_arctan_cachekey="Math.arctan_recip.${__Math_arctan_n}.${__Math_arctan_prec}"
  if [[ -n "${__boop_static[$__Math_arctan_cachekey]:-}" ]]; then
    boop.pass "${__boop_static[$__Math_arctan_cachekey]}" "${3:-}"
    return
  fi

  # All work done on raw triples: digits, scale, neg
  # term = power = 1/n
  local __Math_arctan_pd __Math_arctan_td __Math_arctan_sd __Math_arctan_dd
  local -i __Math_arctan_ps __Math_arctan_ts __Math_arctan_ss __Math_arctan_ds
  local -i __Math_arctan_pn __Math_arctan_tn __Math_arctan_sn __Math_arctan_dn

  # 1/n → power triple
  __Math.rawDiv "1" 0 0 "$__Math_arctan_n" 0 0 __Math_arctan_pd __Math_arctan_ps __Math_arctan_pn $__Math_arctan_workprec

  # Pad to working precision — exact divisions like 1/5 = 0.2 return
  # minimal digit strings. Without padding, the power accumulator
  # carries only 1 significant digit through every multiply, and
  # precision is lost catastrophically.
  if (( ${#__Math_arctan_pd} < __Math_arctan_workprec )); then
    local -i __Math_arctan_padneed=$(( __Math_arctan_workprec - ${#__Math_arctan_pd} ))
    local __Math_arctan_padzeros
    printf -v __Math_arctan_padzeros "%0${__Math_arctan_padneed}d" 0
    __Math_arctan_pd="${__Math_arctan_pd}${__Math_arctan_padzeros}"
    (( __Math_arctan_ps += __Math_arctan_padneed ))
  fi

  # sum = power (copy)
  __Math_arctan_sd="$__Math_arctan_pd"; __Math_arctan_ss=$__Math_arctan_ps; __Math_arctan_sn=$__Math_arctan_pn

  # inv_nsq = 1/n² — precomputed multiplier for stepping power
  local __Math_arctan_id
  local -i __Math_arctan_is __Math_arctan_in
  local -i __Math_arctan_nsq=$(( __Math_arctan_n * __Math_arctan_n ))
  __Math.rawDiv "1" 0 0 "$__Math_arctan_nsq" 0 0 __Math_arctan_id __Math_arctan_is __Math_arctan_in $__Math_arctan_workprec

  # Same padding for inv_nsq
  if (( ${#__Math_arctan_id} < __Math_arctan_workprec )); then
    local -i __Math_arctan_idpadneed=$(( __Math_arctan_workprec - ${#__Math_arctan_id} ))
    local __Math_arctan_idpadzeros
    printf -v __Math_arctan_idpadzeros "%0${__Math_arctan_idpadneed}d" 0
    __Math_arctan_id="${__Math_arctan_id}${__Math_arctan_idpadzeros}"
    (( __Math_arctan_is += __Math_arctan_idpadneed ))
  fi

  local -i __Math_arctan_k=1 __Math_arctan_sign=-1

  while true; do
    # power *= inv_nsq
    __Math.rawMul "$__Math_arctan_pd" $__Math_arctan_ps $__Math_arctan_pn "$__Math_arctan_id" $__Math_arctan_is $__Math_arctan_in __Math_arctan_pd __Math_arctan_ps __Math_arctan_pn

    # Trim power to working precision to prevent digit string bloat.
    # Multiplication doubles the digit count each time; without trimming,
    # strings grow without bound and strMul becomes O(n²) on length.
    if (( ${#__Math_arctan_pd} > __Math_arctan_workprec )); then
      local -i __Math_arctan_trim=$(( ${#__Math_arctan_pd} - __Math_arctan_workprec ))
      __Math_arctan_pd="${__Math_arctan_pd:0:__Math_arctan_workprec}"
      (( __Math_arctan_ps -= __Math_arctan_trim ))
      (( __Math_arctan_ps < 0 )) && __Math_arctan_ps=0
    fi

    # term = power / (2k+1)
    local -i __Math_arctan_divisor=$(( 2 * __Math_arctan_k + 1 ))
    __Math.rawDivSmall "$__Math_arctan_pd" $__Math_arctan_ps $__Math_arctan_pn $__Math_arctan_divisor __Math_arctan_td __Math_arctan_ts __Math_arctan_tn $__Math_arctan_workprec

    # Convergence check: if all significant digits of term are beyond
    # our precision, the term won't affect the sum. Check by comparing
    # the number of leading zeros in the fractional part.
    local -i __Math_arctan_intdigits=$(( ${#__Math_arctan_td} - __Math_arctan_ts ))
    (( __Math_arctan_intdigits < 0 )) && __Math_arctan_intdigits=0
    # If the term has no integer part and enough leading fractional zeros, stop
    if (( __Math_arctan_intdigits == 0 )); then
      # Count leading zeros: pad digits to scale length, count prefix zeros
      local __Math_arctan_padded="$__Math_arctan_td"
      if (( ${#__Math_arctan_padded} < __Math_arctan_ts )); then
        local -i __Math_arctan_pneed=$(( __Math_arctan_ts - ${#__Math_arctan_padded} ))
        local __Math_arctan_pz
        printf -v __Math_arctan_pz "%0${__Math_arctan_pneed}d" 0
        __Math_arctan_padded="${__Math_arctan_pz}${__Math_arctan_padded}"
      fi
      local __Math_arctan_lz="${__Math_arctan_padded%%[!0]*}"
      if (( ${#__Math_arctan_lz} >= __Math_arctan_prec )); then
        break
      fi
    fi

    # Alternating sign: subtract odd terms, add even terms
    if (( __Math_arctan_sign < 0 )); then
      __Math.rawSub "$__Math_arctan_sd" $__Math_arctan_ss $__Math_arctan_sn "$__Math_arctan_td" $__Math_arctan_ts $__Math_arctan_tn __Math_arctan_sd __Math_arctan_ss __Math_arctan_sn
    else
      __Math.rawAdd "$__Math_arctan_sd" $__Math_arctan_ss $__Math_arctan_sn "$__Math_arctan_td" $__Math_arctan_ts $__Math_arctan_tn __Math_arctan_sd __Math_arctan_ss __Math_arctan_sn
    fi

    (( __Math_arctan_sign = -__Math_arctan_sign ))
    (( __Math_arctan_k++ ))
  done

  # Wrap final result in a Math object for the public API
  local __Math_arctan_result
  __Math.fromParts "$__Math_arctan_sd" $__Math_arctan_ss $__Math_arctan_sn __Math_arctan_result

  __boop_static[$__Math_arctan_cachekey]="$__Math_arctan_result"
  boop.pass "$__Math_arctan_result" "${3:-}"
}

# Calculate pi to the specified precision using Machin's formula:
#   π/4 = 4·arctan(1/5) - arctan(1/239)
#   π = 16·arctan(1/5) - 4·arctan(1/239)
#
# This converges fast — arctan(1/5) needs about N/1.4 terms for N digits,
# and arctan(1/239) needs about N/4.8 terms. For 1000 digits, that's
# roughly 700 + 200 = 900 iterations total.
#
# The arctan calls use raw triple arithmetic internally (no object churn).
# Only the final multiply/subtract/round steps create objects, since
# there are only a handful of those.
#
# Usage: into=pi Math.pi           # default precision
#        into=pi Math.pi 100       # 100 significant digits
#        into=pi Math.pi 1000      # go big
Math.pi() {
  local -i __Math_pi_prec="${1:-$__Math_precision}"

  # Check cache
  local __Math_pi_cachekey="Math.pi.${__Math_pi_prec}"
  if [[ -n "${__boop_static[$__Math_pi_cachekey]:-}" ]]; then
    boop.pass "${__boop_static[$__Math_pi_cachekey]}" ${into:-}
    return
  fi

  local -i __Math_pi_workprec=$(( __Math_pi_prec + 15 ))

  # arctan(1/5) and arctan(1/239) — raw triple loops internally
  local __Math_pi_at5 __Math_pi_at239
  __Math.arctan_recip 5 $__Math_pi_workprec __Math_pi_at5
  __Math.arctan_recip 239 $__Math_pi_workprec __Math_pi_at239

  # Extract raw triples from the arctan results for final arithmetic
  local __Math_pi_d5 __Math_pi_d239
  local -i __Math_pi_s5 __Math_pi_n5 __Math_pi_s239 __Math_pi_n239
  __Math.resolve "$__Math_pi_at5" __Math_pi_d5 __Math_pi_s5 __Math_pi_n5
  __Math.resolve "$__Math_pi_at239" __Math_pi_d239 __Math_pi_s239 __Math_pi_n239

  # 16 * arctan(1/5)
  local __Math_pi_rd1
  local -i __Math_pi_rs1 __Math_pi_rn1
  __Math.rawMulSmall "$__Math_pi_d5" $__Math_pi_s5 $__Math_pi_n5 16 __Math_pi_rd1 __Math_pi_rs1 __Math_pi_rn1

  # 4 * arctan(1/239)
  local __Math_pi_rd2
  local -i __Math_pi_rs2 __Math_pi_rn2
  __Math.rawMulSmall "$__Math_pi_d239" $__Math_pi_s239 $__Math_pi_n239 4 __Math_pi_rd2 __Math_pi_rs2 __Math_pi_rn2

  # pi = 16*arctan(1/5) - 4*arctan(1/239)
  local __Math_pi_rd
  local -i __Math_pi_rs __Math_pi_rn
  __Math.rawSub "$__Math_pi_rd1" $__Math_pi_rs1 $__Math_pi_rn1 "$__Math_pi_rd2" $__Math_pi_rs2 $__Math_pi_rn2 __Math_pi_rd __Math_pi_rs __Math_pi_rn

  # Build object, truncate to requested precision
  local __Math_pi_result
  __Math.fromParts "$__Math_pi_rd" $__Math_pi_rs $__Math_pi_rn __Math_pi_result

  local __Math_pi_td; local -i __Math_pi_ts __Math_pi_tn
  __Math.resolve "$__Math_pi_result" __Math_pi_td __Math_pi_ts __Math_pi_tn
  if (( ${#__Math_pi_td} > __Math_pi_prec )); then
    local -i __Math_pi_cut=$(( ${#__Math_pi_td} - __Math_pi_prec ))
    __Math_pi_td="${__Math_pi_td:0:__Math_pi_prec}"
    (( __Math_pi_ts -= __Math_pi_cut ))
    (( __Math_pi_ts < 0 )) && __Math_pi_ts=0
  fi
  __Math.fromParts "$__Math_pi_td" $__Math_pi_ts $__Math_pi_tn __Math_pi_result

  __boop_static[$__Math_pi_cachekey]="$__Math_pi_result"
  boop.pass "$__Math_pi_result" ${into:-}
}


