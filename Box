#!/bin/bash

# Box class

# Load guard — if already registered, nothing to do
[[ -n "${__boop_registry[Box]+set}" ]] && return 2>/dev/null

. boop

# ============================================================================
# Box Implementation Functions
# ============================================================================

# Generic multiplication calculator
Box.calc() {
  local -I _Self; local _Class="${_Class:-Box}"
  local -i __Box_calc_tot=1 required="${required:-0}"

  if ((required)); then
    (( required == $# )) || _Crash "$FUNCNAME requires $required INTEGER arguments to multiply"
  fi

  for __Box_calc_arg in "$@"; do
    [[ "${__Box_calc_arg:-}" =~ ^[0-9]+$ ]] && ((__Box_calc_arg)) || _Crash "$FUNCNAME arguments must be nonzero integers: $*"
    (( __Box_calc_tot *= __Box_calc_arg ))
  done

  boop.pass "$__Box_calc_tot" ${into:-}
}

# Calculate area (2D) — thin wrapper, passes into through
Box.area() {
  local -I _Self; local _Class="${_Class:-Box}"
  required=2 into=${into:-} Box.calc "$@"
}

# Calculate top face area
Box.top() {
  local -I _Self; local _Class="${_Class:-Box}"
  local __Box_top_l __Box_top_w __Box_top_val
  __boop.parse "$_Self" "length" __Box_top_l
  __boop.parse "$_Self" "width" __Box_top_w
  into=__Box_top_val _Self="$_Self" _Class="$_Class" __boop.dispatch area "$__Box_top_l" "$__Box_top_w"
  boop.pass "$__Box_top_val" ${into:-}
}

# Calculate end face area
Box.end() {
  local -I _Self; local _Class="${_Class:-Box}"
  local __Box_end_h __Box_end_w __Box_end_val
  __boop.parse "$_Self" "height" __Box_end_h
  __boop.parse "$_Self" "width" __Box_end_w
  into=__Box_end_val _Self="$_Self" _Class="$_Class" __boop.dispatch area "$__Box_end_h" "$__Box_end_w"
  boop.pass "$__Box_end_val" ${into:-}
}

# Calculate side face area
Box.side() {
  local -I _Self; local _Class="${_Class:-Box}"
  local __Box_side_h __Box_side_l __Box_side_val
  __boop.parse "$_Self" "height" __Box_side_h
  __boop.parse "$_Self" "length" __Box_side_l
  into=__Box_side_val _Self="$_Self" _Class="$_Class" __boop.dispatch area "$__Box_side_h" "$__Box_side_l"
  boop.pass "$__Box_side_val" ${into:-}
}

# Calculate bottom face area (same as top)
Box.bottom() {
  local -I _Self; local _Class="${_Class:-Box}"
  local __Box_bottom_val
  into=__Box_bottom_val _Self="$_Self" _Class="$_Class" __boop.dispatch top
  boop.pass "$__Box_bottom_val" ${into:-}
}

# Calculate volume (3D)
Box.volume() {
  local -I _Self; local _Class="${_Class:-Box}"
  local __Box_volume_l __Box_volume_h __Box_volume_w __Box_volume_vol
  __boop.parse "$_Self" "length" __Box_volume_l
  __boop.parse "$_Self" "height" __Box_volume_h
  __boop.parse "$_Self" "width" __Box_volume_w
  into=__Box_volume_vol required=3 Box.calc "$__Box_volume_l" "$__Box_volume_h" "$__Box_volume_w"
  boop.pass "$__Box_volume_vol" ${into:-}
}

# Box constructor — delegates to base class.
Box.new() {
  local _Class="${_Class:-Box}"
  local __Box_new_self
  into=__Box_new_self __boop.new "$@"
  boop.pass "$__Box_new_self" ${into:-}
}

# ============================================================================
# Class Declaration
# ============================================================================

boopClass Box public:new,calc,area,top,end,side,bottom,volume has:length,width,height,unit,color
