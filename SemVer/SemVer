#!/bin/bash

# SemVer -- Semantic version parsing, comparison, and constraint checking.
#
# Provides public wrappers around the version comparison primitives that live
# in boop core (needed there for the bootstrapping case: checking boop's own
# version before any class loads). SemVer delegates to those primitives so
# the comparison logic exists exactly once.
#
# Public interface:
#   SemVer.satisfies "1.3.0" "1.2+"   # exit 0 = satisfied, 1 = not
#   SemVer.compare  "1.2.3" "1.3.0"  # into= or stdout: -1 / 0 / 1
#
# Constraint syntax:
#   1.2+       >= 1.2.0 (shorthand)
#   >=1.2.3    >= 1.2.3
#   >1.2       > 1.2.0
#   <=2.0      <= 2.0.0
#   <2.0       < 2.0.0
#   1.2.3      exact match
#
# Pre-release suffixes (1.2.3-beta) are stored but ignored in comparisons.
# Missing minor/patch components default to 0: "1" == "1.0.0".

[[ "${BASH_SOURCE[0]}" != "$0" ]] || { printf '%s is a boop class file. Load it with: . boop %s\n' "${BASH_SOURCE[0]##*/}" "${BASH_SOURCE[0]##*/}" >&2; exit 1; }
__boop.guard SemVer && return

. boop

# ============================================================================
# SemVer Implementation Functions
# ============================================================================

# Test whether a version string satisfies a constraint.
#
# Delegates to __boop.versionSatisfies (the boop-core bootstrapping primitive).
#
# Arguments:
#   $1 -- version to test (e.g. "1.3.0")
#   $2 -- constraint (e.g. "1.2+", ">=1.0", "2.0.0")
#
# Returns: exit 0 if satisfied, exit 1 if not.
SemVer.satisfies() {
  local _Self="${_Self:-SemVer}" _Class="${_Class:-SemVer}"
  local __SemVer_satisfies_ver="$1" __SemVer_satisfies_con="$2"
  [[ -n "$__SemVer_satisfies_ver" ]] || _Crash "SemVer.satisfies: version required"
  [[ -n "$__SemVer_satisfies_con" ]] || _Crash "SemVer.satisfies: constraint required"
  _Trace "satisfies: '$__SemVer_satisfies_ver' vs '$__SemVer_satisfies_con'"
  __boop.versionSatisfies "$__SemVer_satisfies_ver" "$__SemVer_satisfies_con"
}

# Compare two version strings.
#
# Arguments:
#   $1 -- version A
#   $2 -- version B
#
# Returns: -1 (A < B), 0 (A == B), 1 (A > B) via into= or stdout.
SemVer.compare() {
  local _Self="${_Self:-SemVer}" _Class="${_Class:-SemVer}"
  local __SemVer_compare_a="$1" __SemVer_compare_b="$2"
  [[ -n "$__SemVer_compare_a" ]] || _Crash "SemVer.compare: version A required"
  [[ -n "$__SemVer_compare_b" ]] || _Crash "SemVer.compare: version B required"
  _Trace "compare: '$__SemVer_compare_a' vs '$__SemVer_compare_b'"
  local __SemVer_compare_result
  __SemVer_compare_result="$(__boop.versionCompare "$__SemVer_compare_a" "$__SemVer_compare_b")"
  boop.pass "$__SemVer_compare_result" ${into:-}
}

# ============================================================================
# Class Declaration
# ============================================================================

boopClass SemVer version:1.0.0 '
  public:satisfies,compare
'
