#!/bin/bash

# Data.JSON -- JSON parser and serializer for boop.
#
# Parses JSON strings into Collection.Map.Fast (flat compound-key store)
# for O(1) point lookups. Optionally inflates into real Map/List objects
# via parseDeep.
#
# Pure bash implementation -- no jq, no python, no external dependencies.
# Handles: objects, arrays, strings, numbers, booleans, null.
#
# Usage:
#   . boop Data::JSON
#   into=doc Data.JSON.parse '{"name":"Alice","age":30}'
#   into=name $doc.get "name"     # "Alice"
#   into=age $doc.get "age"       # "30"
#
#   into=json Data.JSON.stringify "$doc"
#   printf "%s\n" "$json"         # {"name":"Alice","age":"30"}

# Load guard
. boop Collection::Map::Fast

boop.init Data.JSON || return 0

# ── Parser globals ─────────────────────────────────────────────────────────────
# Set by Data.JSON.parse before each run; read by internal helpers.
# __Data_JSON_safe: when 1, parse errors return 1 instead of crashing —
# used by Data.JSON.validate to avoid a subshell.
# __Data_JSON_error: holds the last error message set in safe mode.
declare -gi __Data_JSON_safe=0
declare -g  __Data_JSON_error=""

# ============================================================================
# JSON Tokenizer
# ============================================================================

# __Data_JSON_parse -- recursive descent parser.
# Reads from __Data_JSON_src starting at __Data_JSON_pos.
# Writes compound keys into the Fast object referenced by __Data_JSON_doc.
#
# All state is passed via globals (set by the public parse function):
#   __Data_JSON_src   -- the JSON string
#   __Data_JSON_pos   -- current parse position (integer)
#   __Data_JSON_len   -- length of src
#   __Data_JSON_doc   -- object ID of the target Fast instance
#   __Data_JSON_prefix -- current compound key prefix

# Skip whitespace
__Data_JSON_skipWS() {
  local __Data_JSON_skipWS_c
  while (( __Data_JSON_pos < __Data_JSON_len )); do
    __Data_JSON_skipWS_c="${__Data_JSON_src:__Data_JSON_pos:1}"
    [[ "$__Data_JSON_skipWS_c" == " " || "$__Data_JSON_skipWS_c" == $'\t' || "$__Data_JSON_skipWS_c" == $'\n' || "$__Data_JSON_skipWS_c" == $'\r' ]] || break
    (( __Data_JSON_pos++ ))
  done
}


# Parse a \uXXXX escape sequence (after the 'u' consumed by parseString).
# Reads 4 hex digits. Handles UTF-16 surrogate pairs for characters beyond
# the Basic Multilingual Plane (\uD800-\uDBFF high + \uDC00-\uDFFF low →
# single codepoint in U+10000 to U+10FFFF range).
# Appends the decoded UTF-8 bytes to __Data_JSON_strResult.
__Data_JSON_parseUnicode() {
  local __Data_JSON_pu_hex="${__Data_JSON_src:__Data_JSON_pos:4}"
  [[ "$__Data_JSON_pu_hex" =~ ^[0-9A-Fa-f]{4}$ ]] ||
    __Data_JSON_fail "Data.JSON: invalid \\u escape: '$__Data_JSON_pu_hex'" || return 1
  (( __Data_JSON_pos += 4 ))
  local -i __Data_JSON_pu_code=$((16#$__Data_JSON_pu_hex))

  # High surrogate: expect a low surrogate to follow as \uXXXX
  if (( __Data_JSON_pu_code >= 0xD800 && __Data_JSON_pu_code <= 0xDBFF )); then
    [[ "${__Data_JSON_src:__Data_JSON_pos:2}" == '\u' ]] ||
      __Data_JSON_fail "Data.JSON: unpaired high surrogate \\u$__Data_JSON_pu_hex" || return 1
    (( __Data_JSON_pos += 2 ))
    local __Data_JSON_pu_lowHex="${__Data_JSON_src:__Data_JSON_pos:4}"
    [[ "$__Data_JSON_pu_lowHex" =~ ^[0-9A-Fa-f]{4}$ ]] ||
      __Data_JSON_fail "Data.JSON: invalid \\u escape in surrogate pair: '$__Data_JSON_pu_lowHex'" || return 1
    (( __Data_JSON_pos += 4 ))
    local -i __Data_JSON_pu_low=$((16#$__Data_JSON_pu_lowHex))
    (( __Data_JSON_pu_low >= 0xDC00 && __Data_JSON_pu_low <= 0xDFFF )) ||
      __Data_JSON_fail "Data.JSON: invalid low surrogate \\u$__Data_JSON_pu_lowHex" || return 1
    __Data_JSON_pu_code=$(( 0x10000 + ((__Data_JSON_pu_code - 0xD800) << 10) + (__Data_JSON_pu_low - 0xDC00) ))
  elif (( __Data_JSON_pu_code >= 0xDC00 && __Data_JSON_pu_code <= 0xDFFF )); then
    __Data_JSON_fail "Data.JSON: unexpected low surrogate \\u$__Data_JSON_pu_hex" || return 1
  fi

  # Encode codepoint to UTF-8 bytes via \xNN printf escapes (locale-independent)
  local __Data_JSON_pu_fmt="" __Data_JSON_pu_b __Data_JSON_pu_utf8
  if (( __Data_JSON_pu_code <= 0x7F )); then
    printf -v __Data_JSON_pu_fmt '\\x%02X' "$__Data_JSON_pu_code"
  elif (( __Data_JSON_pu_code <= 0x7FF )); then
    printf -v __Data_JSON_pu_b '\\x%02X' $(( 0xC0 | (__Data_JSON_pu_code >> 6) ))
    __Data_JSON_pu_fmt="$__Data_JSON_pu_b"
    printf -v __Data_JSON_pu_b '\\x%02X' $(( 0x80 | (__Data_JSON_pu_code & 0x3F) ))
    __Data_JSON_pu_fmt+="$__Data_JSON_pu_b"
  elif (( __Data_JSON_pu_code <= 0xFFFF )); then
    printf -v __Data_JSON_pu_b '\\x%02X' $(( 0xE0 | (__Data_JSON_pu_code >> 12) ))
    __Data_JSON_pu_fmt="$__Data_JSON_pu_b"
    printf -v __Data_JSON_pu_b '\\x%02X' $(( 0x80 | ((__Data_JSON_pu_code >> 6) & 0x3F) ))
    __Data_JSON_pu_fmt+="$__Data_JSON_pu_b"
    printf -v __Data_JSON_pu_b '\\x%02X' $(( 0x80 | (__Data_JSON_pu_code & 0x3F) ))
    __Data_JSON_pu_fmt+="$__Data_JSON_pu_b"
  else
    printf -v __Data_JSON_pu_b '\\x%02X' $(( 0xF0 | (__Data_JSON_pu_code >> 18) ))
    __Data_JSON_pu_fmt="$__Data_JSON_pu_b"
    printf -v __Data_JSON_pu_b '\\x%02X' $(( 0x80 | ((__Data_JSON_pu_code >> 12) & 0x3F) ))
    __Data_JSON_pu_fmt+="$__Data_JSON_pu_b"
    printf -v __Data_JSON_pu_b '\\x%02X' $(( 0x80 | ((__Data_JSON_pu_code >> 6) & 0x3F) ))
    __Data_JSON_pu_fmt+="$__Data_JSON_pu_b"
    printf -v __Data_JSON_pu_b '\\x%02X' $(( 0x80 | (__Data_JSON_pu_code & 0x3F) ))
    __Data_JSON_pu_fmt+="$__Data_JSON_pu_b"
  fi
  printf -v __Data_JSON_pu_utf8 "$__Data_JSON_pu_fmt"
  __Data_JSON_strResult+="$__Data_JSON_pu_utf8"
}

# Parse a JSON string value (after opening quote consumed)
# Sets __Data_JSON_strResult (no subshell)
__Data_JSON_parseString() {
  __Data_JSON_strResult=""
  local __Data_JSON_parseString_c
  while (( __Data_JSON_pos < __Data_JSON_len )); do
    __Data_JSON_parseString_c="${__Data_JSON_src:__Data_JSON_pos:1}"
    (( __Data_JSON_pos++ ))
    if [[ "$__Data_JSON_parseString_c" == '"' ]]; then
      return
    elif [[ "$__Data_JSON_parseString_c" == '\' ]]; then
      __Data_JSON_parseString_c="${__Data_JSON_src:__Data_JSON_pos:1}"
      (( __Data_JSON_pos++ ))
      case "$__Data_JSON_parseString_c" in
        '"'|'\'|'/') __Data_JSON_strResult+="$__Data_JSON_parseString_c" ;;
        'n') __Data_JSON_strResult+=$'\n' ;;
        't') __Data_JSON_strResult+=$'\t' ;;
        'r') __Data_JSON_strResult+=$'\r' ;;
        'b') __Data_JSON_strResult+=$'\b' ;;
        'f') __Data_JSON_strResult+=$'\f' ;;
        'u') __Data_JSON_parseUnicode || return 1 ;;
        *) __Data_JSON_strResult+="$__Data_JSON_parseString_c" ;;
      esac
    else
      __Data_JSON_strResult+="$__Data_JSON_parseString_c"
    fi
  done
  __Data_JSON_fail "Data.JSON: unterminated string" || return 1
}

# __Data_JSON_fail -- report a parse error.
# Safe mode: stores msg in __Data_JSON_error and returns 1.
# Normal mode: emits _Error and returns 1.
# Both modes are non-fatal — the caller propagates via "|| return 1".
__Data_JSON_fail() {
  if (( __Data_JSON_safe )); then
    __Data_JSON_error="$1"
    return 1
  fi
  _Error "$1"
  return 1
}

# __Data_JSON_storeLeaf -- write a leaf value into the current doc.
# Records in both the data hash (for O(1) lookup) and the ordered keys array
# (for insertion-order stringify). All leaf writes go through here.
__Data_JSON_storeLeaf() {
  local -n __Data_JSON_storeLeaf_data="__boop_data_${__Data_JSON_doc}"
  local -n __Data_JSON_storeLeaf_keys="__boop_keys_${__Data_JSON_doc}"
  __Data_JSON_storeLeaf_data["$1"]="$2"
  __Data_JSON_storeLeaf_keys+=("$1")
}

# Parse a JSON number -- sets __Data_JSON_numResult (no subshell)
__Data_JSON_parseNumber() {
  local __Data_JSON_parseNumber_start=$__Data_JSON_pos __Data_JSON_parseNumber_c
  while (( __Data_JSON_pos < __Data_JSON_len )); do
    __Data_JSON_parseNumber_c="${__Data_JSON_src:__Data_JSON_pos:1}"
    [[ "$__Data_JSON_parseNumber_c" =~ [0-9.eE+\-] ]] || break
    (( __Data_JSON_pos++ ))
  done
  __Data_JSON_numResult="${__Data_JSON_src:__Data_JSON_parseNumber_start:__Data_JSON_pos - __Data_JSON_parseNumber_start}"
}

# Parse a JSON value at current position, store into doc with given prefix
__Data_JSON_parseValue() {
  local __Data_JSON_parseValue_prefix="$1"
  __Data_JSON_skipWS
  (( __Data_JSON_pos < __Data_JSON_len )) ||
    __Data_JSON_fail "Data.JSON: unexpected end of input" || return 1

  local __Data_JSON_parseValue_c="${__Data_JSON_src:__Data_JSON_pos:1}"

  case "$__Data_JSON_parseValue_c" in
    '"')
      # String
      (( __Data_JSON_pos++ ))
      __Data_JSON_parseString || return 1
      __Data_JSON_storeLeaf "$__Data_JSON_parseValue_prefix" "$__Data_JSON_strResult"
      ;;
    '{')
      # Object
      (( __Data_JSON_pos++ ))
      __Data_JSON_skipWS
      if [[ "${__Data_JSON_src:__Data_JSON_pos:1}" == "}" ]]; then
        (( __Data_JSON_pos++ ))
        return
      fi
      while :; do
        __Data_JSON_skipWS
        # Key
        [[ "${__Data_JSON_src:__Data_JSON_pos:1}" == '"' ]] ||
          __Data_JSON_fail "Data.JSON: expected '\"' for object key" || return 1
        (( __Data_JSON_pos++ ))
        __Data_JSON_parseString || return 1
        local __Data_JSON_parseValue_key="$__Data_JSON_strResult"
        __Data_JSON_skipWS
        # Colon
        [[ "${__Data_JSON_src:__Data_JSON_pos:1}" == ":" ]] ||
          __Data_JSON_fail "Data.JSON: expected ':'" || return 1
        (( __Data_JSON_pos++ ))
        # Value
        local __Data_JSON_parseValue_childPrefix
        if [[ -n "$__Data_JSON_parseValue_prefix" ]]; then
          __Data_JSON_parseValue_childPrefix="${__Data_JSON_parseValue_prefix}.${__Data_JSON_parseValue_key}"
        else
          __Data_JSON_parseValue_childPrefix="$__Data_JSON_parseValue_key"
        fi
        __Data_JSON_parseValue "$__Data_JSON_parseValue_childPrefix" || return 1
        __Data_JSON_skipWS
        # Comma or end
        if [[ "${__Data_JSON_src:__Data_JSON_pos:1}" == "," ]]; then
          (( __Data_JSON_pos++ ))
        elif [[ "${__Data_JSON_src:__Data_JSON_pos:1}" == "}" ]]; then
          (( __Data_JSON_pos++ ))
          return
        else
          __Data_JSON_fail "Data.JSON: expected ',' or '}'" || return 1
        fi
      done
      ;;
    '[')
      # Array
      (( __Data_JSON_pos++ ))
      __Data_JSON_skipWS
      if [[ "${__Data_JSON_src:__Data_JSON_pos:1}" == "]" ]]; then
        (( __Data_JSON_pos++ ))
        return
      fi
      local -i __Data_JSON_parseValue_idx=0
      while :; do
        local __Data_JSON_parseValue_childPrefix
        if [[ -n "$__Data_JSON_parseValue_prefix" ]]; then
          __Data_JSON_parseValue_childPrefix="${__Data_JSON_parseValue_prefix}.${__Data_JSON_parseValue_idx}"
        else
          __Data_JSON_parseValue_childPrefix="$__Data_JSON_parseValue_idx"
        fi
        __Data_JSON_parseValue "$__Data_JSON_parseValue_childPrefix" || return 1
        (( __Data_JSON_parseValue_idx++ ))
        __Data_JSON_skipWS
        if [[ "${__Data_JSON_src:__Data_JSON_pos:1}" == "," ]]; then
          (( __Data_JSON_pos++ ))
        elif [[ "${__Data_JSON_src:__Data_JSON_pos:1}" == "]" ]]; then
          (( __Data_JSON_pos++ ))
          return
        else
          __Data_JSON_fail "Data.JSON: expected ',' or ']'" || return 1
        fi
      done
      ;;
    't')
      # true
      [[ "${__Data_JSON_src:__Data_JSON_pos:4}" == "true" ]] ||
        __Data_JSON_fail "Data.JSON: invalid token" || return 1
      (( __Data_JSON_pos += 4 ))
      __Data_JSON_storeLeaf "$__Data_JSON_parseValue_prefix" "true"
      ;;
    'f')
      # false
      [[ "${__Data_JSON_src:__Data_JSON_pos:5}" == "false" ]] ||
        __Data_JSON_fail "Data.JSON: invalid token" || return 1
      (( __Data_JSON_pos += 5 ))
      __Data_JSON_storeLeaf "$__Data_JSON_parseValue_prefix" "false"
      ;;
    'n')
      # null
      [[ "${__Data_JSON_src:__Data_JSON_pos:4}" == "null" ]] ||
        __Data_JSON_fail "Data.JSON: invalid token" || return 1
      (( __Data_JSON_pos += 4 ))
      __Data_JSON_storeLeaf "$__Data_JSON_parseValue_prefix" ""
      ;;
    '-'|[0-9])
      # Number
      __Data_JSON_parseNumber
      __Data_JSON_storeLeaf "$__Data_JSON_parseValue_prefix" "$__Data_JSON_numResult"
      ;;
    *)
      __Data_JSON_fail "Data.JSON: unexpected character '$__Data_JSON_parseValue_c' at position $__Data_JSON_pos" \
        || return 1
      ;;
  esac
}


# ============================================================================
# Public API
# ============================================================================

# Data.JSON.parse -- parse a JSON string into a Collection.Map.Fast.
#
# Returns a Fast object with compound keys for O(1) point lookups.
#
# Usage:
#   into=doc Data.JSON.parse '{"name":"Alice","scores":[10,20,30]}'
#   into=name $doc.get "name"         # "Alice"
#   into=s $doc.get "scores.1"        # "20"
Data.JSON.parse() {
  local __Data_JSON_parse_json="${1:-}"
  [[ -n "$__Data_JSON_parse_json" ]] || { _Error "Data.JSON.parse: empty input"; return 1; }

  # Create the target Fast object and its companion ordered-key index.
  # __boop_keys_${doc} is an indexed array that records each leaf key as it is
  # parsed, so stringify can reconstruct the original key order without sorting.
  into=__Data_JSON_doc Collection.Map.Fast.new
  declare -ga "__boop_keys_${__Data_JSON_doc}=()"

  # Set up parser state
  __Data_JSON_src="$__Data_JSON_parse_json"
  __Data_JSON_pos=0
  __Data_JSON_len=${#__Data_JSON_src}

  # Parse
  __Data_JSON_parseValue "" || return 1

  boop.pass "$__Data_JSON_doc" "${into:-}"
}

# Data.JSON.stringify -- serialize a Collection.Map.Fast back to JSON.
#
# Reconstructs JSON from compound keys. Objects and arrays are inferred
# from key structure (numeric keys = array, string keys = object).
# Uses shared result string with recursion (no subshells).
# Depth guard: spawns subshell at depth > 50 to reset stack.
#
# Usage:
#   into=json Data.JSON.stringify "$doc"
Data.JSON.stringify() {
  local __Data_JSON_stringify_doc="$1"
  __Data_JSON_result=""
  __Data_JSON_stringifyPrefix "" "$__Data_JSON_stringify_doc" 0
  boop.pass "$__Data_JSON_result" "${into:-}"
}

# Internal: stringify all keys under a prefix, appending to __Data_JSON_result
__Data_JSON_stringifyPrefix() {
  local __Data_JSON_sp_prefix="$1" __Data_JSON_sp_doc="$2"
  local -i __Data_JSON_sp_depth="${3:-0}"
  local -n __Data_JSON_sp_data="__boop_data_${__Data_JSON_sp_doc}"

  # Depth guard -- subshell fallback for pathological nesting
  if (( __Data_JSON_sp_depth > 50 )); then
    __Data_JSON_result+="$(
      __Data_JSON_result=""
      __Data_JSON_stringifyPrefix "$__Data_JSON_sp_prefix" "$__Data_JSON_sp_doc" 0
      printf '%s' "$__Data_JSON_result"
    )"
    return
  fi

  # Collect direct children of this prefix in the correct order.
  # When __boop_keys_${doc} is present (JSON.parse sets it) we iterate in
  # leaf-insertion order so stringify reproduces the original key order.
  # For raw Fast objects (no keys array) we fall back to hash iteration.
  local -a __Data_JSON_sp_children=()
  local -A __Data_JSON_sp_seen=()
  local __Data_JSON_sp_k __Data_JSON_sp_child
  local -a __Data_JSON_sp_walk_keys
  if [[ -v "__boop_keys_${__Data_JSON_sp_doc}" ]]; then
    local -n __Data_JSON_sp_ord="__boop_keys_${__Data_JSON_sp_doc}"
    __Data_JSON_sp_walk_keys=( "${__Data_JSON_sp_ord[@]+"${__Data_JSON_sp_ord[@]}"}" )
  else
    __Data_JSON_sp_walk_keys=( "${!__Data_JSON_sp_data[@]}" )
  fi

  for __Data_JSON_sp_k in "${__Data_JSON_sp_walk_keys[@]+"${__Data_JSON_sp_walk_keys[@]}"}"; do
    if [[ -z "$__Data_JSON_sp_prefix" ]]; then
      __Data_JSON_sp_child="${__Data_JSON_sp_k%%.*}"
    elif [[ "$__Data_JSON_sp_k" == "${__Data_JSON_sp_prefix}."* ]]; then
      local __Data_JSON_sp_rest="${__Data_JSON_sp_k#"${__Data_JSON_sp_prefix}".}"
      __Data_JSON_sp_child="${__Data_JSON_sp_rest%%.*}"
    else
      continue
    fi
    if [[ -z "${__Data_JSON_sp_seen[$__Data_JSON_sp_child]+set}" ]]; then
      __Data_JSON_sp_seen[$__Data_JSON_sp_child]=1
      __Data_JSON_sp_children+=("$__Data_JSON_sp_child")
    fi
  done

  (( ${#__Data_JSON_sp_children[@]} )) || { __Data_JSON_result+='{}'; return; }

  # Determine if this is an array (all numeric children) or object
  local -i __Data_JSON_sp_is_array=1
  for __Data_JSON_sp_child in "${__Data_JSON_sp_children[@]}"; do
    [[ "$__Data_JSON_sp_child" =~ ^[0-9]+$ ]] || { __Data_JSON_sp_is_array=0; break; }
  done

  if (( __Data_JSON_sp_is_array )); then
    # JSON arrays are always sequentially indexed from 0; no sort needed.
    # Find the max index and rebuild the child list in order.
    local -i __Data_JSON_sp_max=0 __Data_JSON_sp_i
    for __Data_JSON_sp_child in "${__Data_JSON_sp_children[@]}"; do
      (( __Data_JSON_sp_child > __Data_JSON_sp_max )) && __Data_JSON_sp_max=$__Data_JSON_sp_child
    done
    __Data_JSON_sp_children=()
    for (( __Data_JSON_sp_i=0; __Data_JSON_sp_i<=__Data_JSON_sp_max; __Data_JSON_sp_i++ )); do
      __Data_JSON_sp_children+=("$__Data_JSON_sp_i")
    done
    __Data_JSON_result+='['
  else
    __Data_JSON_result+='{'
  fi

  local -i __Data_JSON_sp_first=1
  for __Data_JSON_sp_child in "${__Data_JSON_sp_children[@]}"; do
    (( __Data_JSON_sp_first )) || __Data_JSON_result+=','
    __Data_JSON_sp_first=0

    local __Data_JSON_sp_fullkey
    if [[ -n "$__Data_JSON_sp_prefix" ]]; then
      __Data_JSON_sp_fullkey="${__Data_JSON_sp_prefix}.${__Data_JSON_sp_child}"
    else
      __Data_JSON_sp_fullkey="$__Data_JSON_sp_child"
    fi

    (( __Data_JSON_sp_is_array )) || __Data_JSON_result+="\"${__Data_JSON_sp_child}\":"

    # Leaf or branch?
    if [[ -n "${__Data_JSON_sp_data[$__Data_JSON_sp_fullkey]+set}" ]]; then
      local __Data_JSON_sp_val="${__Data_JSON_sp_data[$__Data_JSON_sp_fullkey]}"
      case "$__Data_JSON_sp_val" in
        true|false) __Data_JSON_result+="$__Data_JSON_sp_val" ;;
        '')         __Data_JSON_result+='null' ;;
        *)
          if [[ "$__Data_JSON_sp_val" =~ ^-?[0-9]+\.?[0-9]*([eE][+-]?[0-9]+)?$ ]]; then
            __Data_JSON_result+="$__Data_JSON_sp_val"
          else
            local __Data_JSON_sp_escaped="${__Data_JSON_sp_val//\\/\\\\}"
            __Data_JSON_sp_escaped="${__Data_JSON_sp_escaped//\"/\\\"}"
            __Data_JSON_sp_escaped="${__Data_JSON_sp_escaped//$'\n'/\\n}"
            __Data_JSON_sp_escaped="${__Data_JSON_sp_escaped//$'\t'/\\t}"
            __Data_JSON_result+="\"${__Data_JSON_sp_escaped}\""
          fi
          ;;
      esac
    else
      # Branch -- recurse
      __Data_JSON_stringifyPrefix "$__Data_JSON_sp_fullkey" "$__Data_JSON_sp_doc" $(( __Data_JSON_sp_depth + 1 ))
    fi
  done

  (( __Data_JSON_sp_is_array )) && __Data_JSON_result+=']' || __Data_JSON_result+='}'
}

# Data.JSON.validate -- check whether a string is valid JSON, without crashing.
#
# Returns 0 if valid, 1 if not. When invalid, the error message is passed via
# into= (or stdout if no target is given).
#
# No subshell needed: the parser runs in safe mode, which replaces _Crash with
# a return-1 path. The temporary doc object is cleaned up on both paths.
#
# Usage:
#   Data.JSON.validate '{"ok":true}'       # exit 0
#   Data.JSON.validate 'not json'          # exit 1 (prints error to stdout)
#   into=err Data.JSON.validate '{'        # exit 1; err = "...error message..."
Data.JSON.validate() {
  local _Class="${_Class:-Data.JSON}"
  local __Data_JSON_validate_json="${1:-}"
  if [[ -z "$__Data_JSON_validate_json" ]]; then
    boop.pass "Data.JSON.validate: empty input" "${into:-}"
    return 1
  fi

  local __Data_JSON_validate_prev=$__Data_JSON_safe
  __Data_JSON_safe=1
  __Data_JSON_error=""

  local __Data_JSON_validate_out
  into=__Data_JSON_validate_out Data.JSON.parse "$__Data_JSON_validate_json"
  local __Data_JSON_validate_rc=$?
  __Data_JSON_safe=$__Data_JSON_validate_prev

  # Clean up the doc object (complete or partial) that parse created.
  # __Data_JSON_doc is the global set by parse before any parsing begins.
  unset "__boop_data_${__Data_JSON_doc}" "__boop_keys_${__Data_JSON_doc}"

  if (( __Data_JSON_validate_rc != 0 )); then
    boop.pass "$__Data_JSON_error" "${into:-}"
    return 1
  fi
  boop.pass "" "${into:-}"
  return 0
}

# ============================================================================
# Registration
# ============================================================================

# Data.JSON is a static-only class (no instances, just class methods)
Data.JSON.new() { _Crash "Data.JSON: not instantiable -- use Data.JSON.parse"; }

boopClass Data.JSON 'public:new,parse,stringify,validate'

