#!/bin/bash

# Text.String -- string object with mutating and non-mutating method variants.
#
# Two method families:
#   bare verb  (trim, upcase, ...)   -- mutates in place, delegates to -ed form
#   -ed form   (trimmed, upcased, .) -- returns the transformed VALUE, $self unchanged
#                                       also works statically: Text.String.trimmed "hello"
#
# Getters:
#   read  -- current value (reflects mutations)
#   raw   -- original value as passed to new, never changes
#
# Pipeline:
#   do "op,op,op:arg"  -- execute a type-homogeneous pipeline in one call.
#                         bare pipeline mutates $self; -ed pipeline returns
#                         a new object built on a single internal clone.
#                         Mixing bare and -ed ops crashes.
#
# Inheritance: boop -> Text.String
#
# Usage:
#   . boop Text::String
#   into=s Text.String.new "  Hello, World!  "
#   $s.trim
#   into=v $s.read                        # "Hello, World!"
#   into=v $s.raw                         # "  Hello, World!  "
#   into=s2 $s.do "trimmed,downcased"     # new object; $s unchanged
#   $s.do "trim,downcase,capitalize"      # mutates $s in place

. boop

boop.init Text.String || return 0

# ============================================================================
# Pipeline classification tables
# ============================================================================

declare -gA __Text_String_mutators=(
  [trim]=1 [upcase]=1 [downcase]=1 [capitalize]=1 [decapitalize]=1
  [replace]=1 [reverse]=1 [append]=1 [prepend]=1
  [lpad]=1 [rpad]=1 [center]=1 [fold]=1
)
declare -gA __Text_String_ed_to_bare=(
  [trimmed]=trim [upcased]=upcase [downcased]=downcase
  [capitalized]=capitalize [decapitalized]=decapitalize
  [replaced]=replace [reversed]=reverse [appended]=append [prepended]=prepend
  [lpadded]=lpad [rpadded]=rpad [centered]=center [folded]=fold
)

# ============================================================================
# Constructor
# ============================================================================

Text.String.new() {
  local _Class="${_Class:-Text.String}"
  local __Text_String_new_self __Text_String_new_val="${1:-}"
  into=__Text_String_new_self __boop.new
  local _Self="$__Text_String_new_self"
  $_Self.set value "$__Text_String_new_val"
  $_Self.set raw   "$__Text_String_new_val"
  _Info "new: created $__Text_String_new_self"
  boop.pass "$__Text_String_new_self" ${into:-}
}

# ============================================================================
# Getters
# ============================================================================

# read -- current value (after any mutations)
Text.String.read() {
  local _Self="${_Self:-Text.String}"
  local __Text_String_read_v
  into=__Text_String_read_v $_Self.get value
  boop.pass "$__Text_String_read_v" ${into:-}
}

# raw -- original value as passed to new
Text.String.raw() {
  local _Self="${_Self:-Text.String}"
  local __Text_String_raw_v
  into=__Text_String_raw_v $_Self.get raw
  boop.pass "$__Text_String_raw_v" ${into:-}
}

# ============================================================================
# Read-only queries
# ============================================================================

Text.String.length() {
  local _Self="${_Self:-Text.String}"
  local __Text_String_length_v
  into=__Text_String_length_v $_Self.get value
  boop.pass "${#__Text_String_length_v}" ${into:-}
}

Text.String.isEmpty() {
  local _Self="${_Self:-Text.String}"
  local __Text_String_isEmpty_v
  into=__Text_String_isEmpty_v $_Self.get value
  [[ -z "$__Text_String_isEmpty_v" ]]
}

Text.String.contains() {
  local _Self="${_Self:-Text.String}"
  local __Text_String_contains_v
  into=__Text_String_contains_v $_Self.get value
  [[ "$__Text_String_contains_v" == *"${1}"* ]]
}

Text.String.startsWith() {
  local _Self="${_Self:-Text.String}"
  local __Text_String_startsWith_v
  into=__Text_String_startsWith_v $_Self.get value
  [[ "$__Text_String_startsWith_v" == "${1}"* ]]
}

Text.String.endsWith() {
  local _Self="${_Self:-Text.String}"
  local __Text_String_endsWith_v
  into=__Text_String_endsWith_v $_Self.get value
  [[ "$__Text_String_endsWith_v" == *"${1}" ]]
}

Text.String.indexOf() {
  local _Self="${_Self:-Text.String}"
  local __Text_String_indexOf_v __Text_String_indexOf_needle="${1}"
  into=__Text_String_indexOf_v $_Self.get value
  local __Text_String_indexOf_before="${__Text_String_indexOf_v%%"$__Text_String_indexOf_needle"*}"
  if [[ "$__Text_String_indexOf_before" == "$__Text_String_indexOf_v" ]]; then
    boop.pass "-1" ${into:-}
  else
    boop.pass "${#__Text_String_indexOf_before}" ${into:-}
  fi
}

Text.String.substr() {
  local _Self="${_Self:-Text.String}"
  local __Text_String_substr_v __Text_String_substr_off="${1:-0}" __Text_String_substr_len="${2:-}"
  into=__Text_String_substr_v $_Self.get value
  if [[ -n "$__Text_String_substr_len" ]]; then
    boop.pass "${__Text_String_substr_v:$__Text_String_substr_off:$__Text_String_substr_len}" ${into:-}
  else
    boop.pass "${__Text_String_substr_v:$__Text_String_substr_off}" ${into:-}
  fi
}

# ============================================================================
# -ed forms -- return the mutated string VALUE, $self unchanged
#
# With no argument: object copies its own value buffer as input.
# With argument:    that string is the input (works statically too).
#
# Extra-arg forms (appended, replaced, etc.): when called on an object,
# all positional args are op args and the buffer is input. When called
# statically ($Self == class), $1 is the input string and remaining
# args are op args — so `do` can thread values through with explicit input.
# ============================================================================

Text.String.trimmed() {
  local _Class="${_Class:-Text.String}" _Self="${_Self:-}"
  local __Text_String_trimmed_v
  if [[ $# -gt 0 ]]; then __Text_String_trimmed_v="$1"
  else into=__Text_String_trimmed_v $_Self.get value; fi
  __Text_String_trimmed_v="${__Text_String_trimmed_v#"${__Text_String_trimmed_v%%[![:space:]]*}"}"
  __Text_String_trimmed_v="${__Text_String_trimmed_v%"${__Text_String_trimmed_v##*[![:space:]]}"}"
  boop.pass "$__Text_String_trimmed_v" ${into:-}
}

Text.String.upcased() {
  local _Class="${_Class:-Text.String}" _Self="${_Self:-}"
  local __Text_String_upcased_v
  if [[ $# -gt 0 ]]; then __Text_String_upcased_v="$1"
  else into=__Text_String_upcased_v $_Self.get value; fi
  boop.pass "${__Text_String_upcased_v^^}" ${into:-}
}

Text.String.downcased() {
  local _Class="${_Class:-Text.String}" _Self="${_Self:-}"
  local __Text_String_downcased_v
  if [[ $# -gt 0 ]]; then __Text_String_downcased_v="$1"
  else into=__Text_String_downcased_v $_Self.get value; fi
  boop.pass "${__Text_String_downcased_v,,}" ${into:-}
}

Text.String.capitalized() {
  local _Class="${_Class:-Text.String}" _Self="${_Self:-}"
  local __Text_String_capitalized_v
  if [[ $# -gt 0 ]]; then __Text_String_capitalized_v="$1"
  else into=__Text_String_capitalized_v $_Self.get value; fi
  boop.pass "${__Text_String_capitalized_v^}" ${into:-}
}

Text.String.decapitalized() {
  local _Class="${_Class:-Text.String}" _Self="${_Self:-}"
  local __Text_String_decapitalized_v
  if [[ $# -gt 0 ]]; then __Text_String_decapitalized_v="$1"
  else into=__Text_String_decapitalized_v $_Self.get value; fi
  boop.pass "${__Text_String_decapitalized_v,}" ${into:-}
}

Text.String.reversed() {
  local _Class="${_Class:-Text.String}" _Self="${_Self:-}"
  local __Text_String_reversed_v __Text_String_reversed_r="" __Text_String_reversed_i
  if [[ $# -gt 0 ]]; then __Text_String_reversed_v="$1"
  else into=__Text_String_reversed_v $_Self.get value; fi
  for (( __Text_String_reversed_i = ${#__Text_String_reversed_v} - 1;
         __Text_String_reversed_i >= 0;
         __Text_String_reversed_i-- )); do
    __Text_String_reversed_r+="${__Text_String_reversed_v:$__Text_String_reversed_i:1}"
  done
  boop.pass "$__Text_String_reversed_r" ${into:-}
}

Text.String.appended() {
  local _Class="${_Class:-Text.String}" _Self="${_Self:-}"
  local __Text_String_appended_v __Text_String_appended_sfx
  if [[ "$_Self" =~ ^__obj_ ]]; then
    into=__Text_String_appended_v $_Self.get value; __Text_String_appended_sfx="${1:-}"
  else
    __Text_String_appended_v="${1:-}"; __Text_String_appended_sfx="${2:-}"
  fi
  boop.pass "${__Text_String_appended_v}${__Text_String_appended_sfx}" ${into:-}
}

Text.String.prepended() {
  local _Class="${_Class:-Text.String}" _Self="${_Self:-}"
  local __Text_String_prepended_v __Text_String_prepended_pfx
  if [[ "$_Self" =~ ^__obj_ ]]; then
    into=__Text_String_prepended_v $_Self.get value; __Text_String_prepended_pfx="${1:-}"
  else
    __Text_String_prepended_v="${1:-}"; __Text_String_prepended_pfx="${2:-}"
  fi
  boop.pass "${__Text_String_prepended_pfx}${__Text_String_prepended_v}" ${into:-}
}

Text.String.replaced() {
  local _Class="${_Class:-Text.String}" _Self="${_Self:-}"
  local __Text_String_replaced_v __Text_String_replaced_from __Text_String_replaced_to
  if [[ "$_Self" =~ ^__obj_ ]]; then
    into=__Text_String_replaced_v $_Self.get value
    __Text_String_replaced_from="${1}"; __Text_String_replaced_to="${2:-}"
  else
    __Text_String_replaced_v="${1:-}"
    __Text_String_replaced_from="${2}"; __Text_String_replaced_to="${3:-}"
  fi
  boop.pass "${__Text_String_replaced_v//"$__Text_String_replaced_from"/"$__Text_String_replaced_to"}" ${into:-}
}

Text.String.lpadded() {
  local _Class="${_Class:-Text.String}" _Self="${_Self:-}"
  local __Text_String_lpadded_v __Text_String_lpadded_w __Text_String_lpadded_c
  if [[ "$_Self" =~ ^__obj_ ]]; then
    into=__Text_String_lpadded_v $_Self.get value
    __Text_String_lpadded_w="${1}"; __Text_String_lpadded_c="${2:- }"
  else
    __Text_String_lpadded_v="${1:-}"
    __Text_String_lpadded_w="${2}"; __Text_String_lpadded_c="${3:- }"
  fi
  [[ "$__Text_String_lpadded_w" =~ ^[0-9]+$ ]] || { _Error "Text.String.lpadded: width must be a non-negative integer"; return 1; }
  if (( ${#__Text_String_lpadded_v} < __Text_String_lpadded_w )); then
    while (( ${#__Text_String_lpadded_v} < __Text_String_lpadded_w )); do
      __Text_String_lpadded_v="${__Text_String_lpadded_c}${__Text_String_lpadded_v}"
    done
    __Text_String_lpadded_v="${__Text_String_lpadded_v: -$__Text_String_lpadded_w}"
  fi
  boop.pass "$__Text_String_lpadded_v" ${into:-}
}

Text.String.rpadded() {
  local _Class="${_Class:-Text.String}" _Self="${_Self:-}"
  local __Text_String_rpadded_v __Text_String_rpadded_w __Text_String_rpadded_c
  if [[ "$_Self" =~ ^__obj_ ]]; then
    into=__Text_String_rpadded_v $_Self.get value
    __Text_String_rpadded_w="${1}"; __Text_String_rpadded_c="${2:- }"
  else
    __Text_String_rpadded_v="${1:-}"
    __Text_String_rpadded_w="${2}"; __Text_String_rpadded_c="${3:- }"
  fi
  [[ "$__Text_String_rpadded_w" =~ ^[0-9]+$ ]] || { _Error "Text.String.rpadded: width must be a non-negative integer"; return 1; }
  if (( ${#__Text_String_rpadded_v} < __Text_String_rpadded_w )); then
    while (( ${#__Text_String_rpadded_v} < __Text_String_rpadded_w )); do
      __Text_String_rpadded_v="${__Text_String_rpadded_v}${__Text_String_rpadded_c}"
    done
    __Text_String_rpadded_v="${__Text_String_rpadded_v:0:$__Text_String_rpadded_w}"
  fi
  boop.pass "$__Text_String_rpadded_v" ${into:-}
}

Text.String.centered() {
  local _Class="${_Class:-Text.String}" _Self="${_Self:-}"
  local __Text_String_centered_v __Text_String_centered_w __Text_String_centered_c
  if [[ "$_Self" =~ ^__obj_ ]]; then
    into=__Text_String_centered_v $_Self.get value
    __Text_String_centered_w="${1}"; __Text_String_centered_c="${2:- }"
  else
    __Text_String_centered_v="${1:-}"
    __Text_String_centered_w="${2}"; __Text_String_centered_c="${3:- }"
  fi
  [[ "$__Text_String_centered_w" =~ ^[0-9]+$ ]] || { _Error "Text.String.centered: width must be a non-negative integer"; return 1; }
  local __Text_String_centered_total __Text_String_centered_l __Text_String_centered_r __Text_String_centered_i
  local __Text_String_centered_lp="" __Text_String_centered_rp=""
  (( __Text_String_centered_total = __Text_String_centered_w - ${#__Text_String_centered_v} ))
  if (( __Text_String_centered_total > 0 )); then
    (( __Text_String_centered_l = __Text_String_centered_total / 2 ))
    (( __Text_String_centered_r = __Text_String_centered_total - __Text_String_centered_l ))
    for (( __Text_String_centered_i = 0; __Text_String_centered_i < __Text_String_centered_l; __Text_String_centered_i++ )); do
      __Text_String_centered_lp+="$__Text_String_centered_c"
    done
    for (( __Text_String_centered_i = 0; __Text_String_centered_i < __Text_String_centered_r; __Text_String_centered_i++ )); do
      __Text_String_centered_rp+="$__Text_String_centered_c"
    done
  fi
  boop.pass "${__Text_String_centered_lp}${__Text_String_centered_v}${__Text_String_centered_rp}" ${into:-}
}

Text.String.folded() {
  local _Class="${_Class:-Text.String}" _Self="${_Self:-}"
  local __Text_String_folded_v __Text_String_folded_w
  if [[ "$_Self" =~ ^__obj_ ]]; then
    into=__Text_String_folded_v $_Self.get value; __Text_String_folded_w="${1:-80}"
  else
    __Text_String_folded_v="${1:-}"; __Text_String_folded_w="${2:-80}"
  fi
  [[ "$__Text_String_folded_w" =~ ^[1-9][0-9]*$ ]] || { _Error "Text.String.folded: width must be a positive integer"; return 1; }
  local __Text_String_folded_result="" __Text_String_folded_line="" __Text_String_folded_word
  for __Text_String_folded_word in $__Text_String_folded_v; do
    if [[ -z "$__Text_String_folded_line" ]]; then
      __Text_String_folded_line="$__Text_String_folded_word"
    elif (( ${#__Text_String_folded_line} + 1 + ${#__Text_String_folded_word} > __Text_String_folded_w )); then
      __Text_String_folded_result+="${__Text_String_folded_line}"$'\n'
      __Text_String_folded_line="$__Text_String_folded_word"
    else
      __Text_String_folded_line+=" $__Text_String_folded_word"
    fi
  done
  [[ -n "$__Text_String_folded_line" ]] && __Text_String_folded_result+="$__Text_String_folded_line"
  boop.pass "$__Text_String_folded_result" ${into:-}
}

# ============================================================================
# Bare mutators -- delegate to -ed form, store result back
# ============================================================================

Text.String.trim()        { local _Self="${_Self:-Text.String}"; local __Text_String_trim_v;        into=__Text_String_trim_v        $_Self.trimmed;     $_Self.set value "$__Text_String_trim_v"; }
Text.String.upcase()      { local _Self="${_Self:-Text.String}"; local __Text_String_upcase_v;      into=__Text_String_upcase_v      $_Self.upcased;     $_Self.set value "$__Text_String_upcase_v"; }
Text.String.downcase()    { local _Self="${_Self:-Text.String}"; local __Text_String_downcase_v;    into=__Text_String_downcase_v    $_Self.downcased;   $_Self.set value "$__Text_String_downcase_v"; }
Text.String.capitalize()  { local _Self="${_Self:-Text.String}"; local __Text_String_capitalize_v;  into=__Text_String_capitalize_v  $_Self.capitalized; $_Self.set value "$__Text_String_capitalize_v"; }
Text.String.decapitalize(){ local _Self="${_Self:-Text.String}"; local __Text_String_decapitalize_v;into=__Text_String_decapitalize_v $_Self.decapitalized;$_Self.set value "$__Text_String_decapitalize_v"; }
Text.String.reverse()     { local _Self="${_Self:-Text.String}"; local __Text_String_reverse_v;     into=__Text_String_reverse_v     $_Self.reversed;    $_Self.set value "$__Text_String_reverse_v"; }
Text.String.append()      { local _Self="${_Self:-Text.String}"; local __Text_String_append_v;      into=__Text_String_append_v      $_Self.appended  "$@"; $_Self.set value "$__Text_String_append_v"; }
Text.String.prepend()     { local _Self="${_Self:-Text.String}"; local __Text_String_prepend_v;     into=__Text_String_prepend_v     $_Self.prepended "$@"; $_Self.set value "$__Text_String_prepend_v"; }
Text.String.replace()     { local _Self="${_Self:-Text.String}"; local __Text_String_replace_v;     into=__Text_String_replace_v     $_Self.replaced  "$@"; $_Self.set value "$__Text_String_replace_v"; }
Text.String.lpad()        { local _Self="${_Self:-Text.String}"; local __Text_String_lpad_v;        into=__Text_String_lpad_v        $_Self.lpadded   "$@"; $_Self.set value "$__Text_String_lpad_v"; }
Text.String.rpad()        { local _Self="${_Self:-Text.String}"; local __Text_String_rpad_v;        into=__Text_String_rpad_v        $_Self.rpadded   "$@"; $_Self.set value "$__Text_String_rpad_v"; }
Text.String.center()      { local _Self="${_Self:-Text.String}"; local __Text_String_center_v;      into=__Text_String_center_v      $_Self.centered  "$@"; $_Self.set value "$__Text_String_center_v"; }
Text.String.fold()        { local _Self="${_Self:-Text.String}"; local __Text_String_fold_v;        into=__Text_String_fold_v        $_Self.folded    "$@"; $_Self.set value "$__Text_String_fold_v"; }

# ============================================================================
# do -- type-homogeneous pipeline executor
# ============================================================================

# do "op,op:arg,op:arg:arg"
#   bare pipeline  → mutates $self in place, returns exit code
#   -ed pipeline   → threads value through -ed forms, returns final string value
#   mixed pipeline → crashes
#
# Arg separator within an op is ':': replace:foo:bar, lpad:20, center:40:*
Text.String.do() {
  local _Self="${_Self:-Text.String}"
  local __Text_String_do_pipeline="${1:-}"
  [[ -n "$__Text_String_do_pipeline" ]] || { _Error "Text.String.do: empty pipeline"; return 1; }

  local __Text_String_do_type="" __Text_String_do_op __Text_String_do_name
  local -a __Text_String_do_ops __Text_String_do_opargs

  IFS=',' read -ra __Text_String_do_ops <<< "$__Text_String_do_pipeline"

  # Type-check: all bare or all -ed
  for __Text_String_do_op in "${__Text_String_do_ops[@]}"; do
    __Text_String_do_name="${__Text_String_do_op%%:*}"
    if [[ -n "${__Text_String_mutators[$__Text_String_do_name]+set}" ]]; then
      if [[ "$__Text_String_do_type" == "ed" ]]; then
        _Error "Text.String.do: type mismatch — bare '$__Text_String_do_name' after -ed op"; return 1
      fi
      __Text_String_do_type="bare"
    elif [[ -n "${__Text_String_ed_to_bare[$__Text_String_do_name]+set}" ]]; then
      if [[ "$__Text_String_do_type" == "bare" ]]; then
        _Error "Text.String.do: type mismatch — -ed '$__Text_String_do_name' after bare op"; return 1
      fi
      __Text_String_do_type="ed"
    else
      _Error "Text.String.do: unknown pipeline op '$__Text_String_do_name'"; return 1
    fi
  done

  if [[ "$__Text_String_do_type" == "bare" ]]; then
    for __Text_String_do_op in "${__Text_String_do_ops[@]}"; do
      __Text_String_do_name="${__Text_String_do_op%%:*}"
      if [[ "$__Text_String_do_op" == *:* ]]; then
        IFS=':' read -ra __Text_String_do_opargs <<< "${__Text_String_do_op#*:}"
        _Self="$_Self" "Text.String.$__Text_String_do_name" "${__Text_String_do_opargs[@]}"
      else
        _Self="$_Self" "Text.String.$__Text_String_do_name"
      fi
    done
  else
    # -ed pipeline: thread value through -ed forms with explicit input arg
    local __Text_String_do_v
    into=__Text_String_do_v $_Self.get value
    for __Text_String_do_op in "${__Text_String_do_ops[@]}"; do
      __Text_String_do_name="${__Text_String_do_op%%:*}"
      if [[ "$__Text_String_do_op" == *:* ]]; then
        IFS=':' read -ra __Text_String_do_opargs <<< "${__Text_String_do_op#*:}"
        into=__Text_String_do_v _Self='' _Class='' "Text.String.$__Text_String_do_name" "$__Text_String_do_v" "${__Text_String_do_opargs[@]}"
      else
        into=__Text_String_do_v _Self='' _Class='' "Text.String.$__Text_String_do_name" "$__Text_String_do_v"
      fi
    done
    boop.pass "$__Text_String_do_v" ${into:-}
  fi
}

# ============================================================================
# Class Declaration
# ============================================================================

boopClass Text.String '
  has:value,raw
  public:new,read,raw,length,isEmpty,contains,startsWith,endsWith,indexOf,substr
  public:trim,upcase,downcase,capitalize,decapitalize,replace,reverse
  public:append,prepend,lpad,rpad,center,fold
  public:trimmed,upcased,downcased,capitalized,decapitalized,replaced,reversed
  public:appended,prepended,lpadded,rpadded,centered,folded
  public:do
'
