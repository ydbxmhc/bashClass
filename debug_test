#!/bin/bash

. Box_new

echo "Creating box..."
class=Box __bashClass.dispatch new length=5 width=3 height=7
box="$__bashClass_RETURN"
echo "Box ID: $box"
echo ""

echo "Registry entry for box:"
echo "Keys in registry: ${!__bashClass_registry[@]}"
echo "Value: ${__bashClass_registry[$box]:-NOT FOUND}"
echo ""

echo "Parsing length:"
length=$(__bashClass.parse "$box" "length")
echo "Result: '$length'"
echo ""

echo "Testing regex manually:"
descriptor="${__bashClass_registry[$box]}"
echo "Descriptor: $descriptor"
pattern="\|length=([^|]*)"
if [[ "$descriptor" =~ $pattern ]]; then
  echo "Match found: '${BASH_REMATCH[1]}'"
else
  echo "No match"
fi
