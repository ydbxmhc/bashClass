#!/usr/bin/env bash
# lens — text stream inspection tool

. boop Stream Args

Args.parse '
[Use]
lens [options] [file]

  Inspect and transform text streams. Reads stdin unless a file is given.

  Evaluation order (regardless of argument order):
    position selection  →  match filter  →  --not inversion
    →  field/char extraction  →  formatting

  Common patterns:
    lens --first 20 file.txt              # head
    lens --last 20 file.txt               # tail
    lens --from 5 --to 15 file.txt        # line range
    lens --no-first 1 file.txt            # skip header line
    lens --match ERROR log.txt            # grep
    lens --no-match ERROR log.txt         # grep -v
    lens --match foo --no-match bar       # foo lines that do not contain bar
    lens --not --match ERROR log.txt      # invert: everything except ERROR lines
    lens --last 100 --match error log     # errors among last 100 lines
    lens --chars 1-10,20-30 data.txt      # fixed-width column extraction

[Options]
file              | f =   # input file (default: stdin)

first                 =   # first N records
no-first              =   # skip first N records
last                  =   # last N records
no-last               =   # skip last N records
from                  =   # start at record N (inclusive)
to                    =   # end at record N (inclusive)

match[]           | m =   # include records matching PATTERN (repeatable)
no-match[]        | v =   # exclude records matching PATTERN (repeatable)

not               | X     # invert final record-selection result

fields                =   # field numbers or ranges: 1,3-5
chars                 =   # character positions or ranges: 1-10,20-30
delimiter         | d =   # field delimiter for --fields (default: whitespace)

number            | n     # prepend record numbers
count             | c     # print counts instead of content
' "$@"
