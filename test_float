#!/bin/bash
set -u

# Test suite for Float class — virtual decimal arithmetic with bc fallback

. boop Float

passed=0
failed=0

expect_val() {
  local __desc="$1" __expected="$2" __float="$3"
  local __got
  into=__got $__float.val
  if [[ "$__got" == "$__expected" ]]; then
    printf "  PASS: %s\n" "$__desc"
    (( passed++ ))
  else
    printf "  FAIL: %s expected '%s' got '%s'\n" "$__desc" "$__expected" "$__got"
    (( failed++ ))
  fi
}

expect_rc() {
  local __desc="$1" __expected="$2"; shift 2
  "$@" 2>/dev/null; local __rc=$?
  if (( __rc == __expected )); then
    printf "  PASS: %s (rc=%d)\n" "$__desc" "$__rc"
    (( passed++ ))
  else
    printf "  FAIL: %s expected rc=%d got rc=%d\n" "$__desc" "$__expected" "$__rc"
    (( failed++ ))
  fi
}

expect_fail() {
  local __desc="$1"; shift
  local __out __rc
  __out=$("$@" 2>&1); __rc=$?
  if (( __rc != 0 )); then
    printf "  PASS: %s (correctly rejected)\n" "$__desc"
    (( passed++ ))
  else
    printf "  FAIL: %s (should have failed)\n" "$__desc"
    (( failed++ ))
  fi
}

printf "=== FLOAT TEST SUITE ===\n"

# ============================================================================
# Construction & parsing
# ============================================================================

printf "\n--- Construction ---\n"

into=f1 Float 3.14
expect_val "3.14" "3.14" "$f1"

into=f2 Float 42
expect_val "integer 42" "42" "$f2"

into=f3 Float -0.5
expect_val "-0.5" "-0.5" "$f3"

into=f4 Float 0.001
expect_val "0.001" "0.001" "$f4"

into=f5 Float 0
expect_val "zero" "0" "$f5"

into=f6 Float .25
expect_val ".25 shorthand" "0.25" "$f6"

into=f7 Float value=1.5
expect_val "value= syntax" "1.5" "$f7"

into=f8 Float 3.14 scale=4
expect_val "forced scale=4" "3.1400" "$f8"

into=f9 Float 3.14159 scale=2
expect_val "forced scale=2 (rounds)" "3.14" "$f9"


# ============================================================================
# Basic arithmetic (pure bash mode)
# ============================================================================

printf "\n--- Addition ---\n"

into=a Float 1.5
into=b Float 2.3
into=c $a.add $b
expect_val "1.5 + 2.3 = 3.8" "3.8" "$c"

into=c2 $a.add 0.5
expect_val "1.5 + 0.5 (literal) = 2.0" "2.0" "$c2"

into=c3 $a.add -1.5
expect_val "1.5 + (-1.5) = 0.0" "0.0" "$c3"

printf "\n--- Subtraction ---\n"

into=d Float 5.0
into=e Float 3.2
into=f $d.sub $e
expect_val "5.0 - 3.2 = 1.8" "1.8" "$f"

into=f2 $e.sub $d
expect_val "3.2 - 5.0 = -1.8" "-1.8" "$f2"

printf "\n--- Multiplication ---\n"

into=g Float 2.5
into=h Float 4.0
into=i $g.mul $h
expect_val "2.5 * 4.0 = 10.00" "10.00" "$i"

into=i2 $g.mul 3
expect_val "2.5 * 3 (literal int) = 7.5" "7.5" "$i2"

into=neg1 Float -2.0
into=i3 $g.mul $neg1
expect_val "2.5 * -2.0 = -5.00" "-5.00" "$i3"

printf "\n--- Division ---\n"

into=j Float 10.0
into=k Float 4.0
into=l $j.div $k
# 10/4 = 2.5, but with extra precision from scale-up
into=l_val $l.val
# Just check it starts with 2.5
if [[ "$l_val" == 2.5* ]]; then
  printf "  PASS: 10.0 / 4.0 starts with 2.5\n"; (( passed++ ))
else
  printf "  FAIL: 10.0 / 4.0 expected 2.5... got '%s'\n" "$l_val"; (( failed++ ))
fi

expect_fail "division by zero" bash -c '. boop Float; into=x Float 1.0; $x.div 0'

printf "\n--- Modulo ---\n"

into=m Float 7.5
into=n Float 2.0
into=o $m.mod $n
expect_val "7.5 %% 2.0 = 1.5" "1.5" "$o"

expect_fail "modulo by zero" bash -c '. boop Float; into=x Float 1.0; $x.mod 0'

printf "\n--- Power ---\n"

into=p Float 2.0
into=q $p.pow 3
expect_val "2.0 ^ 3 = 8.000" "8.000" "$q"

into=r Float 1.5
into=s $r.pow 2
expect_val "1.5 ^ 2 = 2.25" "2.25" "$s"

# ============================================================================
# Comparisons
# ============================================================================

printf "\n--- Comparisons ---\n"

into=cmpA Float 3.14
into=cmpB Float 2.71
into=cmpC Float 3.14

expect_rc "3.14 eq 3.14" 0 $cmpA.eq $cmpC
expect_rc "3.14 eq 2.71" 1 $cmpA.eq $cmpB
expect_rc "3.14 gt 2.71" 0 $cmpA.gt $cmpB
expect_rc "2.71 lt 3.14" 0 $cmpB.lt $cmpA
expect_rc "3.14 ge 3.14" 0 $cmpA.ge $cmpC
expect_rc "3.14 le 3.14" 0 $cmpA.le $cmpC
expect_rc "2.71 ge 3.14" 1 $cmpB.ge $cmpA
expect_rc "3.14 le 2.71" 1 $cmpA.le $cmpB

# Compare with literal
expect_rc "3.14 eq 3.14 (literal)" 0 $cmpA.eq 3.14
expect_rc "3.14 lt 4.0 (literal)" 0 $cmpA.lt 4.0

# Different scales
into=cmpD Float 1.50
into=cmpE Float 1.5
expect_rc "1.50 eq 1.5 (different scales)" 0 $cmpD.eq $cmpE

# ============================================================================
# Utility methods
# ============================================================================

printf "\n--- Abs / Neg ---\n"

into=negF Float -3.14
into=absF $negF.abs
expect_val "abs(-3.14) = 3.14" "3.14" "$absF"

into=posF Float 2.5
into=negResult $posF.neg
expect_val "neg(2.5) = -2.5" "-2.5" "$negResult"

printf "\n--- Round ---\n"

into=rndA Float 3.14159
into=rndB $rndA.round 2
expect_val "round 3.14159 to 2 = 3.14" "3.14" "$rndB"

into=rndC $rndA.round 0
expect_val "round 3.14159 to 0 = 3" "3" "$rndC"

into=rndD Float 2.345
into=rndE $rndD.round 2
expect_val "round 2.345 to 2 = 2.35 (half-up)" "2.35" "$rndE"

into=rndF Float 1.5
into=rndG $rndF.round 4
expect_val "round 1.5 to 4 = 1.5000 (pad)" "1.5000" "$rndG"

printf "\n--- toInt ---\n"

into=tiA Float 3.99
into=tiB $tiA.toInt
if [[ "$tiB" == "3" ]]; then
  printf "  PASS: toInt(3.99) = 3 (truncate)\n"; (( passed++ ))
else
  printf "  FAIL: toInt(3.99) expected '3' got '%s'\n" "$tiB"; (( failed++ ))
fi

printf "\n--- toString ---\n"

into=tsA Float 3.14
$tsA.toString
if [[ "$__bashClass_RETURN" == *"3.14"* ]]; then
  printf "  PASS: toString contains 3.14\n"; (( passed++ ))
else
  printf "  FAIL: toString got '%s'\n" "$__bashClass_RETURN"; (( failed++ ))
fi

printf "\n--- isa ---\n"

into=isaF Float 1.0
if $isaF.isa Float; then printf "  PASS: isa Float\n"; (( passed++ )); else printf "  FAIL: isa Float\n"; (( failed++ )); fi
if $isaF.isa bashClass; then printf "  PASS: isa bashClass\n"; (( passed++ )); else printf "  FAIL: isa bashClass\n"; (( failed++ )); fi

# ============================================================================
# Mixed scale arithmetic
# ============================================================================

printf "\n--- Mixed scales ---\n"

into=msA Float 1.5
into=msB Float 0.25
into=msC $msA.add $msB
expect_val "1.5 + 0.25 = 1.75" "1.75" "$msC"

into=msD $msA.sub $msB
expect_val "1.5 - 0.25 = 1.25" "1.25" "$msD"


# ============================================================================
# Edge cases
# ============================================================================

printf "\n--- Edge cases ---\n"

# Fractional exponent should crash
expect_fail "fractional exponent" bash -c '. boop Float; into=x Float 2.0; $x.pow 1.5'

# Negative exponent should crash
expect_fail "negative exponent" bash -c '. boop Float; into=x Float 2.0; $x.pow -1'

# ============================================================================
# Chained operations
# ============================================================================

printf "\n--- Chained operations ---\n"

# (2.5 + 1.5) * 3.0 = 12.0...
into=ch1 Float 2.5
into=ch2 $ch1.add 1.5
into=ch3 $ch2.mul 3.0
into=ch3_val $ch3.val
if [[ "$ch3_val" == 12* ]]; then
  printf "  PASS: (2.5 + 1.5) * 3.0 = 12...\n"; (( passed++ ))
else
  printf "  FAIL: chain expected 12... got '%s'\n" "$ch3_val"; (( failed++ ))
fi

# ============================================================================
# SUMMARY
# ============================================================================

printf "\n=== FLOAT TEST RESULTS ===\n"
printf "  Passed: %d\n" "$passed"
printf "  Failed: %d\n" "$failed"
printf "  Total:  %d\n" "$(( passed + failed ))"

if (( failed > 0 )); then
  printf "\n  *** %d FAILURES ***\n" "$failed"
  exit 1
fi

printf "\n  All tests passed.\n"
exit 0