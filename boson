#!/usr/bin/env bash
# boson — structured data query tool
#
# Queries JSON (and eventually YAML/Config) using jq-style path expressions.
# Operates on Map.Fast storage — format-agnostic once parsed.
#
# Stage 1: path expressions, array iteration, raw output.
#
# Path syntax:
#   .key            → top-level key
#   .key.sub        → nested key
#   .arr[0]         → array index
#   .arr[]          → iterate all array elements (one per line)
#   .obj[].name     → iterate array, extract .name from each
#
# Usage:
#   boson '.name' < data.json
#   boson '.users[0].email' < data.json
#   boson '.users[].name' < data.json
#   boson '.servers[]' config.json

. boop Args Data::JSON

# Installer dispatch
declare -F __installer_dispatch >/dev/null ||
  . "${__boop_root:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}/lib/installer"
__installer_dispatch "$@"

(( $# )) || set -- --help

# --- Help screens (before Args.parse) ---
case "${1:-}" in
  --examples)
    cat <<'EOF'
boson — Examples

  Basic access:
    boson '.name' < data.json                 top-level string
    boson '.address.city' < data.json         nested key
    boson '.scores[0]' < data.json            first array element
    boson '.scores[2]' < data.json            third array element

  Array iteration:
    boson '.users[]' < data.json              all array elements (JSON)
    boson '.users[].name' < data.json         extract field from each
    boson '.tags[]' < data.json               simple array values

  Raw output (-r):
    boson -r '.name' < data.json              no quotes on strings
    boson -r '.users[].email' < data.json     one email per line, unquoted

  Sourceable output (--emit):
    boson --emit '.' < data.json              whole doc as var=value lines
    boson --emit '.database' < config.json    subtree as assignments
    eval "$(boson --emit '.' < config.json)"  load all into current shell

  Named assignment (--into):
    boson --into=host '.database.host' < c.json   → host=localhost
    boson --into=names '.users[].name' < d.json   → names=("Alice" "Bob")
    eval "$(boson --into=port '.server.port' < c.json)"

  Eponymous (--eponymous / -E):
    boson -E '.database.host' < c.json        → host=localhost
    boson -E '.database' < c.json             → host=localhost\nport=5432\n...
    boson -E '.users[].name' < d.json         → name=("Alice" "Bob")

  File argument:
    boson '.version' package.json             file as last arg
    boson -r '.scripts.build' package.json    raw value from file
EOF
    exit 0 ;;
  --about)
    cat <<'EOF'
boson — structured data query tool

  Query JSON files using jq-style path expressions. Pure bash, no
  external dependencies beyond bash 4.3+.

  Built on the boop framework. Run --boop for details.
  https://github.com/ydbxmhc/bashClass
EOF
    exit 0 ;;
  --boop)
    cat <<'EOF'
boson is built on boop — an OOP framework for bash 4.3+.

  boop provides classes, objects, inheritance, method dispatch, a universal
  return system, and a standard library including Data.JSON (recursive
  descent parser), Map.Fast (compound-key store), Args (CLI parsing), and more.

  This tool is a single-file bundle: the framework and required classes are
  embedded inline. It works standalone with no installation.

  To install the full boop framework:
    boson --boop-install              install to ~/.local/lib/boop
    boson --boop-install /opt/boop    install to custom path

  Repository: https://github.com/ydbxmhc/bashClass
EOF
    exit 0 ;;
esac

Args.parse '
[Parser]
show = Use
bareKV = false

[Use]
boson [-r] [--emit|--into=VAR|--eponymous] EXPR [file]

  Query JSON with path expressions. Reads stdin or file.
  Output modes: default (values), -r (raw), --emit (sourceable),
                --into=VAR (named assignment), --eponymous (leaf names).
  More: --examples, --about, --boop

[Options]
raw       | r         # raw output (no quotes on strings)
emit      | e         # emit all values as sourceable bash assignments
into_var  | into  =   # emit single value as VAR=value (sourceable)
eponymous | E         # emit using leaf key names as variable names

[Exclusive]
raw | emit
raw | into_var
raw | eponymous
emit | into_var
emit | eponymous
into_var | eponymous
' "$@" || exit 1

# --- Determine input source ---
__boson_input=""
if [[ -n "${_ArgsRemaining[1]:-}" && -f "${_ArgsRemaining[1]}" ]]; then
  __boson_file="${_ArgsRemaining[1]}"
  __boson_input="$(< "$__boson_file")"
elif [[ -n "${_ArgsRemaining[0]:-}" && ! -t 0 ]]; then
  __boson_input="$(cat)"
else
  printf 'boson: no input (pipe JSON or provide a file)\n' >&2
  exit 1
fi

__boson_expr="${_ArgsRemaining[0]:-}"
[[ -n "$__boson_expr" ]] || { printf 'boson: expression required\n' >&2; exit 1; }

# --- Parse JSON ---
into=__boson_doc Data.JSON.parse "$__boson_input" || {
  printf 'boson: failed to parse JSON\n' >&2
  exit 1
}

# ============================================================================
# Path expression evaluator
# ============================================================================

# Convert a jq-style path to a Map.Fast compound key (or key prefix for []).
#
# .name           → "name"
# .users[0].email → "users.0.email"
# .users[]        → "users." (prefix — iterate)
# .users[].name   → "users." + ".name" (iterate + suffix)
#
# Sets:
#   __boson_key    — the resolved compound key (or prefix for iteration)
#   __boson_iter   — "1" if [] iteration requested, "" otherwise
#   __boson_suffix — the part after [] (e.g., ".name" → "name"), "" if none

__boson_parse_expr() {
  local __boson_pe_expr="$1"
  __boson_key=""
  __boson_iter=""
  __boson_suffix=""

  # Strip leading dot
  [[ "$__boson_pe_expr" == .* ]] && __boson_pe_expr="${__boson_pe_expr:1}"

  # Check for [] iteration
  if [[ "$__boson_pe_expr" == *'[]'* ]]; then
    __boson_iter="1"
    local __boson_pe_before="${__boson_pe_expr%%'[]'*}"
    local __boson_pe_after="${__boson_pe_expr#*'[]'}"
    # Before [] becomes the prefix key
    __boson_key="${__boson_pe_before//\[/.}"
    __boson_key="${__boson_key//\]/}"
    # After [] becomes the suffix (strip leading dot)
    [[ "$__boson_pe_after" == .* ]] && __boson_pe_after="${__boson_pe_after:1}"
    __boson_suffix="$__boson_pe_after"
  else
    # No iteration — straight key conversion
    # Replace [N] with .N
    __boson_key="${__boson_pe_expr//\[/.}"
    __boson_key="${__boson_key//\]/}"
  fi
}

# ============================================================================
# Output helpers
# ============================================================================

# Escape a value for safe sourcing (handles quotes, newlines, special chars)
__boson_quote_val() {
  local __boson_qv_val="$1"
  # If it's a simple value (no special chars), use simple quotes
  if [[ "$__boson_qv_val" == *[\'\"\\$\`\!\ \	]* || "$__boson_qv_val" == *$'\n'* ]]; then
    # Use $'...' quoting for safety
    printf '%s' "$__boson_qv_val" | sed "s/'/'\\\\''/g; 1s/^/'/; \$s/\$/'/"
  else
    printf '%s' "$__boson_qv_val"
  fi
}

# Sanitize a key path into a valid bash variable name (dots/dashes → underscores)
__boson_varname() {
  local __boson_vn="$1"
  __boson_vn="${__boson_vn//./_}"
  __boson_vn="${__boson_vn//-/_}"
  __boson_vn="${__boson_vn//[^a-zA-Z0-9_]/_}"
  # Ensure starts with letter or underscore
  [[ "$__boson_vn" =~ ^[a-zA-Z_] ]] || __boson_vn="_${__boson_vn}"
  printf '%s' "$__boson_vn"
}

# Output a single value in the current mode
__boson_output() {
  local __boson_out_val="$1" __boson_out_varname="${2:-}"

  if [[ -n "$emit" || -n "$into_var" || -n "$eponymous" ]]; then
    # Sourceable output mode
    local __boson_out_name
    if [[ -n "$into_var" ]]; then
      __boson_out_name="$into_var"
    elif [[ -n "$eponymous" ]]; then
      __boson_out_name="$__boson_out_varname"
    else
      __boson_out_name="$__boson_out_varname"
    fi
    printf '%s=%s\n' "$__boson_out_name" "$(__boson_quote_val "$__boson_out_val")"

  elif [[ -n "$raw" ]]; then
    printf '%s\n' "$__boson_out_val"

  else
    # Default: quote strings, bare numbers/booleans
    case "$__boson_out_val" in
      true|false|null) printf '%s\n' "$__boson_out_val" ;;
      *[!0-9.-]*) printf '"%s"\n' "$__boson_out_val" ;;
      *) printf '%s\n' "$__boson_out_val" ;;
    esac
  fi
}

# Output an array in sourceable format
__boson_output_array() {
  local __boson_oa_name="$1"; shift
  local -a __boson_oa_vals=("$@")
  local __boson_oa_v __boson_oa_out=""
  for __boson_oa_v in "${__boson_oa_vals[@]}"; do
    [[ -n "$__boson_oa_out" ]] && __boson_oa_out+=" "
    __boson_oa_out+="$(__boson_quote_val "$__boson_oa_v")"
  done
  printf '%s=(%s)\n' "$__boson_oa_name" "$__boson_oa_out"
}

# ============================================================================
# Execute query
# ============================================================================

__boson_parse_expr "$__boson_expr"

if [[ -n "$__boson_iter" ]]; then
  # Array iteration: enumerate numeric indices under the prefix
  local -n __boson_data="__boop_data_${__boson_doc}"
  local __boson_sep=""
  into=__boson_sep $__boson_doc.get sep
  : "${__boson_sep:=.}"

  # Find all numeric children of the prefix
  local __boson_prefix="${__boson_key}${__boson_sep}"
  local __boson_k __boson_idx __boson_rest __boson_val
  local -A __boson_seen_idx=()

  for __boson_k in "${!__boson_data[@]}"; do
    [[ "$__boson_k" == "$__boson_prefix"* ]] || continue
    __boson_rest="${__boson_k#"$__boson_prefix"}"
    __boson_idx="${__boson_rest%%"$__boson_sep"*}"
    [[ "$__boson_idx" =~ ^[0-9]+$ ]] || continue
    [[ -n "${__boson_seen_idx[$__boson_idx]+set}" ]] && continue
    __boson_seen_idx[$__boson_idx]=1
  done

  # Sort indices numerically
  local -a __boson_indices=()
  for __boson_idx in "${!__boson_seen_idx[@]}"; do
    __boson_indices+=("$__boson_idx")
  done
  local -i __boson_i __boson_j __boson_tmp_idx
  for (( __boson_i = 1; __boson_i < ${#__boson_indices[@]}; __boson_i++ )); do
    __boson_tmp_idx=${__boson_indices[$__boson_i]}
    __boson_j=$__boson_i
    while (( __boson_j > 0 && __boson_indices[__boson_j-1] > __boson_tmp_idx )); do
      __boson_indices[$__boson_j]=${__boson_indices[$((__boson_j-1))]}
      (( --__boson_j ))
    done
    __boson_indices[$__boson_j]=$__boson_tmp_idx
  done

  # Collect values
  local -a __boson_arr_vals=()
  for __boson_idx in "${__boson_indices[@]}"; do
    if [[ -n "$__boson_suffix" ]]; then
      local __boson_full_key="${__boson_key}${__boson_sep}${__boson_idx}${__boson_sep}${__boson_suffix}"
    else
      local __boson_full_key="${__boson_key}${__boson_sep}${__boson_idx}"
    fi
    into=__boson_val $__boson_doc.get "$__boson_full_key"
    [[ -n "$__boson_val" ]] || continue

    if [[ -n "$into_var" || -n "$eponymous" ]]; then
      __boson_arr_vals+=("$__boson_val")
    else
      local __boson_leaf_name="${__boson_suffix:-$__boson_idx}"
      __boson_output "$__boson_val" "$(__boson_varname "$__boson_leaf_name")"
    fi
  done

  # Sourceable array output
  if [[ -n "$into_var" ]]; then
    __boson_output_array "$into_var" "${__boson_arr_vals[@]}"
  elif [[ -n "$eponymous" ]]; then
    local __boson_arr_name
    if [[ -n "$__boson_suffix" ]]; then
      __boson_arr_name="$(__boson_varname "$__boson_suffix")"
    else
      __boson_arr_name="$(__boson_varname "$__boson_key")"
    fi
    __boson_output_array "$__boson_arr_name" "${__boson_arr_vals[@]}"
  fi

elif [[ -n "$emit" ]]; then
  # Emit mode with no iteration: dump all keys under the expression as assignments
  local -n __boson_data="__boop_data_${__boson_doc}"
  local __boson_sep=""
  into=__boson_sep $__boson_doc.get sep
  : "${__boson_sep:=.}"

  local __boson_prefix=""
  [[ -n "$__boson_key" ]] && __boson_prefix="${__boson_key}${__boson_sep}"

  local __boson_k __boson_vname __boson_rel
  for __boson_k in "${!__boson_data[@]}"; do
    if [[ -n "$__boson_prefix" ]]; then
      [[ "$__boson_k" == "$__boson_prefix"* ]] || continue
      __boson_rel="${__boson_k#"$__boson_prefix"}"
    else
      __boson_rel="$__boson_k"
    fi
    __boson_vname="$(__boson_varname "$__boson_rel")"
    printf '%s=%s\n' "$__boson_vname" "$(__boson_quote_val "${__boson_data[$__boson_k]}")"
  done

else
  # Direct key lookup
  local __boson_val
  into=__boson_val $__boson_doc.get "$__boson_key"
  if [[ -n "$__boson_val" ]]; then
    local __boson_leaf="${__boson_key##*.}"
    [[ "$__boson_leaf" == "$__boson_key" ]] || true  # leaf is last segment
    __boson_output "$__boson_val" "$(__boson_varname "$__boson_leaf")"
  else
    # Key not found — might be an object/array (has children)
    local __boson_children
    into=__boson_children $__boson_doc.keysUnder "$__boson_key"
    if [[ -n "$__boson_children" ]]; then
      if [[ -n "$emit" || -n "$eponymous" ]]; then
        # Emit subtree
        local -n __boson_data="__boop_data_${__boson_doc}"
        local __boson_sep=""
        into=__boson_sep $__boson_doc.get sep
        : "${__boson_sep:=.}"
        local __boson_prefix="${__boson_key}${__boson_sep}"
        local __boson_k __boson_rel __boson_vname
        for __boson_k in "${!__boson_data[@]}"; do
          [[ "$__boson_k" == "$__boson_prefix"* ]] || continue
          __boson_rel="${__boson_k#"$__boson_prefix"}"
          __boson_vname="$(__boson_varname "$__boson_rel")"
          printf '%s=%s\n' "$__boson_vname" "$(__boson_quote_val "${__boson_data[$__boson_k]}")"
        done
      else
        printf '{...} (%d keys)\n' "$(printf '%s\n' "$__boson_children" | wc -l)"
      fi
    else
      printf 'null\n'
    fi
  fi
fi

$__boson_doc.destroy
