#!/bin/bash
set -uo pipefail

# ─────────────────────────────────────────────────────────────────────
# BLACKJACK — a boop framework demonstration
#
# Single-player blackjack against the house. You start with $100.
#
# Demonstrates:
#   - Sourcing library classes (PlayingCard, Deck)
#   - Defining local subclasses in a script (BlackjackHand)
#   - Inheritance (BlackjackHand → List), class methods
#   - into= returns, object creation, property access
#   - Using generic containers with domain-specific logic
#
# Library classes used:
#   Card → PlayingCard — suit/rank, newDeck fills 52 standard cards
#   List → Deck        — shuffle, draw
#   List               — BlackjackHand inherits directly
#
# Usage: bash blackjack
# ─────────────────────────────────────────────────────────────────────

. boop PlayingCard Deck

# ═════════════════════════════════════════════════════════════════════
# BlackjackHand — a List of PlayingCards with blackjack scoring
# ═════════════════════════════════════════════════════════════════════
#
# Knows how to score cards by blackjack rules, track which cards
# are face-up, and format itself for display. The faceUp property
# tracks how many cards (from the end) are visible — the rest show
# as [?]. Dealer gets faceUp=1 (hole card hidden), player gets
# faceUp=99 (all visible).

BlackjackHand.new() {
  local _Class="${_Class:-BlackjackHand}"
  local __BH_new_self __BH_new_faceUp=99 __BH_new_deck=""
  local __BH_new_arg
  for __BH_new_arg in "$@"; do
    case "$__BH_new_arg" in
      faceUp=*) __BH_new_faceUp="${__BH_new_arg#faceUp=}" ;;
      deck=*)   __BH_new_deck="${__BH_new_arg#deck=}" ;;
    esac
  done
  into=__BH_new_self List.new faceUp="$__BH_new_faceUp" deck="$__BH_new_deck"
  boop.pass "$__BH_new_self" ${into:-}
}

# Map a PlayingCard's rank to its blackjack numeric value.
# A=11 (ace adjustment happens at the hand level), J/Q/K=10.
BlackjackHand.cardVal() {
  local __BH_cv_rank
  __boop.parse "$1" "rank" __BH_cv_rank
  case "$__BH_cv_rank" in
    A)      boop.pass 11 ${into:-} ;;
    J|Q|K)  boop.pass 10 ${into:-} ;;
    *)      boop.pass "$__BH_cv_rank" ${into:-} ;;
  esac
}

# Sum card values with ace adjustment — aces drop from 11 to 1
# one at a time until the total is ≤21 or no aces remain.
BlackjackHand.total() {
  local -I _Self; local _Class="${_Class:-BlackjackHand}"
  local -i __BH_total_sum=0 __BH_total_aces=0 __BH_total_i __BH_total_len __BH_total_v
  local __BH_total_card __BH_total_rank
  into=__BH_total_len $_Self.length
  for (( __BH_total_i=0; __BH_total_i < __BH_total_len; __BH_total_i++ )); do
    into=__BH_total_card $_Self.getAt $__BH_total_i
    __boop.parse "$__BH_total_card" "rank" __BH_total_rank
    case "$__BH_total_rank" in
      A)     __BH_total_v=11; (( __BH_total_aces++ )) ;;
      J|Q|K) __BH_total_v=10 ;;
      *)     __BH_total_v=$__BH_total_rank ;;
    esac
    (( __BH_total_sum += __BH_total_v ))
  done
  while (( __BH_total_sum > 21 && __BH_total_aces > 0 )); do
    (( __BH_total_sum -= 10 )); (( __BH_total_aces-- ))
  done
  boop.pass "$__BH_total_sum" ${into:-}
}

BlackjackHand.isBust() {
  local -I _Self; local _Class="${_Class:-BlackjackHand}"
  local -i __BH_isBust_t
  into=__BH_isBust_t $_Self.total
  (( __BH_isBust_t > 21 ))
}

BlackjackHand.isBlackjack() {
  local -I _Self; local _Class="${_Class:-BlackjackHand}"
  local -i __BH_isBJ_len __BH_isBJ_t
  into=__BH_isBJ_len $_Self.length
  (( __BH_isBJ_len != 2 )) && return 1
  into=__BH_isBJ_t $_Self.total
  (( __BH_isBJ_t == 21 ))
}

# Format for display. Cards past the faceUp count show as [?].
# When any card is hidden, the total is hidden too.
BlackjackHand.show() {
  local -I _Self; local _Class="${_Class:-BlackjackHand}"
  local __BH_show_label="${1:-Hand}" __BH_show_out="" __BH_show_card __BH_show_str
  local -i __BH_show_i __BH_show_len __BH_show_faceUp __BH_show_hidden=0
  into=__BH_show_len $_Self.length
  into=__BH_show_faceUp $_Self.get faceUp
  for (( __BH_show_i=0; __BH_show_i < __BH_show_len; __BH_show_i++ )); do
    into=__BH_show_card $_Self.getAt $__BH_show_i
    if (( __BH_show_i < __BH_show_len - __BH_show_faceUp )); then
      __BH_show_str="[?]"
      __BH_show_hidden=1
    else
      into=__BH_show_str _Delegate $__BH_show_card.toString
    fi
    (( __BH_show_i > 0 )) && __BH_show_out="$__BH_show_out "
    __BH_show_out="$__BH_show_out$__BH_show_str"
  done
  if (( __BH_show_hidden )); then
    __BH_show_out="$__BH_show_label: $__BH_show_out"
  else
    local -i __BH_show_total
    into=__BH_show_total $_Self.total
    __BH_show_out="$__BH_show_label: $__BH_show_out  [$__BH_show_total]"
  fi
  boop.pass "$__BH_show_out" ${into:-}
}

# Reveal all cards (set faceUp to hand length).
BlackjackHand.reveal() {
  local -I _Self; local _Class="${_Class:-BlackjackHand}"
  local -i __BH_reveal_len
  into=__BH_reveal_len $_Self.length
  $_Self.set faceUp "$__BH_reveal_len"
}

# Draw a card from this hand's deck and push it to a target hand.
# If no target is given, deals to self (the dealer hitting).
BlackjackHand.deal() {
  local -I _Self; local _Class="${_Class:-BlackjackHand}"
  local __BH_deal_target="${1:-$_Self}" __BH_deal_deck __BH_deal_card
  into=__BH_deal_deck $_Self.get deck
  [[ -z "$__BH_deal_deck" ]] && _Crash "BlackjackHand.deal: no deck on this hand"
  into=__BH_deal_card $__BH_deal_deck.draw
  _Delegate $__BH_deal_target.push "$__BH_deal_card"
}

boopClass BlackjackHand isa:List public:new,cardVal,total,isBust,isBlackjack,show,reveal,deal has:type,faceUp,deck

# ═════════════════════════════════════════════════════════════════════
# Game helpers & main loop — only run when executed directly
# ═════════════════════════════════════════════════════════════════════

[[ "${BASH_SOURCE[0]}" != "${0}" ]] && return 0

show_table() {
  local __BJ_st_player="$1" __BJ_st_dealer="$2" __BJ_st_s
  into=__BJ_st_s $__BJ_st_dealer.show "Dealer"; printf "  %s\n" "$__BJ_st_s"
  into=__BJ_st_s $__BJ_st_player.show "You";    printf "  %s\n\n" "$__BJ_st_s"
}

# ═════════════════════════════════════════════════════════════════════
# Main game loop
# ═════════════════════════════════════════════════════════════════════

printf '
  ╔══════════════════════════════════╗
  ║         ♠  BLACKJACK  ♠          ║
  ║         powered by boop!         ║
  ╚══════════════════════════════════╝
\n'

declare -i bankroll=100 round=0
declare -l input

while (( bankroll > 0 )); do
  printf "  Bankroll: \$%d\n" "$bankroll"
  printf "  Bet (or 'q' to quit): "
  read -r input || break

  [[ "$input" == "q" ]] && break

  if [[ ! "$input" =~ ^[0-9]+$ ]] || (( input < 1 )); then
    printf "  Invalid bet.\n\n"; continue
  fi
  declare -i bet=$input
  if (( bet > bankroll )); then
    printf "  You only have \$%d.\n\n" "$bankroll"; continue
  fi

  (( round++ ))
  printf "\n  ── Round %d ──\n\n" "$round"

  # Fresh deck lives on the dealer
  into=deck PlayingCard.newDeck
  into=player BlackjackHand
  into=dealer BlackjackHand faceUp=1 deck="$deck"

  # Deal: player, dealer, player, dealer
  $dealer.deal "$player"
  $dealer.deal
  $dealer.deal "$player"
  $dealer.deal

  show_table "$player" "$dealer"

  # ── Check naturals ──
  declare -i player_bj=0 dealer_bj=0
  $player.isBlackjack && player_bj=1
  # Peek at dealer's hand for natural (both cards known to the game)
  declare -i __BJ_peek_total
  into=__BJ_peek_total $dealer.total
  (( __BJ_peek_total == 21 )) && dealer_bj=1

  if (( player_bj || dealer_bj )); then
    $dealer.reveal
    show_table "$player" "$dealer"
    if (( player_bj && dealer_bj )); then
      printf "  Both have Blackjack — push.\n\n"
    elif (( player_bj )); then
      printf "  ♠ Blackjack! You win \$%d!\n\n" "$(( bet * 3 / 2 ))"
      (( bankroll += bet * 3 / 2 ))
    else
      printf "  Dealer has Blackjack. You lose \$%d.\n\n" "$bet"
      (( bankroll -= bet ))
    fi
    continue
  fi

  # ── Player turn ──
  declare -i busted=0
  while true; do
    printf "  [H]it or [S]tand? "
    read -r choice
    case "${choice,,}" in
      h|hit)
        $dealer.deal "$player"
        show_table "$player" "$dealer"
        if $player.isBust; then
          printf "  Bust! You lose \$%d.\n\n" "$bet"
          (( bankroll -= bet ))
          busted=1; break
        fi
        ;;
      s|stand) break ;;
      *) printf "  Type 'h' or 's'.\n" ;;
    esac
  done

  (( busted )) && continue

  # ── Dealer turn ──
  $dealer.reveal
  printf "  Dealer reveals hole card.\n"
  show_table "$player" "$dealer"

  declare -i dtotal
  while true; do
    into=dtotal $dealer.total
    (( dtotal >= 17 )) && break
    printf "  Dealer hits.\n"
    $dealer.deal
    show_table "$player" "$dealer"
  done

  # ── Outcome ──
  declare -i ptotal; into=ptotal $player.total
  into=dtotal $dealer.total

  if $dealer.isBust; then
    printf "  Dealer busts! You win \$%d!\n\n" "$bet"
    (( bankroll += bet ))
  elif (( ptotal > dtotal )); then
    printf "  You win \$%d!\n\n" "$bet"
    (( bankroll += bet ))
  elif (( dtotal > ptotal )); then
    printf "  Dealer wins. You lose \$%d.\n\n" "$bet"
    (( bankroll -= bet ))
  else
    printf "  Push — bet returned.\n\n"
  fi
done

if (( bankroll <= 0 )); then
  printf "  You're broke. Better luck next time.\n"
else
  printf "\n  You leave with \$%d.\n" "$bankroll"
fi
printf "  Thanks for playing!\n\n"

