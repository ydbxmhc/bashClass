#!/bin/bash
set -uo pipefail

printf '
  ╔══════════════════════════════════╗ 
  ║         ♠  BLACKJACK  ♠          ║ 
  ║         powered by boop!         ║ 
  ╚══════════════════════════════════╝ 
\n'

# Helper: print a loading message, overwriting the previous one.
# Uses \r + spaces to clear the line, so consecutive calls stack
# cleanly without newlines.
__bj_loading() {
  printf "\r                                              \r  %s" "$1"
}

# The heavy work is PlayingCard.newDeck (~9s). The other steps are
# near-instant. These three messages are for color; we pace them
# with short sleeps so the narrative beats feel roughly even.
__bj_loading "Unwrapping a fresh deck..."

# ─────────────────────────────────────────────────────────────────────
# BLACKJACK — a boop framework demonstration
#
# Single-player blackjack against the house. You start with $100.
#
# Usage:
#   bash blackjack            — full ASCII art terminal UI
#   bash blackjack --simple   — plain text output, line-buffered input
#   bash blackjack -s         — same
#
# Demonstrates:
#   - Sourcing library classes (PlayingCard, Deck, Terminal, Args)
#   - Defining local subclasses in a script (BlackjackHand)
#   - Inheritance (BlackjackHand → List), class methods
#   - into= returns, object creation, property access
#   - PlayingCard.render for ASCII art cards
#   - Terminal mixin for clear/redraw and single-keypress input
# ─────────────────────────────────────────────────────────────────────

. boop PlayingCard Deck Terminal Args

# ═════════════════════════════════════════════════════════════════════
# BlackjackHand — a List of PlayingCards with blackjack scoring
# ═════════════════════════════════════════════════════════════════════
#
# hidden=1 on the hand means card at index 0 is face-down.
# hidden=0 (default) means all cards are visible.
# reveal sets hidden=0 on the hand; hasHidden tests it.

BlackjackHand.new() {
  local _Class="${_Class:-BlackjackHand}"
  local __BH_new_self __BH_new_deck="" __BH_new_hidden="0"
  local __BH_new_arg
  for __BH_new_arg in "$@"; do
    case "$__BH_new_arg" in
      deck=*)   __BH_new_deck="${__BH_new_arg#deck=}" ;;
      hidden=*) __BH_new_hidden="${__BH_new_arg#hidden=}" ;;
    esac
  done
  into=__BH_new_self List.new deck="$__BH_new_deck" hidden="$__BH_new_hidden"
  _Bless "$__BH_new_self" BlackjackHand
  boop.pass "$__BH_new_self" ${into:-}
}

BlackjackHand.cardVal() {
  local __BH_cv_rank
  __BH_cv_rank="${__boop_static[${1}.rank]:-}"
  case "$__BH_cv_rank" in
    A)      boop.pass 11 ${into:-} ;;
    J|Q|K)  boop.pass 10 ${into:-} ;;
    *)      boop.pass "$__BH_cv_rank" ${into:-} ;;
  esac
}

BlackjackHand.total() {
  local _Self="${_Self:-}" _Class="${_Class:-BlackjackHand}"
  local -i __BH_total_sum=0 __BH_total_aces=0 __BH_total_i __BH_total_len __BH_total_v
  local __BH_total_card __BH_total_rank
  into=__BH_total_len $_Self.length
  for (( __BH_total_i=0; __BH_total_i < __BH_total_len; __BH_total_i++ )); do
    into=__BH_total_card $_Self.getAt $__BH_total_i
    __BH_total_rank="${__boop_static[${__BH_total_card}.rank]:-}"
    case "$__BH_total_rank" in
      A)     __BH_total_v=11; (( __BH_total_aces++ )) ;;
      J|Q|K) __BH_total_v=10 ;;
      *)     __BH_total_v=$__BH_total_rank ;;
    esac
    (( __BH_total_sum += __BH_total_v ))
  done
  while (( __BH_total_sum > 21 && __BH_total_aces > 0 )); do
    (( __BH_total_sum -= 10 )); (( __BH_total_aces-- ))
  done
  boop.pass "$__BH_total_sum" ${into:-}
}

BlackjackHand.isBust() {
  local _Self="${_Self:-}" _Class="${_Class:-BlackjackHand}"
  local -i __BH_isBust_t
  into=__BH_isBust_t $_Self.total
  (( __BH_isBust_t > 21 ))
}

BlackjackHand.isBlackjack() {
  local _Self="${_Self:-}" _Class="${_Class:-BlackjackHand}"
  local -i __BH_isBJ_len __BH_isBJ_t
  into=__BH_isBJ_len $_Self.length
  (( __BH_isBJ_len != 2 )) && return 1
  into=__BH_isBJ_t $_Self.total
  (( __BH_isBJ_t == 21 ))
}

# Format for display.
#
# Second arg controls how a hidden hole card is rendered:
#   opponent (default) — card 0 shows as [?] (dealer-style; opaque to observer)
#   owner              — card 0 shows bracketed with its value (e.g. [7♠]),
#                        representing "you know what it is, but it's face-down
#                        on the table." Player's own hand should use this.
#
# When hand.hidden=0 (revealed) both modes print the card normally.
BlackjackHand.show() {
  local _Self="${_Self:-}" _Class="${_Class:-BlackjackHand}"
  local __BH_show_label="${1:-Hand}" __BH_show_view="${2:-opponent}"
  local __BH_show_out="" __BH_show_card __BH_show_str __BH_show_h
  local -i __BH_show_i __BH_show_len
  __BH_show_h="${__boop_static[${_Self}.hidden]:-}"
  into=__BH_show_len $_Self.length
  for (( __BH_show_i=0; __BH_show_i < __BH_show_len; __BH_show_i++ )); do
    into=__BH_show_card $_Self.getAt $__BH_show_i
    if [[ "${__BH_show_h:-0}" == "1" && __BH_show_i -eq 0 ]]; then
      if [[ "$__BH_show_view" == "owner" ]]; then
        local __BH_show_cstr
        into=__BH_show_cstr _Delegate $__BH_show_card.toString
        __BH_show_str="[$__BH_show_cstr]"
      else
        __BH_show_str="[?]"
      fi
    else
      into=__BH_show_str _Delegate $__BH_show_card.toString
    fi
    (( __BH_show_i > 0 )) && __BH_show_out="$__BH_show_out "
    __BH_show_out="$__BH_show_out$__BH_show_str"
  done
  if [[ "${__BH_show_h:-0}" == "1" ]]; then
    __BH_show_out="$__BH_show_label: $__BH_show_out"
  else
    local -i __BH_show_total
    into=__BH_show_total $_Self.total
    __BH_show_out="$__BH_show_label: $__BH_show_out  [$__BH_show_total]"
  fi
  boop.pass "$__BH_show_out" ${into:-}
}

# Reveal all cards by clearing the hand's hidden flag.
BlackjackHand.reveal() {
  local _Self="${_Self:-}" _Class="${_Class:-BlackjackHand}"
  __boop.set hidden "0"
}

# Draw a card from the deck and push it to target (default: self).
BlackjackHand.deal() {
  local _Self="${_Self:-}" _Class="${_Class:-BlackjackHand}"
  local __BH_deal_target="${1:-}" __BH_deal_deck __BH_deal_card
  : "${__BH_deal_target:=$_Self}"
  into=__BH_deal_deck $_Self.get deck
  [[ -z "$__BH_deal_deck" ]] && _Crash "BlackjackHand.deal: no deck on this hand"
  into=__BH_deal_card $__BH_deal_deck.draw
  _Delegate $__BH_deal_target.push "$__BH_deal_card"
}

# Exit 0 if hand.hidden=1 (card 0 is face-down).
BlackjackHand.hasHidden() {
  local _Self="${_Self:-}" _Class="${_Class:-BlackjackHand}"
  local __BH_hasHidden_h
  __BH_hasHidden_h="${__boop_static[${_Self}.hidden]:-}"
  [[ "${__BH_hasHidden_h:-0}" == "1" ]]
}

boopClass BlackjackHand isa:List has:type,deck,hidden '
  public:new,cardVal,total,isBust,isBlackjack,show,reveal,deal,hasHidden
'

# ═════════════════════════════════════════════════════════════════════
# Game helpers & main loop — only run when executed directly
# ═════════════════════════════════════════════════════════════════════

[[ "${BASH_SOURCE[0]}" != "${0}" ]] && return 0

# ─────────────────────────────────────────────────────────────────────
# CLI options — --simple / -s skips ASCII art
# ─────────────────────────────────────────────────────────────────────

declare simple=0
Args.parse '
[Options]
simple | s
' "$@"
declare -i __BJ_simple="${simple:-0}"
unset simple

# ─────────────────────────────────────────────────────────────────────
# Terminal cleanup on exit
# ─────────────────────────────────────────────────────────────────────
#
# No top-level trap — we only enter raw mode briefly inside player_action,
# and that function installs its own narrow-scope trap for the duration
# of the keypress. See player_action below.

# ─────────────────────────────────────────────────────────────────────
# UI helpers
# ─────────────────────────────────────────────────────────────────────

# Render all cards in a hand side by side (9 cols × 7 rows each).
# If hand.hidden=1, card 0 is drawn as a back (face-down).
draw_cards() {
  local __BJ_dc_hand="$1" __BJ_dc_h
  __BJ_dc_h="${__boop_static[${__BJ_dc_hand}.hidden]:-}"
  local -i __BJ_dc_len __BJ_dc_i
  into=__BJ_dc_len $__BJ_dc_hand.length

  local -a __BJ_dc_r0=() __BJ_dc_r1=() __BJ_dc_r2=() __BJ_dc_r3=() \
           __BJ_dc_r4=() __BJ_dc_r5=() __BJ_dc_r6=()

  for (( __BJ_dc_i=0; __BJ_dc_i < __BJ_dc_len; __BJ_dc_i++ )); do
    local __BJ_dc_card
    into=__BJ_dc_card $__BJ_dc_hand.getAt $__BJ_dc_i

    local -a __BJ_dc_lines=()
    if [[ "${__BJ_dc_h:-0}" == "1" && __BJ_dc_i -eq 0 ]]; then
      # Blue background throughout. Plain white for structure (border),
      # cyan for the decorative ░ pattern, black for the lettering.
      # No bright/bold variants anywhere.
      local __BJ_dc_bw=$'\033[44;37m' __BJ_dc_cy=$'\033[44;36m' \
            __BJ_dc_bk=$'\033[44;30m' __BJ_dc_rs=$'\033[0m'
      __BJ_dc_lines=(
        "${__BJ_dc_bw}╔═══════╗${__BJ_dc_rs}"
        "${__BJ_dc_bw}║${__BJ_dc_cy}░░░░░░░${__BJ_dc_bw}║${__BJ_dc_rs}"
        "${__BJ_dc_bw}║${__BJ_dc_cy}░${__BJ_dc_bk}CARDS${__BJ_dc_cy}░${__BJ_dc_bw}║${__BJ_dc_rs}"
        "${__BJ_dc_bw}║${__BJ_dc_cy}░${__BJ_dc_bk}WITH${__BJ_dc_cy}░░${__BJ_dc_bw}║${__BJ_dc_rs}"
        "${__BJ_dc_bw}║${__BJ_dc_cy}░${__BJ_dc_bk}BOOP!${__BJ_dc_cy}░${__BJ_dc_bw}║${__BJ_dc_rs}"
        "${__BJ_dc_bw}║${__BJ_dc_cy}░░░░░░░${__BJ_dc_bw}║${__BJ_dc_rs}"
        "${__BJ_dc_bw}╚═══════╝${__BJ_dc_rs}"
      )
    else
      readarray -t __BJ_dc_lines < <($__BJ_dc_card.render)
    fi

    __BJ_dc_r0+=("${__BJ_dc_lines[0]:-}")
    __BJ_dc_r1+=("${__BJ_dc_lines[1]:-}")
    __BJ_dc_r2+=("${__BJ_dc_lines[2]:-}")
    __BJ_dc_r3+=("${__BJ_dc_lines[3]:-}")
    __BJ_dc_r4+=("${__BJ_dc_lines[4]:-}")
    __BJ_dc_r5+=("${__BJ_dc_lines[5]:-}")
    __BJ_dc_r6+=("${__BJ_dc_lines[6]:-}")
  done

  # Print all 7 rows; cards separated by two spaces
  local __BJ_dc_j
  for __BJ_dc_j in 0 1 2 3 4 5 6; do
    local -n __BJ_dc_row="__BJ_dc_r${__BJ_dc_j}"
    printf '    '
    local -i __BJ_dc_k=0
    local __BJ_dc_cell
    for __BJ_dc_cell in "${__BJ_dc_row[@]+"${__BJ_dc_row[@]}"}"; do
      (( __BJ_dc_k++ > 0 )) && printf '  '
      printf '%s' "$__BJ_dc_cell"
    done
    printf '\n'
    unset -n __BJ_dc_row
  done
}

# Clear screen and redraw full game state.
# Args: player dealer round bankroll bet [message]
draw_table() {
  local __BJ_dt_player="$1" __BJ_dt_dealer="$2"
  local -i __BJ_dt_round="$3" __BJ_dt_bankroll="$4" __BJ_dt_bet="$5"
  local __BJ_dt_msg="${6:-}"

  # ── Simple (text) mode ──
  if (( __BJ_simple )); then
    local __BJ_dt_s
    into=__BJ_dt_s $__BJ_dt_dealer.show "Dealer"; printf "  %s\n" "$__BJ_dt_s"
    into=__BJ_dt_s $__BJ_dt_player.show "You" "owner"
    local __BJ_dt_ph
    __BJ_dt_ph="${__boop_static[${__BJ_dt_player}.hidden]:-}"
    if [[ "${__BJ_dt_ph:-0}" == "1" ]]; then
      local -i __BJ_dt_ptot; into=__BJ_dt_ptot $__BJ_dt_player.total
      __BJ_dt_s+="  [$__BJ_dt_ptot]"
    fi
    printf "  %s\n\n" "$__BJ_dt_s"
    [[ -n "$__BJ_dt_msg" ]] && printf '  %s\n\n' "$__BJ_dt_msg"
    return
  fi

  # ── Full (ASCII art) mode ──
  Terminal.clear
  printf '\n'
  printf '  ╔══════════════════════════════════╗\n'
  printf '  ║         ♠  BLACKJACK  ♠          ║\n'
  printf '  ║         powered by boop!         ║\n'
  printf '  ╚══════════════════════════════════╝\n\n'
  printf '  Round %-3d  ·  Bankroll: $%-6d  ·  Bet: $%d\n\n' \
    "$__BJ_dt_round" "$__BJ_dt_bankroll" "$__BJ_dt_bet"

  # Dealer — hide total while hole card is down
  if $__BJ_dt_dealer.hasHidden; then
    printf '  DEALER\n'
  else
    local -i __BJ_dt_dtot; into=__BJ_dt_dtot $__BJ_dt_dealer.total
    printf '  DEALER  [%d]\n' "$__BJ_dt_dtot"
  fi
  draw_cards "$__BJ_dt_dealer"

  # Player — always show the running total (even when the hole card
  # is face-down). The player knows their own total.
  printf '\n'
  local -i __BJ_dt_ptot; into=__BJ_dt_ptot $__BJ_dt_player.total
  printf '  YOU  [%d]\n' "$__BJ_dt_ptot"
  draw_cards "$__BJ_dt_player"

  [[ -n "$__BJ_dt_msg" ]] && printf '\n  %s' "$__BJ_dt_msg"
  printf '\n'
}

# Read a single keypress (full mode) or a word (simple mode).
# Prints the first character of the response to stdout.
player_action() {
  local __BJ_pa_prompt="${1:-}" __BJ_pa_key
  if (( __BJ_simple )); then
    printf '  %s: ' "$__BJ_pa_prompt"
    read -r __BJ_pa_key || __BJ_pa_key="q"
  else
    # Raw mode is scoped tightly around the keypress: install the
    # restore-trap after entering raw mode and tear it down once we
    # restore cleanly. If a signal fires during readKey, the trap
    # runs and the terminal is left in a sane state.
    Terminal.raw
    trap 'Terminal.restore; printf "\n"' EXIT INT TERM
    into=__BJ_pa_key Terminal.readKey
    Terminal.restore
    trap - EXIT INT TERM
    printf '%s\n' "${__BJ_pa_key:-}"
  fi
  boop.pass "${__BJ_pa_key:0:1}" ${into:-}
}

# ─────────────────────────────────────────────────────────────────────
# Main game loop
# ─────────────────────────────────────────────────────────────────────

declare -i bankroll=100 round=0

# ─────────────────────────────────────────────────────────────────────
# Deck: Platonic Master + indexed working order
# ─────────────────────────────────────────────────────────────────────
#
# The expensive operation here is creating PlayingCard objects (~10 seconds
# for 52 cards on fork-heavy platforms like Git Bash on Windows). We do
# that exactly once at session start to build __BJ_master -- a flat bash
# array of 52 card IDs. That's the Platonic deck; it never changes.
#
# The working state is __BJ_order (a shuffled permutation of 0..51) plus
# __BJ_next (the cursor into __BJ_order). Drawing advances the cursor;
# shuffling just Fisher-Yates'es the index array and resets the cursor.
# Both are pure bash-array operations -- sub-millisecond on any platform.
#
# At end-of-hand, hands are "discarded" (cleared). The cards stay in the
# master forever; we just stop referencing them via the hands.
__bj_loading "Shuffling thoroughly..."
into=__BJ_one_deck PlayingCard.newDeck
declare -a __BJ_master=()
declare -i __BJ_mi __BJ_mlen
__bj_loading "Loading into the shoe..."
into=__BJ_mlen $__BJ_one_deck.length
for (( __BJ_mi=0; __BJ_mi < __BJ_mlen; __BJ_mi++ )); do
  into=__BJ_master[__BJ_mi] $__BJ_one_deck.getAt $__BJ_mi
done
unset __BJ_one_deck __BJ_mi __BJ_mlen
sleep 0.5

# Clear the final loading message.
printf '\r                                              \r'

declare -a __BJ_order=()
declare -i __BJ_next=0

# Shuffle the index array (Fisher-Yates) and reset the cursor.
# Sub-millisecond since we're only moving integers around.
__bj_shuffle() {
  local -i __i __j __tmp
  __BJ_order=()
  for (( __i = 0; __i < 52; __i++ )); do __BJ_order[__i]="$__i"; done
  for (( __i = 51; __i > 0; __i-- )); do
    __j=$(( RANDOM % (__i + 1) ))
    __tmp="${__BJ_order[__i]}"
    __BJ_order[__i]="${__BJ_order[__j]}"
    __BJ_order[__j]="$__tmp"
  done
  __BJ_next=0
}

# Draw the next card from the shuffled order and advance the cursor.
# Returns the card's object ID via boop.pass, honoring into=.
__bj_draw() {
  local __card="${__BJ_master[${__BJ_order[__BJ_next]}]}"
  (( __BJ_next++ ))
  boop.pass "$__card" ${into:-}
}

# Discard a hand: clear its contents. The cards stay in the master
# forever -- hands just stop referencing them.
__bj_discard() {
  local __hand="$1"
  $__hand.clear
}

__bj_shuffle

# Hands are reused across rounds -- at end-of-round we discard (clear)
# them, which is cheap, rather than creating new hand objects each time.
into=player BlackjackHand hidden=1
into=dealer BlackjackHand hidden=1

while (( bankroll > 0 )); do
  printf "  Bankroll: \$%d\n" "$bankroll"
  printf "  Bet (or 'q' to quit): "
  read -r __BJ_input || break

  [[ "$__BJ_input" == "q" ]] && break

  if [[ ! "$__BJ_input" =~ ^[0-9]+$ ]] || (( __BJ_input < 1 )); then
    printf "  Invalid bet.\n\n"; continue
  fi
  declare -i bet=__BJ_input
  if (( bet > bankroll )); then
    printf "  You only have \$%d.\n\n" "$bankroll"; continue
  fi

  (( round++ ))
  (( __BJ_simple )) && printf "\n  ── Round %d ──\n\n" "$round"

  # Reshuffle only when cards run low. Worst-case single hand is
  # ~18 cards (2 initial each + up to ~8 hits per player before bust).
  # 20 is a safe threshold. The reshuffle itself is sub-millisecond.
  if (( 52 - __BJ_next < 20 )); then
    __bj_loading "Shuffling..."
    __bj_shuffle
    printf '\r                                              \r'
  fi

  # Start of round: discard both hands (carried over from prior round
  # on rounds 2+) and reset the hole-card flag.
  __bj_discard "$player"; $player.set hidden "1"
  __bj_discard "$dealer"; $dealer.set hidden "1"

  # Deal: player, dealer, player, dealer. We draw from the working
  # order and push straight into the hand.
  declare __BJ_card
  into=__BJ_card __bj_draw; $player.push "$__BJ_card"
  into=__BJ_card __bj_draw; $dealer.push "$__BJ_card"
  into=__BJ_card __bj_draw; $player.push "$__BJ_card"
  into=__BJ_card __bj_draw; $dealer.push "$__BJ_card"

  # ── Check naturals ──
  declare -i player_bj=0 dealer_bj=0
  $player.isBlackjack && player_bj=1
  declare -i __BJ_nat_dtot
  into=__BJ_nat_dtot $dealer.total
  (( __BJ_nat_dtot == 21 )) && dealer_bj=1

  if (( player_bj || dealer_bj )); then
    $dealer.reveal; $player.reveal
    if (( player_bj && dealer_bj )); then
      draw_table "$player" "$dealer" "$round" "$bankroll" "$bet" "Both have Blackjack — push."
    elif (( player_bj )); then
      (( bankroll += bet * 3 / 2 ))
      draw_table "$player" "$dealer" "$round" "$bankroll" "$bet" \
        "♠ Blackjack! You win \$$(( bet * 3 / 2 ))!"
    else
      (( bankroll -= bet ))
      draw_table "$player" "$dealer" "$round" "$bankroll" "$bet" \
        "Dealer has Blackjack. You lose \$$bet."
    fi
    continue
  fi

  # ── Player turn ──
  declare -i busted=0 charlie=0
  while true; do
    # Full mode shows the action hint as the table message; simple mode
    # lets player_action emit its own prompt (avoids duplicate lines).
    if (( __BJ_simple )); then
      draw_table "$player" "$dealer" "$round" "$bankroll" "$bet"
    else
      draw_table "$player" "$dealer" "$round" "$bankroll" "$bet" \
        "[H]it  [S]tand  [P]eek  [Q]uit"
    fi
    into=__BJ_choice player_action "[H]it, [S]tand, [P]eek, [Q]uit"
    case "${__BJ_choice,,}" in
      h)
        into=__BJ_card __bj_draw; $player.push "$__BJ_card"
        if $player.isBust; then
          $player.reveal
          (( bankroll -= bet ))
          draw_table "$player" "$dealer" "$round" "$bankroll" "$bet" \
            "Bust! You lose \$$bet."
          busted=1; break
        fi
        # Five-Card Charlie: 5 cards without busting is an auto-win at 2:1.
        declare -i __BJ_plen
        into=__BJ_plen $player.length
        if (( __BJ_plen >= 5 )); then
          $player.reveal
          (( bankroll += bet * 2 ))
          draw_table "$player" "$dealer" "$round" "$bankroll" "$bet" \
            "Five-Card Charlie! You win \$$(( bet * 2 ))!"
          charlie=1; break
        fi
        ;;
      s) $player.reveal; break ;;
      p)
        if (( __BJ_simple )); then
          declare __BJ_peek_c __BJ_peek_s
          into=__BJ_peek_c $player.getAt 0
          into=__BJ_peek_s _Delegate $__BJ_peek_c.toString
          printf '  [Peek] Your hole card: %s\n\n' "$__BJ_peek_s"
        else
          $player.reveal
          draw_table "$player" "$dealer" "$round" "$bankroll" "$bet" "Peeking..."
          (( __BJ_simple )) || sleep 1
          $player.set hidden "1"
        fi
        ;;
      q) exit 0 ;;
      *) : ;;
    esac
  done

  (( busted || charlie )) && continue

  # ── Dealer turn ──
  $dealer.reveal
  draw_table "$player" "$dealer" "$round" "$bankroll" "$bet" \
    "Dealer reveals hole card..."
  sleep 1

  declare -i dtotal
  while true; do
    into=dtotal $dealer.total
    (( dtotal >= 17 )) && break
    into=__BJ_card __bj_draw; $dealer.push "$__BJ_card"
    draw_table "$player" "$dealer" "$round" "$bankroll" "$bet" \
      "Dealer hits..."
    (( __BJ_simple )) || sleep 1
  done

  # ── Outcome ──
  declare -i ptotal; into=ptotal $player.total
  into=dtotal $dealer.total

  declare __BJ_outcome_msg
  if $dealer.isBust; then
    (( bankroll += bet ))
    __BJ_outcome_msg="Dealer busts! You win \$$bet!"
  elif (( ptotal > dtotal )); then
    (( bankroll += bet ))
    __BJ_outcome_msg="You win \$$bet!"
  elif (( dtotal > ptotal )); then
    (( bankroll -= bet ))
    __BJ_outcome_msg="Dealer wins. You lose \$$bet."
  else
    __BJ_outcome_msg="Push — bet returned."
  fi
  draw_table "$player" "$dealer" "$round" "$bankroll" "$bet" "$__BJ_outcome_msg"
done

if (( bankroll <= 0 )); then
  printf "\n  You're broke. Better luck next time.\n"
else
  printf "\n  You leave with \$%d.\n" "$bankroll"
fi
printf "  Thanks for playing!\n\n"
