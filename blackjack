#!/bin/bash
set -u

# ============================================================================
# BLACKJACK — a boop demonstration
#
# Single-player blackjack. The script is the dealer. You start with $100.
# All classes defined inline — no separate files needed.
#
# Usage: bash blackjack
# ============================================================================

. boop List

# ============================================================================
# Card — base playing card
# ============================================================================

__bashClass_registry["Card"]="|class=Card|parent=bashClass\
|methods=new,flip,val,toString\
|properties=suit,rank,faceUp"

Card.new() {
  local -I class
  : "${class:=Card}"
  local __Card_new_self __Card_new_suit="" __Card_new_rank="" __Card_new_faceUp=0
  for __Card_new_arg in "$@"; do
    case "$__Card_new_arg" in
      suit=*)   __Card_new_suit="${__Card_new_arg#suit=}" ;;
      rank=*)   __Card_new_rank="${__Card_new_arg#rank=}" ;;
      faceUp=*) __Card_new_faceUp="${__Card_new_arg#faceUp=}" ;;
    esac
  done
  [[ -n "$__Card_new_suit" ]] || __bashClass.crash "Card: suit is required"
  [[ -n "$__Card_new_rank" ]] || __bashClass.crash "Card: rank is required"
  into=__Card_new_self __bashClass.new \
    suit="$__Card_new_suit" rank="$__Card_new_rank" faceUp="$__Card_new_faceUp"
  __bashClass.return "$__Card_new_self" ${into:-}
}

Card.flip() {
  local -I self class
  local __Card_flip_v
  __bashClass.parse "$self" "faceUp" __Card_flip_v
  if [[ "$__Card_flip_v" == "1" ]]; then
    self="$self" class="$class" __bashClass.dispatch set faceUp 0
  else
    self="$self" class="$class" __bashClass.dispatch set faceUp 1
  fi
}

Card.val() {
  local -I self class
  local __Card_val_rank
  __bashClass.parse "$self" "rank" __Card_val_rank
  local -i __Card_val_v=0
  case "$__Card_val_rank" in
    [2-9])  __Card_val_v=$__Card_val_rank ;;
    10)     __Card_val_v=10 ;;
    *)      __Card_val_v=0 ;;  # subclasses override
  esac
  __bashClass.return "$__Card_val_v" ${into:-}
}

Card.toString() {
  local -I self class
  local __Card_ts_faceUp __Card_ts_rank __Card_ts_suit
  __bashClass.parse "$self" "faceUp" __Card_ts_faceUp
  if [[ "$__Card_ts_faceUp" != "1" ]]; then
    __bashClass.return "[?]" ${into:-}
    return
  fi
  __bashClass.parse "$self" "rank" __Card_ts_rank
  __bashClass.parse "$self" "suit" __Card_ts_suit
  __bashClass.return "${__Card_ts_rank}${__Card_ts_suit}" ${into:-}
}

__bashClass.registerMethod Card new      Card.new
__bashClass.registerMethod Card flip     Card.flip
__bashClass.registerMethod Card val      Card.val
__bashClass.registerMethod Card toString Card.toString
__bashClass.registerClass Card

# ============================================================================
# FaceCard extends Card — J, Q, K are always worth 10
# ============================================================================

__bashClass_registry["FaceCard"]="|class=FaceCard|parent=Card\
|methods=new,val\
|properties=suit,rank,faceUp"

FaceCard.new() {
  local -I class
  class=FaceCard Card.new "$@"
}

FaceCard.val() {
  local -I self class
  __bashClass.return "10" ${into:-}
}

__bashClass.registerMethod FaceCard new FaceCard.new
__bashClass.registerMethod FaceCard val FaceCard.val
__bashClass.registerClass FaceCard

# ============================================================================
# Ace extends Card — worth 11 (Hand adjusts to 1 if bust)
# ============================================================================

__bashClass_registry["Ace"]="|class=Ace|parent=Card\
|methods=new,val\
|properties=suit,rank,faceUp"

Ace.new() {
  local -I class
  class=Ace Card.new "$@"
}

Ace.val() {
  local -I self class
  __bashClass.return "11" ${into:-}
}

__bashClass.registerMethod Ace new Ace.new
__bashClass.registerMethod Ace val Ace.val
__bashClass.registerClass Ace

# ============================================================================
# Deck extends List — 52 cards, shuffle, draw
# ============================================================================

__bashClass_registry["Deck"]="|class=Deck|parent=List\
|methods=new,reset,shuffle,draw\
|properties=type"

Deck.new() {
  local -I class
  class=Deck
  local __Deck_new_self
  into=__Deck_new_self List.new "$@"
  # Populate and shuffle
  self="$__Deck_new_self" class=Deck Deck.reset
  self="$__Deck_new_self" class=Deck Deck.shuffle
  __bashClass.return "$__Deck_new_self" ${into:-}
}

Deck.reset() {
  local -I self class
  $self.clear
  local __Deck_reset_suits=("♠" "♥" "♦" "♣")
  local __Deck_reset_s __Deck_reset_r __Deck_reset_card
  for __Deck_reset_s in "${__Deck_reset_suits[@]}"; do
    # Number cards 2-10
    for __Deck_reset_r in 2 3 4 5 6 7 8 9 10; do
      into=__Deck_reset_card Card suit="$__Deck_reset_s" rank="$__Deck_reset_r"
      $self.push "$__Deck_reset_card"
    done
    # Face cards
    for __Deck_reset_r in J Q K; do
      into=__Deck_reset_card FaceCard suit="$__Deck_reset_s" rank="$__Deck_reset_r"
      $self.push "$__Deck_reset_card"
    done
    # Ace
    into=__Deck_reset_card Ace suit="$__Deck_reset_s" rank=A
    $self.push "$__Deck_reset_card"
  done
}

Deck.shuffle() {
  local -I self class
  local -i __Deck_shuf_len __Deck_shuf_i __Deck_shuf_j
  local __Deck_shuf_a __Deck_shuf_b
  into=__Deck_shuf_len $self.length
  for (( __Deck_shuf_i = __Deck_shuf_len - 1; __Deck_shuf_i > 0; __Deck_shuf_i-- )); do
    __Deck_shuf_j=$(( RANDOM % (__Deck_shuf_i + 1) ))
    into=__Deck_shuf_a $self.get $__Deck_shuf_i
    into=__Deck_shuf_b $self.get $__Deck_shuf_j
    $self.set $__Deck_shuf_i "$__Deck_shuf_b"
    $self.set $__Deck_shuf_j "$__Deck_shuf_a"
  done
}

Deck.draw() {
  local -I self class
  local __Deck_draw_card
  into=__Deck_draw_card $self.pop
  __bashClass.return "$__Deck_draw_card" ${into:-}
}

__bashClass.registerMethod Deck new     Deck.new
__bashClass.registerMethod Deck reset   Deck.reset
__bashClass.registerMethod Deck shuffle Deck.shuffle
__bashClass.registerMethod Deck draw    Deck.draw
__bashClass.registerClass Deck

# ============================================================================
# Hand extends List — holds cards, computes totals
# ============================================================================

__bashClass_registry["Hand"]="|class=Hand|parent=List\
|methods=new,total,isBust,isBlackjack,hasBlackjack,show\
|properties=type,owner"

Hand.new() {
  local -I class
  class=Hand
  local __Hand_new_self __Hand_new_owner=""
  for __Hand_new_arg in "$@"; do
    case "$__Hand_new_arg" in
      owner=*) __Hand_new_owner="${__Hand_new_arg#owner=}" ;;
    esac
  done
  into=__Hand_new_self List.new "$@"
  [[ -n "$__Hand_new_owner" ]] && \
    self="$__Hand_new_self" class=Hand __bashClass.dispatch set owner "$__Hand_new_owner"
  __bashClass.return "$__Hand_new_self" ${into:-}
}

Hand.total() {
  local -I self class
  local -i __Hand_total_sum=0 __Hand_total_aces=0 __Hand_total_i __Hand_total_len
  local __Hand_total_card __Hand_total_v

  into=__Hand_total_len $self.length

  for (( __Hand_total_i=0; __Hand_total_i < __Hand_total_len; __Hand_total_i++ )); do
    into=__Hand_total_card $self.get $__Hand_total_i
    into=__Hand_total_v $__Hand_total_card.val
    (( __Hand_total_sum += __Hand_total_v ))
    $__Hand_total_card.isa Ace && (( __Hand_total_aces++ )) || true
  done

  while (( __Hand_total_sum > 21 && __Hand_total_aces > 0 )); do
    (( __Hand_total_sum -= 10 ))
    (( __Hand_total_aces-- ))
  done

  __bashClass.return "$__Hand_total_sum" ${into:-}
}

Hand.isBust() {
  local -I self class
  local -i __Hand_isBust_total
  into=__Hand_isBust_total self="$self" class=Hand Hand.total
  (( __Hand_isBust_total > 21 )) && return 0 || return 1
}

Hand.isBlackjack() {
  local -I self class
  local -i __Hand_isBJ_len __Hand_isBJ_total
  into=__Hand_isBJ_len $self.length
  (( __Hand_isBJ_len != 2 )) && return 1
  into=__Hand_isBJ_total self="$self" class=Hand Hand.total
  (( __Hand_isBJ_total == 21 )) && return 0 || return 1
}

# Alias for readability in game logic
Hand.hasBlackjack() { local -I self class; self="$self" class=Hand Hand.isBlackjack; }

Hand.show() {
  local -I self class
  local __Hand_show_owner __Hand_show_out="" __Hand_show_card __Hand_show_str
  local -i __Hand_show_i __Hand_show_len __Hand_show_total __Hand_show_hidden=0

  __bashClass.parse "$self" "owner" __Hand_show_owner
  into=__Hand_show_len $self.length

  for (( __Hand_show_i=0; __Hand_show_i < __Hand_show_len; __Hand_show_i++ )); do
    into=__Hand_show_card $self.get $__Hand_show_i
    into=__Hand_show_str $__Hand_show_card.toString
    [[ "$__Hand_show_str" == "[?]" ]] && __Hand_show_hidden=1
    (( __Hand_show_i > 0 )) && __Hand_show_out="$__Hand_show_out "
    __Hand_show_out="$__Hand_show_out$__Hand_show_str"
  done

  if (( __Hand_show_hidden )); then
    __Hand_show_out="$__Hand_show_owner: $__Hand_show_out"
  else
    into=__Hand_show_total self="$self" class=Hand Hand.total
    __Hand_show_out="$__Hand_show_owner: $__Hand_show_out  [$__Hand_show_total]"
  fi

  __bashClass.return "$__Hand_show_out" ${into:-}
}

__bashClass.registerMethod Hand new           Hand.new
__bashClass.registerMethod Hand total         Hand.total
__bashClass.registerMethod Hand isBust        Hand.isBust
__bashClass.registerMethod Hand isBlackjack   Hand.isBlackjack
__bashClass.registerMethod Hand hasBlackjack  Hand.hasBlackjack
__bashClass.registerMethod Hand show          Hand.show
__bashClass.registerClass Hand

# ============================================================================
# GAME HELPERS
# ============================================================================

# Deal a card face-up into a hand
__deal_up() {
  local __du_hand="$1" __du_deck="$2" __du_card
  into=__du_card $__du_deck.draw
  $__du_card.flip
  $__du_hand.push "$__du_card"
}

# Deal a card face-down into a hand
__deal_down() {
  local __dd_hand="$1" __dd_deck="$2" __dd_card
  into=__dd_card $__dd_deck.draw
  $__dd_hand.push "$__dd_card"
}

# Show both hands
__show_table() {
  local __st_player="$1" __st_house="$2" __st_s
  into=__st_s $__st_house.show; printf "  %s\n" "$__st_s"
  into=__st_s $__st_player.show; printf "  %s\n\n" "$__st_s"
}

# Flip all cards in a hand face-up
__reveal() {
  local __rv_hand="$1" __rv_card
  local -i __rv_i __rv_len __rv_fu
  into=__rv_len $__rv_hand.length
  for (( __rv_i=0; __rv_i < __rv_len; __rv_i++ )); do
    into=__rv_card $__rv_hand.get $__rv_i
    __bashClass.parse "$__rv_card" "faceUp" __rv_fu
    [[ "$__rv_fu" != "1" ]] && $__rv_card.flip
  done
}

# ============================================================================
# MAIN GAME LOOP
# ============================================================================

printf "\n"
printf "  ╔══════════════════════════════════╗\n"
printf "  ║         ♠  BLACKJACK  ♠          ║\n"
printf "  ║     powered by bashClass/boop    ║\n"
printf "  ╚══════════════════════════════════╝\n\n"

declare -i __bankroll=100
declare -i __round=0

while (( __bankroll > 0 )); do
  printf "  Bankroll: \$%d\n" "$__bankroll"
  printf "  Bet amount (or 'q' to leave): "
  read -r __bet_input

  [[ "$__bet_input" == "q" || "$__bet_input" == "Q" ]] && break

  # Validate bet
  if [[ ! "$__bet_input" =~ ^[0-9]+$ ]] || (( __bet_input < 1 )); then
    printf "  Invalid bet. Enter a number.\n\n"
    continue
  fi
  declare -i __bet=$__bet_input
  if (( __bet > __bankroll )); then
    printf "  You only have \$%d.\n\n" "$__bankroll"
    continue
  fi

  (( __round++ ))
  printf "\n  ── Round %d ──\n\n" "$__round"

  # Fresh deck each round (casino style — no card counting)
  into=__deck Deck
  into=__player Hand owner="You"
  into=__house Hand owner="Dealer"

  # Initial deal: player, house, player, house
  __deal_up "$__player" "$__deck"
  __deal_down "$__house" "$__deck"
  __deal_up "$__player" "$__deck"
  __deal_up "$__house" "$__deck"

  __show_table "$__player" "$__house"

  # Check for naturals
  declare -i __player_bj=0 __house_bj=0
  $__player.hasBlackjack && __player_bj=1
  # Peek: check house blackjack without revealing
  __reveal "$__house"
  $__house.hasBlackjack && __house_bj=1

  if (( __player_bj || __house_bj )); then
    # Show the real table
    __show_table "$__player" "$__house"
    if (( __player_bj && __house_bj )); then
      printf "  Both have Blackjack — push.\n\n"
    elif (( __player_bj )); then
      printf "  ♠ Blackjack! You win \$%d!\n\n" "$(( __bet * 3 / 2 ))"
      (( __bankroll += __bet * 3 / 2 ))
    else
      printf "  Dealer has Blackjack. You lose \$%d.\n\n" "$__bet"
      (( __bankroll -= __bet ))
    fi
    # Re-hide house hole card for display consistency was already revealed
    continue
  fi

  # Undo the peek — re-hide the hole card
  into=__hole_card $__house.get 0
  __bashClass.parse "$__hole_card" "faceUp" __hole_fu
  [[ "$__hole_fu" == "1" ]] && {
    # First card was dealt face-down, we flipped it to peek — flip back
    $__hole_card.flip
  }

  # ── Player turn ──
  declare -i __player_done=0
  while (( ! __player_done )); do
    into=__ptotal $__player.total

    if $__player.isBust; then
      __show_table "$__player" "$__house"
      printf "  Bust! You lose \$%d.\n\n" "$__bet"
      (( __bankroll -= __bet ))
      __player_done=2  # signal: skip house turn
      break
    fi

    printf "  [H]it or [S]tand? "
    read -r __choice
    case "${__choice,,}" in
      h|hit)
        __deal_up "$__player" "$__deck"
        __show_table "$__player" "$__house"
        ;;
      s|stand)
        __player_done=1
        ;;
      *)
        printf "  Type 'h' or 's'.\n"
        ;;
    esac
  done

  # Skip house turn if player busted
  (( __player_done == 2 )) && continue

  # ── House turn ──
  __reveal "$__house"
  printf "  Dealer reveals hole card.\n"
  __show_table "$__player" "$__house"

  while true; do
    into=__htotal $__house.total
    (( __htotal >= 17 )) && break
    printf "  Dealer hits.\n"
    __deal_up "$__house" "$__deck"
    __show_table "$__player" "$__house"
  done

  # ── Outcome ──
  into=__ptotal $__player.total
  into=__htotal $__house.total

  if $__house.isBust; then
    printf "  Dealer busts! You win \$%d!\n\n" "$__bet"
    (( __bankroll += __bet ))
  elif (( __ptotal > __htotal )); then
    printf "  You win \$%d!\n\n" "$__bet"
    (( __bankroll += __bet ))
  elif (( __htotal > __ptotal )); then
    printf "  Dealer wins. You lose \$%d.\n\n" "$__bet"
    (( __bankroll -= __bet ))
  else
    printf "  Push — bet returned.\n\n"
  fi
done

if (( __bankroll <= 0 )); then
  printf "  You're broke. Better luck next time.\n"
else
  printf "\n  You leave the table with \$%d.\n" "$__bankroll"
fi

printf "  Thanks for playing!\n\n"
