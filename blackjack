#!/bin/bash
set -uo pipefail

# ─────────────────────────────────────────────────────────────────────
# BLACKJACK — a boop framework demonstration
#
# Single-player blackjack against the house. You start with $100.
# All classes defined inline — no separate files needed.
#
# Demonstrates: inheritance, method override, isa, List composition,
#               into= returns, object creation, and property access.
#
# Usage: bash blackjack
# ─────────────────────────────────────────────────────────────────────

. boop List

# ═════════════════════════════════════════════════════════════════════
# Card — base playing card
# ═════════════════════════════════════════════════════════════════════

__bashClass_registry["Card"]="|class=Card|parent=bashClass\
|methods=new,flip,val,toString\
|properties=suit,rank,faceUp"

Card.new() {
  local -I class; : "${class:=Card}"
  local __Card_new_self __Card_new_suit="" __Card_new_rank="" __Card_new_faceUp=0
  for __Card_new_arg in "$@"; do
    case "$__Card_new_arg" in
      suit=*)   __Card_new_suit="${__Card_new_arg#suit=}" ;;
      rank=*)   __Card_new_rank="${__Card_new_arg#rank=}" ;;
      faceUp=*) __Card_new_faceUp="${__Card_new_arg#faceUp=}" ;;
    esac
  done
  [[ -n "$__Card_new_suit" ]] || __bashClass.crash "Card: suit= is required"
  [[ -n "$__Card_new_rank" ]] || __bashClass.crash "Card: rank= is required"
  into=__Card_new_self __bashClass.new suit="$__Card_new_suit" rank="$__Card_new_rank" faceUp="$__Card_new_faceUp"
  __bashClass.return "$__Card_new_self" ${into:-}
}

Card.flip() {
  local -I self class
  local __Card_flip_fu; __bashClass.parse "$self" "faceUp" __Card_flip_fu
  if [[ "$__Card_flip_fu" == "1" ]]; then
    $self.set faceUp 0
  else
    $self.set faceUp 1
  fi
}

Card.val() {
  local -I self class
  local __Card_val_rank; __bashClass.parse "$self" "rank" __Card_val_rank
  case "$__Card_val_rank" in
    [2-9]) __bashClass.return "$__Card_val_rank" ${into:-} ;;
    10)    __bashClass.return "10" ${into:-} ;;
    *)     __bashClass.return "0" ${into:-} ;;
  esac
}

Card.toString() {
  local -I self class
  local __Card_ts_fu; __bashClass.parse "$self" "faceUp" __Card_ts_fu
  if [[ "$__Card_ts_fu" != "1" ]]; then
    __bashClass.return "[?]" ${into:-}
    return
  fi
  local __Card_ts_rank __Card_ts_suit
  __bashClass.parse "$self" "rank" __Card_ts_rank
  __bashClass.parse "$self" "suit" __Card_ts_suit
  __bashClass.return "${__Card_ts_rank}${__Card_ts_suit}" ${into:-}
}

__bashClass.registerMethod Card new      Card.new
__bashClass.registerMethod Card flip     Card.flip
__bashClass.registerMethod Card val      Card.val
__bashClass.registerMethod Card toString Card.toString
__bashClass.registerClass Card

# ═════════════════════════════════════════════════════════════════════
# FaceCard extends Card — J, Q, K are always worth 10
# ═════════════════════════════════════════════════════════════════════

__bashClass_registry["FaceCard"]="|class=FaceCard|parent=Card\
|methods=new,val\
|properties=suit,rank,faceUp"

FaceCard.new() {
  local -I class; class=FaceCard; Card.new "$@"
}

FaceCard.val() {
  local -I self class
  __bashClass.return "10" ${into:-}
}

__bashClass.registerMethod FaceCard new FaceCard.new
__bashClass.registerMethod FaceCard val FaceCard.val
__bashClass.registerClass FaceCard

# ═════════════════════════════════════════════════════════════════════
# Ace extends Card — worth 11 (Hand adjusts to 1 when bust)
# ═════════════════════════════════════════════════════════════════════

__bashClass_registry["Ace"]="|class=Ace|parent=Card\
|methods=new,val\
|properties=suit,rank,faceUp"

Ace.new() {
  local -I class; class=Ace; Card.new "$@"
}

Ace.val() {
  local -I self class
  __bashClass.return "11" ${into:-}
}

__bashClass.registerMethod Ace new Ace.new
__bashClass.registerMethod Ace val Ace.val
__bashClass.registerClass Ace

# ═════════════════════════════════════════════════════════════════════
# Deck extends List — 52 cards, shuffle, draw
# ═════════════════════════════════════════════════════════════════════

__bashClass_registry["Deck"]="|class=Deck|parent=List\
|methods=new,fill,shuffle,draw\
|properties=type"

Deck.new() {
  local -I class; class=Deck
  local __Deck_new_self
  into=__Deck_new_self List.new "$@"
  self="$__Deck_new_self" class=Deck Deck.fill
  self="$__Deck_new_self" class=Deck Deck.shuffle
  __bashClass.return "$__Deck_new_self" ${into:-}
}

Deck.fill() {
  local -I self class
  $self.clear
  local __Deck_fill_suits=("♠" "♥" "♦" "♣") __Deck_fill_s __Deck_fill_r __Deck_fill_c
  for __Deck_fill_s in "${__Deck_fill_suits[@]}"; do
    for __Deck_fill_r in 2 3 4 5 6 7 8 9 10; do
      into=__Deck_fill_c Card suit="$__Deck_fill_s" rank="$__Deck_fill_r"
      $self.push "$__Deck_fill_c"
    done
    for __Deck_fill_r in J Q K; do
      into=__Deck_fill_c FaceCard suit="$__Deck_fill_s" rank="$__Deck_fill_r"
      $self.push "$__Deck_fill_c"
    done
    into=__Deck_fill_c Ace suit="$__Deck_fill_s" rank=A
    $self.push "$__Deck_fill_c"
  done
}

Deck.shuffle() {
  local -I self class
  local -i __Deck_shuf_len __Deck_shuf_i __Deck_shuf_j
  local __Deck_shuf_a __Deck_shuf_b
  into=__Deck_shuf_len $self.length
  for (( __Deck_shuf_i = __Deck_shuf_len - 1; __Deck_shuf_i > 0; __Deck_shuf_i-- )); do
    __Deck_shuf_j=$(( RANDOM % (__Deck_shuf_i + 1) ))
    into=__Deck_shuf_a $self.get $__Deck_shuf_i
    into=__Deck_shuf_b $self.get $__Deck_shuf_j
    $self.set $__Deck_shuf_i "$__Deck_shuf_b"
    $self.set $__Deck_shuf_j "$__Deck_shuf_a"
  done
}

Deck.draw() {
  local -I self class
  local __Deck_draw_card; into=__Deck_draw_card $self.pop
  __bashClass.return "$__Deck_draw_card" ${into:-}
}

__bashClass.registerMethod Deck new     Deck.new
__bashClass.registerMethod Deck fill    Deck.fill
__bashClass.registerMethod Deck shuffle Deck.shuffle
__bashClass.registerMethod Deck draw    Deck.draw
__bashClass.registerClass Deck

# ═════════════════════════════════════════════════════════════════════
# Hand extends List — holds cards, computes score
#
# Hand methods read card properties directly via __bashClass.parse
# rather than dispatching methods on card objects. This avoids the
# baked-wrapper typecast ambiguity that occurs when a Hand method
# (with class=Hand in scope) calls a baked wrapper on a Card object.
# ═════════════════════════════════════════════════════════════════════

__bashClass_registry["Hand"]="|class=Hand|parent=List\
|methods=new,total,isBust,isBlackjack,show\
|properties=type,owner"

Hand.new() {
  local -I class; class=Hand
  local __Hand_new_self
  into=__Hand_new_self List.new "$@"
  __bashClass.return "$__Hand_new_self" ${into:-}
}

# Compute hand value. Reads rank directly from each card's descriptor.
# Aces count as 11, adjusted down to 1 while bust.
Hand.total() {
  local -I self class
  local -i __Hand_total_sum=0 __Hand_total_aces=0 __Hand_total_i __Hand_total_len
  local __Hand_total_card __Hand_total_rank
  into=__Hand_total_len self="$self" class=Hand __bashClass.dispatch length
  for (( __Hand_total_i=0; __Hand_total_i < __Hand_total_len; __Hand_total_i++ )); do
    into=__Hand_total_card self="$self" class=Hand __bashClass.dispatch get $__Hand_total_i
    __bashClass.parse "$__Hand_total_card" "rank" __Hand_total_rank
    case "$__Hand_total_rank" in
      A)         (( __Hand_total_sum += 11 )); (( __Hand_total_aces++ )) ;;
      [JQK]|10)  (( __Hand_total_sum += 10 )) ;;
      *)         (( __Hand_total_sum += __Hand_total_rank )) ;;
    esac
  done
  while (( __Hand_total_sum > 21 && __Hand_total_aces > 0 )); do
    (( __Hand_total_sum -= 10 )); (( __Hand_total_aces-- ))
  done
  __bashClass.return "$__Hand_total_sum" ${into:-}
}

Hand.isBust() {
  local -I self class
  local -i __Hand_isBust_total
  into=__Hand_isBust_total self="$self" class=Hand Hand.total
  (( __Hand_isBust_total > 21 )) && return 0 || return 1
}

Hand.isBlackjack() {
  local -I self class
  local -i __Hand_isBJ_len __Hand_isBJ_total
  into=__Hand_isBJ_len self="$self" class=Hand __bashClass.dispatch length
  (( __Hand_isBJ_len != 2 )) && return 1
  into=__Hand_isBJ_total self="$self" class=Hand Hand.total
  (( __Hand_isBJ_total == 21 )) && return 0 || return 1
}

# Display hand. Reads card properties directly from descriptors.
Hand.show() {
  local -I self class
  local __Hand_show_owner __Hand_show_out="" __Hand_show_rank __Hand_show_suit __Hand_show_fu
  local __Hand_show_card __Hand_show_str
  local -i __Hand_show_i __Hand_show_len __Hand_show_total __Hand_show_hidden=0
  __bashClass.parse "$self" "owner" __Hand_show_owner
  into=__Hand_show_len self="$self" class=Hand __bashClass.dispatch length
  for (( __Hand_show_i=0; __Hand_show_i < __Hand_show_len; __Hand_show_i++ )); do
    into=__Hand_show_card self="$self" class=Hand __bashClass.dispatch get $__Hand_show_i
    __bashClass.parse "$__Hand_show_card" "faceUp" __Hand_show_fu
    if [[ "$__Hand_show_fu" == "1" ]]; then
      __bashClass.parse "$__Hand_show_card" "rank" __Hand_show_rank
      __bashClass.parse "$__Hand_show_card" "suit" __Hand_show_suit
      __Hand_show_str="${__Hand_show_rank}${__Hand_show_suit}"
    else
      __Hand_show_str="[?]"
      __Hand_show_hidden=1
    fi
    (( __Hand_show_i > 0 )) && __Hand_show_out="$__Hand_show_out "
    __Hand_show_out="$__Hand_show_out$__Hand_show_str"
  done
  if (( __Hand_show_hidden )); then
    __Hand_show_out="$__Hand_show_owner: $__Hand_show_out"
  else
    into=__Hand_show_total self="$self" class=Hand Hand.total
    __Hand_show_out="$__Hand_show_owner: $__Hand_show_out  [$__Hand_show_total]"
  fi
  __bashClass.return "$__Hand_show_out" ${into:-}
}

__bashClass.registerMethod Hand new          Hand.new
__bashClass.registerMethod Hand total        Hand.total
__bashClass.registerMethod Hand isBust       Hand.isBust
__bashClass.registerMethod Hand isBlackjack  Hand.isBlackjack
__bashClass.registerMethod Hand show         Hand.show
__bashClass.registerClass Hand

# ═════════════════════════════════════════════════════════════════════
# Game helpers
# ═════════════════════════════════════════════════════════════════════

deal_up() {
  local _hand="$1" _deck="$2" _card
  into=_card $_deck.draw; $_card.flip; $_hand.push "$_card"
}

deal_down() {
  local _hand="$1" _deck="$2" _card
  into=_card $_deck.draw; $_hand.push "$_card"
}

show_table() {
  local _p="$1" _h="$2" _s
  into=_s $_h.show;  printf "  %s\n" "$_s"
  into=_s $_p.show;  printf "  %s\n\n" "$_s"
}

reveal() {
  local _hand="$1" _card _fu
  local -i _i _len
  into=_len $_hand.length
  for (( _i=0; _i < _len; _i++ )); do
    into=_card $_hand.get $_i
    __bashClass.parse "$_card" "faceUp" _fu
    [[ "$_fu" != "1" ]] && $_card.flip
  done
}

# ═════════════════════════════════════════════════════════════════════
# Main game loop
# ═════════════════════════════════════════════════════════════════════

printf '
  ╔══════════════════════════════════╗
  ║         ♠  BLACKJACK  ♠          ║
  ║     powered by bashClass/boop    ║
  ╚══════════════════════════════════╝
\n'

declare -i bankroll=100 round=0

while (( bankroll > 0 )); do
  printf "  Bankroll: \$%d\n" "$bankroll"
  printf "  Bet (or 'q' to quit): "
  read -r input

  [[ "$input" == "q" || "$input" == "Q" ]] && break

  if [[ ! "$input" =~ ^[0-9]+$ ]] || (( input < 1 )); then
    printf "  Invalid bet.\n\n"; continue
  fi
  declare -i bet=$input
  if (( bet > bankroll )); then
    printf "  You only have \$%d.\n\n" "$bankroll"; continue
  fi

  (( round++ ))
  printf "\n  ── Round %d ──\n\n" "$round"

  # Fresh deck each round
  into=deck Deck
  into=player Hand owner="You"
  into=house  Hand owner="Dealer"

  # Deal: player up, house down, player up, house up
  deal_up   "$player" "$deck"
  deal_down "$house"  "$deck"
  deal_up   "$player" "$deck"
  deal_up   "$house"  "$deck"

  show_table "$player" "$house"

  # ── Check naturals (peek at house cards without revealing) ──
  declare _hole_rank _up_rank
  declare -i _hole_val _up_val
  declare _hole_card _up_card
  into=_hole_card $house.get 0
  into=_up_card   $house.get 1
  __bashClass.parse "$_hole_card" "rank" _hole_rank
  __bashClass.parse "$_up_card"   "rank" _up_rank

  case "$_hole_rank" in
    A)        _hole_val=11 ;;
    [JQK]|10) _hole_val=10 ;;
    *)        _hole_val=$_hole_rank ;;
  esac
  case "$_up_rank" in
    A)        _up_val=11 ;;
    [JQK]|10) _up_val=10 ;;
    *)        _up_val=$_up_rank ;;
  esac

  declare -i player_bj=0 house_bj=0 house_peek=0
  $player.isBlackjack && player_bj=1
  (( house_peek = _hole_val + _up_val ))
  (( house_peek > 21 )) && (( house_peek -= 10 ))
  (( house_peek == 21 )) && house_bj=1

  if (( player_bj || house_bj )); then
    reveal "$house"
    show_table "$player" "$house"
    if (( player_bj && house_bj )); then
      printf "  Both have Blackjack — push.\n\n"
    elif (( player_bj )); then
      printf "  ♠ Blackjack! You win \$%d!\n\n" "$(( bet * 3 / 2 ))"
      (( bankroll += bet * 3 / 2 ))
    else
      printf "  Dealer has Blackjack. You lose \$%d.\n\n" "$bet"
      (( bankroll -= bet ))
    fi
    continue
  fi

  # ── Player turn ──
  declare -i busted=0
  while true; do
    printf "  [H]it or [S]tand? "
    read -r choice
    case "${choice,,}" in
      h|hit)
        deal_up "$player" "$deck"
        show_table "$player" "$house"
        if $player.isBust; then
          printf "  Bust! You lose \$%d.\n\n" "$bet"
          (( bankroll -= bet ))
          busted=1; break
        fi
        ;;
      s|stand) break ;;
      *) printf "  Type 'h' or 's'.\n" ;;
    esac
  done

  (( busted )) && continue

  # ── House turn ──
  reveal "$house"
  printf "  Dealer reveals hole card.\n"
  show_table "$player" "$house"

  declare -i htotal
  while true; do
    into=htotal $house.total
    (( htotal >= 17 )) && break
    printf "  Dealer hits.\n"
    deal_up "$house" "$deck"
    show_table "$player" "$house"
  done

  # ── Outcome ──
  declare -i ptotal; into=ptotal $player.total
  into=htotal $house.total

  if $house.isBust; then
    printf "  Dealer busts! You win \$%d!\n\n" "$bet"
    (( bankroll += bet ))
  elif (( ptotal > htotal )); then
    printf "  You win \$%d!\n\n" "$bet"
    (( bankroll += bet ))
  elif (( htotal > ptotal )); then
    printf "  Dealer wins. You lose \$%d.\n\n" "$bet"
    (( bankroll -= bet ))
  else
    printf "  Push — bet returned.\n\n"
  fi
done

if (( bankroll <= 0 )); then
  printf "  You're broke. Better luck next time.\n"
else
  printf "\n  You leave with \$%d.\n" "$bankroll"
fi
printf "  Thanks for playing!\n\n"
