#!/usr/bin/env bash
# bundled by collider — do not edit
# tool: probe

# ============================================================
# boop core
# ============================================================

## boop - Modern OOP dispatch system for bash
##
## Provides secure, efficient method dispatch with multiple return modes
## and proper inheritance support.
##
## Usage:
##   . boop                    # load framework only
##   . boop Box Cube           # load framework + import classes

# ============================================================================
# SOURCED MODE — Framework definitions (once only)
# ============================================================================
if (( ! ${__boop_loaded:-0} )); then

# ============================================================================
# GLOBALS - Process State
# ============================================================================

# Captured at load time so boop.pass can detect subshells later.
# If BASHPID != this value at call time, we're in a subshell and auto mode
# switches to stdout (since globals can't escape a subshell boundary).
declare -gi __boop_rootPID=$BASHPID

# Directory where the boop framework file lives. Resolved once at load time
# via realpath so symlinks don't fool it; the trailing segment is stripped
# with parameter expansion to avoid a second subshell. Used as a fallback
# root in the resolution chain -- checked last, after . + BOOPPATH + PATH.
declare -g __boop_root
__boop_root="$(realpath "${BASH_SOURCE[0]}")"
__boop_root="${__boop_root%/*}"

# ============================================================================
# GLOBALS - Registries
# ============================================================================

# Master object/class store. Keys are object IDs (_a1b2c3) or class names (Box).
# Values are pipe-delimited descriptors: |class=Box|parent=boop|length=%33|...
# Classes and objects share this registry — distinguished by context, not type field.
declare -gA __boop_registry

# Method resolution cache. Keys are "ClassName.methodName", values are the
# implementing function name (e.g., "Box.volume" → "Box.volume" the function).
# Populated on first dispatch; inherited methods get cached under the calling
# class so the MRO walk only happens once per class+method pair.
declare -gA __boop_methodRegistry

# Mixin registry. Keys are mixin names; values are pipe-delimited descriptors
# with the mixin's method list. Separate from __boop_registry (which holds
# class and object descriptors) so mixin vs class lookups are unambiguous.
declare -gA __boop_mixin_registry

# Explicit path overrides for class file resolution. If a class is registered
# here, __boop.import skips directory and PATH searches entirely.
# Usage: __boop_classPath["MyClass"]="/opt/lib/MyClass"
declare -gA __boop_classPath

# In-progress load tracker. Set to 1 while a class file is being sourced,
# cleared when done. Prevents circular recursion when a class file sources
# boop as part of its own dependency chain (e.g., Cube sources boop Box,
# Box sources boop — without this flag, boop would try to re-import Box
# mid-load and recurse until bash gives up).
declare -gA __boop_loading

# Function-level static storage. A flat associative array for any function
# to stash values between calls — memoization, cached intermediates,
# convergence state, lookup tables, whatever. Keyed by compound strings
# so each function owns its own namespace without polluting globals.
#
# Convention: keys are "FunctionName.varName" or "ClassName.method.varName".
# Functions read/write directly — no helper needed.
#
# Usage:
#   __boop_static["Math.arctan.cache_1_5"]="0.19739555984988..."
#   local cached="${__boop_static[Math.arctan.cache_1_5]:-}"
#   __boop_static["factorial.12"]="479001600"
#
# This lives in boop (not in a class file) because it's a framework-level
# facility. Any function in any class can use it. The data persists for
# the lifetime of the shell process.
declare -gA __boop_static

# Short-name → namespace-path index. Populated by sourcing .boopIndex files
# from each library root during initialization. Maps bare class names to their
# full namespace paths (e.g., ["List"]="Collection/List"). Earlier roots in the
# effective BOOPPATH take precedence for duplicate short names.
declare -gA __boop_Index

# Alias registry. Maps user-facing names to fully qualified class names (FQNs).
# Aliases are created automatically on class load (if unambiguous) or explicitly
# via _Import. Keys are stored literally as specified by the user.
# Values are always FQNs (dot-separated).
declare -gA __boop_alias

# Framework version string. Used for mismatch detection when RC files indicate
# a preferred version. Read-only after initialization.
declare -gr __boop_version="1.0.0"

# ============================================================================
# GLOBALS - Configuration
# ============================================================================

# Controls auto-aliasing behavior on class load.
# full:  alias at all namespace levels (short + intermediate + FQN). Default.
# best:  alias only the shortest unique (unambiguous) level + FQN.
# short: alias only the short name + FQN.
# none:  no auto-aliasing; only explicit _Import creates aliases.
declare -g _AutoAlias="${_AutoAlias:-full}"

# Controls how boop.pass delivers values when no explicit nameref
# target is provided. Modes: auto (stdout, always), global (writes to $_Out),
# reply (writes to $REPLY), stdout, nameref (crashes without target), filesystem.
# Can be overridden per-call via environment: _OutMode=stdout $obj.volume
declare -g _OutMode="${_OutMode:-auto}"

# Line ending appended to stdout output in boop.pass. When _OutMode is
# "stdout" (or "auto" in a subshell), this value is printed after the
# payload. Default is newline — set to empty string for raw output.
#
# Unquoted in the printf call so an empty value vanishes entirely
# (no trailing whitespace, no extra argument).
#
# Usage:
#   _EOL=$'\n'     # default -- newline after each value (CLI-friendly)
#   _EOL=""        # raw -- no trailing newline (pipe-friendly)
#   _EOL=$'\r\n'   # Windows-style line endings
#
# Also used as the record separator for multi-value returns: arrays
# join elements on _EOL, maps join records (key+value pairs) on _EOL.
declare -g _EOL="${_EOL:-$'\n'}"

# _Delimiter -- field separator within a record.
#
# Separates key from value inside a single record (e.g. in Map.toArray,
# Config.toFlat). Each method picks its own sensible default when
# _Delimiter is unset -- Map uses '=', a CSV parser would use ',', a
# URL parser would use '&' or '='. The caller overrides per-call to
# change the field separator without touching _EOL.
#
# Relationship to _EOL:
#   _EOL       = record boundary (between entries)
#   _Delimiter = field boundary (within an entry, e.g. key from value)
#
# Usage:
#   _Delimiter=':'  into=out $map.toArray   # host:localhost\nport:8080
#   _Delimiter='|'  into=out $cfg.toFlat    # theme|dark\nhost|localhost
#
# Default: empty (unset). Methods fall back to their context-appropriate
# default. This is intentional -- "not configured" is a valid state that
# means "use whatever makes sense for this operation."
declare -g _Delimiter="${_Delimiter:-}"

# ============================================================================
# GLOBALS - Log Levels
# ============================================================================

# Numeric log levels. Higher = more verbose.
# Level 0 is reserved as a crash trigger — if __boop.log receives
# level 0 (e.g., from a missing/empty argument coerced by -i), it
# prints the message and exits. This catches accidental direct calls
# to __boop.log without a level argument.
#
# silent=-1: suppress everything (even errors — use with care)
# crash=0:   reserved — triggers immediate crash (see above)
# error=1:   fatal or near-fatal conditions
# warn=2:    unexpected but recoverable situations (default)
# info=3:    notable lifecycle events (object creation, class loading)
# debug=4:   detailed internal state for troubleshooting
# trace=5:   finest grain — descriptor dumps, dispatch steps, etc.
declare -gri __boop_LOG_SILENT=-1
declare -gri __boop_LOG_CRASH=0
declare -gri __boop_LOG_ERROR=1
declare -gri __boop_LOG_WARN=2
declare -gri __boop_LOG_INFO=3
declare -gri __boop_LOG_DEBUG=4
declare -gri __boop_LOG_TRACE=5

# Global default log level. Controls what gets emitted when no per-class
# override exists. Default is warn — errors and warnings show, info and
# below are silent.
declare -gi __boop_logLevel=$__boop_LOG_WARN

# Per-class log level overrides. Keyed by class name, values are numeric
# levels. When a class has an entry here, it (and its descendants, unless
# they have their own override) use this level instead of the global.
declare -gA __boop_classLogLevel

# Resolved log level cache. Keyed by class name, values are the numeric
# level that was resolved by walking the inheritance chain. Populated on
# first log call for a given class, cleared when setLogLevel changes
# anything in the chain.
declare -gA __boop_resolvedLogLevel

# Human-readable level names for output formatting.
declare -gA __boop_logLevelName=(
  [$__boop_LOG_SILENT]="SILENT" [$__boop_LOG_CRASH]="CRASH"  [$__boop_LOG_ERROR]="ERROR"
  [$__boop_LOG_WARN]="WARN"     [$__boop_LOG_INFO]="INFO"    [$__boop_LOG_DEBUG]="DEBUG"
  [$__boop_LOG_TRACE]="TRACE"
)

# Fallback log file. If stderr is unavailable (redirected to /dev/null,
# closed, etc.), log output goes here instead. Per-process PID suffix
# prevents concurrent sessions from stomping each other.
declare -g __boop_logFile="${TMPDIR:-/tmp}/boop_$$.log"

# Global default fatality level. Controls which log levels auto-crash after
# printing. Default is crash(0): only explicit _Crash calls are fatal; _Error
# and _Warn are never auto-fatal. Set higher to escalate: _FatalLevel error
# crashes on _Error; _FatalLevel warn crashes on _Warn or _Error; etc.
declare -gi __boop_fatalLevel=$__boop_LOG_CRASH

# Per-class fatality level overrides. Mirrors __boop_classLogLevel.
declare -gA __boop_classFatalLevel

# Resolved fatality level cache. Mirrors __boop_resolvedLogLevel.
declare -gA __boop_resolvedFatalLevel

# ============================================================================
# GLOBALS - Return Values
# ============================================================================

# Side-channel for global return mode. When boop.pass is called
# without a nameref target and mode is "global", the value lands here.
# Intentionally a single flat global — keeps the API simple. If you need
# to capture a value without clobbering this, use into=varname instead.
declare -g  _Out="" # no dedicated method for this; no need

# ============================================================================
# GLOBALS - Initialization Flags
# ============================================================================

# Set to 1 at the bottom of this block. The outer guard (( ! __boop_loaded ))
# checks this so re-sourcing boop (e.g., from a class file's `. boop`) skips
# all definitions and jumps straight to the import-arguments section at the end.
declare -gi __boop_loaded=0

# Global object counter for unique ID generation. Incremented by __boop.new.
declare -gi __boop_id=0

# EXIT guard: if the script crashes mid-load (e.g. inside a sourced tmpfile),
# remove any in-progress class-loading tmpfiles for this PID so they don't
# accumulate in /tmp. On normal exit these files are already gone; the trap
# is a no-op in that case.
trap 'rm -f "${TMPDIR:-/tmp}/__boop_bf_$$" "${TMPDIR:-/tmp}/__boop_rc_$$" "${TMPDIR:-/tmp}/__boop_alias_$$"' EXIT

# ============================================================================
# UTILITY
# ============================================================================

# Unified crash handler. Prints a tagged message to stderr with optional
# stack trace, then exits. All output goes to stderr via `} >&2` on the
# function body — no per-line redirection needed.
#
# Caller controls all whitespace in the message, including newlines.
# `printf '%s'` with `$@` means each argument is concatenated literally —
# add $'\n' between arguments if you want line breaks.
#
# Inherited variables (Tier 2, set as env-var prefixes by callers):
#   _Err        — exit code (default: 1)
#   _StackTrace — number of stack frames to show (default: 1)
#                  0 = no trace, negative = show all frames
#
# Usage:
#   _Crash "something broke"
#   _Err=42 _Crash "custom exit code"
#   _StackTrace=-1 _Crash "full trace"
#   _Crash "line one" $'\n' "line two" $'\n'
_Crash() {
  local _Err="${_Err:-1}" _StackTrace="${_StackTrace:-1}"
  printf '%s' '[CRASH] ' "$@" $'\n'
  (( _StackTrace = ${_StackTrace:- 1} ))
  (( _StackTrace < 0 )) && _StackTrace=${#FUNCNAME[@]}
  if (( _StackTrace > 0 )); then
    local -i __Crash_i
    for (( __Crash_i=1; __Crash_i <= _StackTrace && __Crash_i < ${#FUNCNAME[@]}; __Crash_i++ )); do
      printf "  in %s (%s:%s)\n" "${FUNCNAME[$__Crash_i]}" "${BASH_SOURCE[$__Crash_i]}" "${BASH_LINENO[$__Crash_i-1]}"
    done
  fi
  exit ${_Err:-1}
} >&2

# Returns 0 if the current execution context is a subshell (BASHPID differs
# from the root PID captured at framework load time). Used by auto return mode.
__boop.inSubshell() { [[ $BASHPID != $__boop_rootPID ]]; }

# ============================================================================
# LOGGING
# ============================================================================

# Core log function. Checks the resolved level for the current class
# (via inherited _Class) and emits to stderr if the message level is
# at or below the threshold. Bails immediately on cache hit when the
# level is too verbose — the hot path is one hash lookup + one compare.
#
# On cache miss, walks the inheritance chain looking for the first class
# with an explicit override in __boop_classLogLevel, falling back to the
# global default. Result is cached in __boop_resolvedLogLevel so the walk
# happens at most once per class (until invalidated by setLogLevel).
#
# Usage (internal): __boop.log 2 "something unexpected"
# Users should use the public wrappers: _Warn, _Debug, etc.
__boop.log() {
  local -i __boop_log_level=${1:-0}; shift    # numeric level; empty/missing → 0 → crash
  (( __boop_log_level ==  0 )) && _Crash "$@" # level 0 = Crash; die loud, right now
  (( __boop_log_level == -1 )) && return 0    # explicit silent; nothing to do
  [[ -n "${__boop_logLevelName[$__boop_log_level]+set}" ]] || _Crash "invalid log level: '$__boop_log_level'"
  local _Class="${_Class:-}"                # pick up caller's class context if set

  local __boop_log_class="${_Class:-boop}"   # fall back to "boop" if no class in scope
  local __boop_log_threshold

  # Hot path: one hash lookup against the resolved cache.
  if [[ -n "${__boop_resolvedLogLevel[$__boop_log_class]+set}" ]]; then
    __boop_log_threshold=${__boop_resolvedLogLevel[$__boop_log_class]}
  else
    # Cold path: walk the inheritance chain for the first class with an
    # explicit level override. Cache the result when done.
    local __boop_log_cursor="$__boop_log_class"
    __boop_log_threshold=""
    while [[ -n "$__boop_log_cursor" ]]; do
      if [[ -n "${__boop_classLogLevel[$__boop_log_cursor]+set}" ]]; then
        __boop_log_threshold=${__boop_classLogLevel[$__boop_log_cursor]}
        break
      fi
      # Move to parent via descriptor
      local __boop_log_parent=""
      if [[ -n "${__boop_registry[$__boop_log_cursor]+set}" ]]; then
        [[ "${__boop_registry[$__boop_log_cursor]}" =~ \|parent=([^|]*)\| ]] &&
          __boop_log_parent="${BASH_REMATCH[1]}"
      fi
      __boop_log_cursor="$__boop_log_parent"
    done
    # Fall back to global default
    [[ -z "$__boop_log_threshold" ]] && __boop_log_threshold=$__boop_logLevel
    # Cache it
    __boop_resolvedLogLevel[$__boop_log_class]=$__boop_log_threshold
  fi

  # Message level exceeds threshold — nothing to print.
  (( __boop_log_level > __boop_log_threshold )) && return 0

  # Identify the real caller. FUNCNAME[0] is __boop.log, [1] is the
  # wrapper (_Warn, _Debug, etc.), [2] is who actually called the wrapper.
  # If [2] is one of our public wrappers, step one more frame to [3].
  local __boop_log_caller="${FUNCNAME[2]:-main}"
  [[ "$__boop_log_caller" =~ ^_(Error|Warn|Info|Debug|Trace)$ ]] &&
    __boop_log_caller="${FUNCNAME[3]:-main}"

  # Format: timestamp [LEVEL] caller: message
  local __boop_log_label="${__boop_logLevelName[$__boop_log_level]:-LOG}"
  printf '%(%Y-%m-%d %H:%M:%S)T %7s %s: ' -1 "[$__boop_log_label]" "$__boop_log_caller"
  printf '%s' "$@" "${_EOL}"

  # Fatality check. Same hot/cold resolution as the log threshold above,
  # but against __boop_classFatalLevel / __boop_fatalLevel. If the message
  # level is at or below the fatal threshold, crash after printing.
  local __boop_log_fatalThreshold
  if [[ -n "${__boop_resolvedFatalLevel[$__boop_log_class]+set}" ]]; then
    __boop_log_fatalThreshold=${__boop_resolvedFatalLevel[$__boop_log_class]}
  else
    local __boop_log_fat_cursor="$__boop_log_class" __boop_log_fat_found=""
    while [[ -n "$__boop_log_fat_cursor" ]]; do
      if [[ -n "${__boop_classFatalLevel[$__boop_log_fat_cursor]+set}" ]]; then
        __boop_log_fat_found=${__boop_classFatalLevel[$__boop_log_fat_cursor]}
        break
      fi
      local __boop_log_fat_parent=""
      [[ -n "${__boop_registry[$__boop_log_fat_cursor]+set}" ]] &&
        [[ "${__boop_registry[$__boop_log_fat_cursor]}" =~ \|parent=([^|]*)\| ]] &&
        __boop_log_fat_parent="${BASH_REMATCH[1]}"
      __boop_log_fat_cursor="$__boop_log_fat_parent"
    done
    [[ -z "$__boop_log_fat_found" ]] && __boop_log_fat_found=$__boop_fatalLevel
    __boop_resolvedFatalLevel[$__boop_log_class]=$__boop_log_fat_found
    __boop_log_fatalThreshold=$__boop_log_fat_found
  fi
  (( __boop_log_level > __boop_log_fatalThreshold )) ||
    _Crash "$__boop_log_label elevated to fatal (from $__boop_log_caller)"
} >&2

# Set log level. With one argument, sets the global default.
# With two arguments, sets a per-class override and invalidates
# the resolved cache for that class and all its descendants.
#
# Usage: __boop.setLogLevel warn          # global
#        __boop.setLogLevel debug Math     # per-class
__boop.setLogLevel() {
  local __boop_setLogLevel_name="$1" __boop_setLogLevel_class="${2:-}"
  local -i __boop_setLogLevel_num

  # Resolve name to number
  case "${__boop_setLogLevel_name,,}" in
    silent|-1) __boop_setLogLevel_num=$__boop_LOG_SILENT ;; error|1)  __boop_setLogLevel_num=$__boop_LOG_ERROR ;;
    warn|2)    __boop_setLogLevel_num=$__boop_LOG_WARN   ;; info|3)   __boop_setLogLevel_num=$__boop_LOG_INFO  ;;
    debug|4)   __boop_setLogLevel_num=$__boop_LOG_DEBUG  ;; trace|5)  __boop_setLogLevel_num=$__boop_LOG_TRACE ;;
    *) _Crash "Invalid log level: $__boop_setLogLevel_name (use: silent, error, warn, info, debug, trace)" ;;
  esac

  if [[ -z "$__boop_setLogLevel_class" ]]; then
    # Global default — clear entire resolved cache
    __boop_logLevel=$__boop_setLogLevel_num
    __boop_resolvedLogLevel=()
  else
    # Per-class override — set it and invalidate cache for this class
    # and any class whose resolved level might have been inherited from it
    __boop_classLogLevel[$__boop_setLogLevel_class]=$__boop_setLogLevel_num
    # Simple invalidation: clear the whole resolved cache. The walks
    # are cheap and only happen once after a level change.
    __boop_resolvedLogLevel=()
  fi
  __boop.__applyLogBypass
}

# Set fatality level. With one argument, sets the global default.
# With two arguments, sets a per-class override.
# "crash" (the default) means only explicit _Crash calls are fatal;
# "error" means _Error auto-crashes; "warn" means _Warn and _Error auto-crash.
#
# Usage: __boop.setFatalLevel crash          # global (reset to default)
#        __boop.setFatalLevel error           # global
#        __boop.setFatalLevel warn Math       # per-class
__boop.setFatalLevel() {
  local __boop_setFatalLevel_name="$1" __boop_setFatalLevel_class="${2:-}"
  local -i __boop_setFatalLevel_num

  case "${__boop_setFatalLevel_name,,}" in
    crash|0) __boop_setFatalLevel_num=$__boop_LOG_CRASH ;;
    error|1) __boop_setFatalLevel_num=$__boop_LOG_ERROR ;;
    warn|2)  __boop_setFatalLevel_num=$__boop_LOG_WARN  ;;
    info|3)  __boop_setFatalLevel_num=$__boop_LOG_INFO  ;;
    debug|4) __boop_setFatalLevel_num=$__boop_LOG_DEBUG ;;
    trace|5) __boop_setFatalLevel_num=$__boop_LOG_TRACE ;;
    *) _Crash "Invalid fatal level: $__boop_setFatalLevel_name (use: crash, error, warn, info, debug, trace)" ;;
  esac

  if [[ -z "$__boop_setFatalLevel_class" ]]; then
    __boop_fatalLevel=$__boop_setFatalLevel_num
    __boop_resolvedFatalLevel=()
  else
    __boop_classFatalLevel[$__boop_setFatalLevel_class]=$__boop_setFatalLevel_num
    __boop_resolvedFatalLevel=()
  fi
}

# ---------------------------------------------------------------------------
# Public convenience wrappers — the user-facing API
# ---------------------------------------------------------------------------
#
# _Trace/_Debug/_Info/_Warn/_Error are set by __boop.__applyLogBypass (below)
# rather than defined statically. The bypass replaces silenced tiers with ':'
# (bash no-op builtin) to eliminate function-call overhead for log levels that
# will never produce output. Real implementations are restored when the level
# rises. Initial state is established by calling __boop.__applyLogBypass once
# after the function is defined.

# Replace each log-tier function with ':' (no-op) if it is fully silenced by
# the effective log level, or restore the real implementation if it is active.
#
# Effective level = max(global __boop_logLevel, all per-class overrides).
# Using the max ensures per-class overrides that RAISE verbosity above the
# global keep their tier's function alive. Per-class overrides that LOWER
# verbosity are still handled inside __boop.log's per-class threshold check.
#
# Trade-off: if any class has a high-verbosity override the corresponding
# global function stays real for everyone. That is the correct behaviour --
# silencing it globally would suppress that class's legitimate output.
__boop.__applyLogBypass() {
  local -i __boop_applyLogBypass_max=$__boop_logLevel
  local    __boop_applyLogBypass_cls
  for __boop_applyLogBypass_cls in "${!__boop_classLogLevel[@]}"; do
    (( __boop_classLogLevel[$__boop_applyLogBypass_cls] > __boop_applyLogBypass_max )) &&
      __boop_applyLogBypass_max=${__boop_classLogLevel[$__boop_applyLogBypass_cls]}
  done

  if (( __boop_applyLogBypass_max < __boop_LOG_ERROR )); then
    _Error() { :; }
  else
    _Error() { __boop.log $__boop_LOG_ERROR "$@"; }
  fi
  if (( __boop_applyLogBypass_max < __boop_LOG_WARN )); then
    _Warn() { :; }
  else
    _Warn() { __boop.log $__boop_LOG_WARN "$@"; }
  fi
  if (( __boop_applyLogBypass_max < __boop_LOG_INFO )); then
    _Info() { :; }
  else
    _Info() { __boop.log $__boop_LOG_INFO "$@"; }
  fi
  if (( __boop_applyLogBypass_max < __boop_LOG_DEBUG )); then
    _Debug() { :; }
  else
    _Debug() { __boop.log $__boop_LOG_DEBUG "$@"; }
  fi
  if (( __boop_applyLogBypass_max < __boop_LOG_TRACE )); then
    _Trace() { :; }
  else
    _Trace() { __boop.log $__boop_LOG_TRACE "$@"; }
  fi
}

# Establish initial state from the default log level (warn=2).
# At warn: _Error and _Warn are active; _Info, _Debug, _Trace are no-ops.
__boop.__applyLogBypass

# _LogLevel: convenience wrapper for __boop.setLogLevel
_LogLevel() { __boop.setLogLevel "$@"; }

# _FatalLevel: convenience wrapper for __boop.setFatalLevel
_FatalLevel() { __boop.setFatalLevel "$@"; }

# ---------------------------------------------------------------------------
# Identity and Static Storage — Tier 2 helpers
# ---------------------------------------------------------------------------

# _Me — returns the current identity: object ID if in an object context,
# class name otherwise, defaulting to "boop" if neither is set.
_Me() { boop.pass "${_Self:-${_Class:-boop}}" ${into:-}; }

# _Static — per-method persistent storage in __boop_static.
#
# Key is automatically prefixed with identity + calling function name,
# so two methods on the same object can each have their own "x" without
# collision.
#
# Usage:
#   _Static x=1              # set: key = "_abc123.Math.arctan.x"
#   into=val _Static x       # get: returns value or empty
#   _Static count=0          # initialize a counter
#   _Static "count=$(( $(_Static count) + 1 ))"  # increment (subshell for read)
_Static() {
  local __Static_me="${_Self:-${_Class:-boop}}"
  local __Static_key="${__Static_me}.${FUNCNAME[1]}.${1%%=*}"
  if [[ "$1" == *=* ]]; then
    __boop_static["$__Static_key"]="${1#*=}"
  else
    boop.pass "${__boop_static[$__Static_key]:-}" ${into:-}
  fi
}

# _Property — per-object/class persistent storage in __boop_static.
#
# Same as _Static but WITHOUT the function name in the key. Shared
# across all methods on the same object/class. Use for object-level
# state that isn't in the descriptor (lightweight alternative to
# $obj.set / $obj.get).
#
# Usage:
#   _Property initialized=1   # set: key = "_abc123.initialized"
#   into=val _Property initialized  # get
_Property() {
  local __Property_me="${_Self:-${_Class:-boop}}"
  local __Property_key="${__Property_me}.${1%%=*}"
  if [[ "$1" == *=* ]]; then
    __boop_static["$__Property_key"]="${1#*=}"
  else
    boop.pass "${__boop_static[$__Property_key]:-}" ${into:-}
  fi
}

# ============================================================================
# ALIAS RESOLUTION
# ============================================================================

# __boop.autoAlias -- create auto-aliases for a class at multiple levels.
#
# For FQN "Collection.Map.Fast", attempts aliases:
#   Fast, Map.Fast, Collection.Map.Fast
# Each level checks for collisions independently.
#
# Respects _AutoAlias setting (full/best/short/none).
__boop.autoAlias() {
  local __boop_aa_fqn="$1"
  [[ "$_AutoAlias" == "none" ]] && return

  # Split FQN on dots to get segments
  local __boop_aa_IFS_save="$IFS"
  local -a __boop_aa_parts
  IFS='.'; read -ra __boop_aa_parts <<< "$__boop_aa_fqn"; IFS="$__boop_aa_IFS_save"

  local -i __boop_aa_len=${#__boop_aa_parts[@]}
  (( __boop_aa_len == 0 )) && return

  # Build alias candidates from shortest to longest
  # For A.B.C: candidates are C, B.C, A.B.C
  local -a __boop_aa_candidates=()
  local -i __boop_aa_i
  local __boop_aa_candidate
  for (( __boop_aa_i = __boop_aa_len - 1; __boop_aa_i >= 0; __boop_aa_i-- )); do
    __boop_aa_candidate=""
    local -i __boop_aa_j
    for (( __boop_aa_j = __boop_aa_i; __boop_aa_j < __boop_aa_len; __boop_aa_j++ )); do
      [[ -n "$__boop_aa_candidate" ]] && __boop_aa_candidate+="."
      __boop_aa_candidate+="${__boop_aa_parts[$__boop_aa_j]}"
    done
    __boop_aa_candidates+=("$__boop_aa_candidate")
  done

  # Apply based on _AutoAlias mode
  local __boop_aa_best_set=0
  for __boop_aa_candidate in "${__boop_aa_candidates[@]}"; do
    # FQN itself -- skip, already registered
    [[ "$__boop_aa_candidate" == "$__boop_aa_fqn" ]] && continue

    local __boop_aa_should_create=0
    case "$_AutoAlias" in
      short)
        [[ "$__boop_aa_candidate" == "${__boop_aa_candidates[0]}" ]] && __boop_aa_should_create=1
        ;;
      best)
        (( ! __boop_aa_best_set )) && __boop_aa_should_create=1
        ;;
      full|*)
        __boop_aa_should_create=1
        ;;
    esac

    (( __boop_aa_should_create )) || continue

    # Check for collision
    if [[ -n "${__boop_registry[$__boop_aa_candidate]+set}" ]]; then
      local __boop_aa_existing_true
      __boop.parse "$__boop_aa_candidate" "trueClass" __boop_aa_existing_true
      if [[ "$__boop_aa_existing_true" != "$__boop_aa_fqn" ]]; then
        _Info "Alias '$__boop_aa_candidate' is ambiguous ($__boop_aa_existing_true vs $__boop_aa_fqn)"
        continue
      fi
      # Already aliased to same FQN, skip
      continue
    fi

    # Create the alias as a real registry entry
    __boop.createAlias "$__boop_aa_candidate" "$__boop_aa_fqn"
    __boop_alias["$__boop_aa_candidate"]="$__boop_aa_fqn"

    if [[ "$_AutoAlias" == "best" ]]; then
      __boop_aa_best_set=1
    fi
  done
}

# __boop.createAlias -- create a real registry entry for an alias.
#
# Clones the FQN's descriptor with class=alias and trueClass=FQN.
# Clones all method registry entries as alias.method -> FQN.method.
# Writes wrapper functions to a temp file and sources it (faster than
# eval, no quoting gymnastics).
# Creates constructor shorthand alias() that forwards to FQN.new().
__boop.createAlias() {
  local __boop_ca_alias="$1" __boop_ca_fqn="$2"

  # Clone descriptor: replace class= but keep trueClass= pointing to FQN
  local __boop_ca_desc="${__boop_registry[$__boop_ca_fqn]:-}"
  [[ -n "$__boop_ca_desc" ]] || return
  __boop_ca_desc="${__boop_ca_desc/"|class=$__boop_ca_fqn"/"|class=$__boop_ca_alias"}"
  __boop_registry["$__boop_ca_alias"]="$__boop_ca_desc"

  # Walk the inheritance chain and clone method entries + create wrappers.
  # Uses the methods= field from each class descriptor (O(1) per method).
  # All wrapper functions are written to a temp file and sourced once.
  local __boop_ca_tmpfile="${TMPDIR:-/tmp}/__boop_alias_$$"
  local __boop_ca_current="$__boop_ca_fqn"
  local __boop_ca_methods __boop_ca_method __boop_ca_impl

  : > "$__boop_ca_tmpfile"
  while [[ -n "$__boop_ca_current" ]]; do
    __boop.parse "$__boop_ca_current" "methods" __boop_ca_methods
    IFS=',' read -ra __boop_ca_methodList <<< "${__boop_ca_methods:-}"
    for __boop_ca_method in "${__boop_ca_methodList[@]}"; do
      [[ -n "$__boop_ca_method" ]] || continue
      [[ -n "${__boop_methodRegistry[$__boop_ca_alias.$__boop_ca_method]+set}" ]] && continue
      __boop_ca_impl="${__boop_methodRegistry[$__boop_ca_current.$__boop_ca_method]:-}"
      [[ -n "$__boop_ca_impl" ]] || continue
      __boop_methodRegistry["$__boop_ca_alias.$__boop_ca_method"]="$__boop_ca_impl"
      printf '%s.%s() { _Self="${_Self:-}" _Class=%q %s "$@"; }\n' \
        "$__boop_ca_alias" "$__boop_ca_method" "$__boop_ca_alias" "$__boop_ca_impl" \
        >> "$__boop_ca_tmpfile"
    done
    __boop.parse "$__boop_ca_current" "parent" __boop_ca_current
  done

  # Constructor shorthand
  if declare -F "${__boop_ca_fqn}.new" >/dev/null; then
    printf '%s() { _Class=%q %s.new "$@"; }\n' \
      "$__boop_ca_alias" "$__boop_ca_alias" "$__boop_ca_fqn" \
      >> "$__boop_ca_tmpfile"
  else
    printf '%s() { _Class=%q __boop.new "$@"; }\n' \
      "$__boop_ca_alias" "$__boop_ca_alias" \
      >> "$__boop_ca_tmpfile"
  fi

  . "$__boop_ca_tmpfile"
  rm -f "$__boop_ca_tmpfile"
}

# _Import -- load a class and create an alias.
#
# Usage:
#   _Import Collection::Map::Fast           # load + auto-alias
#   _Import Collection::Map::Fast as MapFast  # load + explicit alias
#   _Import Collection::Map::Fast as Map::Fast  # literal alias key
_Import() {
  local __boop_import_class="$1"
  shift || true

  # Normalize the target to FQN (dots)
  local __boop_import_fqn="${__boop_import_class//::/.}"
  __boop_import_fqn="${__boop_import_fqn//\//.}"

  # Load the class
  _Require "$__boop_import_class"

  # Check for "as" clause
  if [[ "${1:-}" == "as" && -n "${2:-}" ]]; then
    local __boop_import_alias="$2"
    # Explicit alias -- create real registry entry, overrides any existing
    __boop.createAlias "$__boop_import_alias" "$__boop_import_fqn"
    __boop_alias["$__boop_import_alias"]="$__boop_import_fqn"
    _Debug "import: aliased '$__boop_import_alias' -> '$__boop_import_fqn'"
  fi
  # Auto-aliasing happens during class load (in __boop.import)
}

# ============================================================================
# UNIVERSAL RETURN HANDLER
# ============================================================================

# Every function that produces a value calls this as its last act.
# This is the single choke point for all value delivery in the framework.
# Respects _OutMode globally; auto mode uses context clues.
#
# When a nameref target ($2) is provided, it ALWAYS wins — the value is
# written directly into the caller's named variable via bash nameref,
# regardless of the global mode setting. This is the zero-copy fast path
# used by into=varname delegation chains.
#
# When no target is provided, the global mode governs:
#   auto       → stdout (default; same as stdout mode)
#   global     → writes to _Out
#   reply      → writes to REPLY (bash convention; aligns with read/select/${| })
#   stdout     → printf to stdout (natural for $() capture)
#   nameref    → crashes (target is required -- this is intentional)
#   filesystem → writes to a temp file keyed by caller function name + PID
#
# Subshell footgun: if into=varname is used inside a $() subshell, the
# nameref write succeeds within the subshell scope but the value is lost
# when the subshell exits. A _Debug message is emitted when this is
# detected (BASHPID != __boop_rootPID). Note: this cannot distinguish a
# legitimate "use the value inside this same subshell" pattern from a
# genuine mistake -- the debug message is advisory, not an error.
#
# Usage:
#   boop.pass "$value"              # uses current mode (auto = stdout)
#   boop.pass "$value" target_var   # nameref -- always direct write
boop.pass() {
  local __boop_pass_val="${1:-}" __boop_pass_target="${2:-}"
  local __boop_pass_mode="${_OutMode:-auto}"

  # If a nameref target is explicitly provided, always use it.
  if [[ -n "${__boop_pass_target:-}" ]]; then
    [[ $BASHPID != $__boop_rootPID ]] &&
      _Debug "boop.pass: into=$__boop_pass_target used in subshell -- value will not reach parent scope"
    local -n __boop_pass_ref="$__boop_pass_target"
    __boop_pass_ref="${__boop_pass_val:-}"
    return
  fi
  if [[ "$__boop_pass_mode" == "auto" ]]; then
    __boop_pass_mode="stdout"
  fi
  case "$__boop_pass_mode" in
    nameref)    _Crash "nameref mode requires target variable" ;; # wouldn't be here if it had one!
    stdout)     printf "%s" "${__boop_pass_val:-}" "${_EOL:-}" ;; # with line ending if set
    global)     _Out="$__boop_pass_val"                        ;;
    reply)      REPLY="$__boop_pass_val"                       ;;
    filesystem)
      # TODO: boop.passPath from call stack introspection
      printf "%s" "$__boop_pass_val" >| "${__boop_tmpdir:-/tmp}/__boop_${FUNCNAME[1]}_$BASHPID"
      ;;
    *) _Crash "Invalid return mode: $__boop_pass_mode" ;;
  esac
}

# _OutMode — get or set the output delivery mode for boop.pass.
#
# Controls how boop.pass delivers values when no explicit into= target
# is provided. Works as both a variable and a function — you can't
# really get it wrong:
#
#   _OutMode            # print current mode
#   _OutMode stdout     # set mode and print it
#   _OutMode=stdout     # set mode directly (no output)
#   echo "$_OutMode"    # read mode directly
#
# Modes:
#   auto        default — stdout (safe for subshell callers)
#   global      always write to _Out (the default side-channel)
#   reply       always write to REPLY (bash convention; pairs with read/select/${| })
#   stdout      always print to stdout (good for CLI use)
#   nameref     requires into= — crashes without one
#   filesystem  write to temp file keyed by caller + PID
#
# global vs reply: both are globals clobbered on every call and read
# immediately after. reply aligns with bash's own convention; global
# predates it. Use whichever fits; switch per-call with _OutMode=reply.
#
# Validation: invalid mode crashes immediately with a clear message
# rather than failing later inside boop.pass.
#
# Typically set once at the top of a script or in ~/.bash_profile:
#   _OutMode=stdout
#   _EOL=$'\n'
_OutMode() {
  if [[ $# -gt 0 ]]; then
    case "$1" in auto|global|reply|stdout|nameref|filesystem) _OutMode="$1"          ;;
    *) _Crash "invalid _OutMode: '$1' (auto|global|reply|stdout|nameref|filesystem)" ;;
    esac
  fi
  boop.pass "$_OutMode"
}

# boop.isObject -- test whether _Self is an object (not a class or empty).
#
# Returns 0 (true) if _Self starts with __obj_, 1 (false) otherwise.
# No boop.pass -- communicates via exit code only, like isa.
#
# Used as a guard in methods that require object identity:
#   boop.isObject || { _Error "requires an object"; return 1; }
#
# Also callable on an object to branch on instance vs class context:
#   if $obj.isObject; then ... fi
#   if boop.isObject;  then ... fi   # reads ambient _Self
boop.isObject() {
  local _Self="${_Self:-}"
  [[ "$_Self" == __obj_* ]]
}

# _EOL — get or set the line ending for stdout output.
#
# Appended after the payload in boop.pass stdout mode. Default is
# newline. Set to empty string for raw output (pipe-friendly).
#
# Works as both a variable and a function:
#   _EOL              # print current value, set _EOL to itself
#   _EOL $'\n'        # set to newline
#   _EOL ""           # clear (no trailing newline)
#   _EOL=""           # clear directly (no output)
#   into=x _EOL       # read into x without side effects
#
# Uses ${1-$_EOL} (no colon) so empty string passes through as a
# valid value, while no argument falls back to the current setting.
_EOL() { boop.pass "${1-$_EOL}" ${into:-_EOL}; }

# _Delimiter -- get or set the field separator.
#
# When called with no argument and _Delimiter is unset, returns empty
# (not _EOL). This reflects the "not configured" state -- methods that
# need a field separator provide their own context-appropriate default.
#
# Works as both a variable and a function:
#   _Delimiter='='      # set directly
#   _Delimiter ':'      # set via function (also prints new value)
#   into=d _Delimiter   # read without side effects
_Delimiter() { boop.pass "${1-${_Delimiter:-}}" ${into:-_Delimiter}; }

# ============================================================================
# VALUE ENCODING/DECODING
# ============================================================================

# Fast encode: escapes the five characters that would break pipe-delimited
# descriptor storage. Uses bash parameter expansion (no subshell, no fork).
#
# ORDER MATTERS: percent must be encoded FIRST. If pipes were encoded first,
# the literal "|" becomes "%7C" — then the percent pass would re-encode the
# "%" in "%7C" to "%257C", corrupting the value. Percent-first ensures the
# escape character itself is safe before anything else touches it.
# Handles: % | = newline tab
__boop.encode() {
  local __boop_encode_val="$1"
  __boop_encode_val="${__boop_encode_val//%/%25}"
  __boop_encode_val="${__boop_encode_val//|/%7C}"
  __boop_encode_val="${__boop_encode_val//=/%3D}"
  __boop_encode_val="${__boop_encode_val//$'\n'/%0A}"
  __boop_encode_val="${__boop_encode_val//$'\t'/%09}"
  boop.pass "$__boop_encode_val" "${2:-}"
}

# Fast decode: reverses encode. Uses bash parameter expansion (no subshell).
#
# ORDER MATTERS: percent must be decoded LAST — the mirror image of encode.
# If percent were decoded first, "%257C" would become "%7C", and then the
# pipe pass would decode that to "|", producing a value that was never there.
# By decoding percent last, we guarantee that only sequences we encoded are
# restored, and user data containing literal "%7C" survives the round-trip.
__boop.decode() {
  local __boop_decode_val="$1"
  __boop_decode_val="${__boop_decode_val//%09/$'\t'}"
  __boop_decode_val="${__boop_decode_val//%0A/$'\n'}"
  __boop_decode_val="${__boop_decode_val//%3D/=}"
  __boop_decode_val="${__boop_decode_val//%7C/|}"
  __boop_decode_val="${__boop_decode_val//%25/%}"
  boop.pass "$__boop_decode_val" "${2:-}"
}

# ============================================================================
# VALIDATION
# ============================================================================

# Polymorphic input validator. Rejects anything that isn't a safe identifier
# or function name, depending on the type= typecast. This is the front door
# for every user-supplied name that touches eval, registries, or dispatch.
# Validate and reject — never sanitize and proceed.
#
# In identifier mode (default): allows [A-Za-z_][A-Za-z0-9_]* — no dots.
# In function mode: allows dots in the name (e.g., "Box.calc", "boop.pass")
# because bash functions can contain dots, and our dispatch system relies on them.
#
# The type= typecast uses `local -l` for case-insensitive matching, so
# type=Function, type=FUNCTION, and type=function all work. A misspelled
# typecast (e.g., typ=function) silently falls through to identifier mode
# because the unrecognized variable doesn't set `type` — this is correct
# behavior (strictest validation wins by default).
#
# Usage: __boop.validate "Box"                     # identifier (default)
#        type=function __boop.validate "Box.calc"  # function name (dots ok)
__boop.validate() {
  local __boop_validate_pat; local -l type; : "${type:=identifier}"
  case $type in
    func|function) __boop_validate_pat='^[A-Za-z_][A-Za-z0-9_.]*$' ;;
    class)         __boop_validate_pat='^[A-Za-z_][A-Za-z0-9_.]*$' ;;
    *)             __boop_validate_pat='^[A-Za-z_][A-Za-z0-9_]*$' ;;
  esac
  [[ "$1" =~ $__boop_validate_pat ]] || _Crash "Invalid $type: '$1'"
}

# ============================================================================
# CONFIGURATION
# ============================================================================

# ============================================================================
# PARSING & DATA ACCESS
# ============================================================================

# Extract a single field from a pipe-delimited descriptor string.
# The descriptor format is: |field1=value1|field2=value2|...
# Values are stored encoded (via __boop.encode); this function
# decodes them before returning.
#
# Accepts an optional $3 nameref target for zero-copy extraction.
# If the field doesn't exist, returns empty string (not an error —
# missing properties are a normal condition, not a crash).
#
# The regex pattern anchors on the leading pipe to avoid partial matches:
# searching for "id" won't accidentally match "grid" because the pipe
# delimiter guarantees field-name boundaries.
#
# Usage:
#   value=$(__boop.parse "Box" "parent")           # stdout (subshell)
#   __boop.parse "Box" "parent" my_var             # nameref (no subshell)
#   _OutMode=global __boop.parse ... # global variable
__boop.parse() {
  local __boop_parse_key="$1" __boop_parse_field="$2" __boop_parse_target="${3:-}"
  [[ -n "$__boop_parse_key" && "$__boop_parse_key" != *" "* ]] || _Crash "Invalid key: '$__boop_parse_key'"

  local __boop_parse_descriptor="${__boop_registry[$__boop_parse_key]:-}"
  local __boop_parse_pattern="\\|${__boop_parse_field}=([^|]*)"
  local __boop_parse_value=""
  if [[ "$__boop_parse_descriptor" =~ $__boop_parse_pattern ]]; then
    __boop.decode "${BASH_REMATCH[1]}" __boop_parse_value
  fi

  boop.pass "$__boop_parse_value" "$__boop_parse_target"
}

# ============================================================================
# METHOD REGISTRY
# ============================================================================

# Register a method implementation in the method registry.
# Maps "ClassName.methodName" → "implementingFunctionName" so dispatch
# can resolve calls. The implementing function must already exist (declared
# via `declare -f`) at registration time — no forward declarations.
#
# Arguments:
#   $1 — class name (identifier)
#   $2 — method name (identifier)
#   $3 — implementing function name (optional; defaults to "$1.$2")
#
# All names are validated: class as identifier, method as identifier,
# impl as function (dots allowed). This is the only way methods enter the
# registry, so validation here protects every downstream dispatch.
__boop.registerMethod() {
  local __boop_registerMethod_class="$1" __boop_registerMethod_method="$2"
  local __boop_registerMethod_impl="${3:-$1.$2}"

  type=class __boop.validate "$__boop_registerMethod_class"
  __boop.validate "$__boop_registerMethod_method"
  type=function __boop.validate "$__boop_registerMethod_impl"

  declare -F "$__boop_registerMethod_impl" >/dev/null || _Crash "Function '$__boop_registerMethod_impl' does not exist"

  __boop_methodRegistry["$__boop_registerMethod_class.$__boop_registerMethod_method"]="$__boop_registerMethod_impl"
}

# ============================================================================
# METHOD DISPATCH
# ============================================================================

# Unified dispatcher with inheritance support, MRO caching, and lazy baking.
#
# Resolution: checks __boop_methodRegistry for "class.method" first (O(1)).
# On cache miss, walks the parent chain via descriptor "parent" fields until
# it finds a registered implementation, then caches the result under the
# original class so the walk never happens again for that pair.
#
# Unified dispatcher with MRO resolution and direct call-through.
#
# Resolves a method name to its implementing function by checking the
# method registry cache first (O(1)), then walking the inheritance chain
# on cache miss. Caches the result so the walk never repeats for that
# class+method pair.
#
# There is no runtime dispatcher function. Method calls go directly
# to the resolved implementation via wrappers written at creation time:
#
#   - Class-level methods: registerClass writes Box.toString as a wrapper
#     that calls _Self=$_Self _Class='Box' __boop.toString "$@".
#   - Instance methods: wrapperAll writes per-instance wrappers (e.g.
#     _abc123.length) at object creation that delegate the same way.
#   - Constructor shorthand: Box() { _Class='Box' Box.new "$@"; }
#
# MRO walks are explicit (see __boop.methodResolve below) and used only by
# registerClass / refresh / backfill at class-construction time. Once the
# wrappers are baked, normal method invocation has zero dispatch overhead.

# __boop.methodResolve — MRO lookup for a class+method pair.
#
# Walks the inheritance chain from Class upward, returning the implementing
# function name via nameref. Crashes if the class isn't registered or the
# method isn't found anywhere in the chain.
#
# Usage: __boop.methodResolve ClassName methodName resultVar
#
# Example:
#   local impl
#   __boop.methodResolve Box volume impl
#   $impl "$@"
__boop.methodResolve() {
  local __boop_methodResolve_class="$1" __boop_methodResolve_method="$2"
  local -n __boop_methodResolve_out="$3"

  [[ -n "${__boop_registry[$__boop_methodResolve_class]:-}" ]] ||
    _Crash "Unknown class: '$__boop_methodResolve_class'"

  # Cache key — same cache as dispatch, they share the registry
  local __boop_methodResolve_cachekey="$__boop_methodResolve_class.$__boop_methodResolve_method"
  __boop_methodResolve_out="${__boop_methodRegistry[$__boop_methodResolve_cachekey]:-}"
  [[ -n "$__boop_methodResolve_out" ]] && return

  # Cache miss — walk the MRO
  local __boop_methodResolve_current="$__boop_methodResolve_class"
  while [[ -n "$__boop_methodResolve_current" ]]; do
    __boop_methodResolve_out="${__boop_methodRegistry[$__boop_methodResolve_current.$__boop_methodResolve_method]:-}"
    if [[ -n "$__boop_methodResolve_out" ]]; then
      [[ "$__boop_methodResolve_current" != "$__boop_methodResolve_class" ]] &&
        __boop_methodRegistry[$__boop_methodResolve_cachekey]="$__boop_methodResolve_out"
      return
    fi
    __boop.parse "$__boop_methodResolve_current" "parent" __boop_methodResolve_current
  done

  _Crash "Method not found: $__boop_methodResolve_class.$__boop_methodResolve_method"
}

# ============================================================================
# SERIALIZATION
# ============================================================================

# Dump the entire registry to a tab-delimited file. Each line is:
#   key<TAB>descriptor
# where key is an object ID or class name and descriptor is the raw
# pipe-delimited string. This captures the full state of all objects
# and class definitions. Does NOT serialize wrapper functions —
# those are regenerated by wrapperAll after deserializing.
__boop.serialize() {
  local __boop_serialize_file="${1:-objects.dat}"
  for __boop_serialize_key in "${!__boop_registry[@]}"; do
    printf "%s\t%s\n" "$__boop_serialize_key" "${__boop_registry[$__boop_serialize_key]}"
  done > "$__boop_serialize_file"
}

# Load a previously serialized registry from a tab-delimited file.
# Each key is validated before insertion to prevent injection from
# tampered data files. Existing registry entries with the same key
# are overwritten — last write wins.
# NOTE: This restores descriptor data only. Object wrapper functions
# are NOT recreated — call __boop.backfillMethods or __boop.refresh on
# each object after deserializing if you need to call methods on them.
__boop.deserialize() {
  local __boop_deserialize_file="${1:-objects.dat}"
  [[ -f "$__boop_deserialize_file" ]] || { _Error "File not found: $__boop_deserialize_file"; return 1; }
  local __boop_deserialize_key __boop_deserialize_descriptor
  while IFS=$'\t' read -r __boop_deserialize_key __boop_deserialize_descriptor; do
    type=class __boop.validate "$__boop_deserialize_key"
    __boop_registry[$__boop_deserialize_key]="$__boop_deserialize_descriptor"
  done < "$__boop_deserialize_file"
}

# ============================================================================
# STANDARD INTERFACE METHODS (inherited by all classes)
# ============================================================================

# Retrieve a property value from the object's descriptor.
# Delegates to parse, which handles decoding and return routing.
# Read a property value from the object's storage in __boop_static.
# Returns the value via boop.pass (respects into=).
# If the property was never set, returns empty string.
__boop.get() {
  local _Self="${_Self:-}"; local _Class="${_Class:-boop}"
  boop.pass "${__boop_static[${_Self}.${1}]:-}" ${into:-}
}

# __boop.getOrClass -- REMOVED. No implicit fallback.
# Use $obj.inheritValueFor prop for explicit opt-in inheritance.

# Store a property value in the object's storage (__boop_static).
# Simple hash write — no encoding needed, no descriptor mutation.
__boop.set() {
  local _Self="${_Self:-}"; local _Class="${_Class:-boop}"
  __boop_static["${_Self}.${1}"]="$2"
}

# Type checking with ancestry walk.
# No args: returns the object's class name (via boop.pass).
# With arg: walks the inheritance chain and returns 0 (true) if the
# object's class matches or inherits from the queried class, 1 (false)
# otherwise. The walk follows "parent" fields in class descriptors
# up to the root (boop, whose parent is empty string).
#
# Note: isa with a query does NOT call boop.pass — it
# communicates via exit code only (0/1), which is the bash convention
# for boolean checks: `$obj.isa Box && printf "it's a box"`
__boop.isa() {
  local _Self="${_Self:-}"; local _Class="${_Class:-boop}"
  local __boop_isa_query="${1:-}"

  if [[ -z "$__boop_isa_query" ]]; then
    # Return the object's true class (FQN)
    local __boop_isa_true
    __boop.parse "$_Self" "trueClass" __boop_isa_true
    boop.pass "${__boop_isa_true:-$_Class}" ${into:-}
    return 0
  fi

  # Get the trueClass of the query (resolve alias to FQN)
  local __boop_isa_query_true
  __boop.parse "$__boop_isa_query" "trueClass" __boop_isa_query_true
  : "${__boop_isa_query_true:=$__boop_isa_query}"

  # Walk the inheritance chain comparing trueClass values
  local __boop_isa_current="$_Class"
  while [[ -n "$__boop_isa_current" ]]; do
    local __boop_isa_current_true
    __boop.parse "$__boop_isa_current" "trueClass" __boop_isa_current_true
    : "${__boop_isa_current_true:=$__boop_isa_current}"
    [[ "$__boop_isa_current_true" == "$__boop_isa_query_true" ]] && return 0
    __boop.parse "$__boop_isa_current" "parent" __boop_isa_current
  done
  return 1
}

# Check whether the object's class (or any ancestor class) mixes in a given
# mixin. Exit 0 if yes, 1 if no. Analogous to isa but for the mixin dimension.
# Usage: $obj.mixes Printable && echo "can print"
__boop.mixes() {
  local _Self="${_Self:-}" _Class="${_Class:-boop}"
  local __boop_mixes_query="${1:-}"
  [[ -n "$__boop_mixes_query" ]] || return 1
  local __boop_mixes_current="$_Class" __boop_mixes_mixins __boop_mixes_m
  while [[ -n "$__boop_mixes_current" ]]; do
    __boop.parse "$__boop_mixes_current" "mixins" __boop_mixes_mixins
    if [[ -n "$__boop_mixes_mixins" ]]; then
      local __boop_mixes_list; IFS=',' read -ra __boop_mixes_list <<< "$__boop_mixes_mixins"
      for __boop_mixes_m in "${__boop_mixes_list[@]}"; do
        [[ "$__boop_mixes_m" == "$__boop_mixes_query" ]] && return 0
      done
    fi
    __boop.parse "$__boop_mixes_current" "parent" __boop_mixes_current
  done
  return 1
}

# Return the object's Fully Qualified class Name (FQN).
# Unlike isa (no arg), this is explicit and unambiguous.
# Usage: into=fqn $obj.trueClass
__boop.trueClass() {
  local _Self="${_Self:-}"
  local __boop_trueClass_val
  __boop.parse "$_Self" "trueClass" __boop_trueClass_val
  boop.pass "${__boop_trueClass_val:-${_Class:-}}" ${into:-}
}

# Format an object's descriptor for human-readable display.
# Skips internal metadata fields (class, parent, methods, properties)
# and shows only user-defined properties.
#
# Compact mode (default): single-line format
#   Box(_a1b2c3){ length=5 width=3 height=7 }
#
# Pretty mode: columnar with newlines, field names right-padded for
# alignment. Two-pass: first pass measures max field name length,
# second pass formats with printf %-Ns alignment.
#
# Pretty mode is activated by either:
#   $obj.toString pretty          # positional argument
#   prettyPrint=true $obj.toString # typecast (uses local -l for case-insensitive match)
#
# Usage: $obj.toString                    # compact one-liner
#        $obj.toString pretty             # columnar with newlines
#        prettyPrint=true $obj.toString    # same, via environment
__boop.toString() {
  local _Self="${_Self:-}"; local _Class="${_Class:-boop}"
  local -l prettyPrint; : "${prettyPrint:=false}"
  [[ "${1:-}" == "pretty" ]] && prettyPrint=true

  # Get declared properties from the class descriptor (schema)
  local __boop_toString_props __boop_toString_trueClass
  __boop.parse "$_Self" "trueClass" __boop_toString_trueClass
  : "${__boop_toString_trueClass:=$_Class}"
  __boop.parse "$__boop_toString_trueClass" "properties" __boop_toString_props

  # Collect all properties: declared first, then any undeclared extras
  local -a __boop_toString_keys=() __boop_toString_vals=()
  local -A __boop_toString_seen=()
  local __boop_toString_field __boop_toString_value

  # Declared properties (always shown, even if empty)
  if [[ -n "$__boop_toString_props" ]]; then
    local -a __boop_toString_propArr
    IFS=',' read -ra __boop_toString_propArr <<< "$__boop_toString_props"
    for __boop_toString_field in "${__boop_toString_propArr[@]}"; do
      [[ -n "$__boop_toString_field" ]] || continue
      __boop_toString_value="${__boop_static[${_Self}.${__boop_toString_field}]:-}"
      __boop_toString_keys+=("$__boop_toString_field")
      __boop_toString_vals+=("$__boop_toString_value")
      __boop_toString_seen[$__boop_toString_field]=1
    done
  fi

  # Undeclared properties (dynamic additions)
  local __boop_toString_k __boop_toString_prefix="${_Self}."
  for __boop_toString_k in "${!__boop_static[@]}"; do
    [[ "$__boop_toString_k" == "${__boop_toString_prefix}"* ]] || continue
    __boop_toString_field="${__boop_toString_k#"$__boop_toString_prefix"}"
    [[ -n "${__boop_toString_seen[$__boop_toString_field]+set}" ]] && continue
    __boop_toString_keys+=("$__boop_toString_field")
    __boop_toString_vals+=("${__boop_static[$__boop_toString_k]}")
  done

  # Format output
  local __boop_toString_output
  if [[ "$prettyPrint" != "true" ]]; then
    __boop_toString_output="$_Class($_Self){"
    local -i __boop_toString_i
    for (( __boop_toString_i=0; __boop_toString_i < ${#__boop_toString_keys[@]}; __boop_toString_i++ )); do
      __boop_toString_output="$__boop_toString_output ${__boop_toString_keys[$__boop_toString_i]}=${__boop_toString_vals[$__boop_toString_i]}"
    done
    boop.pass "$__boop_toString_output }" ${into:-}
    return
  fi

  # Pretty print: columnar alignment
  local -i __boop_toString_maxlen=0 __boop_toString_i
  for (( __boop_toString_i=0; __boop_toString_i < ${#__boop_toString_keys[@]}; __boop_toString_i++ )); do
    (( ${#__boop_toString_keys[$__boop_toString_i]} > __boop_toString_maxlen )) &&
      __boop_toString_maxlen=${#__boop_toString_keys[$__boop_toString_i]} || true
  done

  printf -v __boop_toString_output "%s(%s) {\n" "$_Class" "$_Self"
  for (( __boop_toString_i=0; __boop_toString_i < ${#__boop_toString_keys[@]}; __boop_toString_i++ )); do
    printf -v __boop_toString_field "  %-${__boop_toString_maxlen}s = %s\n" \
      "${__boop_toString_keys[$__boop_toString_i]}" "${__boop_toString_vals[$__boop_toString_i]}"
    __boop_toString_output="$__boop_toString_output$__boop_toString_field"
  done
  __boop_toString_output="$__boop_toString_output}"

  boop.pass "$__boop_toString_output" ${into:-}
}

# Pretty-print an object's full state for debugging.
#
# Shows: class + full inheritance chain, all user-defined properties
# with their decoded values aligned in columns, and the flat method
# list inherited from the entire chain.
#
# Output always goes to stdout -- this is a debug display function,
# not a value producer. into= is intentionally not supported.
#
# Usage:
#   $obj.inspect             # dump to stdout
#   $obj.inspect | less      # page through a big object
#
# Example output:
#   [Box _1a2b3c]
#     class:   Box extends boop
#     height = 7
#     length = 5
#     width  = 3
#     methods: new, volume, area, top, side, front, get, set, isa, toString
__boop.inspect() {
  local _Self="${_Self:-}"; local _Class="${_Class:-boop}"

  : "build inheritance chain label"
  local __boop_inspect_chain="$_Class"
  local __boop_inspect_walk
  __boop.parse "$_Class" "parent" __boop_inspect_walk
  while [[ -n "$__boop_inspect_walk" ]]; do
    __boop_inspect_chain="$__boop_inspect_chain extends $__boop_inspect_walk"
    __boop.parse "$__boop_inspect_walk" "parent" __boop_inspect_walk
  done

  : "collect user-defined properties from __boop_static"
  local __boop_inspect_trueClass
  __boop.parse "$_Self" "trueClass" __boop_inspect_trueClass
  : "${__boop_inspect_trueClass:=$_Class}"
  local __boop_inspect_props
  __boop.parse "$__boop_inspect_trueClass" "properties" __boop_inspect_props

  local __boop_inspect_field __boop_inspect_value
  local -a __boop_inspect_keys=() __boop_inspect_vals=()
  local -A __boop_inspect_seen=()
  local -i __boop_inspect_maxlen=0

  if [[ -n "$__boop_inspect_props" ]]; then
    local -a __boop_inspect_propArr
    IFS=',' read -ra __boop_inspect_propArr <<< "$__boop_inspect_props"
    for __boop_inspect_field in "${__boop_inspect_propArr[@]}"; do
      [[ -n "$__boop_inspect_field" ]] || continue
      __boop_inspect_value="${__boop_static[${_Self}.${__boop_inspect_field}]:-}"
      __boop_inspect_keys+=("$__boop_inspect_field")
      __boop_inspect_vals+=("$__boop_inspect_value")
      __boop_inspect_seen[$__boop_inspect_field]=1
      (( ${#__boop_inspect_field} > __boop_inspect_maxlen )) && __boop_inspect_maxlen=${#__boop_inspect_field} || true
    done
  fi
  local __boop_inspect_k __boop_inspect_prefix="${_Self}."
  for __boop_inspect_k in "${!__boop_static[@]}"; do
    [[ "$__boop_inspect_k" == "${__boop_inspect_prefix}"* ]] || continue
    __boop_inspect_field="${__boop_inspect_k#"$__boop_inspect_prefix"}"
    [[ -n "${__boop_inspect_seen[$__boop_inspect_field]+set}" ]] && continue
    __boop_inspect_keys+=("$__boop_inspect_field")
    __boop_inspect_vals+=("${__boop_static[$__boop_inspect_k]}")
    (( ${#__boop_inspect_field} > __boop_inspect_maxlen )) && __boop_inspect_maxlen=${#__boop_inspect_field} || true
  done

  : "collect all callable methods walking the full inheritance chain; deduplicate"
  local __boop_inspect_methods="" __boop_inspect_m __boop_inspect_sep=""
  local -A __boop_inspect_seen=()
  __boop_inspect_walk="$_Class"
  while [[ -n "$__boop_inspect_walk" ]]; do
    __boop.parse "$__boop_inspect_walk" "methods" __boop_inspect_m
    local __boop_inspect_name
    IFS=',' read -ra __boop_inspect_mlist <<< "$__boop_inspect_m"
    for __boop_inspect_name in "${__boop_inspect_mlist[@]}"; do
      [[ -z "$__boop_inspect_name" ]] && continue
      [[ -n "${__boop_inspect_seen[$__boop_inspect_name]+set}" ]] && continue
      __boop_inspect_seen[$__boop_inspect_name]=1
      __boop_inspect_methods="${__boop_inspect_methods}${__boop_inspect_sep}${__boop_inspect_name}"
      __boop_inspect_sep=", "
    done
    __boop.parse "$__boop_inspect_walk" "parent" __boop_inspect_walk
  done

  : "print"
  printf "[%s %s]\n" "$_Class" "$_Self"
  printf "  class:   %s\n" "$__boop_inspect_chain"
  local -i __boop_inspect_i
  for (( __boop_inspect_i=0; __boop_inspect_i < ${#__boop_inspect_keys[@]}; __boop_inspect_i++ )); do
    printf "  %-${__boop_inspect_maxlen}s = %s\n" \
      "${__boop_inspect_keys[$__boop_inspect_i]}" "${__boop_inspect_vals[$__boop_inspect_i]}"
  done
  (( ${#__boop_inspect_keys[@]} == 0 )) && printf "  (no properties)\n"
  printf "  methods: %s\n" "$__boop_inspect_methods"
}

# Object destructor. The symmetric inverse of __boop.new.
#
# Tears down everything that object creation and class-level initialization
# built. Execution order:
#
#   1. Dispatch to class-level _destroy hook (if defined). The class knows
#      what companion arrays, file descriptors, temp files, or child objects
#      it created — the core does not. The hook is a private function named
#      ClassName._destroy (not a registered method — not dispatchable by
#      users, not in the public: list). This keeps the MRO clean: `destroy`
#      always resolves to __boop.destroy, and class authors implement their
#      cleanup in a private function that the core calls.
#
#   2. Wipe __boop_static keys. Every key prefixed "${_Self}." is removed.
#      This is O(n) over the full static table — unavoidable since bash has
#      no prefix-delete on associative arrays. Acceptable because destroy is
#      not a hot-path operation.
#
#   3. Unset wrapper functions. compgen -A function gives us every function
#      whose name starts with "${_Self}." in one shot. Each is unset.
#
#   4. Remove the registry entry. After this, the object ID is unresolvable.
#
# After destroy, the object ID is dead. Calling any method on it will fail
# with "command not found" (the wrappers are gone). Holding a stale ID is
# the caller's problem — same as a dangling pointer in C. The framework
# does not track references.
#
# Class-level cleanup hook convention:
#   ClassName._destroy() { ... }
#   — NOT registered as a method (no public: entry, no boopClass token)
#   — Called with _Self and _Class set correctly
#   — Responsible for: companion arrays, owned child objects, FDs, temp files
#   — Must NOT call __boop.destroy (the core handles that)
#
# Usage:
#   $obj.destroy              # clean teardown
#   into=hand Hand.new ...    # use it
#   $hand.destroy             # done with it
__boop.destroy() {
  local _Self="${_Self:-}"; local _Class="${_Class:-boop}"
  [[ -n "$_Self" ]] || _Crash "destroy: no object identity (_Self is empty)"
  [[ -n "${__boop_registry[$_Self]+set}" ]] || {
    _Error "destroy: '$_Self' is not a registered object"; return 1; }

  _Debug "destroy: $_Self ($_Class) — beginning teardown"

  # --- Phase 1: class-level _destroy hook ---
  # Resolve the trueClass (FQN) and walk the inheritance chain looking for
  # ClassName._destroy functions. Call each one found, from most-derived to
  # root. This lets a subclass clean up its own additions while the parent
  # cleans up what it allocated.
  local __boop_destroy_trueClass
  __boop.parse "$_Self" "trueClass" __boop_destroy_trueClass
  : "${__boop_destroy_trueClass:=$_Class}"

  _Trace "destroy: phase 1 — walking chain from '$__boop_destroy_trueClass' for _destroy hooks"
  local __boop_destroy_walk="$__boop_destroy_trueClass"
  while [[ -n "$__boop_destroy_walk" ]]; do
    if declare -F "${__boop_destroy_walk}._destroy" >/dev/null; then
      _Trace "destroy: calling ${__boop_destroy_walk}._destroy on $_Self"
      _Self="$_Self" _Class="$__boop_destroy_walk" "${__boop_destroy_walk}._destroy"
    else
      _Trace "destroy: no _destroy hook on $__boop_destroy_walk"
    fi
    __boop.parse "$__boop_destroy_walk" "parent" __boop_destroy_walk
  done

  # --- Phase 2: wipe __boop_static keys ---
  # Prefix match: every key starting with "${_Self}." belongs to this object.
  local __boop_destroy_prefix="${_Self}."
  local __boop_destroy_key
  local -i __boop_destroy_static_count=0
  for __boop_destroy_key in "${!__boop_static[@]}"; do
    if [[ "$__boop_destroy_key" == "$__boop_destroy_prefix"* ]]; then
      unset '__boop_static[$__boop_destroy_key]'
      (( ++__boop_destroy_static_count ))
    fi
  done
  _Trace "destroy: phase 2 — removed $__boop_destroy_static_count __boop_static keys"

  # --- Phase 3: unset wrapper functions ---
  # compgen -A function lists all defined functions matching a prefix.
  # Each object's wrappers are named "${_Self}.methodName".
  local __boop_destroy_fn
  local -i __boop_destroy_fn_count=0
  while IFS= read -r __boop_destroy_fn; do
    unset -f "$__boop_destroy_fn"
    (( ++__boop_destroy_fn_count ))
  done < <(compgen -A function "${_Self}.")
  _Trace "destroy: phase 3 — unset $__boop_destroy_fn_count wrapper functions"

  # --- Phase 4: remove registry entry ---
  unset '__boop_registry[$_Self]'
  _Trace "destroy: phase 4 — registry entry removed. $_Self is dead."
}

# Object constructor. This is the beating heart of object creation.
#
# 1. Generates a unique object ID from a global counter — fast, no subshell,
#    monotonically increasing. Format: __obj_XX (hex counter).
# 2. Builds a pipe-delimited descriptor from the class name and any
#    key=value arguments, encoding values for safe storage.
# 3. Registers the descriptor in __boop_registry.
# 4. Generates direct wrappers for all methods and property accessors
#    via __boop.backfillMethods. Each wrapper is a one-hop delegation to the
#    class-level function — no dispatch overhead on normal calls.
#
# Arguments are key=value pairs. Duplicate keys are allowed — both
# end up in the descriptor, but get/parse will match the first one.
# (This is documented behavior, not a bug.)
__boop.new() {
  local _Class="${_Class:-boop}"

  # Generate unique object ID
  local _Self; printf -v _Self "__obj_%02x" $(( ++__boop_id ))

  # Build descriptor -- trueClass comes from the class's trueClass
  local __boop_new_trueClass
  __boop.parse "$_Class" "trueClass" __boop_new_trueClass
  : "${__boop_new_trueClass:=$_Class}"
  local __boop_new_descriptor="|class=$_Class|trueClass=$__boop_new_trueClass"

  # Parse arguments and store values in __boop_static.
  # The descriptor stays schema-only; values live in the hash.
  local __boop_new_prop __boop_new_val
  for __boop_new_arg in "$@"; do
    [[ "$__boop_new_arg" == *=* ]] || continue
    __boop_new_prop="${__boop_new_arg%%=*}"
    __boop_new_val="${__boop_new_arg#*=}"
    __boop_static["${_Self}.${__boop_new_prop}"]="$__boop_new_val"
  done

  # Register object
  __boop_registry[$_Self]="$__boop_new_descriptor"

  # Generate direct wrappers using the trueClass (FQN) so wrappers
  # always call the real implementing functions, not alias stubs
  __boop.backfillMethods "$_Self" "$__boop_new_trueClass"

  boop.pass "$_Self" ${into:-}
}

# ============================================================================
# STUB GENERATION & CLASS REGISTRATION
# ============================================================================

# Generate direct wrappers for all methods and property accessors on an
# object. Walks the full inheritance chain so inherited methods get
# wrappers too.
#
# Method wrappers: one-hop delegation to the class-level function.
# The class-level function is either the author's real impl (e.g.,
# Box.volume) or a wrapper that registerClass created for inherited
# methods. No dispatch on normal calls — zero overhead after creation.
#
#   $obj.volume() { _Self='$id' Box.volume "$@"; }
#
# Property wrappers: dual-purpose get/set accessors. Called with no
# args, they dispatch to "get" with the property name. Called with one
# arg, they dispatch to "set". This gives you $obj.length (get) and
# $obj.length 42 (set) syntax.
#
# Pass "force" as $3 to overwrite existing functions — used by refresh
# to tear down wrappers and regenerate everything.
__boop.backfillMethods() {
  local __boop_backfillMethods_self="$1" __boop_backfillMethods_class="$2" __boop_backfillMethods_force="${3:-}"
  local __boop_backfillMethods_current="$__boop_backfillMethods_class" __boop_backfillMethods_method __boop_backfillMethods_tmp
  local __boop_backfillMethods_tmpfile="${TMPDIR:-/tmp}/__boop_bf_$$"
  local -A __boop_backfillMethods_written=()
  : > "$__boop_backfillMethods_tmpfile"

  # Walk inheritance chain, create direct wrappers for all methods
  while [[ -n "$__boop_backfillMethods_current" ]]; do
    __boop.parse "$__boop_backfillMethods_current" "methods" __boop_backfillMethods_tmp
    IFS=',' read -ra __boop_backfillMethods_methodList <<< "$__boop_backfillMethods_tmp"
    for __boop_backfillMethods_method in "${__boop_backfillMethods_methodList[@]}"; do
      [[ -n "$__boop_backfillMethods_method" ]] || continue
      [[ "$__boop_backfillMethods_force" != "force" ]] && declare -F "$__boop_backfillMethods_self.$__boop_backfillMethods_method" >/dev/null && continue
      [[ -n "${__boop_backfillMethods_written[$__boop_backfillMethods_method]+set}" ]] && continue
      printf '%s.%s() { _Self=%q _Class=%q %s.%s "$@"; }\n' \
        "$__boop_backfillMethods_self" "$__boop_backfillMethods_method" \
        "$__boop_backfillMethods_self" "$__boop_backfillMethods_class" \
        "$__boop_backfillMethods_class" "$__boop_backfillMethods_method" \
        >> "$__boop_backfillMethods_tmpfile"
      __boop_backfillMethods_written[$__boop_backfillMethods_method]=1
    done
    __boop.parse "$__boop_backfillMethods_current" "parent" __boop_backfillMethods_current
  done

  # Property accessors (get/set by property name)
  local __boop_backfillMethods_props __boop_backfillMethods_prop
  __boop.parse "$__boop_backfillMethods_class" "properties" __boop_backfillMethods_props
  IFS=',' read -ra __boop_backfillMethods_propList <<< "$__boop_backfillMethods_props"
  for __boop_backfillMethods_prop in "${__boop_backfillMethods_propList[@]}"; do
    [[ -n "$__boop_backfillMethods_prop" ]] || continue
    # Skip if a method wrapper was already written for this name
    [[ -n "${__boop_backfillMethods_written[$__boop_backfillMethods_prop]+set}" ]] && continue
    [[ "$__boop_backfillMethods_force" != "force" ]] && declare -F "$__boop_backfillMethods_self.$__boop_backfillMethods_prop" >/dev/null && continue
    printf '%s.%s() { if (($#)); then _Self=%q _Class=%q __boop.set %q "$1"; else _Self=%q _Class=%q __boop.get %q; fi; }\n' \
      "$__boop_backfillMethods_self" "$__boop_backfillMethods_prop" \
      "$__boop_backfillMethods_self" "$__boop_backfillMethods_class" "$__boop_backfillMethods_prop" \
      "$__boop_backfillMethods_self" "$__boop_backfillMethods_class" "$__boop_backfillMethods_prop" \
      >> "$__boop_backfillMethods_tmpfile"
  done

  # Mixin provenance wrappers: objid.Mixin::method always routes to that
  # mixin's implementation directly, regardless of which method won dispatch.
  local __boop_backfillMethods_mixins __boop_backfillMethods_mixin __boop_backfillMethods_mmethods __boop_backfillMethods_mixinImpl
  __boop.parse "$__boop_backfillMethods_class" "mixins" __boop_backfillMethods_mixins
  if [[ -n "$__boop_backfillMethods_mixins" ]]; then
    local __boop_backfillMethods_mArr; IFS=',' read -ra __boop_backfillMethods_mArr <<< "$__boop_backfillMethods_mixins"
    for __boop_backfillMethods_mixin in "${__boop_backfillMethods_mArr[@]}"; do
      [[ -n "$__boop_backfillMethods_mixin" ]] || continue
      __boop_backfillMethods_mmethods=""
      [[ "${__boop_mixin_registry[$__boop_backfillMethods_mixin]:-}" =~ \|methods=([^|]*)\| ]] &&
        __boop_backfillMethods_mmethods="${BASH_REMATCH[1]}"
      [[ -n "$__boop_backfillMethods_mmethods" ]] || continue
      local __boop_backfillMethods_mMArr; IFS=',' read -ra __boop_backfillMethods_mMArr <<< "$__boop_backfillMethods_mmethods"
      for __boop_backfillMethods_method in "${__boop_backfillMethods_mMArr[@]}"; do
        [[ -n "$__boop_backfillMethods_method" ]] || continue
        __boop_backfillMethods_mixinImpl="${__boop_methodRegistry[$__boop_backfillMethods_mixin.$__boop_backfillMethods_method]:-}"
        [[ -n "$__boop_backfillMethods_mixinImpl" ]] || continue
        printf '%s.%s::%s() { _Self=%q _Class=%q %s "$@"; }\n' \
          "$__boop_backfillMethods_self" \
          "$__boop_backfillMethods_mixin" \
          "$__boop_backfillMethods_method" \
          "$__boop_backfillMethods_self" \
          "$__boop_backfillMethods_class" \
          "$__boop_backfillMethods_mixinImpl" \
          >> "$__boop_backfillMethods_tmpfile"
      done
    done
  fi

  . "$__boop_backfillMethods_tmpfile"
  rm -f "$__boop_backfillMethods_tmpfile"
}

# Re-wrap all methods on an existing object. Tears down existing wrappers
# and replaces them with fresh ones. Useful after modifying the method
# registry at runtime (e.g., monkey-patching a method implementation).
__boop.refresh() {
  local __boop_refresh_self="$1"
  local __boop_refresh_class; __boop.parse "$__boop_refresh_self" "class" __boop_refresh_class
  [[ -n "$__boop_refresh_class" ]] || _Crash "Cannot refresh: no class for '$__boop_refresh_self'"
  __boop.backfillMethods "$__boop_refresh_self" "$__boop_refresh_class" force
}

# Finalize a class definition. Call this at the bottom of a class file
# after all method functions are defined and registered.
#
# What it does:
# 1. Walks the inheritance chain collecting all method names.
# 2. For each inherited method where ClassName.method doesn't already
#    exist, resolves the impl via the method registry (MRO walk) and
#    creates a direct class-level wrapper:
#      Box.toString() { _Self=$_Self _Class='Box' __boop.toString "$@"; }
#    These are one-hop delegations — no dispatch on normal calls.
# 3. If the class name itself isn't already a function, creates a
#    constructor shorthand: Box() { _Class=Box __boop.dispatch new "$@"; }
#    This enables the clean `Box length=5 width=3 height=7` syntax.
#
# Methods already defined by the class author (e.g., Box.calc as a real
# function) take priority — registerClass will NOT overwrite them. This
# lets class authors provide custom implementations that bypass dispatch
# when called directly.
__boop.registerClass() {
  local __boop_registerClass_class="$1"
  type=class __boop.validate "$__boop_registerClass_class"

  [[ -n "${__boop_registry[$__boop_registerClass_class]:-}" ]] || 
    _Crash "No descriptor for class '$__boop_registerClass_class' -- register it first"

  local __boop_registerClass_current="$__boop_registerClass_class"
  local __boop_registerClass_method __boop_registerClass_methods __boop_registerClass_impl
  local __boop_registerClass_tmpfile="${TMPDIR:-/tmp}/__boop_rc_$$"
  local -A __boop_registerClass_written=()
  : > "$__boop_registerClass_tmpfile"

  # Walk inheritance chain, create direct class-level wrappers
  while [[ -n "$__boop_registerClass_current" ]]; do
    __boop.parse "$__boop_registerClass_current" "methods" __boop_registerClass_methods
    IFS=',' read -ra __boop_registerClass_methodList <<< "${__boop_registerClass_methods:-}"
    for __boop_registerClass_method in "${__boop_registerClass_methodList[@]}"; do
      [[ -n "$__boop_registerClass_method" ]] || continue
      # Don't overwrite -- class author's definitions take priority
      declare -F "$__boop_registerClass_class.$__boop_registerClass_method" >/dev/null && continue
      # Don't overwrite -- closer ancestor already written to temp file
      [[ -n "${__boop_registerClass_written[$__boop_registerClass_method]+set}" ]] && continue
      # Resolve the impl via MRO
      __boop_registerClass_impl="${__boop_methodRegistry[$__boop_registerClass_current.$__boop_registerClass_method]:-}"
      if [[ -z "$__boop_registerClass_impl" ]]; then
        local __boop_registerClass_walk="$__boop_registerClass_current"
        while [[ -n "$__boop_registerClass_walk" ]]; do
          __boop_registerClass_impl="${__boop_methodRegistry[$__boop_registerClass_walk.$__boop_registerClass_method]:-}"
          [[ -n "$__boop_registerClass_impl" ]] && break
          __boop.parse "$__boop_registerClass_walk" "parent" __boop_registerClass_walk
        done
      fi
      [[ -n "$__boop_registerClass_impl" ]] || continue
      printf '%s.%s() { _Self="${_Self:-}" _Class=%q %s "$@"; }\n' \
        "$__boop_registerClass_class" "$__boop_registerClass_method" \
        "$__boop_registerClass_class" "$__boop_registerClass_impl" \
        >> "$__boop_registerClass_tmpfile"
      __boop_registerClass_written[$__boop_registerClass_method]=1
    done
    __boop.parse "$__boop_registerClass_current" "parent" __boop_registerClass_current
  done

  # Mixin methods — bake class-level wrappers and register in methodRegistry
  # so subclasses can inherit them via normal MRO walk.
  local __boop_registerClass_mixins __boop_registerClass_mixin __boop_registerClass_mixinMethods __boop_registerClass_mixinImpl
  __boop.parse "$__boop_registerClass_class" "mixins" __boop_registerClass_mixins
  if [[ -n "$__boop_registerClass_mixins" ]]; then
    local __boop_registerClass_mArr; IFS=',' read -ra __boop_registerClass_mArr <<< "$__boop_registerClass_mixins"
    for __boop_registerClass_mixin in "${__boop_registerClass_mArr[@]}"; do
      [[ -n "$__boop_registerClass_mixin" ]] || continue
      __boop_registerClass_mixinMethods=""
      [[ "${__boop_mixin_registry[$__boop_registerClass_mixin]:-}" =~ \|methods=([^|]*)\| ]] &&
        __boop_registerClass_mixinMethods="${BASH_REMATCH[1]}"
      [[ -n "$__boop_registerClass_mixinMethods" ]] || continue
      local __boop_registerClass_mMethodArr; IFS=',' read -ra __boop_registerClass_mMethodArr <<< "$__boop_registerClass_mixinMethods"
      for __boop_registerClass_method in "${__boop_registerClass_mMethodArr[@]}"; do
        [[ -n "$__boop_registerClass_method" ]] || continue
        # Class and higher-priority mixins win
        [[ -n "${__boop_registerClass_written[$__boop_registerClass_method]+set}" ]] && continue
        declare -F "$__boop_registerClass_class.$__boop_registerClass_method" >/dev/null && continue
        __boop_registerClass_mixinImpl="${__boop_methodRegistry[$__boop_registerClass_mixin.$__boop_registerClass_method]:-}"
        [[ -n "$__boop_registerClass_mixinImpl" ]] || continue
        printf '%s.%s() { _Self="${_Self:-}" _Class=%q %s "$@"; }\n' \
          "$__boop_registerClass_class" "$__boop_registerClass_method" \
          "$__boop_registerClass_class" "$__boop_registerClass_mixinImpl" \
          >> "$__boop_registerClass_tmpfile"
        # Register so subclasses inherit via normal MRO walk
        __boop_methodRegistry["$__boop_registerClass_class.$__boop_registerClass_method"]="$__boop_registerClass_mixinImpl"
        __boop_registerClass_written[$__boop_registerClass_method]=1
      done
    done
  fi

  # Class-level property accessors — read/write via _Static.
  # These provide ClassName.prop as a getter/setter for class-level defaults.
  # Instance accessors (generated in backfillMethods) fall back to these
  # when the property is absent from the instance descriptor.
  local __boop_registerClass_props __boop_registerClass_prop
  __boop.parse "$__boop_registerClass_class" "properties" __boop_registerClass_props
  if [[ -n "$__boop_registerClass_props" ]]; then
    IFS=',' read -ra __boop_registerClass_propArr <<< "$__boop_registerClass_props"
    for __boop_registerClass_prop in "${__boop_registerClass_propArr[@]}"; do
      [[ -n "$__boop_registerClass_prop" ]] || continue
      # Don't overwrite if a method with this name was already written
      [[ -n "${__boop_registerClass_written[$__boop_registerClass_prop]+set}" ]] && continue
      # Don't overwrite class author's definition
      declare -F "$__boop_registerClass_class.$__boop_registerClass_prop" >/dev/null && continue
      # Class-level property accessor: get with no args, set with one arg.
      # Uses _Property (keyed as ClassName.propName in __boop_static).
      printf '%s.%s() { if (($#)); then _Class=%q _Property "%s=$1"; else _Class=%q _Property %q; fi; }\n' \
        "$__boop_registerClass_class" "$__boop_registerClass_prop" \
        "$__boop_registerClass_class" "$__boop_registerClass_prop" \
        "$__boop_registerClass_class" "$__boop_registerClass_prop" \
        >> "$__boop_registerClass_tmpfile"
    done
  fi

  # Constructor shorthand
  if declare -F "${__boop_registerClass_class}.new" >/dev/null; then
    printf '%s() { _Class=%q %s.new "$@"; }\n' \
      "$__boop_registerClass_class" "$__boop_registerClass_class" "$__boop_registerClass_class" \
      >> "$__boop_registerClass_tmpfile"
  else
    printf '%s() { _Class=%q __boop.new "$@"; }\n' \
      "$__boop_registerClass_class" "$__boop_registerClass_class" \
      >> "$__boop_registerClass_tmpfile"
  fi

  . "$__boop_registerClass_tmpfile"
  rm -f "$__boop_registerClass_tmpfile"
}

# Global convenience constructor. Slightly friendlier than the class-as-
# constructor syntax for people who prefer explicit "new" semantics.
# Validates the class name, then delegates to dispatch.
# Usage: new Box length=5 width=3 height=7
#        into=mybox new Cube size=4
#new() {
#  local __boop_newGlobal_class="$1"; shift
#  __boop.validate "$__boop_newGlobal_class"
#  _Class="$__boop_newGlobal_class" __boop.new "$@"
#}
new() {
  local __boop_newGlobal_class="$1" __boop_newGlobal_impl; shift
  __boop.methodResolve "$__boop_newGlobal_class" new __boop_newGlobal_impl
  _Class="$__boop_newGlobal_class" $__boop_newGlobal_impl "$@"
}

# ============================================================================
# CONFIG PARSING
# ============================================================================

# __boop.parseConfig — Read a config file as data into an associative array.
#
# Handles three line formats (all backward-compatible):
#   Key=Value                         — new canonical format
#   [Key]="Value"                     — old .boopIndex array-literal format
#   __boop_classPath["Key"]="Value"   — old .boop.cfg assignment format
#
# Blank lines and lines beginning with '#' are skipped.
# Lines matching 'declare *' or a bare ')' are skipped (old array wrappers).
# Unrecognized lines emit _Warn and are skipped.
# First-write-wins: if a key is already present, later entries are ignored.
# This gives earlier roots precedence when merging multiple index files.
#
# Usage: __boop.parseConfig /path/to/file array_name
__boop.parseConfig() {
  local __boop_parseConfig_file="$1"
  local -n __boop_parseConfig_arr="$2"
  local __boop_parseConfig_line __boop_parseConfig_key __boop_parseConfig_val
  while IFS= read -r __boop_parseConfig_line; do
    # Strip leading whitespace
    while [[ "${__boop_parseConfig_line:0:1}" == ' ' || "${__boop_parseConfig_line:0:1}" == $'\t' ]]; do
      __boop_parseConfig_line="${__boop_parseConfig_line:1}"
    done
    [[ -z "$__boop_parseConfig_line" ]] && continue
    [[ "${__boop_parseConfig_line:0:1}" == '#' ]] && continue
    case "$__boop_parseConfig_line" in declare\ *|')') continue ;; esac

    if [[ "$__boop_parseConfig_line" =~ ^\[([^]]+)\]=\"(.*)\"$ ]]; then
      # Old .boopIndex format: [Key]="Value"
      __boop_parseConfig_key="${BASH_REMATCH[1]}"
      __boop_parseConfig_val="${BASH_REMATCH[2]}"
    elif [[ "$__boop_parseConfig_line" =~ \[\"([^\"]+)\"\]=\"(.*)\"$ ]]; then
      # Old .boop.cfg format: __boop_classPath["Key"]="Value"
      __boop_parseConfig_key="${BASH_REMATCH[1]}"
      __boop_parseConfig_val="${BASH_REMATCH[2]}"
    elif [[ "$__boop_parseConfig_line" =~ ^([A-Za-z0-9_./:-]+)=(.*)$ ]]; then
      # New canonical format: Key=Value (optional surrounding quotes stripped)
      __boop_parseConfig_key="${BASH_REMATCH[1]}"
      __boop_parseConfig_val="${BASH_REMATCH[2]}"
      if [[ "${__boop_parseConfig_val:0:1}" == '"' && "${__boop_parseConfig_val: -1}" == '"' && ${#__boop_parseConfig_val} -ge 2 ]]; then
        __boop_parseConfig_val="${__boop_parseConfig_val:1:${#__boop_parseConfig_val}-2}"
      fi
    else
      _Warn "parseConfig: unrecognized line in '$__boop_parseConfig_file': $__boop_parseConfig_line"
      continue
    fi

    # First-write-wins: skip if already populated
    [[ -n "${__boop_parseConfig_arr[$__boop_parseConfig_key]+set}" ]] && continue
    __boop_parseConfig_arr["$__boop_parseConfig_key"]="$__boop_parseConfig_val"
  done < "$__boop_parseConfig_file"
}

# ============================================================================
# LOADER — RC/CFG Bootstrap and BOOPPATH Initialization
# ============================================================================

# __boop.loader — Bootstrap the framework configuration layer.
#
# Called once during initialization (inside the __boop_loaded guard).
# Responsibilities:
#   1. Source the RC chain: /etc/booprc → ~/.booprc → ./.booprc
#      Each RC file is responsible for sourcing its own .boop.cfg.
#      Missing files are skipped silently; source failures crash.
#   2. Parse BOOPPATH — split on ':', filter empty segments, skip
#      non-existent directories with _Info diagnostic.
#   3. Source .boopIndex from each valid root (. + BOOPPATH + PATH).
#      Earlier roots take precedence for duplicate short names.
#   4. Version mismatch detection — if RC files set
#      __boop_preferred_version, compare against __boop_version
#      and emit _Warn if they differ.
#
# The function is idempotent — calling it twice won't break anything,
# though in practice it's called exactly once from the init guard.
#
# This function does NOT call __boop.import or process class arguments.
# It only prepares the configuration state that import will use later.
__boop.loader() {
  _Debug "loader: starting RC chain"

  # -----------------------------------------------------------------
  # 1. RC chain sourcing
  # -----------------------------------------------------------------
  local __boop_loader_rc __boop_loader_rc_version_source=""
  for __boop_loader_rc in "/etc/booprc" "$HOME/.booprc" "./.booprc"; do
    if [[ ! -f "$__boop_loader_rc" ]]; then
      _Trace "loader: RC file $__boop_loader_rc not found, skipped"
      continue
    fi
    local __boop_loader_prev_pref="${__boop_preferred_version:-}"
    . "$__boop_loader_rc" || _Crash "Failed to source $__boop_loader_rc"
    _Info "sourced $__boop_loader_rc"
    # Track which RC file set or changed __boop_preferred_version
    if [[ "${__boop_preferred_version:-}" != "$__boop_loader_prev_pref" ]]; then
      __boop_loader_rc_version_source="$__boop_loader_rc"
    fi
  done

  # -----------------------------------------------------------------
  # 2. BOOPPATH parsing — validate entries exist
  # -----------------------------------------------------------------
  _Trace "loader: parsing BOOPPATH='${BOOPPATH:-}'"
  local __boop_loader_IFS_save="$IFS"
  local -a __boop_loader_bp_segments
  IFS=':'
  read -ra __boop_loader_bp_segments <<< "${BOOPPATH:-}"
  IFS="$__boop_loader_IFS_save"

  local __boop_loader_seg
  for __boop_loader_seg in "${__boop_loader_bp_segments[@]}"; do
    [[ -n "$__boop_loader_seg" ]] || continue
    if [[ ! -d "$__boop_loader_seg" ]]; then
      _Info "BOOPPATH entry '$__boop_loader_seg' does not exist, skipping"
    else
      _Trace "loader: BOOPPATH entry '$__boop_loader_seg' valid"
    fi
  done

  # -----------------------------------------------------------------
  # 1b. Parse .boop.cfg as data into __boop_classPath
  # -----------------------------------------------------------------
  # RC files may source .boop.cfg the old way; we also parse it directly
  # so that the new Key=Value format works even without RC file changes.
  # First-write-wins: RC-sourced entries (already in __boop_classPath) win.
  local __boop_loader_cfg
  for __boop_loader_cfg in "/etc/boop.cfg" "$HOME/.boop.cfg" "./.boop.cfg"; do
    [[ -f "$__boop_loader_cfg" ]] || continue
    _Trace "loader: parsing cfg $__boop_loader_cfg"
    __boop.parseConfig "$__boop_loader_cfg" __boop_classPath
    _Info "parsed cfg: $__boop_loader_cfg"
  done

  # -----------------------------------------------------------------
  # 3. .boopIndex parsing from each valid root
  # -----------------------------------------------------------------
  _Trace "loader: building effective root list"
  # Build the effective root list: . + BOOPPATH + PATH
  local -A __boop_loader_seen
  local -a __boop_loader_roots=()
  trap 'unset -f __boop_loader_addRoot' RETURN

  __boop_loader_addRoot() {
    local __boop_loader_addRoot_r="$1"
    [[ -n "$__boop_loader_addRoot_r" ]] || return
    [[ -n "${__boop_loader_seen[$__boop_loader_addRoot_r]+set}" ]] && return
    __boop_loader_seen[$__boop_loader_addRoot_r]=1
    __boop_loader_roots+=("$__boop_loader_addRoot_r")
  }

  # Current directory first
  __boop_loader_addRoot "."

  # BOOPPATH entries (reuse already-parsed segments)
  for __boop_loader_seg in "${__boop_loader_bp_segments[@]}"; do
    [[ -n "$__boop_loader_seg" ]] || continue
    [[ -d "$__boop_loader_seg" ]] || continue
    __boop_loader_addRoot "$__boop_loader_seg"
  done

  # PATH entries
  local -a __boop_loader_path_segments
  IFS=':'
  read -ra __boop_loader_path_segments <<< "${PATH:-}"
  IFS="$__boop_loader_IFS_save"
  for __boop_loader_seg in "${__boop_loader_path_segments[@]}"; do
    [[ -n "$__boop_loader_seg" ]] || continue
    __boop_loader_addRoot "$__boop_loader_seg"
  done

  # Boop's own directory as fallback root (last priority)
  __boop_loader_addRoot "$__boop_root"

  unset -f __boop_loader_addRoot

  _Trace "loader: effective root list has ${#__boop_loader_roots[@]} entries"
  _Debug "loader: effective roots: ${__boop_loader_roots[*]}"

  # Parse .boopIndex from each root as data (not sourced as code).
  # __boop.parseConfig uses first-write-wins, so earlier roots take precedence.
  local __boop_loader_root
  for __boop_loader_root in "${__boop_loader_roots[@]}"; do
    local __boop_loader_idx="$__boop_loader_root/.boopIndex"
    [[ -f "$__boop_loader_idx" ]] || continue
    _Trace "loader: parsing index $__boop_loader_idx"
    __boop.parseConfig "$__boop_loader_idx" __boop_Index
    _Info "parsed index: $__boop_loader_idx"
  done

  # -----------------------------------------------------------------
  # 4. Version mismatch detection
  # -----------------------------------------------------------------
  _Trace "loader: checking version mismatch"
  if [[ -n "${__boop_preferred_version:-}" && "$__boop_preferred_version" != "$__boop_version" ]]; then
    _Warn "Loaded boop v${__boop_version} but ${__boop_loader_rc_version_source:-RC chain} prefers v${__boop_preferred_version} — check PATH"
  fi

  _Debug "loader: bootstrap complete"
}

# ============================================================================
# CLASS RESOLUTION (Classpath / Namespace)
# ============================================================================

# __boop.classResolve — Resolve a class identifier to a filesystem path.
#
# Takes a class name (possibly namespaced with :: or /), searches the
# classpath registry, short-name index, and filesystem roots in priority
# order, and returns the resolved path without sourcing.
#
# Resolution priority:
#   1. __boop_classPath — explicit path override (highest priority)
#   2. __boop_Index     — short-name index lookup, resolved via R1 per root
#   3. Dynamic discovery — R1 against each root using the normalized name
#
# R1 resolution rule (per root):
#   Try root/$class/${class##*/} first (namespace convention),
#   then root/$class (bare file fallback). First readable file wins.
#
# The effective root list is built fresh each call from:
#   "." + BOOPPATH entries + PATH entries (deduplicated, exact match only).
#
# Returns the resolved path via optional nameref ($2), or empty string
# on failure. Exit code 0 if found, 1 if not found.
#
# Usage:
#   local path
#   __boop.classResolve "Collection::List" path
#   [[ -n "$path" ]] && . "$path"
__boop.classResolve() {
  local __boop_classResolve_class="$1"
  local __boop_classResolve_target="${2:-}"

  # --- Normalize :: to / ---
  __boop_classResolve_class="${__boop_classResolve_class//::/"/"}"

  # --- Reject empty identifiers ---
  [[ -n "$__boop_classResolve_class" ]] || _Crash "Empty class identifier"

  _Debug "classResolve: resolving '$__boop_classResolve_class'"

  # --- Priority 1: classPath explicit override ---
  if [[ -n "${__boop_classPath[$__boop_classResolve_class]:-}" ]]; then
    local __boop_classResolve_cp="${__boop_classPath[$__boop_classResolve_class]}"
    if [[ -f "$__boop_classResolve_cp" && -r "$__boop_classResolve_cp" ]]; then
      _Trace "classResolve: found '$__boop_classResolve_class' via classPath: $__boop_classResolve_cp"
      [[ -n "$__boop_classResolve_target" ]] && {
        local -n __boop_classResolve_ref="$__boop_classResolve_target"
        __boop_classResolve_ref="$__boop_classResolve_cp"
      }
      return 0
    fi
  fi

  # --- Build effective root list: . + BOOPPATH + PATH ---
  # Deduplicate via scratchpad associative array (exact path match only).
  local -A __boop_classResolve_seen
  local -a __boop_classResolve_roots=()
  trap 'unset -f __boop_classResolve_addRoot __boop_classResolve_r1' RETURN

  # Helper: add a root if not already seen
  __boop_classResolve_addRoot() {
    local __boop_classResolve_addRoot_r="$1"
    [[ -n "$__boop_classResolve_addRoot_r" ]] || return
    [[ -n "${__boop_classResolve_seen[$__boop_classResolve_addRoot_r]+set}" ]] && return
    __boop_classResolve_seen[$__boop_classResolve_addRoot_r]=1
    __boop_classResolve_roots+=("$__boop_classResolve_addRoot_r")
  }

  # Current directory first
  __boop_classResolve_addRoot "."

  # BOOPPATH entries
  local __boop_classResolve_IFS_save="$IFS"
  IFS=':'
  local -a __boop_classResolve_segments
  read -ra __boop_classResolve_segments <<< "${BOOPPATH:-}"
  IFS="$__boop_classResolve_IFS_save"
  local __boop_classResolve_seg
  for __boop_classResolve_seg in "${__boop_classResolve_segments[@]}"; do
    __boop_classResolve_addRoot "$__boop_classResolve_seg"
  done

  # PATH entries
  IFS=':'
  read -ra __boop_classResolve_segments <<< "${PATH:-}"
  IFS="$__boop_classResolve_IFS_save"
  for __boop_classResolve_seg in "${__boop_classResolve_segments[@]}"; do
    __boop_classResolve_addRoot "$__boop_classResolve_seg"
  done

  # Boop's own directory as fallback root (last priority)
  __boop_classResolve_addRoot "$__boop_root"

  unset -f __boop_classResolve_addRoot

  _Trace "classResolve: effective roots (${#__boop_classResolve_roots[@]}): ${__boop_classResolve_roots[*]}"

  # --- R1 resolution rule (local helper) ---
  # Try root/$class/${class##*/} then root/$class. Sets result in caller var.
  # Returns 0 if found, 1 if not.
  __boop_classResolve_r1() {
    local __boop_classResolve_r1_root="$1" __boop_classResolve_r1_cls="$2"
    local __boop_classResolve_r1_tail="${__boop_classResolve_r1_cls##*/}"
    local __boop_classResolve_r1_try

    # Namespace convention: root/class/tail
    __boop_classResolve_r1_try="$__boop_classResolve_r1_root/$__boop_classResolve_r1_cls/$__boop_classResolve_r1_tail"
    if [[ -f "$__boop_classResolve_r1_try" && -r "$__boop_classResolve_r1_try" ]]; then
      _Trace "classResolve R1: hit namespace convention: $__boop_classResolve_r1_try"
      __boop_classResolve_r1_result="$__boop_classResolve_r1_try"
      return 0
    fi

    # Bare file fallback: root/class
    __boop_classResolve_r1_try="$__boop_classResolve_r1_root/$__boop_classResolve_r1_cls"
    if [[ -f "$__boop_classResolve_r1_try" && -r "$__boop_classResolve_r1_try" ]]; then
      _Trace "classResolve R1: hit bare file: $__boop_classResolve_r1_try"
      __boop_classResolve_r1_result="$__boop_classResolve_r1_try"
      return 0
    fi

    return 1
  }

  local __boop_classResolve_r1_result=""
  local __boop_classResolve_root

  # --- Priority 2: Index lookup ---
  if [[ -n "${__boop_Index[$__boop_classResolve_class]:-}" ]]; then
    local __boop_classResolve_indexVal="${__boop_Index[$__boop_classResolve_class]}"
    # Normalize index value (:: → /)
    __boop_classResolve_indexVal="${__boop_classResolve_indexVal//::/"/"}"
    _Debug "classResolve: index hit for '$__boop_classResolve_class' → '$__boop_classResolve_indexVal'"

    for __boop_classResolve_root in "${__boop_classResolve_roots[@]}"; do
      if __boop_classResolve_r1 "$__boop_classResolve_root" "$__boop_classResolve_indexVal"; then
        _Trace "classResolve: resolved '$__boop_classResolve_class' via index at $__boop_classResolve_r1_result"
        unset -f __boop_classResolve_r1
        [[ -n "$__boop_classResolve_target" ]] && {
          local -n __boop_classResolve_ref="$__boop_classResolve_target"
          __boop_classResolve_ref="$__boop_classResolve_r1_result"
        }
        return 0
      fi
    done
  fi

  # --- Priority 2b: Partial namespace via index prefix ---
  # If the name contains a /, check whether the first segment is in the
  # index. If so, expand it and resolve the full path. This allows
  # "Map::Fast" to resolve via index["Map"]="Collection/Map" → try
  # "Collection/Map/Fast" through R1.
  if [[ "$__boop_classResolve_class" == */* ]]; then
    local __boop_classResolve_head="${__boop_classResolve_class%%/*}"
    local __boop_classResolve_tail="${__boop_classResolve_class#*/}"
    if [[ -n "${__boop_Index[$__boop_classResolve_head]:-}" ]]; then
      local __boop_classResolve_expanded="${__boop_Index[$__boop_classResolve_head]}"
      __boop_classResolve_expanded="${__boop_classResolve_expanded//::/"/"}"
      __boop_classResolve_expanded="$__boop_classResolve_expanded/$__boop_classResolve_tail"
      _Debug "classResolve: partial namespace '$__boop_classResolve_class' → expanded '$__boop_classResolve_expanded'"

      for __boop_classResolve_root in "${__boop_classResolve_roots[@]}"; do
        if __boop_classResolve_r1 "$__boop_classResolve_root" "$__boop_classResolve_expanded"; then
          _Trace "classResolve: resolved '$__boop_classResolve_class' via partial namespace at $__boop_classResolve_r1_result"
          unset -f __boop_classResolve_r1
          [[ -n "$__boop_classResolve_target" ]] && {
            local -n __boop_classResolve_ref="$__boop_classResolve_target"
            __boop_classResolve_ref="$__boop_classResolve_r1_result"
          }
          return 0
        fi
      done
    fi
  fi

  # --- Priority 3: Dynamic discovery ---
  _Debug "classResolve: dynamic discovery for '$__boop_classResolve_class'"
  for __boop_classResolve_root in "${__boop_classResolve_roots[@]}"; do
    if __boop_classResolve_r1 "$__boop_classResolve_root" "$__boop_classResolve_class"; then
      _Info "'$__boop_classResolve_class' resolved via filesystem fallback -- consider running \`boop.classPath rebuild\`"
      unset -f __boop_classResolve_r1
      [[ -n "$__boop_classResolve_target" ]] && {
        local -n __boop_classResolve_ref="$__boop_classResolve_target"
        __boop_classResolve_ref="$__boop_classResolve_r1_result"
      }
      return 0
    fi
  done

  # --- Not found ---
  _Debug "classResolve: '$__boop_classResolve_class' not found"
  unset -f __boop_classResolve_r1
  [[ -n "$__boop_classResolve_target" ]] && {
    local -n __boop_classResolve_ref="$__boop_classResolve_target"
    __boop_classResolve_ref=""
  }
  return 1
}

# ============================================================================
# PUBLIC RESOLUTION API
# ============================================================================

# boop.resolve — Public, non-fatal wrapper around __boop.classResolve.
#
# Returns exit code 0 and the resolved path via boop.pass if found.
# Returns exit code 1 if not found (no crash, no output).
#
# Usage:
#   if into=loc boop.resolve Math::Trig; then
#     . "$loc"
#   fi
boop.resolve() {
  local __boop_resolve_path=""
  if __boop.classResolve "$1" __boop_resolve_path; then
    boop.pass "$__boop_resolve_path" "${into:-}"
    return 0
  fi
  return 1
}

# ============================================================================
# CLASSPATH PUBLIC API
# ============================================================================

# __boop.classPath.writeCfg — Serialize __boop_classPath to the CFG file.
#
# Rewrites the target CFG file as a complete serialization of __boop_classPath.
# Default target: ~/.boop.cfg. Override via _CfgFile environment variable.
# Output is only hash assignments -- no procedural logic.
__boop.classPath.writeCfg() {
  local __boop_writeCfg_target="${_CfgFile:-$HOME/.boop.cfg}"
  {
    printf '# Auto-generated by boop.classPath -- do not edit manually\n'
    local __boop_writeCfg_key
    for __boop_writeCfg_key in "${!__boop_classPath[@]}"; do
      printf '%s=%s\n' "$__boop_writeCfg_key" "${__boop_classPath[$__boop_writeCfg_key]}"
    done
  } >| "$__boop_writeCfg_target"
}

# boop.classPath — Subcommand-dispatched public method for classpath management.
#
# Subcommands: set, get, list, remove, has, dirs, rebuild
#
# Usage:
#   boop.classPath set MyClass /path/to/MyClass
#   boop.classPath get MyClass
#   boop.classPath list
#   boop.classPath remove MyClass
#   boop.classPath has MyClass
#   boop.classPath dirs
#   boop.classPath rebuild [root]
boop.classPath() {
  local __boop_cp_sub="${1:-}"
  shift || true

  case "$__boop_cp_sub" in
    set)
      local __boop_cp_class="${1:-}" __boop_cp_path="${2:-}"
      __boop_cp_class="${__boop_cp_class//::/"/"}"
      [[ -n "$__boop_cp_class" ]] || _Crash "boop.classPath set: class name required"
      [[ -f "$__boop_cp_path" && -r "$__boop_cp_path" ]] ||
        _Crash "boop.classPath set: '$__boop_cp_path' is not a readable file"
      if [[ -n "${__boop_classPath[$__boop_cp_class]:-}" ]]; then
        _Info "boop.classPath set: overwriting '$__boop_cp_class' (was ${__boop_classPath[$__boop_cp_class]}, now $__boop_cp_path)"
      fi
      __boop_classPath["$__boop_cp_class"]="$__boop_cp_path"
      __boop.classPath.writeCfg
      ;;
    get)
      local __boop_cp_gkey="${1:-}"
      __boop_cp_gkey="${__boop_cp_gkey//::/"/"}"
      boop.pass "${__boop_classPath[$__boop_cp_gkey]:-}" "${into:-}"
      ;;
    list)
      local __boop_cp_out=""
      local __boop_cp_key
      for __boop_cp_key in "${!__boop_classPath[@]}"; do
        __boop_cp_out+="${__boop_cp_key}=${__boop_classPath[$__boop_cp_key]}"$'\n'
      done
      # Strip trailing newline
      [[ -n "$__boop_cp_out" ]] && __boop_cp_out="${__boop_cp_out%$'\n'}"
      boop.pass "$__boop_cp_out" "${into:-}"
      ;;
    remove)
      local __boop_cp_class="${1:-}"
      __boop_cp_class="${__boop_cp_class//::/"/"}"
      if [[ -z "${__boop_classPath[$__boop_cp_class]:-}" ]]; then
        _Info "boop.classPath remove: '$__boop_cp_class' is not registered"
      else
        unset '__boop_classPath[$__boop_cp_class]'
      fi
      __boop.classPath.writeCfg
      ;;
    has)
      local __boop_cp_hkey="${1:-}"
      __boop_cp_hkey="${__boop_cp_hkey//::/"/"}"
      [[ -n "${__boop_classPath[$__boop_cp_hkey]:-}" ]]
      return $?
      ;;
    dirs)
      # Build effective root list: . + BOOPPATH + PATH (deduplicated)
      local -A __boop_cp_seen
      local __boop_cp_out=""
      local __boop_cp_seg

      # Helper to add unique roots
      __boop_cp_addDir() {
        [[ -n "$1" ]] || return
        [[ -n "${__boop_cp_seen[$1]+set}" ]] && return
        __boop_cp_seen[$1]=1
        __boop_cp_out+="$1"$'\n'
      }

      __boop_cp_addDir "."

      local __boop_cp_IFS_save="$IFS"
      local -a __boop_cp_segments
      IFS=':'
      read -ra __boop_cp_segments <<< "${BOOPPATH:-}"
      IFS="$__boop_cp_IFS_save"
      for __boop_cp_seg in "${__boop_cp_segments[@]}"; do
        [[ -n "$__boop_cp_seg" ]] && __boop_cp_addDir "$__boop_cp_seg"
      done

      IFS=':'
      read -ra __boop_cp_segments <<< "${PATH:-}"
      IFS="$__boop_cp_IFS_save"
      for __boop_cp_seg in "${__boop_cp_segments[@]}"; do
        [[ -n "$__boop_cp_seg" ]] && __boop_cp_addDir "$__boop_cp_seg"
      done

      # Boop's own directory as fallback root (last priority)
      __boop_cp_addDir "$__boop_root"

      unset -f __boop_cp_addDir
      [[ -n "$__boop_cp_out" ]] && __boop_cp_out="${__boop_cp_out%$'\n'}"
      boop.pass "$__boop_cp_out" "${into:-}"
      ;;
    rebuild)
      # Scan namespace tree of target root, discover class files matching
      # R1 convention (dir containing same-named file), detect short-name
      # conflicts, write .boopIndex as sourceable bash.
      local __boop_cp_root="${1:-.}"
      [[ -d "$__boop_cp_root" ]] || _Crash "boop.classPath rebuild: '$__boop_cp_root' is not a directory"

      # Discover all R1-convention class files: dir/Name/Name
      local -A __boop_cp_short2ns   # short-name → namespace path (first hit)
      local -A __boop_cp_conflicts  # short-name → 1 if conflicting

      # Walk the tree looking for R1-convention class files (dir/Name/Name)
      local __boop_cp_entry
      while IFS= read -r -d '' __boop_cp_entry; do
        # Glob includes directories -- skip non-files
        [[ -f "$__boop_cp_entry" ]] || continue
        # entry is a file path like root/Collection/List/List
        local __boop_cp_dir="${__boop_cp_entry%/*}"
        local __boop_cp_file="${__boop_cp_entry##*/}"
        local __boop_cp_dirname="${__boop_cp_dir##*/}"

        # R1 convention: directory name must match file name
        [[ "$__boop_cp_file" == "$__boop_cp_dirname" ]] || continue
        # Skip the root itself
        [[ "$__boop_cp_dir" == "$__boop_cp_root" ]] && continue

        # Compute namespace path relative to root
        local __boop_cp_relpath="${__boop_cp_dir#"$__boop_cp_root"/}"
        local __boop_cp_short="$__boop_cp_file"

        if [[ -n "${__boop_cp_conflicts[$__boop_cp_short]+set}" ]]; then
          # Already known conflict, skip
          continue
        elif [[ -n "${__boop_cp_short2ns[$__boop_cp_short]+set}" ]]; then
          # Second occurrence -- conflict
          _Info "Short name '$__boop_cp_short' conflicts: ${__boop_cp_short2ns[$__boop_cp_short]} and $__boop_cp_relpath -- excluded from index"
          __boop_cp_conflicts[$__boop_cp_short]=1
          unset '__boop_cp_short2ns[$__boop_cp_short]'
        else
          # First occurrence
          __boop_cp_short2ns[$__boop_cp_short]="$__boop_cp_relpath"
        fi
      done < <( shopt -s globstar nullglob; shopt -u dotglob; printf '%s\0' "$__boop_cp_root"/** )

      # Write .boopIndex
      local __boop_cp_idx="$__boop_cp_root/.boopIndex"
      {
        printf '# .boopIndex -- auto-generated by boop.classPath rebuild\n'
        local __boop_cp_key
        for __boop_cp_key in "${!__boop_cp_short2ns[@]}"; do
          printf '%s=%s\n' "$__boop_cp_key" "${__boop_cp_short2ns[$__boop_cp_key]}"
        done
      } >| "$__boop_cp_idx"
      _Info "rebuilt index: $__boop_cp_idx (${#__boop_cp_short2ns[@]} entries)"
      ;;
    "")
      _Crash "boop.classPath: subcommand required (set, get, list, remove, has, dirs, rebuild)"
      ;;
    *)
      _Crash "boop.classPath: unknown subcommand '$__boop_cp_sub'"
      ;;
  esac
}

# ============================================================================
# CLASS IMPORT
# ============================================================================

# Resolve and source a class file. Iterates each argument as a class name
# and sources the corresponding file into the current shell.
#
# Resolution order (via __boop.classResolve, first match wins):
#   1. __boop_classPath — explicit path overrides
#   2. __boop_Index     — short-name index, resolved via R1 per root
#   3. Dynamic discovery — R1 against each root (. + BOOPPATH + PATH)
#   4. Raw source fallback — `. "$class"` (lets bash try PATH directly)
#
# Load guards (two layers):
#   - __boop_registry[ClassName]+set — class already fully loaded, skip entirely.
#   - __boop_loading[ClassName] — class is mid-load (its file is currently being
#     sourced). This prevents circular recursion: Cube's file sources `. boop Box`,
#     Box's file sources `. boop`, boop re-enters import for Box — the loading flag
#     catches this and skips, letting the original load complete.
#
# The loading flag is unset after each successful source. If the source fails
# (exit code != 0), we crash — a half-loaded class is worse than no class.
__boop.import() {
  # Non-fatal loader. Returns 0 on success, 1 on failure (not found or
  # source error). Callers that need fatal behavior use _Require, which
  # calls _Load, which calls this. The import args block (`. boop Class`)
  # uses _Require so user-facing class-file sourcing remains fatal.
  local __boop_import_class
  for __boop_import_class in "$@"; do
    _Debug "import: '$__boop_import_class'"

    # Already loaded? Skip.
    if [[ -n "${__boop_registry[$__boop_import_class]+set}" ]]; then
      _Trace "import: '$__boop_import_class' already in registry, skipping"
      continue
    fi

    # Already loading? Skip (prevents circular recursion when a class
    # file sources boop as part of its own load sequence).
    if [[ -n "${__boop_loading[$__boop_import_class]:-}" ]]; then
      _Trace "import: '$__boop_import_class' already loading (circular guard), skipping"
      continue
    fi
    __boop_loading[$__boop_import_class]=1

    # Resolve via classPath -> index -> dynamic discovery
    local __boop_import_path=""
    if __boop.classResolve "$__boop_import_class" __boop_import_path; then
      _Debug "import: '$__boop_import_class' resolved to '$__boop_import_path'"
      # Clear $@ before sourcing so class files that call `. boop` with no
      # explicit args don't inherit this function's positional parameters
      # and accidentally trigger a second recursive import of the full list.
      set --
      if ! . "$__boop_import_path"; then
        unset '__boop_loading[$__boop_import_class]'
        _Warn "import: failed to source '$__boop_import_class' from $__boop_import_path"
        return 1
      fi
      unset '__boop_loading[$__boop_import_class]'
      _Trace "import: '$__boop_import_class' loaded successfully"
      continue
    fi

    # Raw source fallback -- let bash try PATH directly
    _Debug "import: '$__boop_import_class' not resolved, trying raw source fallback"
    set --
    local __boop_import_stderr; __boop_import_stderr=$(mktemp)
    if . "$__boop_import_class" 2>"$__boop_import_stderr"; then
      rm -f "$__boop_import_stderr"
      unset '__boop_loading[$__boop_import_class]'
      _Info "import: '$__boop_import_class' loaded via raw source fallback"
      continue
    fi
    [[ -s "$__boop_import_stderr" ]] && _Debug "import fallback stderr: $(<"$__boop_import_stderr")"
    rm -f "$__boop_import_stderr"

    # Complete resolution failure — non-fatal, return 1
    unset '__boop_loading[$__boop_import_class]'
    _Debug "import: '$__boop_import_class' not found (checked classPath, index, roots)"
    return 1
  done
}

# ============================================================================
# CLASS LOADING — PUBLIC API
# ============================================================================

# __boop.guard — registry presence check.
#
# Returns 0 if the named class is already registered, 1 otherwise.
# Used by boop.init and other framework internals.
__boop.guard() {
  [[ -n "${__boop_registry[$1]+set}" ]]
}

# boop.init — standard class file initializer.
#
# Every class file calls this immediately after `. boop`:
#   boop.init ClassName || return
#
# Handles three cases:
#   Already loaded   -- returns 1, caller exits via `|| return`
#   Executed directly -- prints a help message and exits 1
#   First load       -- returns 0, loading proceeds normally
#
# BASH_SOURCE[1] is the class file itself (one frame up from boop.init),
# so the direct-execution check is correct regardless of load depth.
# Future hooks (logging, help registration, etc.) belong here.
boop.init() {
  __boop.guard "$1" && return 1
  if [[ "${BASH_SOURCE[1]}" == "$0" ]]; then
    printf '%s is a boop class file. Load it with: . boop %s\n' \
      "${BASH_SOURCE[1]##*/}" "${BASH_SOURCE[1]##*/}" >&2
    exit 1
  fi
  return 0
}

# boop.initMixin — standard mixin file initializer.
#
# Every mixin file calls this immediately after `. boop`:
#   boop.initMixin MixinName || return 0
#
# Same three-case semantics as boop.init, but checks __boop_mixin_registry
# instead of __boop_registry.
boop.initMixin() {
  [[ -n "${__boop_mixin_registry[$1]+set}" ]] && return 1
  if [[ "${BASH_SOURCE[1]}" == "$0" ]]; then
    printf '%s is a boop mixin file. Load it with: . boop %s\n' \
      "${BASH_SOURCE[1]##*/}" "${BASH_SOURCE[1]##*/}" >&2
    exit 1
  fi
  return 0
}

# _Load — non-fatal class loader.
#
# Loads each named class if not already in the registry. Returns 0 if all
# classes are available (already loaded or successfully loaded now). Returns
# 1 if any class cannot be found or fails to source. Never crashes.
#
# Use for optional or graceful-degradation dependencies:
#   _Load Math || printf "precision math unavailable, using native arithmetic\n"
#   if _Load Args; then _Load ArgParser; fi   # load ArgParser only if Args present
#   _Load Math Config                          # 0 only if both succeed
#
# Tier-2 inherited variables: none.
_Load() {
  local __Load_class __Load_rc=0
  for __Load_class in "$@"; do
    [[ -n "${__boop_registry[$__Load_class]+set}" ]] && continue
    __boop.import "$__Load_class" || __Load_rc=1
  done
  return $__Load_rc
}

# __boop.versionCompare — compare two version strings.
#
# Arguments:
#   $1 -- version A (e.g. "1.2.3")
#   $2 -- version B (e.g. "1.3.0")
#
# Returns via stdout: -1 (A < B), 0 (A == B), 1 (A > B).
# Pre-release suffixes (1.2.3-beta) are stripped and ignored.
__boop.versionCompare() {
  local __boop_vc_a="$1" __boop_vc_b="$2"
  local __boop_vc_amaj __boop_vc_amin __boop_vc_apat
  local __boop_vc_bmaj __boop_vc_bmin __boop_vc_bpat
  IFS=. read -r __boop_vc_amaj __boop_vc_amin __boop_vc_apat <<< "$__boop_vc_a"
  IFS=. read -r __boop_vc_bmaj __boop_vc_bmin __boop_vc_bpat <<< "$__boop_vc_b"
  : "${__boop_vc_amaj:=0}" "${__boop_vc_amin:=0}" "${__boop_vc_apat:=0}"
  : "${__boop_vc_bmaj:=0}" "${__boop_vc_bmin:=0}" "${__boop_vc_bpat:=0}"
  __boop_vc_apat="${__boop_vc_apat%%-*}"   # strip pre-release
  __boop_vc_bpat="${__boop_vc_bpat%%-*}"
  if   (( __boop_vc_amaj < __boop_vc_bmaj )); then printf -- '-1'
  elif (( __boop_vc_amaj > __boop_vc_bmaj )); then printf -- '1'
  elif (( __boop_vc_amin < __boop_vc_bmin )); then printf -- '-1'
  elif (( __boop_vc_amin > __boop_vc_bmin )); then printf -- '1'
  elif (( __boop_vc_apat < __boop_vc_bpat )); then printf -- '-1'
  elif (( __boop_vc_apat > __boop_vc_bpat )); then printf -- '1'
  else printf -- '0'
  fi
}

# __boop.versionSatisfies -- test whether a version meets a constraint.
#
# Arguments:
#   $1 -- version to test (e.g. "1.3.0")
#   $2 -- constraint (e.g. "1.2+", ">=1.2", ">1.0", "<=2.0", "<2.0", "1.2.3")
#
# Returns: 0 if satisfied, 1 if not.
__boop.versionSatisfies() {
  local __boop_vs_ver="$1" __boop_vs_con="$2"
  local __boop_vs_op __boop_vs_req
  case "$__boop_vs_con" in
    '>='*) __boop_vs_op=">=" ; __boop_vs_req="${__boop_vs_con#>=}" ;;
    '>'*)  __boop_vs_op=">"  ; __boop_vs_req="${__boop_vs_con#>}"  ;;
    '<='*) __boop_vs_op="<=" ; __boop_vs_req="${__boop_vs_con#<=}" ;;
    '<'*)  __boop_vs_op="<"  ; __boop_vs_req="${__boop_vs_con#<}"  ;;
    *'+')  __boop_vs_op=">=" ; __boop_vs_req="${__boop_vs_con%+}"  ;;
    *)     __boop_vs_op="="  ; __boop_vs_req="$__boop_vs_con"      ;;
  esac
  local __boop_vs_cmp
  __boop_vs_cmp="$(__boop.versionCompare "$__boop_vs_ver" "$__boop_vs_req")"
  case "$__boop_vs_op" in
    ">=" ) (( __boop_vs_cmp >= 0 )) ;;
    ">"  ) (( __boop_vs_cmp >  0 )) ;;
    "<=" ) (( __boop_vs_cmp <= 0 )) ;;
    "<"  ) (( __boop_vs_cmp <  0 )) ;;
    "="  ) (( __boop_vs_cmp == 0 )) ;;
  esac
}

# __boop.requireVersion -- enforce a boop version constraint.
#
# Called from the import-args block when `. boop require:1.2+` is used.
# If the running boop does not satisfy the constraint, searches BOOPPATH
# and PATH for a compatible boop, includes the path in the crash message
# if found, then crashes either way.
#
# Arguments:
#   $1 -- version constraint (e.g. "1.2+", ">=1.0.0")
__boop.requireVersion() {
  local __boop_rv_con="$1"
  if __boop.versionSatisfies "$__boop_version" "$__boop_rv_con"; then
    _Trace "requireVersion: boop v${__boop_version} satisfies '$__boop_rv_con'"
    return 0
  fi
  _Debug "requireVersion: boop v${__boop_version} does not satisfy '$__boop_rv_con' -- searching"

  # Search . + BOOPPATH + PATH for a compatible boop file.
  local __boop_rv_found="" __boop_rv_root __boop_rv_candidate __boop_rv_v __boop_rv_line
  local -a __boop_rv_roots=(".")
  local -a __boop_rv_bp=()
  read -ra __boop_rv_bp <<< "${BOOPPATH:-}"
  local __boop_rv_seg
  for __boop_rv_seg in "${__boop_rv_bp[@]+"${__boop_rv_bp[@]}"}"; do
    [[ -d "$__boop_rv_seg" ]] && __boop_rv_roots+=("$__boop_rv_seg")
  done
  local __boop_rv_pe
  while IFS= read -r __boop_rv_pe; do
    [[ -d "$__boop_rv_pe" ]] && __boop_rv_roots+=("$__boop_rv_pe")
  done <<< "${PATH//:/$'\n'}"

  for __boop_rv_root in "${__boop_rv_roots[@]}"; do
    __boop_rv_candidate="${__boop_rv_root}/boop"
    [[ -f "$__boop_rv_candidate" ]] || continue
    # Skip the currently running boop
    [[ "$__boop_rv_candidate" -ef "${BASH_SOURCE[0]}" ]] && continue
    # Read its version directly from the file (no sourcing)
    __boop_rv_v=""
    while IFS= read -r __boop_rv_line; do
      if [[ "$__boop_rv_line" =~ ^declare\ -gr\ __boop_version=\"([^\"]+)\"$ ]]; then
        __boop_rv_v="${BASH_REMATCH[1]}"
        break
      fi
    done < "$__boop_rv_candidate"
    [[ -z "$__boop_rv_v" ]] && continue
    if __boop.versionSatisfies "$__boop_rv_v" "$__boop_rv_con"; then
      __boop_rv_found="$__boop_rv_candidate (v${__boop_rv_v})"
      break
    fi
  done

  if [[ -n "$__boop_rv_found" ]]; then
    _Crash "boop '$__boop_rv_con' required (running v${__boop_version}) -- compatible version found at: $__boop_rv_found"
  else
    _Crash "boop '$__boop_rv_con' required (running v${__boop_version}) -- none found on BOOPPATH/PATH"
  fi
}

# __boop.checkClassVersion -- verify a loaded class meets a version constraint.
#
# Called by _Require after loading a class. If SemVer is not loaded, warns
# and returns successfully (graceful degradation). If the class declares no
# version, warns and returns successfully.
#
# Arguments:
#   $1 -- class name (already loaded)
#   $2 -- version constraint (e.g. "1.2+")
__boop.checkClassVersion() {
  local __boop_ccv_class="$1" __boop_ccv_con="$2"
  local __boop_ccv_desc="${__boop_registry[$__boop_ccv_class]:-}"
  local __boop_ccv_ver=""
  [[ "$__boop_ccv_desc" =~ \|version=([^|]*) ]] && __boop_ccv_ver="${BASH_REMATCH[1]}"
  if [[ -z "$__boop_ccv_ver" ]]; then
    _Warn "_Require: '$__boop_ccv_class' declares no version, skipping check for '$__boop_ccv_con'"
    return 0
  fi
  if [[ -n "${__boop_registry[SemVer]+set}" ]]; then
    SemVer.satisfies "$__boop_ccv_ver" "$__boop_ccv_con" ||
      _Crash "_Require: '$__boop_ccv_class' v${__boop_ccv_ver} does not satisfy '$__boop_ccv_con'"
  else
    _Warn "_Require: SemVer not loaded, skipping version check for '$__boop_ccv_class $__boop_ccv_con'"
  fi
}

# _Require — fatal class loader. Hard dependency declaration.
#
# Loads each named class or crashes if any cannot be loaded. Accepts an
# optional version constraint after a class name; if present, the class
# must be loaded and satisfy the constraint via SemVer (warn + skip if
# SemVer is not loaded -- graceful degradation).
#
# The `. boop ClassName` entry point uses _Require internally, so class
# files sourcing their own dependencies via `. boop X` remain fatal.
#
#   _Require Config             # crash if Config unavailable
#   _Require Math Config List   # crash if any are unavailable
#   _Require SemVer Math 1.2+  # load SemVer, then load Math and enforce >= 1.2
#
# A version constraint is any arg that starts with a digit or comparison
# operator (>=, >, <=, <) or ends with +. Class names start with uppercase,
# so there is no ambiguity.
#
# Tier-2 inherited variables: _Err (exit code on crash, default 1).
_Require() {
  local __Require_class="" __Require_ver="" __Require_arg
  for __Require_arg in "$@"; do
    if [[ "$__Require_arg" =~ ^[0-9] ]] || [[ "$__Require_arg" == '>'* ]] || [[ "$__Require_arg" == '<'* ]]; then
      __Require_ver="$__Require_arg"
    else
      if [[ -n "$__Require_class" ]]; then
        _Load "$__Require_class" || _Crash "_Require: '$__Require_class' could not be loaded"
        [[ -n "$__Require_ver" ]] && { __boop.checkClassVersion "$__Require_class" "$__Require_ver"; __Require_ver=""; }
      fi
      __Require_class="$__Require_arg"
    fi
  done
  if [[ -n "$__Require_class" ]]; then
    _Load "$__Require_class" || _Crash "_Require: '$__Require_class' could not be loaded"
    [[ -n "$__Require_ver" ]] && __boop.checkClassVersion "$__Require_class" "$__Require_ver"
  fi
  return 0
}

# ============================================================================
# ============================================================================
# CLASS DECLARATION — PUBLIC API
# ============================================================================

# Declare a class in one call. Builds the registry descriptor, registers
# all methods (standard and custom-impl), and bakes the dispatch wrappers.
#
# Replaces the manual three-step pattern (write __boop_registry, call
# registerMethod N times, call registerClass) with a single declaration.
#
# Arguments: all args are joined into one string, then parsed as
#   whitespace-separated tokens. First token is the class name.
#   Remaining tokens are key:value pairs:
#
#   isa:Parent       — parent class (default: boop)
#   has:p1,p2,p3     — property names (comma-separated)
#   public:m1,m2,m3  — methods with standard Class.method impl
#   custom:m=fn,...   — methods with explicit impl (m=implFunction)
#
# Tokens can appear in any order. Multiple tokens of the same key are
# merged (so you can split long lists across multiple args).
#
# Usage:
#   boopClass Hand isa:List public:new,total,isBust,isBlackjack,show has:type
#
#   boopClass Math isa:boop \
#     public:new,eq,lt,gt,le,ge,cmp,round,toInt,toScale,format,val,toString,isZero \
#     custom:add=__Math.i_add,sub=__Math.i_sub,mul=__Math.i_mul \
#     has:digits,scale,neg
#
# For methods registered on a DIFFERENT class (e.g., Container adding
# methods to boop), use boopExtend — it appends methods to an existing
# class without overwriting its descriptor.

# Shared helper — parse public:/custom: token lists and call
# registerMethod for each entry. Used by both boopClass and boopExtend.
#   $1 = class name
#   $2 = comma-separated public method names (may be empty)
#   $3 = comma-separated custom entries "name=impl" (may be empty)
__boopClass.registerMethods() {
  local __boopClass_rm_class="$1" __boopClass_rm_public="$2" __boopClass_rm_custom="$3"
  local __boopClass_rm_mname __boopClass_rm_entry __boopClass_rm_impl

  if [[ -n "$__boopClass_rm_public" ]]; then
    IFS=',' read -ra __boopClass_rm_pubArr <<< "$__boopClass_rm_public"
    for __boopClass_rm_mname in "${__boopClass_rm_pubArr[@]}"; do
      [[ -n "$__boopClass_rm_mname" ]] || continue
      __boop.registerMethod "$__boopClass_rm_class" "$__boopClass_rm_mname"
    done
  fi

  if [[ -n "$__boopClass_rm_custom" ]]; then
    IFS=',' read -ra __boopClass_rm_customArr <<< "$__boopClass_rm_custom"
    for __boopClass_rm_entry in "${__boopClass_rm_customArr[@]}"; do
      __boopClass_rm_mname="${__boopClass_rm_entry%%=*}"
      __boopClass_rm_impl="${__boopClass_rm_entry#*=}"
      [[ -n "$__boopClass_rm_mname" && -n "$__boopClass_rm_impl" ]] ||
        _Crash "boopClass: bad custom entry '$__boopClass_rm_entry' — expected name=impl"
      __boop.registerMethod "$__boopClass_rm_class" "$__boopClass_rm_mname" "$__boopClass_rm_impl"
    done
  fi
}

# Parse the token stream shared by boopClass and boopExtend.
# Sets caller-scoped variables: __boopClass_class, __boopClass_parent,
# __boopClass_public, __boopClass_custom, __boopClass_has.
__boopClass.parseTokens() {
  local IFS=$' \t\n'
  local __boopClass_pt_input="$*"
  __boopClass_class="" ; __boopClass_parent="boop"
  __boopClass_public=""; __boopClass_custom=""; __boopClass_has=""
  __boopClass_version=""; __boopClass_mixins=""
  local __boopClass_pt_token __boopClass_pt_val

  for __boopClass_pt_token in $__boopClass_pt_input; do
    case "$__boopClass_pt_token" in
      isa:*)     __boopClass_parent="${__boopClass_pt_token#isa:}" ;;
      has:*)     __boopClass_pt_val="${__boopClass_pt_token#has:}"
                 __boopClass_has="${__boopClass_has:+$__boopClass_has,}$__boopClass_pt_val" ;;
      public:*)  __boopClass_pt_val="${__boopClass_pt_token#public:}"
                 __boopClass_public="${__boopClass_public:+$__boopClass_public,}$__boopClass_pt_val" ;;
      custom:*)  __boopClass_pt_val="${__boopClass_pt_token#custom:}"
                 __boopClass_custom="${__boopClass_custom:+$__boopClass_custom,}$__boopClass_pt_val" ;;
      version:*) __boopClass_version="${__boopClass_pt_token#version:}" ;;
      mixin:*)   __boopClass_pt_val="${__boopClass_pt_token#mixin:}"
                 __boopClass_mixins="${__boopClass_mixins:+$__boopClass_mixins,}$__boopClass_pt_val" ;;
      *)         if [[ -z "$__boopClass_class" ]]; then
                   __boopClass_class="$__boopClass_pt_token"
                 else
                   _Crash "boopClass: unexpected token '$__boopClass_pt_token' (class already set to '$__boopClass_class')"
                 fi ;;
    esac
  done
}

# Build a combined method name list from public + custom tokens.
# Returns via nameref $1.
__boopClass.methodList() {
  local -n __boopClass_ml_out="$1"
  __boopClass_ml_out="$__boopClass_public"
  if [[ -n "$__boopClass_custom" ]]; then
    local __boopClass_ml_entry __boopClass_ml_mname
    IFS=',' read -ra __boopClass_ml_arr <<< "$__boopClass_custom"
    for __boopClass_ml_entry in "${__boopClass_ml_arr[@]}"; do
      __boopClass_ml_mname="${__boopClass_ml_entry%%=*}"
      __boopClass_ml_out="${__boopClass_ml_out:+$__boopClass_ml_out,}$__boopClass_ml_mname"
    done
  fi
}

# boopMixin — declare a mixin (method bundle with no constructor or state).
#
# Syntax:
#   boopMixin MixinName public:m1,m2 [custom:m3=impl]
#
# The mixin's methods must be defined as functions before calling boopMixin.
# A class mixes in a mixin via the mixin: token in boopClass:
#   boopClass MyClass mixin:Printable public:new,...
#
# Resolution order: class methods win, then mixins in declaration order.
# Later mixins are shadowed but always reachable via $obj.Mixin::method.
boopMixin() {
  local __boopMixin_name="" __boopMixin_public="" __boopMixin_custom=""
  local __boopMixin_token __boopMixin_val
  for __boopMixin_token in "$@"; do
    case "$__boopMixin_token" in
      public:*) __boopMixin_val="${__boopMixin_token#public:}"
                __boopMixin_public="${__boopMixin_public:+$__boopMixin_public,}$__boopMixin_val" ;;
      custom:*) __boopMixin_val="${__boopMixin_token#custom:}"
                __boopMixin_custom="${__boopMixin_custom:+$__boopMixin_custom,}$__boopMixin_val" ;;
      *)        if [[ -z "$__boopMixin_name" ]]; then
                  __boopMixin_name="$__boopMixin_token"
                else
                  _Crash "boopMixin: unexpected token '$__boopMixin_token'"
                fi ;;
    esac
  done
  [[ -n "$__boopMixin_name" ]] || _Crash "boopMixin: no mixin name given"
  __boop.validate "$__boopMixin_name"

  # Build full method list
  local __boopMixin_allMethods="$__boopMixin_public"
  if [[ -n "$__boopMixin_custom" ]]; then
    local __boopMixin_entry __boopMixin_mname
    local __boopMixin_cArr; IFS=',' read -ra __boopMixin_cArr <<< "$__boopMixin_custom"
    for __boopMixin_entry in "${__boopMixin_cArr[@]}"; do
      __boopMixin_mname="${__boopMixin_entry%%=*}"
      __boopMixin_allMethods="${__boopMixin_allMethods:+$__boopMixin_allMethods,}$__boopMixin_mname"
    done
  fi

  __boop_mixin_registry["$__boopMixin_name"]="|methods=$__boopMixin_allMethods|"
  __boopClass.registerMethods "$__boopMixin_name" "$__boopMixin_public" "$__boopMixin_custom"
}

# boopClass — declare a new class in one statement.
#
# Writes a fresh descriptor, registers all methods, and builds
# dispatch wrappers. This is the standard way to define a class.
#
# Syntax:
#   boopClass ClassName [isa:Parent] public:m1,m2 [custom:m3=impl] [has:p1,p2]
#
# Examples:
#   boopClass Box public:new,volume,area,top,toString has:length,width,height
#   boopClass Hand isa:List public:new,total,isBust,isBlackjack,show has:type
#   boopClass Math public:new,val,toString custom:add=__Math.i_add has:digits,scale,neg
boopClass() {
  local __boopClass_class __boopClass_parent __boopClass_public __boopClass_custom __boopClass_has __boopClass_version __boopClass_mixins
  __boopClass.parseTokens "$@"
  [[ -n "$__boopClass_class" ]] || _Crash "boopClass: no class name given"

  local __boopClass_allMethods
  __boopClass.methodList __boopClass_allMethods

  # Validate mixins and collect their method names so backfillMethods finds them
  local __boopClass_mixin __boopClass_mixinMethods=""
  if [[ -n "$__boopClass_mixins" ]]; then
    local __boopClass_mArr; IFS=',' read -ra __boopClass_mArr <<< "$__boopClass_mixins"
    for __boopClass_mixin in "${__boopClass_mArr[@]}"; do
      [[ -n "$__boopClass_mixin" ]] || continue
      [[ -n "${__boop_mixin_registry[$__boopClass_mixin]+set}" ]] ||
        _Crash "boopClass: mixin '$__boopClass_mixin' not registered — load it before the class"
      local __boopClass_mMethods=""
      [[ "${__boop_mixin_registry[$__boopClass_mixin]}" =~ \|methods=([^|]*)\| ]] &&
        __boopClass_mMethods="${BASH_REMATCH[1]}"
      __boopClass_mixinMethods="${__boopClass_mixinMethods:+$__boopClass_mixinMethods,}$__boopClass_mMethods"
    done
  fi
  local __boopClass_allWithMixins="${__boopClass_allMethods}${__boopClass_mixinMethods:+${__boopClass_allMethods:+,}$__boopClass_mixinMethods}"

  __boop_registry["$__boopClass_class"]="|class=$__boopClass_class|trueClass=$__boopClass_class|parent=$__boopClass_parent|methods=$__boopClass_allWithMixins|properties=$__boopClass_has|version=$__boopClass_version|mixins=$__boopClass_mixins|"
  __boopClass.registerMethods "$__boopClass_class" "$__boopClass_public" "$__boopClass_custom"
  __boop.registerClass "$__boopClass_class"
  __boop.autoAlias "$__boopClass_class"
}

# boopExtend — add methods and properties to an existing class.
#
# Appends to the existing descriptor's methods= and properties= lists,
# registers the new methods, and rebuilds dispatch wrappers. Does not
# touch existing methods or properties.
#
# Usage:
#   boopExtend boop custom:itemFrom=__boop.itemFrom,setOn=__boop.setOn
boopExtend() {
  local __boopClass_class __boopClass_parent __boopClass_public __boopClass_custom __boopClass_has __boopClass_version
  __boopClass.parseTokens "$@"
  [[ -n "$__boopClass_class" ]] || _Crash "boopExtend: no class name given"
  [[ -n "${__boop_registry[$__boopClass_class]+set}" ]] ||
    _Crash "boopExtend: class '$__boopClass_class' not registered"

  local __boopExtend_newMethods
  __boopClass.methodList __boopExtend_newMethods

  # Append new methods to existing descriptor's methods= list
  if [[ -n "$__boopExtend_newMethods" ]]; then
    local __boopExtend_existing
    __boop.parse "$__boopClass_class" "methods" __boopExtend_existing
    local __boopExtend_combined="${__boopExtend_existing:+$__boopExtend_existing,}$__boopExtend_newMethods"
    __boop_registry["$__boopClass_class"]="${__boop_registry[$__boopClass_class]/|methods=*/|methods=$__boopExtend_combined|properties=}"
  fi

  # Append new properties to existing descriptor's properties= list
  if [[ -n "$__boopClass_has" ]]; then
    local __boopExtend_existingProps
    __boop.parse "$__boopClass_class" "properties" __boopExtend_existingProps
    local __boopExtend_combinedProps="${__boopExtend_existingProps:+$__boopExtend_existingProps,}$__boopClass_has"
    __boop_registry["$__boopClass_class"]="${__boop_registry[$__boopClass_class]/|properties=*/|properties=$__boopExtend_combinedProps}"
  fi

  __boopClass.registerMethods "$__boopClass_class" "$__boopClass_public" "$__boopClass_custom"
  __boop.registerClass "$__boopClass_class"
}

# ============================================================================
# DISPATCH HELPERS — _Delegate, _Super, _Cast
#
# Three helpers for the cases where normal $obj.method dispatch isn't enough.
# All three work by manipulating _Self and/or _Class before calling a function
# directly — no registry, no MRO walk, one hop.
#
# _Delegate — call a method on a DIFFERENT object from within a method body.
#   Clears _Class so the target object's own baked wrapper resolves correctly.
#   Without this, the calling method's _Class leaks into the called method.
#   Usage (inside a method): _Delegate $other.method "$@"
#
# _Super — call the PARENT class's version of a method from within an override.
#   Reads _Class to find the parent, sets _Class to parent for correct chaining.
#   Falls back to reading class from _Self descriptor if _Class is unset.
#   Usage (inside a method): _Super methodName "$@"
#
# _Cast — call a SPECIFIC class's method on an object, bypassing its own type.
#   Intentional typecast — use sparingly, document why at the call site.
#   Usage: _Cast ClassName $obj methodName "$@"
#
# Quick reference:
#   _Delegate $other.method   — different object, clean class context
#   _Super method             — same object, parent class implementation
#   _Cast Box $cube volume    — same object, explicit class override
# ============================================================================
_Delegate() { _Class='' into="${into:-}" "$@"; }

_Super() {
  [[ -n "${1:-}" ]] || _Crash "_Super: method name required"
  local __boop_Super_class="${_Class:-}"
  [[ -z "$__boop_Super_class" && -n "${_Self:-}" ]] &&
    __boop.parse "$_Self" "class" __boop_Super_class
  [[ -n "$__boop_Super_class" ]] || _Crash "_Super: no class context"
  local __boop_Super_parent
  __boop.parse "$__boop_Super_class" "parent" __boop_Super_parent
  [[ -n "$__boop_Super_parent" ]] || _Crash "_Super: $__boop_Super_class has no parent"
  _Self="${_Self:-}" _Class="$__boop_Super_parent" into="${into:-}" "$__boop_Super_parent.$@"
}

_Cast() {
  [[ -n "${1:-}" ]] || _Crash "_Cast: class name required"
  [[ -n "${2:-}" ]] || _Crash "_Cast: object required"
  [[ -n "${3:-}" ]] || _Crash "_Cast: method name required"
  local __boop_Cast_class="$1" __boop_Cast_self="$2"; shift 2
  _Self="$__boop_Cast_self" _Class="$__boop_Cast_class" into="${into:-}" "$__boop_Cast_class.$@"
}

# Stamp an existing object with a new class in the registry.
# Rewrites the class= field in the descriptor, then force-regenerates
# ALL method and property wrappers so every wrapper reflects the new
# class identity. Force is required because inherited wrappers (e.g.,
# isa, toString) were baked with the old class and must be overwritten.
# Usage: _Bless $obj ClassName
_Bless() {
  local __boop_Bless_id="$1" __boop_Bless_class="$2" __boop_Bless_current_class
  __boop.parse "$__boop_Bless_id" "class" __boop_Bless_current_class
  [[ "$__boop_Bless_current_class" == "$__boop_Bless_id" ]] && 
    _Crash "_Bless: '$__boop_Bless_id' is a class, not an object"
  [[ -n "${__boop_registry[$__boop_Bless_id]:-}" ]] || 
    _Crash "_Bless: '$__boop_Bless_id' is not a registered object"
  [[ -n "${__boop_registry[$__boop_Bless_class]:-}" ]] || 
    _Crash "_Bless: '$__boop_Bless_class' is not a registered class"

  # Stamp the new class and trueClass
  local __boop_Bless_old="|class=$__boop_Bless_current_class"
  local __boop_Bless_new="|class=$__boop_Bless_class"
  __boop_registry[$__boop_Bless_id]="${__boop_registry[$__boop_Bless_id]/$__boop_Bless_old/$__boop_Bless_new}"

  # Update trueClass to the new class's trueClass
  local __boop_Bless_old_true __boop_Bless_new_true
  __boop.parse "$__boop_Bless_id" "trueClass" __boop_Bless_old_true
  __boop.parse "$__boop_Bless_class" "trueClass" __boop_Bless_new_true
  : "${__boop_Bless_new_true:=$__boop_Bless_class}"
  if [[ -n "$__boop_Bless_old_true" ]]; then
    __boop_registry[$__boop_Bless_id]="${__boop_registry[$__boop_Bless_id]/"|trueClass=$__boop_Bless_old_true"/"|trueClass=$__boop_Bless_new_true"}"
  fi

  # Force-regenerate ALL wrappers using the trueClass (FQN)
  __boop.backfillMethods "$__boop_Bless_id" "$__boop_Bless_new_true" force
}


# REGISTER BASE CLASS
# ============================================================================

# boop is the root of all inheritance. Every class ultimately inherits
# from it (parent chain terminates at boop's empty parent field).
# The standard methods registered here (get, set, isa, toString, new, super)
# are available to all objects unless overridden by a subclass.
__boop_registry["boop"]="|class=boop|trueClass=boop|parent=|methods=new,destroy,get,set,isa,mixes,trueClass,toString,inspect,super,isObject|properties=|mixins=|"

#boopClass boop '
#  custom:new=__boop.new,get=__boop.get,set=__boop.set,isa=__boop.isa,toString=__boop.toString
#'

__boop.registerMethod boop get __boop.get
__boop.registerMethod boop set __boop.set
__boop.registerMethod boop destroy __boop.destroy
__boop.registerMethod boop isa __boop.isa
__boop.registerMethod boop mixes __boop.mixes
__boop.registerMethod boop trueClass __boop.trueClass
__boop.registerMethod boop toString __boop.toString
__boop.registerMethod boop inspect __boop.inspect
__boop.registerMethod boop new __boop.new
__boop.registerMethod boop isObject boop.isObject
__boop.registerMethod boop resolve boop.resolve
__boop.registerMethod boop classPath boop.classPath
#__boop.registerMethod boop super __boop.super
__boop.registerClass boop

# ============================================================================
# INITIALIZATION COMPLETE
# ============================================================================

# Bootstrap the configuration layer: source RC chain, parse BOOPPATH,
# source .boopIndex files, check version mismatch.
__boop.loader

__boop_loaded=1

fi  # end of (( ! __boop_loaded ))
boop.init()     { __boop.guard "$1"                            && return 1; return 0; }
boop.initMixin(){ [[ -n "${__boop_mixin_registry[$1]+set}" ]] && return 1; return 0; }

# ============================================================
# Net/Socket/Socket
# ============================================================

# Socket — plaintext TCP connection via bash /dev/tcp.
#
# Manages the connection lifecycle (open, write, close) and exposes the
# underlying fd. Reading is left to the caller using bash primitives —
# bare read(1) for line-oriented protocols, $(cat <&$fd) for bulk slurp.
# No TLS (bash /dev/tcp is plaintext only).
#
# Usage:
#   into=s Socket.new host=example.com port=80 [timeout=30]
#   fd="${__boop_static[$s.fd]}"
#
#   printf 'GET / HTTP/1.1\r\nHost: example.com\r\nConnection: close\r\n\r\n' >&"$fd"
#
#   IFS= read -r status <&"$fd"; status="${status%$'\r'}"
#   while IFS= read -r h <&"$fd"; do h="${h%$'\r'}"; [[ -z "$h" ]] && break; done
#   body=$(cat <&"$fd")
#
#   $s.close

: # bundled
boop.init Socket || return 0

# ============================================================================
# Constructor
# ============================================================================

Socket.new() {
  local _Class="${_Class:-Socket}"
  local __Socket_new_self __Socket_new_host="" __Socket_new_port="" __Socket_new_timeout=30
  local __Socket_new_arg
  for __Socket_new_arg in "$@"; do
    case "$__Socket_new_arg" in
      host=*)    __Socket_new_host="${__Socket_new_arg#host=}" ;;
      port=*)    __Socket_new_port="${__Socket_new_arg#port=}" ;;
      timeout=*) __Socket_new_timeout="${__Socket_new_arg#timeout=}" ;;
    esac
  done
  [[ -n "$__Socket_new_host" ]] || { _Error "Socket.new: host required"; return 1; }
  [[ -n "$__Socket_new_port" ]] || { _Error "Socket.new: port required"; return 1; }

  local -i __Socket_new_fd=0
  exec {__Socket_new_fd}<>/dev/tcp/"$__Socket_new_host"/"$__Socket_new_port" || {
    _Error "Socket.new: could not connect to ${__Socket_new_host}:${__Socket_new_port}"
    return 1
  }

  into=__Socket_new_self __boop.new \
    host="$__Socket_new_host" \
    port="$__Socket_new_port" \
    fd="$__Socket_new_fd" \
    timeout="$__Socket_new_timeout" \
    closed="0"
  boop.pass "$__Socket_new_self" "${into:-}"
}

# ============================================================================
# Write
# ============================================================================

# Write raw bytes (no newline appended).
Socket.write() {
  local _Self="${_Self:-}" _Class="${_Class:-Socket}"
  printf '%s' "$1" >&"${__boop_static[${_Self}.fd]}"
}

# Write a line terminated with \r\n (HTTP, SMTP, etc.).
Socket.writeLine() {
  local _Self="${_Self:-}" _Class="${_Class:-Socket}"
  printf '%s\r\n' "$1" >&"${__boop_static[${_Self}.fd]}"
}

# ============================================================================
# Lifecycle
# ============================================================================

Socket.close() {
  local _Self="${_Self:-}" _Class="${_Class:-Socket}"
  [[ "${__boop_static[${_Self}.closed]:-0}" == "1" ]] && return
  local __Socket_close_fd="${__boop_static[${_Self}.fd]:-}"
  [[ -n "$__Socket_close_fd" && "$__Socket_close_fd" =~ ^[0-9]+$ ]] && \
    exec {__Socket_close_fd}>&-
  __boop_static["${_Self}.closed"]="1"
}

Socket._destroy() {
  local _Self="${_Self:-}" _Class="${_Class:-Socket}"
  [[ "${__boop_static[${_Self}.closed]:-0}" == "1" ]] && return
  local __Socket_destroy_fd="${__boop_static[${_Self}.fd]:-}"
  [[ -n "$__Socket_destroy_fd" && "$__Socket_destroy_fd" =~ ^[0-9]+$ ]] && \
    exec {__Socket_destroy_fd}>&-
}

# ============================================================================
# Registration
# ============================================================================

boopClass Socket 'has:host,port,fd,timeout,closed public:new,write,writeLine,close'

# ============================================================
# Config/Config
# ============================================================

# Config — structured config file reader/writer.
#
# Two formats, one interface:
#   Flat: key=value lines, # comments, blank lines ignored. Top-level keys.
#   INI:  [section] headers group key=value pairs. Keys stored as "section.key".
#         Top-level keys (before any header) have no prefix.
#
# Pure bash parsing (while IFS= read -r). Zero forks. No eval, no source.
#
# Storage: each Config instance owns:
#   __boop_config_${_Self}      (gA) — key → value
#   __boop_config_keys_${_Self} (ga) — insertion-ordered key list
#
# Descriptor properties:
#   file   — path of the file loaded from (used by save with no arg)
#   format — "flat" or "ini" (used by save to choose write format)

: # bundled

boop.init Config || return 0

# ============================================================================
# Config Implementation
# ============================================================================

# Constructor — creates an empty Config with no backing file.
# Usage: into=cfg Config.new
Config.new() {
  local _Class="${_Class:-Config}"
  local __Config_new_self
  into=__Config_new_self __boop.new "$@"
  declare -gA "__boop_config_${__Config_new_self}=()"
  declare -ga "__boop_config_keys_${__Config_new_self}=()"
  boop.pass "$__Config_new_self" ${into:-}
}

# Parse flat key=value lines from stdin into an existing Config object.
# Reduced-form primitive shared by load (file) and fromFlatString (string).
# Usage: __Config.parseFlat <config_id> < input
__Config.parseFlat() {
  local __Config_pf_self="$1"
  local -n __Config_pf_data="__boop_config_${__Config_pf_self}"
  local -n __Config_pf_keys_arr="__boop_config_keys_${__Config_pf_self}"
  local __Config_pf_line __Config_pf_key __Config_pf_val

  while IFS= read -r __Config_pf_line; do
    [[ -z "$__Config_pf_line" || "$__Config_pf_line" == '#'* ]] && continue
    [[ "$__Config_pf_line" != *'='* ]] && continue
    __Config_pf_key="${__Config_pf_line%%=*}"
    __Config_pf_val="${__Config_pf_line#*=}"
    [[ -z "$__Config_pf_key" ]] && continue
    _Trace "parseFlat: '$__Config_pf_key' = '$__Config_pf_val'"
    if [[ -z "${__Config_pf_data[$__Config_pf_key]+set}" ]]; then
      __Config_pf_keys_arr+=("$__Config_pf_key")
    fi
    __Config_pf_data[$__Config_pf_key]="$__Config_pf_val"
  done
}

# Load a flat key=value property file.
# Lines starting with # are comments. Blank lines are ignored.
# Usage: into=cfg Config.load ~/.myapp.cfg
Config.load() {
  local _Class="${_Class:-Config}"
  local __Config_load_file="${1:-}"
  [[ -n "$__Config_load_file" ]] || { _Error "Config.load: file path required"; return 1; }
  [[ -f "$__Config_load_file" ]] || { _Error "Config.load: file not found: $__Config_load_file"; return 1; }

  local __Config_load_self
  into=__Config_load_self __boop.new format=flat "file=$__Config_load_file"
  declare -gA "__boop_config_${__Config_load_self}=()"
  declare -ga "__boop_config_keys_${__Config_load_self}=()"

  _Debug "load: reading '$__Config_load_file'"
  __Config.parseFlat "$__Config_load_self" < "$__Config_load_file"
  local -n __Config_load_data="__boop_config_${__Config_load_self}"
  _Info "load: loaded '$__Config_load_file' (${#__Config_load_data[@]} keys) -> $__Config_load_self"
  boop.pass "$__Config_load_self" ${into:-}
}

# Parse a flat key=value string directly (no file required).
# Usage: into=cfg Config.fromFlatString "$prop_string"
Config.fromFlatString() {
  local _Class="${_Class:-Config}"
  local __Config_ffs_str="${1:-}"
  local __Config_ffs_self
  into=__Config_ffs_self __boop.new format=flat
  declare -gA "__boop_config_${__Config_ffs_self}=()"
  declare -ga "__boop_config_keys_${__Config_ffs_self}=()"
  __Config.parseFlat "$__Config_ffs_self" <<< "$__Config_ffs_str"
  boop.pass "$__Config_ffs_self" ${into:-}
}

# Parse INI-format lines from stdin into an existing Config object.
# Reduced-form primitive shared by loadINI (file) and fromString (string).
# Usage: __Config.parseINI <config_id> < input
__Config.parseINI() {
  local __Config_pi_self="$1"
  local -n __Config_pi_data="__boop_config_${__Config_pi_self}"
  local -n __Config_pi_keys_arr="__boop_config_keys_${__Config_pi_self}"
  local __Config_pi_line __Config_pi_section="" __Config_pi_key __Config_pi_val

  while IFS= read -r __Config_pi_line; do
    [[ -z "$__Config_pi_line" || "$__Config_pi_line" == '#'* ]] && continue
    if [[ "$__Config_pi_line" =~ ^\[([^]]+)\]$ ]]; then
      __Config_pi_section="${BASH_REMATCH[1]}"
      _Trace "parseINI: section [$__Config_pi_section]"
      continue
    fi
    [[ "$__Config_pi_line" != *'='* ]] && continue
    __Config_pi_key="${__Config_pi_line%%=*}"
    __Config_pi_val="${__Config_pi_line#*=}"
    [[ -z "$__Config_pi_key" ]] && continue
    [[ -n "$__Config_pi_section" ]] && __Config_pi_key="${__Config_pi_section}.${__Config_pi_key}"
    _Trace "parseINI: '$__Config_pi_key' = '$__Config_pi_val'"
    if [[ -z "${__Config_pi_data[$__Config_pi_key]+set}" ]]; then
      __Config_pi_keys_arr+=("$__Config_pi_key")
    fi
    __Config_pi_data[$__Config_pi_key]="$__Config_pi_val"
  done
}

# Load an INI-format file.
# [section] headers group key=value pairs. Keys stored as "section.key".
# Keys before the first header are top-level (stored as-is, no prefix).
# Usage: into=cfg Config.loadINI /etc/myapp.ini
Config.loadINI() {
  local _Class="${_Class:-Config}"
  local __Config_ini_file="${1:-}"
  [[ -n "$__Config_ini_file" ]] || { _Error "Config.loadINI: file path required"; return 1; }
  [[ -f "$__Config_ini_file" ]] || { _Error "Config.loadINI: file not found: $__Config_ini_file"; return 1; }

  local __Config_ini_self
  into=__Config_ini_self __boop.new format=ini "file=$__Config_ini_file"
  declare -gA "__boop_config_${__Config_ini_self}=()"
  declare -ga "__boop_config_keys_${__Config_ini_self}=()"

  _Debug "loadINI: reading '$__Config_ini_file'"
  __Config.parseINI "$__Config_ini_self" < "$__Config_ini_file"
  local -n __Config_ini_data="__boop_config_${__Config_ini_self}"
  _Info "loadINI: loaded '$__Config_ini_file' (${#__Config_ini_data[@]} keys) -> $__Config_ini_self"
  boop.pass "$__Config_ini_self" ${into:-}
}

# Get a value by key. Returns empty string if the key does not exist.
# Usage: into=val $cfg.get theme
#        into=host $cfg.get database.host
Config.get() {
  local _Class="${_Class:-Config}" _Self="${_Self:-}"
  local __Config_get_key="$1"
  local -n __Config_get_data="__boop_config_${_Self}"
  local __Config_get_val="${__Config_get_data[$__Config_get_key]:-}"
  _Trace "get: '$__Config_get_key' -> '$__Config_get_val'"
  boop.pass "$__Config_get_val" ${into:-}
}

# Set a key to a value. Adds the key at the end if new; preserves position
# if it already exists.
# Usage: $cfg.set theme dark
#        $cfg.set database.host localhost
Config.set() {
  local _Class="${_Class:-Config}" _Self="${_Self:-}"
  local __Config_set_key="$1" __Config_set_val="$2"
  local -n __Config_set_data="__boop_config_${_Self}"
  local -n __Config_set_keys="__boop_config_keys_${_Self}"
  if [[ -z "${__Config_set_data[$__Config_set_key]+set}" ]]; then
    _Debug "set: '$__Config_set_key' = '$__Config_set_val' (new key)"
    __Config_set_keys+=("$__Config_set_key")
  else
    _Debug "set: '$__Config_set_key' = '$__Config_set_val' (update)"
  fi
  __Config_set_data[$__Config_set_key]="$__Config_set_val"
}

# Test whether a key exists. Returns exit code 0 (present) or 1 (absent).
# Usage: $cfg.has database.port && echo "port configured"
Config.has() {
  local _Class="${_Class:-Config}" _Self="${_Self:-}"
  local -n __Config_has_data="__boop_config_${_Self}"
  if [[ -n "${__Config_has_data[$1]+set}" ]]; then
    _Trace "has: '$1' -> true"
    return 0
  fi
  _Trace "has: '$1' -> false"
  return 1
}

# Return keys as a newline-delimited string in insertion order.
# With no argument: all keys (including section-prefixed INI keys).
# With a section argument: keys in that section only, without the prefix.
# Usage: into=all_keys $cfg.keys
#        into=db_keys  $cfg.keys database
Config.keys() {
  local _Class="${_Class:-Config}" _Self="${_Self:-}"
  local __Config_keys_section="${1:-}"
  local -n __Config_keys_list="__boop_config_keys_${_Self}"
  local __Config_keys_out="" __Config_keys_k __Config_keys_sep=""
  local __Config_keys_prefix="${__Config_keys_section:+${__Config_keys_section}.}"

  local __Config_keys_d="${_EOL:-$'\n'}"
  _Trace "keys: ${#__Config_keys_list[@]} key(s)${__Config_keys_section:+ in section '$__Config_keys_section'}"
  for __Config_keys_k in "${__Config_keys_list[@]+"${__Config_keys_list[@]}"}"; do
    if [[ -n "$__Config_keys_section" ]]; then
      [[ "$__Config_keys_k" == "$__Config_keys_prefix"* ]] || continue
      __Config_keys_k="${__Config_keys_k#"$__Config_keys_prefix"}"
    fi
    __Config_keys_out="${__Config_keys_out}${__Config_keys_sep}${__Config_keys_k}"
    __Config_keys_sep="${__Config_keys_d}"
  done
  boop.pass "$__Config_keys_out" ${into:-}
}

# Return a newline-delimited list of distinct section names in insertion order.
# Keys without a dot (top-level keys) are not listed.
# Usage: into=sections $cfg.sections
Config.sections() {
  local _Class="${_Class:-Config}" _Self="${_Self:-}"
  local -n __Config_sections_keys="__boop_config_keys_${_Self}"
  local __Config_sections_d="${_EOL:-$'\n'}"
  local __Config_sections_out="" __Config_sections_sep=""
  local -A __Config_sections_seen=()
  local __Config_sections_k __Config_sections_s
  _Trace "sections: scanning ${#__Config_sections_keys[@]} key(s)"
  for __Config_sections_k in "${__Config_sections_keys[@]+"${__Config_sections_keys[@]}"}"; do
    [[ "$__Config_sections_k" == *'.'* ]] || continue
    __Config_sections_s="${__Config_sections_k%%.*}"
    [[ -n "${__Config_sections_seen[$__Config_sections_s]+set}" ]] && continue
    __Config_sections_seen[$__Config_sections_s]=1
    __Config_sections_out="${__Config_sections_out}${__Config_sections_sep}${__Config_sections_s}"
    __Config_sections_sep="${__Config_sections_d}"
  done
  boop.pass "$__Config_sections_out" ${into:-}
}

# Write the current state back to a file.
# Uses the format the config was originally loaded in (flat or ini).
# If no file argument is given, uses the file it was loaded from.
# Usage: $cfg.save
#        $cfg.save /path/to/output.cfg
Config.save() {
  local _Class="${_Class:-Config}" _Self="${_Self:-}"
  local __Config_save_target="${1:-}"
  if [[ -z "$__Config_save_target" ]]; then
    into=__Config_save_target __boop.get file
  fi
  [[ -n "$__Config_save_target" ]] || { _Error "Config.save: no file specified and no source file recorded"; return 1; }

  local __Config_save_format
  into=__Config_save_format __boop.get format
  _Debug "save: -> '$__Config_save_target' (format=${__Config_save_format:-flat})"
  case "${__Config_save_format:-flat}" in
    ini) Config.toINI  "$__Config_save_target" ;;
    *)   Config.toFlat "$__Config_save_target" ;;
  esac
}

# Write as flat key=value format.
# With a file argument: write to that file. Without: return as string via boop.pass.
# Usage: $cfg.toFlat ~/.myapp.cfg
#        into=text $cfg.toFlat
Config.toFlat() {
  local _Class="${_Class:-Config}" _Self="${_Self:-}"
  local __Config_toFlat_file="${1:-}"
  local -n __Config_toFlat_data="__boop_config_${_Self}"
  local -n __Config_toFlat_keys="__boop_config_keys_${_Self}"
  local __Config_toFlat_eol="${_EOL:-$'\n'}"
  local __Config_toFlat_delim="${_Delimiter:-=}"
  local __Config_toFlat_out="" __Config_toFlat_k __Config_toFlat_sep=""

  for __Config_toFlat_k in "${__Config_toFlat_keys[@]+"${__Config_toFlat_keys[@]}"}"; do
    __Config_toFlat_out="${__Config_toFlat_out}${__Config_toFlat_sep}${__Config_toFlat_k}${__Config_toFlat_delim}${__Config_toFlat_data[$__Config_toFlat_k]}"
    __Config_toFlat_sep="${__Config_toFlat_eol}"
  done

  if [[ -n "$__Config_toFlat_file" ]]; then
    _Debug "toFlat: writing ${#__Config_toFlat_keys[@]} key(s) to '$__Config_toFlat_file'"
    printf "%s\n" "$__Config_toFlat_out" > "$__Config_toFlat_file"
  else
    _Trace "toFlat: serializing ${#__Config_toFlat_keys[@]} key(s) to string"
    boop.pass "$__Config_toFlat_out" ${into:-}
  fi
}

# Write as INI format, grouping section-prefixed keys under [section] headers.
# Top-level keys (no dot) appear first with no header.
# With a file argument: write to that file. Without: return as string via boop.pass.
# Usage: $cfg.toINI /etc/myapp.ini
#        into=text $cfg.toINI
Config.toINI() {
  local _Class="${_Class:-Config}" _Self="${_Self:-}"
  local __Config_toINI_file="${1:-}"
  local -n __Config_toINI_data="__boop_config_${_Self}"
  local -n __Config_toINI_keys="__boop_config_keys_${_Self}"
  local __Config_toINI_eol="${_EOL:-$'\n'}"
  local __Config_toINI_delim="${_Delimiter:-=}"
  local __Config_toINI_out="" __Config_toINI_k __Config_toINI_s __Config_toINI_bare
  local -a __Config_toINI_sections=()
  local -A __Config_toINI_sec_seen=()

  # Top-level keys first (no dot in key name)
  for __Config_toINI_k in "${__Config_toINI_keys[@]+"${__Config_toINI_keys[@]}"}"; do
    [[ "$__Config_toINI_k" == *'.'* ]] && continue
    __Config_toINI_out="${__Config_toINI_out}${__Config_toINI_k}${__Config_toINI_delim}${__Config_toINI_data[$__Config_toINI_k]}${__Config_toINI_eol}"
  done

  # Collect section names in insertion order
  for __Config_toINI_k in "${__Config_toINI_keys[@]+"${__Config_toINI_keys[@]}"}"; do
    [[ "$__Config_toINI_k" == *'.'* ]] || continue
    __Config_toINI_s="${__Config_toINI_k%%.*}"
    [[ -n "${__Config_toINI_sec_seen[$__Config_toINI_s]+set}" ]] && continue
    __Config_toINI_sec_seen[$__Config_toINI_s]=1
    __Config_toINI_sections+=("$__Config_toINI_s")
  done

  # Write each section
  for __Config_toINI_s in "${__Config_toINI_sections[@]+"${__Config_toINI_sections[@]}"}"; do
    __Config_toINI_out="${__Config_toINI_out}${__Config_toINI_eol}[${__Config_toINI_s}]${__Config_toINI_eol}"
    for __Config_toINI_k in "${__Config_toINI_keys[@]+"${__Config_toINI_keys[@]}"}"; do
      [[ "$__Config_toINI_k" == "${__Config_toINI_s}."* ]] || continue
      __Config_toINI_bare="${__Config_toINI_k#"${__Config_toINI_s}."}"
      __Config_toINI_out="${__Config_toINI_out}${__Config_toINI_bare}${__Config_toINI_delim}${__Config_toINI_data[$__Config_toINI_k]}${__Config_toINI_eol}"
    done
  done

  __Config_toINI_out="${__Config_toINI_out%"${__Config_toINI_eol}"}"

  if [[ -n "$__Config_toINI_file" ]]; then
    _Debug "toINI: writing ${#__Config_toINI_keys[@]} key(s) to '$__Config_toINI_file'"
    printf "%s\n" "$__Config_toINI_out" > "$__Config_toINI_file"
  else
    _Trace "toINI: serializing ${#__Config_toINI_keys[@]} key(s) to string"
    boop.pass "$__Config_toINI_out" ${into:-}
  fi
}

# Parse an INI-format string directly (no file required).
# Usage: into=cfg Config.fromString "$schema_string"
Config.fromString() {
  local _Class="${_Class:-Config}"
  local __Config_fs_str="${1:-}"
  local __Config_fs_self
  into=__Config_fs_self __boop.new format=ini
  declare -gA "__boop_config_${__Config_fs_self}=()"
  declare -ga "__boop_config_keys_${__Config_fs_self}=()"
  __Config.parseINI "$__Config_fs_self" <<< "$__Config_fs_str"
  boop.pass "$__Config_fs_self" ${into:-}
}

# Destroy companion arrays. Private hook called by __boop.destroy.
Config._destroy() {
  local _Class="${_Class:-Config}" _Self="${_Self:-}"
  _Trace "destroy: unsetting __boop_config_${_Self}, __boop_config_keys_${_Self}"
  unset "__boop_config_${_Self}" "__boop_config_keys_${_Self}"
}

# ============================================================================
# Class Declaration
# ============================================================================

boopClass Config has:file,format '
  public:new,load,loadINI,fromString,fromFlatString,get,set,has,keys,sections,save,toFlat,toINI
'

# ============================================================
# Args/Args
# ============================================================

# Args -- CLI argument parser.
#
# Two entry points:
#   Args.getOpts ":x:y" "$@"   -- POSIX short options via getopts
#   Args.parse 'schema' "$@"   -- GNU long + subcommand parser
#
# Schema format (INI-style string, left of # is parsed):
#   [Use]         -- synopsis text, documentation only
#   [Options]     -- global options
#   [Subcommands] -- valid subcommands: name [| alias...]  [# description]
#   [SubcmdName]  -- options specific to that subcommand
#   [Parser]      -- parser-behavior toggles (bareKV)
#
# Option line syntax:
#   [: ] varName[TYPE][<] [| alias...]  [= [default] | :]
#
#   Leading :        → required
#   TYPE suffix:
#     (none)         → scalar (string); duplicate crashes
#     []             → array; each occurrence appends (no duplicate check)
#     {}             → map; each occurrence is k=v or bare k (boolean)
#   < suffix         → load value from file rather than using it directly
#   Trailing =       → takes a value; "= default" sets the default
#   Trailing :       → takes a value (no default)
#   No value sigil   → boolean (absent → "", present → "1")
#
# Arrays and maps always take a value (the type marker implies it).
# Maps accept k=v (sets key k to value v) or bare k (sets key k to "1").
# Duplicate scalar/boolean options crash. Duplicate map keys crash.
# Arrays allow unlimited repetition.
#
# File loading (<): the CLI value is treated as a filename.
#   scalar< -- entire file content slurped into the variable
#   []<     -- each line of the file appended as one array element
#   {}<     -- each non-empty line parsed as k=v or bare k into the map
#
# First entry in an option line is the variable name (valid bash identifier,
# no hyphens). Remaining entries are CLI aliases (may contain hyphens).
# Single-char entries map to -x; multi-char entries map to --name.
#
# Subcommand-scoped options (defined under [SubcmdName]) are only accepted
# after their subcommand is identified on the command line. Using a scoped
# option before the subcommand or under the wrong subcommand is a hard error.
#
# Scope-write mode (no into=):
#   Scalars/booleans: $varName set to value or ""
#   Arrays:           $varName declared as indexed bash array (declare -ga)
#   Maps:             $varName declared as associative bash array (declare -gA)
#   Also sets: $_Action (subcommand), $__Args_orig (original args),
#              $_ArgsRemaining (remaining positionals array).
#   To restore $@: set -- "${_ArgsRemaining[@]}"
#
# Object mode (into=):
#   Returns a Config object. Requires Config installed. Scope vars not set.
#   Scalars/booleans: $obj.get varName → string
#   Arrays:           $obj.get varName → _Delimiter-separated string
#   Maps:             $obj.get varName.key → string per key
#   Also: $obj.get _action / $obj.get _remaining (delimiter-separated)

: # bundled

boop.init Args || return 0

# ============================================================================
# Args.getOpts -- thin getopts wrapper
# ============================================================================

# Parses POSIX short options and sets a variable per recognized option.
# Value-taking options (letter followed by : in optstr) get the value string.
# Boolean options get "1". Caller must: shift $((OPTIND-1))
# Usage: Args.getOpts ":vf:" "$@"
Args.getOpts() {
  local __Args_getOpts_optstr="${1:-}"; shift
  declare -ga __Args_orig=("$@")

  # Build a value-flag set by scanning the optstr once
  local -A __Args_getOpts_takes=()
  local __Args_getOpts_i __Args_getOpts_ch
  for (( __Args_getOpts_i = 0; __Args_getOpts_i < ${#__Args_getOpts_optstr}; __Args_getOpts_i++ )); do
    __Args_getOpts_ch="${__Args_getOpts_optstr:$__Args_getOpts_i:1}"
    [[ "$__Args_getOpts_ch" == ":" ]] && continue
    [[ "${__Args_getOpts_optstr:$(( __Args_getOpts_i + 1 )):1}" == ":" ]] &&
      __Args_getOpts_takes[$__Args_getOpts_ch]=1
  done

  _Debug "getOpts: optstr='$__Args_getOpts_optstr'"
  local __Args_getOpts_opt
  OPTIND=1
  while getopts "$__Args_getOpts_optstr" __Args_getOpts_opt "$@"; do
    case "$__Args_getOpts_opt" in
      '?') _Error "Args.getOpts: unknown option: -$OPTARG"; OPTIND=$((OPTIND-1)); return 1 ;;
      ':') _Error "Args.getOpts: -$OPTARG requires a value"; OPTIND=$((OPTIND-1)); return 1 ;;
      *)
        if [[ -n "${__Args_getOpts_takes[$__Args_getOpts_opt]:-}" ]]; then
          _Debug "getOpts: -$__Args_getOpts_opt = '$OPTARG'"
          declare -g "${__Args_getOpts_opt}=${OPTARG}"
        else
          _Debug "getOpts: -$__Args_getOpts_opt = true"
          declare -g "${__Args_getOpts_opt}=1"
        fi
        ;;
    esac
  done
}

# ============================================================================
# Internal schema parsers (global tables __Args_* set during Args.parse)
# ============================================================================

# Parse one subcommand definition line into __Args_subcmd_map.
__Args.parseSubcmdLine() {
  # Capture description from # comment
  local __Args_psl_desc=""
  if [[ "$1" == *"#"* ]]; then
    __Args_psl_desc="${1#*#}"
    __Args_psl_desc="${__Args_psl_desc#"${__Args_psl_desc%%[![:space:]]*}"}"
    __Args_psl_desc="${__Args_psl_desc%"${__Args_psl_desc##*[![:space:]]}"}"
  fi
  local __Args_psl_line="${1%%#*}"
  __Args_psl_line="${__Args_psl_line%"${__Args_psl_line##*[![:space:]]}"}"
  [[ -z "$__Args_psl_line" ]] && return 0

  local __Args_psl_canonical="" __Args_psl_part __Args_psl_rest="$__Args_psl_line"
  while [[ -n "$__Args_psl_rest" ]]; do
    if [[ "$__Args_psl_rest" == *'|'* ]]; then
      __Args_psl_part="${__Args_psl_rest%%|*}"
      __Args_psl_rest="${__Args_psl_rest#*|}"
    else
      __Args_psl_part="$__Args_psl_rest"; __Args_psl_rest=""
    fi
    __Args_psl_part="${__Args_psl_part#"${__Args_psl_part%%[![:space:]]*}"}"
    __Args_psl_part="${__Args_psl_part%"${__Args_psl_part##*[![:space:]]}"}"
    [[ -z "$__Args_psl_part" ]] && continue
    [[ -z "$__Args_psl_canonical" ]] && __Args_psl_canonical="$__Args_psl_part"
    __Args_subcmd_map[$__Args_psl_part]="$__Args_psl_canonical"
  done
  [[ -n "$__Args_psl_canonical" && -n "$__Args_psl_desc" ]] &&
    __Args_subcmd_desc[$__Args_psl_canonical]="$__Args_psl_desc"
}

# Parse one option definition line. Populates __Args_alias_map, __Args_takes_val,
# __Args_required, __Args_defaults, __Args_varlist, __Args_var_scope,
# __Args_types, __Args_fileload.
# $1 = scope (subcommand name for scoped options, "" for global)
# $2 = raw line
__Args.parseOptLine() {
  local __Args_pol_scope="${1:-}" __Args_pol_line="${2%%#*}"
  local __Args_pol_desc=""
  if [[ "$2" == *"#"* ]]; then
    __Args_pol_desc="${2#*#}"
    __Args_pol_desc="${__Args_pol_desc#"${__Args_pol_desc%%[![:space:]]*}"}"
    __Args_pol_desc="${__Args_pol_desc%"${__Args_pol_desc##*[![:space:]]}"}"
  fi
  __Args_pol_line="${__Args_pol_line%"${__Args_pol_line##*[![:space:]]}"}"
  [[ -z "$__Args_pol_line" ]] && return 0

  # Required marker (leading :)
  local __Args_pol_required=0
  if [[ "$__Args_pol_line" == :* ]]; then
    __Args_pol_required=1
    __Args_pol_line="${__Args_pol_line#:}"
    __Args_pol_line="${__Args_pol_line#"${__Args_pol_line%%[![:space:]]*}"}"
  fi

  # Value sigil: trailing = (with optional default) or trailing :
  local __Args_pol_takesVal=0 __Args_pol_default=""
  if [[ "$__Args_pol_line" =~ ^(.*[^[:space:]])[[:space:]]*=[[:space:]]*(.*)$ ]]; then
    __Args_pol_takesVal=1
    __Args_pol_default="${BASH_REMATCH[2]}"
    __Args_pol_default="${__Args_pol_default%"${__Args_pol_default##*[![:space:]]}"}"
    __Args_pol_line="${BASH_REMATCH[1]}"
  elif [[ "$__Args_pol_line" =~ ^(.*[^[:space:]])[[:space:]]*:[[:space:]]*$ ]]; then
    __Args_pol_takesVal=1
    __Args_pol_line="${BASH_REMATCH[1]}"
  fi

  # Split on | -- first part is the variable name (with optional type markers),
  # rest are CLI aliases
  local __Args_pol_varName="" __Args_pol_part __Args_pol_rest="$__Args_pol_line"
  while [[ -n "$__Args_pol_rest" ]]; do
    if [[ "$__Args_pol_rest" == *'|'* ]]; then
      __Args_pol_part="${__Args_pol_rest%%|*}"
      __Args_pol_rest="${__Args_pol_rest#*|}"
    else
      __Args_pol_part="$__Args_pol_rest"; __Args_pol_rest=""
    fi
    __Args_pol_part="${__Args_pol_part#"${__Args_pol_part%%[![:space:]]*}"}"
    __Args_pol_part="${__Args_pol_part%"${__Args_pol_part##*[![:space:]]}"}"
    [[ -z "$__Args_pol_part" ]] && continue

    if [[ -z "$__Args_pol_varName" ]]; then
      # Detect and strip type markers: []< {}}< [] {} <
      # Order matters: check compound markers before simple ones.
      local __Args_pol_type="" __Args_pol_fl=0
      case "$__Args_pol_part" in
        *'[]<') __Args_pol_type="array"; __Args_pol_fl=1; __Args_pol_part="${__Args_pol_part%'[]<'}" ;;
        *'{}<') __Args_pol_type="map";   __Args_pol_fl=1; __Args_pol_part="${__Args_pol_part%'{}<'}" ;;
        *'[]')  __Args_pol_type="array";                  __Args_pol_part="${__Args_pol_part%'[]'}"  ;;
        *'{}')  __Args_pol_type="map";                    __Args_pol_part="${__Args_pol_part%'{}'}"  ;;
        *'<')   __Args_pol_fl=1;                          __Args_pol_part="${__Args_pol_part%'<'}"   ;;
      esac

      [[ "$__Args_pol_part" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]] ||
        _Crash "Args: '$__Args_pol_part' is not a valid variable name (hyphens only allowed in aliases)"
      __Args_pol_varName="$__Args_pol_part"
      __Args_varlist+=("$__Args_pol_varName")
      __Args_required[$__Args_pol_varName]=$__Args_pol_required
      __Args_defaults[$__Args_pol_varName]="$__Args_pol_default"
      __Args_descriptions[$__Args_pol_varName]="$__Args_pol_desc"
      __Args_var_scope[$__Args_pol_varName]="$__Args_pol_scope"
      __Args_types[$__Args_pol_varName]="$__Args_pol_type"
      [[ $__Args_pol_fl -eq 1 ]] && __Args_fileload[$__Args_pol_varName]=1
      # Arrays, maps, and file-loads always take a value; enforce regardless of sigil.
      [[ -n "$__Args_pol_type" || $__Args_pol_fl -eq 1 ]] && __Args_pol_takesVal=1
      __Args_takes_val[$__Args_pol_varName]=$__Args_pol_takesVal
    fi

    # Single-char → -x, multi-char → --name
    if [[ ${#__Args_pol_part} -eq 1 ]]; then
      __Args_alias_map["-${__Args_pol_part}"]="$__Args_pol_varName"
    else
      __Args_alias_map["--${__Args_pol_part}"]="$__Args_pol_varName"
    fi
  done
}

# ============================================================================
# Help generation
# ============================================================================

# Print formatted help from parsed schema tables, then exit 0.
# Respects __Args_parser_show: if set, only prints sections listed there.
# Default (empty): prints all sections except [Parser] and [Exclusive].
__Args.printHelp() {
  local __Args_ph_show="${__Args_parser_show:-}"
  local __Args_ph_section="" __Args_ph_line __Args_ph_printing=1

  while IFS= read -r __Args_ph_line; do
    # Detect section headers
    if [[ "$__Args_ph_line" =~ ^\[([^]]+)\]$ ]]; then
      __Args_ph_section="${BASH_REMATCH[1]}"
      if [[ -n "$__Args_ph_show" ]]; then
        # Only print sections in the show list
        __Args_ph_printing=0
        local __Args_ph_s
        local IFS=','
        for __Args_ph_s in $__Args_ph_show; do
          # Strip whitespace
          __Args_ph_s="${__Args_ph_s#"${__Args_ph_s%%[![:space:]]*}"}"
          __Args_ph_s="${__Args_ph_s%"${__Args_ph_s##*[![:space:]]}"}"
          if [[ "${__Args_ph_s,,}" == "${__Args_ph_section,,}" ]]; then
            __Args_ph_printing=1
            break
          fi
        done
      else
        # Default: skip internal sections and subscreen content sections
        case "$__Args_ph_section" in
          Parser|Exclusive|Requires|Together) __Args_ph_printing=0 ;;
          *)
            if [[ "${__Args_subscreen_sections[$__Args_ph_section]+_}" ]]; then
              __Args_ph_printing=0
            else
              __Args_ph_printing=1
            fi
            ;;
        esac
      fi
      # A section header line is structural markup, never content -- skip it
      # in all cases (shown or hidden). The section's body lines still print
      # when the section is shown.
      continue
    fi
    (( __Args_ph_printing )) && printf '%s\n' "$__Args_ph_line"
  done <<< "$__Args_parse_schema"
  # Explicit success: the loop's final '(( printing )) && printf' can leave a
  # non-zero status when the last line belongs to a hidden section, which under
  # the caller's `set -e` would abort before the post-help `exit 0`.
  return 0
}

# ============================================================================
# __Args.schemaLine -- parse a single [Parser] section line.
#
# [Parser] is the schema section for parser-behavior toggles. Recognized keys:
#
#   bareKV = true  -- accept bare 'key=value' positional args as '--key=value'.
#                     For boop-style constructors: `MyClass foo=bar` forwarded
#                     directly to Args.parse. Default: false (strict CLI).
#
# Unknown keys crash to catch typos.
__Args.schemaLine() {
  local __Args_sl_line="${1%%#*}"
  __Args_sl_line="${__Args_sl_line%"${__Args_sl_line##*[![:space:]]}"}"
  [[ -z "$__Args_sl_line" ]] && return 0
  local __Args_sl_key __Args_sl_val
  if [[ "$__Args_sl_line" =~ ^([A-Za-z_][A-Za-z0-9_]*)[[:space:]]*=[[:space:]]*(.*)$ ]]; then
    __Args_sl_key="${BASH_REMATCH[1]}"
    __Args_sl_val="${BASH_REMATCH[2]}"
  else
    _Crash "Args.parse: invalid [Parser] line: $__Args_sl_line"
  fi
  case "$__Args_sl_key" in
    bareKV)
      case "$__Args_sl_val" in
        true|1|yes|on)     __Args_parser_bareKV=1 ;;
        false|0|no|off|'') __Args_parser_bareKV=0 ;;
        *) _Crash "Args.parse: [Parser] bareKV expects true|false, got '$__Args_sl_val'" ;;
      esac
      ;;
    show) __Args_parser_show="$__Args_sl_val" ;;
    subscreen)
      [[ "$__Args_sl_val" =~ ^([A-Za-z_][A-Za-z0-9_]*)=([A-Za-z_][A-Za-z0-9_]*)$ ]] ||
        _Crash "Args.parse: [Parser] subscreen expects varName=SectionName, got '$__Args_sl_val'"
      local __Args_sl_vn="${BASH_REMATCH[1]}" __Args_sl_sn="${BASH_REMATCH[2]}"
      __Args_subscreen_map[$__Args_sl_vn]="$__Args_sl_sn"
      __Args_subscreen_sections[$__Args_sl_sn]="$__Args_sl_vn"
      __Args_subscreen_order+=("$__Args_sl_vn")
      # Register as a boolean option
      __Args_varlist+=("$__Args_sl_vn")
      __Args_required[$__Args_sl_vn]=0
      __Args_defaults[$__Args_sl_vn]=""
      __Args_descriptions[$__Args_sl_vn]=""
      __Args_var_scope[$__Args_sl_vn]=""
      __Args_types[$__Args_sl_vn]=""
      __Args_fileload[$__Args_sl_vn]=0
      __Args_takes_val[$__Args_sl_vn]=0
      __Args_alias_map["--$__Args_sl_vn"]="$__Args_sl_vn"
      ;;
    *) _Crash "Args.parse: [Parser] unknown key: $__Args_sl_key" ;;
  esac
}

# ============================================================================
# __Args_setVar -- store a scalar/boolean value into the working table.
# Array and map values are handled inline in phase 3 (they need special logic).
__Args_setVar() {
  __Args_values[$1]="$2"
}

# __Args_applyValue -- store one parsed option value, respecting type.
# Called from both the long-option and short-option paths in phase 3.
# $1 = varName  $2 = raw CLI value  $3 = CLI key (for error messages)
# Reads: __Args_types, __Args_fileload, __Args_values, __Args_parse_d (caller local)
__Args_applyValue() {
  local __Args_av_vn="$1" __Args_av_raw="$2" __Args_av_key="$3"
  local __Args_av_type="${__Args_types[$__Args_av_vn]:-}"
  local __Args_av_fl="${__Args_fileload[$__Args_av_vn]:-0}"

  if [[ "$__Args_av_type" == "array" ]]; then
    if [[ "$__Args_av_fl" == "1" ]]; then
      # Load each line of the file as one array element
      [[ -f "$__Args_av_raw" ]] ||
        { _Error "Args.parse: $__Args_av_key: file not found: '$__Args_av_raw'"; return 1; }
      local __Args_av_line
      while IFS= read -r __Args_av_line; do
        __Args_values[$__Args_av_vn]+="${__Args_values[$__Args_av_vn]:+${__Args_parse_d}}${__Args_av_line}"
      done < "$__Args_av_raw"
    else
      __Args_values[$__Args_av_vn]+="${__Args_values[$__Args_av_vn]:+${__Args_parse_d}}${__Args_av_raw}"
    fi

  elif [[ "$__Args_av_type" == "map" ]]; then
    # Parse k=v or bare k (boolean). File load reads k=v / bare-k lines.
    local __Args_av_lines
    if [[ "$__Args_av_fl" == "1" ]]; then
      [[ -f "$__Args_av_raw" ]] ||
        { _Error "Args.parse: $__Args_av_key: file not found: '$__Args_av_raw'"; return 1; }
      local __Args_av_fline
      while IFS= read -r __Args_av_fline; do
        [[ -n "$__Args_av_fline" ]] && __Args_av_lines+="${__Args_av_lines:+$'\n'}${__Args_av_fline}"
      done < "$__Args_av_raw"
    else
      __Args_av_lines="$__Args_av_raw"
    fi
    local __Args_av_entry __Args_av_mk __Args_av_mv
    while IFS= read -r __Args_av_entry; do
      [[ -n "$__Args_av_entry" ]] || continue
      if [[ "$__Args_av_entry" == *=* ]]; then
        __Args_av_mk="${__Args_av_entry%%=*}"
        __Args_av_mv="${__Args_av_entry#*=}"
      else
        __Args_av_mk="$__Args_av_entry"
        __Args_av_mv="1"
      fi
      [[ -z "${__Args_values[${__Args_av_vn}.${__Args_av_mk}]+set}" ]] ||
        { _Error "Args.parse: $__Args_av_key: duplicate map key '$__Args_av_mk'"; return 1; }
      __Args_values[${__Args_av_vn}.${__Args_av_mk}]="$__Args_av_mv"
      # Track key list in sentinel value (delimiter-joined)
      __Args_values[$__Args_av_vn]+="${__Args_values[$__Args_av_vn]:+${__Args_parse_d}}${__Args_av_mk}"
    done <<< "$__Args_av_lines"

  elif [[ "$__Args_av_fl" == "1" ]]; then
    # Scalar file load: slurp entire file (no subshell)
    [[ -f "$__Args_av_raw" ]] ||
      { _Error "Args.parse: $__Args_av_key: file not found: '$__Args_av_raw'"; return 1; }
    local __Args_av_content="" __Args_av_fline __Args_av_first=1
    while IFS= read -r __Args_av_fline || [[ -n "$__Args_av_fline" ]]; do
      if (( __Args_av_first )); then
        __Args_av_content="$__Args_av_fline"; __Args_av_first=0
      else
        __Args_av_content+=$'\n'"$__Args_av_fline"
      fi
    done < "$__Args_av_raw"
    __Args_setVar "$__Args_av_vn" "$__Args_av_content"

  else
    __Args_setVar "$__Args_av_vn" "$__Args_av_raw"
  fi
}

# Print subscreen sections for the given active varNames (in that order).
# Reads __Args_parse_schema (passed as $1) directly to preserve formatting.
# Prints a blank line separator between multiple subscreens.
__Args.printSubscreens() {
  local __Args_ps_schema="$1"; shift
  local -a __Args_ps_active=("$@")
  local __Args_ps_vn __Args_ps_target_sn __Args_ps_first=1
  for __Args_ps_vn in "${__Args_ps_active[@]}"; do
    __Args_ps_target_sn="${__Args_subscreen_map[$__Args_ps_vn]:-}"
    [[ -n "$__Args_ps_target_sn" ]] || continue
    (( __Args_ps_first )) || printf '\n'
    __Args_ps_first=0
    local __Args_ps_section="" __Args_ps_line __Args_ps_printing=0
    while IFS= read -r __Args_ps_line; do
      if [[ "$__Args_ps_line" =~ ^\[([^]]+)\]$ ]]; then
        __Args_ps_section="${BASH_REMATCH[1]}"
        if [[ "$__Args_ps_section" == "$__Args_ps_target_sn" ]]; then
          __Args_ps_printing=1
        elif (( __Args_ps_printing )); then
          break
        fi
        continue
      fi
      (( __Args_ps_printing )) && printf '%s\n' "$__Args_ps_line"
    done <<< "$__Args_ps_schema"
  done
}

# Args.parse -- GNU long + subcommand parser
# ============================================================================

Args.parse() {
  local __Args_parse_schema="${1:-}"; shift
  [[ -n "$__Args_parse_schema" ]] || { _Error "Args.parse: schema required"; return 1; }

  # Effective record separator for _ArgsRemaining in object mode
  local __Args_parse_d="${_EOL:-$'\n'}"

  # Working tables -- global for duration of parse, cleaned up after phase 5
  declare -gA __Args_alias_map=()
  declare -gA __Args_takes_val=()
  declare -gA __Args_required=()
  declare -gA __Args_defaults=()
  declare -gA __Args_subcmd_map=()
  declare -gA __Args_var_scope=()
  declare -ga __Args_varlist=()
  declare -gA __Args_descriptions=()
  declare -gA __Args_subcmd_desc=()
  declare -g  __Args_usage=""
  # Two seen-tables, deliberately separate:
  #   __Args_seen      -- PERSISTENT (+=). Records what the user supplied across
  #                       parses so Args.given still answers after a nested parse
  #                       (e.g. inside Stream.new) runs. The intended model is a
  #                       single script-argv parse per process; constructors may
  #                       parse internally without erasing the script's record.
  #   __Args_seen_this -- PER-PARSE (=). Reset every parse; backs duplicate-option
  #                       detection, which must only consider the current parse.
  declare -gA __Args_seen+=()
  declare -gA __Args_seen_this=()
  declare -gA __Args_values=()
  declare -gA __Args_types=()     # varname → "array" | "map" | "" (scalar/bool)
  declare -gA __Args_fileload=()  # varname → "1" if value is a filename to load
  # Parser-behavior flags set by the [Parser] schema section.
  declare -gi __Args_parser_bareKV=0
  declare -g  __Args_parser_show=""
  # Mutual exclusion groups from [Exclusive] section.
  declare -ga __Args_exclusive=()
  # Subscreens: [Parser] subscreen = varName=SectionName
  declare -gA __Args_subscreen_map=()      # varName → SectionName
  declare -gA __Args_subscreen_sections=() # SectionName → varName
  declare -ga __Args_subscreen_order=()    # varNames in declaration order
  # Dependency validation from [Requires] and [Together] sections.
  declare -ga __Args_requires=()
  declare -ga __Args_together=()

  # --- Phase 1: Parse schema ---
  _Debug "parse: parsing schema"
  local __Args_parse_section="" __Args_parse_ln
  while IFS= read -r __Args_parse_ln; do
    __Args_parse_ln="${__Args_parse_ln#"${__Args_parse_ln%%[![:space:]]*}"}"
    [[ -z "$__Args_parse_ln" ]] && continue
    if [[ "$__Args_parse_ln" =~ ^\[([^]]+)\]$ ]]; then
      __Args_parse_section="${BASH_REMATCH[1]}"
      _Trace "parse: schema section [$__Args_parse_section]"
      continue
    fi
    case "$__Args_parse_section" in
      Use|'') __Args_usage+="${__Args_parse_ln}"$'\n' ;;
      Subcommands) __Args.parseSubcmdLine "$__Args_parse_ln" ;;
      Options)     __Args.parseOptLine "" "$__Args_parse_ln" ;;
      Parser)      __Args.schemaLine "$__Args_parse_ln" ;;
      Exclusive)   __Args_exclusive+=("${__Args_parse_ln%%#*}") ;;
      Requires)    __Args_requires+=("${__Args_parse_ln%%#*}") ;;
      Together)    __Args_together+=("${__Args_parse_ln%%#*}") ;;
      *)
        if [[ "${__Args_subscreen_sections[$__Args_parse_section]+_}" ]]; then
          : # subscreen content — printed on demand; skip option parsing
        else
          __Args.parseOptLine "$__Args_parse_section" "$__Args_parse_ln"
        fi
        ;;
    esac
  done <<< "$__Args_parse_schema"

  # Snapshot varlist before cleanup (needed for object-mode pass)
  local -a __Args_parse_vars=("${__Args_varlist[@]+"${__Args_varlist[@]}"}")
  _Debug "parse: schema has ${#__Args_parse_vars[@]} option(s), ${#__Args_subcmd_map[@]} subcommand(s)"

  # --- Phase 2: Initialize result variables ---
  declare -ga __Args_orig=("$@")
  declare -g  _Action=""
  declare -ga _ArgsRemaining=()

  local __Args_parse_v
  for __Args_parse_v in "${__Args_parse_vars[@]+"${__Args_parse_vars[@]}"}"; do
    # Arrays and maps start empty; defaults only apply to scalars
    if [[ -z "${__Args_types[$__Args_parse_v]:-}" ]]; then
      __Args_setVar "$__Args_parse_v" "${__Args_defaults[$__Args_parse_v]:-}"
    else
      __Args_values[$__Args_parse_v]=""
    fi
  done

  # --- Phase 3: Walk args ---
  local __Args_parse_endopts=0
  local __Args_parse_arg __Args_parse_key __Args_parse_val __Args_parse_hasval
  local __Args_parse_vn __Args_parse_scope
  local __Args_parse_cluster __Args_parse_c __Args_parse_cvn __Args_parse_sv
  local __Args_parse_canon

  while [[ $# -gt 0 ]]; do
    __Args_parse_arg="$1"; shift

    if [[ "$__Args_parse_arg" == "--" && $__Args_parse_endopts -eq 0 ]]; then
      __Args_parse_endopts=1; continue
    fi

    if [[ $__Args_parse_endopts -eq 1 ]]; then
      _ArgsRemaining+=("$__Args_parse_arg"); continue
    fi

    # Help: --help or -h prints formatted help and exits
    if [[ "$__Args_parse_arg" == "--help" || "$__Args_parse_arg" == "-h" ]]; then
      __Args.printHelp
      exit 0
    fi

    # [Parser] bareKV=true: accept bare 'key=value' as '--key=value'.
    if (( __Args_parser_bareKV )) \
      && [[ "$__Args_parse_arg" != -* && "$__Args_parse_arg" == *=* ]]; then
      __Args_parse_arg="--${__Args_parse_arg}"
    fi

    # Long option: --name or --name=value
    if [[ "$__Args_parse_arg" == --?* ]]; then
      __Args_parse_hasval=0; __Args_parse_val=""
      if [[ "$__Args_parse_arg" == *=* ]]; then
        __Args_parse_key="${__Args_parse_arg%%=*}"
        __Args_parse_val="${__Args_parse_arg#*=}"
        __Args_parse_hasval=1
      else
        __Args_parse_key="$__Args_parse_arg"
      fi
      __Args_parse_vn="${__Args_alias_map[$__Args_parse_key]:-}"
      [[ -n "$__Args_parse_vn" ]] || { _Error "Args.parse: unknown option: $__Args_parse_key"; return 1; }

      # Duplicate detection: scalars/booleans only; arrays and maps allow repeats.
      # Checks the PER-PARSE table so a prior parse's options don't false-trip it.
      if [[ -z "${__Args_types[$__Args_parse_vn]:-}" ]]; then
        [[ -z "${__Args_seen_this[$__Args_parse_vn]+set}" ]] ||
          { _Error "Args.parse: duplicate option: $__Args_parse_key"; return 1; }
      fi
      # Mark given (all types) in both the per-parse and persistent tables.
      __Args_seen_this[$__Args_parse_vn]=1
      __Args_seen[$__Args_parse_vn]=1

      __Args_parse_scope="${__Args_var_scope[$__Args_parse_vn]:-}"
      if [[ -n "$__Args_parse_scope" ]]; then
        if [[ -z "$_Action" ]]; then
          _Error "Args.parse: $__Args_parse_key is only valid after subcommand '$__Args_parse_scope'"; return 1
        elif [[ "$__Args_parse_scope" != "$_Action" ]]; then
          _Error "Args.parse: $__Args_parse_key is not valid for subcommand '$_Action'"; return 1
        fi
      fi
      if [[ "${__Args_takes_val[$__Args_parse_vn]}" == 1 ]]; then
        if [[ $__Args_parse_hasval -eq 0 ]]; then
          [[ $# -gt 0 ]] || { _Error "Args.parse: $__Args_parse_key requires a value"; return 1; }
          __Args_parse_val="$1"; shift
        fi
        _Debug "parse: $__Args_parse_key ($__Args_parse_vn) = '$__Args_parse_val'"
        __Args_applyValue "$__Args_parse_vn" "$__Args_parse_val" "$__Args_parse_key" || return 1
      else
        [[ $__Args_parse_hasval -eq 0 ]] ||
          { _Error "Args.parse: $__Args_parse_key is a boolean flag, does not take a value"; return 1; }
        _Debug "parse: $__Args_parse_key ($__Args_parse_vn) = true"
        __Args_setVar "$__Args_parse_vn" "1"
      fi
      continue
    fi

    # Short option(s): -x, -xVALUE, or cluster -abc
    if [[ "$__Args_parse_arg" == -?* ]]; then
      __Args_parse_cluster="${__Args_parse_arg#-}"
      while [[ -n "$__Args_parse_cluster" ]]; do
        __Args_parse_c="${__Args_parse_cluster:0:1}"
        __Args_parse_cluster="${__Args_parse_cluster:1}"
        __Args_parse_cvn="${__Args_alias_map["-${__Args_parse_c}"]:-}"
        [[ -n "$__Args_parse_cvn" ]] || { _Error "Args.parse: unknown option: -${__Args_parse_c}"; return 1; }

        # Duplicate detection: scalars/booleans only (per-parse table).
        if [[ -z "${__Args_types[$__Args_parse_cvn]:-}" ]]; then
          [[ -z "${__Args_seen_this[$__Args_parse_cvn]+set}" ]] ||
            { _Error "Args.parse: duplicate option: -${__Args_parse_c}"; return 1; }
        fi
        # Mark given (all types) in both the per-parse and persistent tables.
        __Args_seen_this[$__Args_parse_cvn]=1
        __Args_seen[$__Args_parse_cvn]=1

        __Args_parse_scope="${__Args_var_scope[$__Args_parse_cvn]:-}"
        if [[ -n "$__Args_parse_scope" ]]; then
          if [[ -z "$_Action" ]]; then
            _Error "Args.parse: -$__Args_parse_c is only valid after subcommand '$__Args_parse_scope'"; return 1
          elif [[ "$__Args_parse_scope" != "$_Action" ]]; then
            _Error "Args.parse: -$__Args_parse_c is not valid for subcommand '$_Action'"; return 1
          fi
        fi
        if [[ "${__Args_takes_val[$__Args_parse_cvn]}" == 1 ]]; then
          if [[ -n "$__Args_parse_cluster" ]]; then
            __Args_parse_sv="$__Args_parse_cluster"; __Args_parse_cluster=""
          else
            [[ $# -gt 0 ]] || { _Error "Args.parse: -${__Args_parse_c} requires a value"; return 1; }
            __Args_parse_sv="$1"; shift
          fi
          _Debug "parse: -$__Args_parse_c ($__Args_parse_cvn) = '$__Args_parse_sv'"
          __Args_applyValue "$__Args_parse_cvn" "$__Args_parse_sv" "-$__Args_parse_c" || return 1
        else
          _Debug "parse: -$__Args_parse_c ($__Args_parse_cvn) = true"
          __Args_setVar "$__Args_parse_cvn" "1"
        fi
      done
      continue
    fi

    # Positional: check for subcommand match (first positional only)
    if [[ -z "$_Action" && ${#__Args_subcmd_map[@]} -gt 0 ]]; then
      __Args_parse_canon="${__Args_subcmd_map[$__Args_parse_arg]:-}"
      if [[ -n "$__Args_parse_canon" ]]; then
        _Debug "parse: subcommand '$__Args_parse_arg' -> '$__Args_parse_canon'"
        declare -g "_Action=$__Args_parse_canon"; continue
      fi
    fi

    _Trace "parse: positional '$__Args_parse_arg'"
    _ArgsRemaining+=("$__Args_parse_arg")
  done

  _Debug "parse: done -- action='$_Action', ${#_ArgsRemaining[@]} remaining"

  # --- Phase 3.5: Print subscreens if any are set, then exit ---
  if (( ${#__Args_subscreen_order[@]} > 0 )); then
    local -a __Args_parse_active_ss=()
    local __Args_parse_ss_vn
    for __Args_parse_ss_vn in "${__Args_subscreen_order[@]}"; do
      [[ -n "${__Args_values[$__Args_parse_ss_vn]:-}" ]] && \
        __Args_parse_active_ss+=("$__Args_parse_ss_vn")
    done
    if (( ${#__Args_parse_active_ss[@]} > 0 )); then
      __Args.printSubscreens "$__Args_parse_schema" "${__Args_parse_active_ss[@]}"
      exit 0
    fi
  fi

  # --- Phase 4: Validate required ---
  # For scalars: __Args_values[v] is the string value, empty means unset.
  # For arrays:  __Args_values[v] is the delimiter-joined list, empty means no entries.
  # For maps:    __Args_values[v] is the delimiter-joined key list, empty means no entries.
  # The same emptiness check works for all three types.
  local __Args_parse_missing="" __Args_parse_v_scope
  for __Args_parse_v in "${__Args_parse_vars[@]+"${__Args_parse_vars[@]}"}"; do
    __Args_parse_v_scope="${__Args_var_scope[$__Args_parse_v]:-}"
    [[ -n "$__Args_parse_v_scope" && "$__Args_parse_v_scope" != "$_Action" ]] && continue
    if [[ "${__Args_required[$__Args_parse_v]:-0}" == 1 \
       && -z "${__Args_values[$__Args_parse_v]:-}" ]]; then
      __Args_parse_missing="${__Args_parse_missing:+$__Args_parse_missing, }$__Args_parse_v"
    fi
  done
  [[ -z "$__Args_parse_missing" ]] ||
    { _Error "Args.parse: required options not provided: $__Args_parse_missing"; return 1; }

  # --- Phase 4b: Validate mutual exclusion groups ---
  # Pairwise form:  a | b | c         — at most one may be set
  # Group form:     (a b) | (c d) | e — at most one group may have any member set
  local __Args_parse_group __Args_parse_gvar __Args_parse_grest __Args_parse_gpart
  local __Args_parse_set_names __Args_parse_set_count
  local __Args_parse_gm __Args_parse_gmembers
  for __Args_parse_group in "${__Args_exclusive[@]+"${__Args_exclusive[@]}"}"; do
    __Args_parse_group="${__Args_parse_group#"${__Args_parse_group%%[![:space:]]*}"}"
    __Args_parse_group="${__Args_parse_group%"${__Args_parse_group##*[![:space:]]}"}"
    [[ -z "$__Args_parse_group" ]] && continue

    if [[ "$__Args_parse_group" == '('* ]]; then
      # Group form: (a b c) | (d e) — at most one group may have any member set
      local __Args_parse_groups_with_set=0 __Args_parse_group_names=""
      __Args_parse_grest="$__Args_parse_group"
      while [[ -n "$__Args_parse_grest" ]]; do
        if [[ "$__Args_parse_grest" == *'|'* ]]; then
          __Args_parse_gpart="${__Args_parse_grest%%|*}"
          __Args_parse_grest="${__Args_parse_grest#*|}"
        else
          __Args_parse_gpart="$__Args_parse_grest"; __Args_parse_grest=""
        fi
        __Args_parse_gpart="${__Args_parse_gpart#"${__Args_parse_gpart%%[![:space:]]*}"}"
        __Args_parse_gpart="${__Args_parse_gpart%"${__Args_parse_gpart##*[![:space:]]}"}"
        __Args_parse_gpart="${__Args_parse_gpart#'('}"
        __Args_parse_gpart="${__Args_parse_gpart%')'}"
        __Args_parse_gpart="${__Args_parse_gpart#"${__Args_parse_gpart%%[![:space:]]*}"}"
        __Args_parse_gpart="${__Args_parse_gpart%"${__Args_parse_gpart##*[![:space:]]}"}"
        [[ -z "$__Args_parse_gpart" ]] && continue
        local __Args_parse_g_has_set=0 __Args_parse_g_set_names=""
        local IFS=$' \t\n'
        read -ra __Args_parse_gmembers <<< "$__Args_parse_gpart"
        for __Args_parse_gm in "${__Args_parse_gmembers[@]+"${__Args_parse_gmembers[@]}"}"; do
          if [[ -n "${__Args_values[$__Args_parse_gm]:-}" ]]; then
            __Args_parse_g_has_set=1
            __Args_parse_g_set_names="${__Args_parse_g_set_names:+$__Args_parse_g_set_names, }$__Args_parse_gm"
          fi
        done
        if (( __Args_parse_g_has_set )); then
          (( __Args_parse_groups_with_set++ ))
          __Args_parse_group_names="${__Args_parse_group_names:+$__Args_parse_group_names; }$__Args_parse_g_set_names"
        fi
      done
      (( __Args_parse_groups_with_set <= 1 )) ||
        { _Error "Args.parse: mutually exclusive option groups used together: $__Args_parse_group_names"; return 1; }

    else
      # Pairwise form: a | b | c — at most one may be set
      __Args_parse_set_names="" __Args_parse_set_count=0
      __Args_parse_grest="$__Args_parse_group"
      while [[ -n "$__Args_parse_grest" ]]; do
        if [[ "$__Args_parse_grest" == *'|'* ]]; then
          __Args_parse_gvar="${__Args_parse_grest%%|*}"
          __Args_parse_grest="${__Args_parse_grest#*|}"
        else
          __Args_parse_gvar="$__Args_parse_grest"; __Args_parse_grest=""
        fi
        __Args_parse_gvar="${__Args_parse_gvar#"${__Args_parse_gvar%%[![:space:]]*}"}"
        __Args_parse_gvar="${__Args_parse_gvar%"${__Args_parse_gvar##*[![:space:]]}"}"
        [[ -z "$__Args_parse_gvar" ]] && continue
        if [[ -n "${__Args_values[$__Args_parse_gvar]:-}" ]]; then
          (( __Args_parse_set_count++ ))
          __Args_parse_set_names="${__Args_parse_set_names:+$__Args_parse_set_names, }$__Args_parse_gvar"
        fi
      done
      (( __Args_parse_set_count <= 1 )) ||
        { _Error "Args.parse: mutually exclusive options used together: $__Args_parse_set_names"; return 1; }
    fi
  done

  # --- Phase 4c: Validate [Requires] — if A set, at least one of B|C must be set ---
  local __Args_parse_req __Args_parse_req_lhs __Args_parse_req_rhs
  local __Args_parse_req_rvar __Args_parse_req_rhs_names __Args_parse_req_rest __Args_parse_req_found
  for __Args_parse_req in "${__Args_requires[@]+"${__Args_requires[@]}"}"; do
    __Args_parse_req="${__Args_parse_req#"${__Args_parse_req%%[![:space:]]*}"}"
    __Args_parse_req="${__Args_parse_req%"${__Args_parse_req##*[![:space:]]}"}"
    [[ -z "$__Args_parse_req" || "$__Args_parse_req" != *'=>'* ]] && continue
    __Args_parse_req_lhs="${__Args_parse_req%%'=>'*}"
    __Args_parse_req_rhs="${__Args_parse_req#*'=>'}"
    __Args_parse_req_lhs="${__Args_parse_req_lhs%"${__Args_parse_req_lhs##*[![:space:]]}"}"
    __Args_parse_req_lhs="${__Args_parse_req_lhs#"${__Args_parse_req_lhs%%[![:space:]]*}"}"
    __Args_parse_req_rhs="${__Args_parse_req_rhs#"${__Args_parse_req_rhs%%[![:space:]]*}"}"
    __Args_parse_req_rhs="${__Args_parse_req_rhs%"${__Args_parse_req_rhs##*[![:space:]]}"}"
    [[ -n "${__Args_values[$__Args_parse_req_lhs]:-}" ]] || continue
    __Args_parse_req_found=0
    __Args_parse_req_rhs_names=""
    __Args_parse_req_rest="$__Args_parse_req_rhs"
    while [[ -n "$__Args_parse_req_rest" ]]; do
      if [[ "$__Args_parse_req_rest" == *'|'* ]]; then
        __Args_parse_req_rvar="${__Args_parse_req_rest%%|*}"
        __Args_parse_req_rest="${__Args_parse_req_rest#*|}"
      else
        __Args_parse_req_rvar="$__Args_parse_req_rest"; __Args_parse_req_rest=""
      fi
      __Args_parse_req_rvar="${__Args_parse_req_rvar#"${__Args_parse_req_rvar%%[![:space:]]*}"}"
      __Args_parse_req_rvar="${__Args_parse_req_rvar%"${__Args_parse_req_rvar##*[![:space:]]}"}"
      [[ -z "$__Args_parse_req_rvar" ]] && continue
      __Args_parse_req_rhs_names="${__Args_parse_req_rhs_names:+$__Args_parse_req_rhs_names | }$__Args_parse_req_rvar"
      if [[ -n "${__Args_values[$__Args_parse_req_rvar]:-}" ]]; then
        __Args_parse_req_found=1; break
      fi
    done
    (( __Args_parse_req_found )) ||
      { _Error "Args.parse: $__Args_parse_req_lhs requires one of: $__Args_parse_req_rhs_names"; return 1; }
  done

  # --- Phase 4d: Validate [Together] — all or none ---
  local __Args_parse_tog __Args_parse_tog_set __Args_parse_tog_unset __Args_parse_tog_m
  local -a __Args_parse_tog_members
  for __Args_parse_tog in "${__Args_together[@]+"${__Args_together[@]}"}"; do
    __Args_parse_tog="${__Args_parse_tog#"${__Args_parse_tog%%[![:space:]]*}"}"
    __Args_parse_tog="${__Args_parse_tog%"${__Args_parse_tog##*[![:space:]]}"}"
    [[ -z "$__Args_parse_tog" ]] && continue
    local IFS=$' \t\n'
    read -ra __Args_parse_tog_members <<< "$__Args_parse_tog"
    __Args_parse_tog_set=0; __Args_parse_tog_unset=0
    for __Args_parse_tog_m in "${__Args_parse_tog_members[@]+"${__Args_parse_tog_members[@]}"}"; do
      if [[ -n "${__Args_values[$__Args_parse_tog_m]:-}" ]]; then
        (( __Args_parse_tog_set++ ))
      else
        (( __Args_parse_tog_unset++ ))
      fi
    done
    (( __Args_parse_tog_set == 0 || __Args_parse_tog_unset == 0 )) ||
      { _Error "Args.parse: options must be used together: ${__Args_parse_tog_members[*]:-}"; return 1; }
  done

  # --- Phase 5: Route parsed values to their destination ---
  if [[ -n "${into:-}" ]]; then
    # Object mode: build a Config and return it via into=
    _Require Config
    local __Args_parse_obj __Args_parse_rem=""
    into=__Args_parse_obj Config.new
    for __Args_parse_v in "${__Args_parse_vars[@]+"${__Args_parse_vars[@]}"}"; do
      __Args_parse_v_scope="${__Args_var_scope[$__Args_parse_v]:-}"
      [[ -z "$__Args_parse_v_scope" || "$__Args_parse_v_scope" == "$_Action" ]] || continue
      local __Args_parse_typ="${__Args_types[$__Args_parse_v]:-}"
      if [[ "$__Args_parse_typ" == "map" ]]; then
        # Store each key as varname.key — consistent with Config/JSON dot notation
        if [[ -n "${__Args_values[$__Args_parse_v]:-}" ]]; then
          local __Args_parse_mk
          while IFS= read -r __Args_parse_mk; do
            $__Args_parse_obj.set "${__Args_parse_v}.${__Args_parse_mk}" \
              "${__Args_values[${__Args_parse_v}.${__Args_parse_mk}]}"
          done <<< "${__Args_values[$__Args_parse_v]}"
        fi
      else
        # Scalars and arrays: arrays are already delimiter-joined strings
        $__Args_parse_obj.set "$__Args_parse_v" "${__Args_values[$__Args_parse_v]:-}"
      fi
    done
    if (( ${#_ArgsRemaining[@]} > 0 )); then
      printf -v __Args_parse_rem "%s${__Args_parse_d}" "${_ArgsRemaining[@]}"
      __Args_parse_rem="${__Args_parse_rem%"${__Args_parse_d}"}"
    fi
    $__Args_parse_obj.set _action    "$_Action"
    $__Args_parse_obj.set _remaining "$__Args_parse_rem"
    unset _Action _ArgsRemaining
    boop.pass "$__Args_parse_obj" ${into:-}

  elif [[ -n "${_Self:-${_Class:-}}" && "${_Self:-${_Class:-}}" != "Args" ]]; then
    # Object/class context: route each value to the property system.
    # Arrays and maps are stored as delimiter-joined strings (same as object mode).
    local __Args_parse_target="${_Self:-${_Class:-}}"
    for __Args_parse_v in "${__Args_parse_vars[@]+"${__Args_parse_vars[@]}"}"; do
      __Args_parse_v_scope="${__Args_var_scope[$__Args_parse_v]:-}"
      [[ -z "$__Args_parse_v_scope" || "$__Args_parse_v_scope" == "$_Action" ]] || continue
      local __Args_parse_typ="${__Args_types[$__Args_parse_v]:-}"
      if [[ "$__Args_parse_typ" == "map" ]]; then
        if [[ -n "${__Args_values[$__Args_parse_v]:-}" ]]; then
          local __Args_parse_mk
          while IFS= read -r __Args_parse_mk; do
            "$__Args_parse_target".set "${__Args_parse_v}.${__Args_parse_mk}" \
              "${__Args_values[${__Args_parse_v}.${__Args_parse_mk}]}"
          done <<< "${__Args_values[$__Args_parse_v]}"
        fi
      else
        "$__Args_parse_target".set "$__Args_parse_v" "${__Args_values[$__Args_parse_v]:-}"
      fi
    done

  else
    # Script context: set global variables with correct bash types.
    for __Args_parse_v in "${__Args_parse_vars[@]+"${__Args_parse_vars[@]}"}"; do
      __Args_parse_v_scope="${__Args_var_scope[$__Args_parse_v]:-}"
      [[ -z "$__Args_parse_v_scope" || "$__Args_parse_v_scope" == "$_Action" ]] || continue
      local __Args_parse_typ="${__Args_types[$__Args_parse_v]:-}"
      if [[ "$__Args_parse_typ" == "array" ]]; then
        unset "$__Args_parse_v"
        declare -ga "$__Args_parse_v"
        local -n __Args_parse_arr_ref="$__Args_parse_v"
        __Args_parse_arr_ref=()
        if [[ -n "${__Args_values[$__Args_parse_v]:-}" ]]; then
          local __Args_parse_arr_item
          while IFS= read -r __Args_parse_arr_item; do
            __Args_parse_arr_ref+=("$__Args_parse_arr_item")
          done <<< "${__Args_values[$__Args_parse_v]}"
        fi
      elif [[ "$__Args_parse_typ" == "map" ]]; then
        unset "$__Args_parse_v"
        declare -gA "$__Args_parse_v"
        local -n __Args_parse_map_ref="$__Args_parse_v"
        __Args_parse_map_ref=()
        if [[ -n "${__Args_values[$__Args_parse_v]:-}" ]]; then
          local __Args_parse_map_key
          while IFS= read -r __Args_parse_map_key; do
            __Args_parse_map_ref[$__Args_parse_map_key]="${__Args_values[${__Args_parse_v}.${__Args_parse_map_key}]}"
          done <<< "${__Args_values[$__Args_parse_v]}"
        fi
      else
        declare -g "${__Args_parse_v}=${__Args_values[$__Args_parse_v]:-}"
      fi
    done
  fi

  # Cleanup working tables. __Args_seen is intentionally NOT unset here: it
  # survives the parse to back Args.given (the "was this option supplied?"
  # query). It is reset at the top of the next parse.
  unset __Args_alias_map __Args_takes_val __Args_required __Args_defaults \
        __Args_subcmd_map __Args_varlist __Args_var_scope \
        __Args_descriptions __Args_subcmd_desc __Args_usage \
        __Args_seen_this __Args_values __Args_types __Args_fileload \
        __Args_parser_bareKV __Args_parser_show __Args_exclusive \
        __Args_subscreen_map __Args_subscreen_sections __Args_subscreen_order \
        __Args_requires __Args_together
}

# ============================================================================
# Args.given -- was an option supplied on the command line?
#
# After a scope-write Args.parse, a scalar option that was omitted and one
# that was given an empty value (--opt '') both leave $opt empty, so the value
# alone cannot tell them apart. Args.given answers the "was it supplied?"
# question by consulting the seen-table that parse leaves behind.
#
# Arguments:
#   $1 -- the option's variable name (the first name in its schema line,
#         e.g. "ofs" for `ofs | --output-sep =`)
# Returns: exit 0 if the option was supplied (any value, including empty),
#          exit 1 if it was not. Prints nothing.
#
# Scope: reflects the most recent scope-write Args.parse. In object mode
# (into=), query the returned object instead.
#
# Usage:
#   Args.parse '...' "$@"
#   if Args.given ofs; then printf 'output sep explicitly set to [%s]\n' "$ofs"; fi
Args.given() {
  local _Self="${_Self:-}" _Class="${_Class:-Args}"
  [[ -n "${1:-}" ]] || { _Error "Args.given: option name required"; return 2; }
  # Ensure the seen-table exists as an associative array before indexing it,
  # so a call before any Args.parse can't trip arithmetic-index evaluation on
  # a non-numeric key. Idempotent: creates it empty if absent, else no-op.
  declare -gA __Args_seen+=()
  [[ -n "${__Args_seen[$1]+set}" ]]
}

