__installer_self_name="probe"
__installer_self_url="${BOOP_DIST_URL:-https://boopshell.com/dist}/probe"

# Installer dispatch
declare -F __installer_dispatch >/dev/null ||
  . "$__probe_root/lib/installer"
__installer_dispatch "$@"

(( $# )) || set -- --help

Args.parse '
