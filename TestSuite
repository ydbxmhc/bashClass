#!/bin/bash

# TestSuite — structured test harness for boop
#
# Provides consistent assertion syntax, section grouping with timing,
# pass/fail accumulation, and a clean summary. Tests boop with boop.
#
# Modes:
#   immediate (default) — assertions execute and report as called
#   queue               — assertions are registered, then run as a batch via $t.run
#
# Verbosity:
#   Default is quiet — only failures and the summary are printed.
#   Set verbose=1 on construction or TESTSUITE_VERBOSE=1 in the environment
#   to see PASS lines, INFO lines, section headers, and section timing.
#
# Usage:
#   . boop TestSuite
#   into=t TestSuite name="My Tests"
#   $t.section "Basics"
#   $t.assert_eq "one is one" "1" "1"
#   $t.assert_ok "true is true" true
#   $t.summary
#
#   # Verbose: TESTSUITE_VERBOSE=1 bash my_test
#   # Or:     into=t TestSuite name="My Tests" verbose=1

[[ -n "${__boop_registry[TestSuite]+set}" ]] && return 2>/dev/null

. boop List Map

# ============================================================================
# Private helpers — _Self inherited from calling scope, not passed as $1
# ============================================================================

# Record a passing assertion. Prints PASS line if verbose.
__TestSuite._pass() {
  local __TS_pass_desc="$1" __TS_pass_v __TS_pass_p
  into=__TS_pass_v $_Self.get verbose
  [[ "$__TS_pass_v" == "1" ]] && printf "  PASS: %s\n" "$__TS_pass_desc"
  into=__TS_pass_p $_Self.get passed
  $_Self.set passed "$(( ${__TS_pass_p:-0} + 1 ))"
}

# Record a failing assertion. Always prints FAIL line.
__TestSuite._fail() {
  local __TS_fail_desc="$1" __TS_fail_detail="${2:-}" __TS_fail_f
  [[ -n "$__TS_fail_detail" ]]                                       && 
    printf "  FAIL: %s — %s\n" "$__TS_fail_desc" "$__TS_fail_detail" ||
    printf "  FAIL: %s\n" "$__TS_fail_desc"
  into=__TS_fail_f $_Self.get failed
  $_Self.set failed "$(( ${__TS_fail_f:-0} + 1 ))"
}

# Execute a single assertion.
# Called directly in immediate mode, or by $t.run for each queued assertion.
# Args: type desc [arg1 arg2 ...]
__TestSuite._exec() {
  local __TS_exec_type="$1" __TS_exec_desc="$2"; shift 2

  case "$__TS_exec_type" in
    eq) [[ "$1" == "$2" ]] && __TestSuite._pass "$__TS_exec_desc" ||
        __TestSuite._fail "$__TS_exec_desc" "expected '$2' got '$1'"
      ;;
    ne) [[ "$1" != "$2" ]] && __TestSuite._pass "$__TS_exec_desc" ||
        __TestSuite._fail "$__TS_exec_desc" "expected not '$2'"
      ;;
    ok)
      # Clear _Self/_Class so the user's command doesn't see TestSuite's
      # identity leaking into the code under test. The if/else captures
      # the exit code without triggering set -e on failure.
      local -i __TS_exec_rc=0
      local __TS_exec_stderr; __TS_exec_stderr=$(mktemp)
      if _Self="" _Class="" "$@" 2>"$__TS_exec_stderr"; then
        __TS_exec_rc=0
      else
        __TS_exec_rc=$?
      fi
      [[ -s "$__TS_exec_stderr" ]] && _Debug "$(<"$__TS_exec_stderr")"
      rm -f "$__TS_exec_stderr"
      (( __TS_exec_rc == 0 )) && __TestSuite._pass "$__TS_exec_desc" ||
        __TestSuite._fail "$__TS_exec_desc" "exit code $__TS_exec_rc"
      ;;
    fail)
      # Subshell contains any exit from the user's command.
      local -i __TS_exec_rc=0
      local __TS_exec_stderr; __TS_exec_stderr=$(mktemp)
      if ( _Self="" _Class="" "$@" ) 2>"$__TS_exec_stderr"; then
        __TS_exec_rc=0
      else
        __TS_exec_rc=$?
      fi
      [[ -s "$__TS_exec_stderr" ]] && _Debug "$(<"$__TS_exec_stderr")"
      rm -f "$__TS_exec_stderr"
      (( __TS_exec_rc != 0 )) && __TestSuite._pass "$__TS_exec_desc" ||
        __TestSuite._fail "$__TS_exec_desc" "expected non-zero exit, got 0"
      ;;
    match) [[ "$1" == $2 ]] && __TestSuite._pass "$__TS_exec_desc" ||
        __TestSuite._fail "$__TS_exec_desc" "'$1' doesn't match '$2'"
      ;;
    contains) [[ "$1" == *"$2"* ]] && __TestSuite._pass "$__TS_exec_desc" ||
      __TestSuite._fail "$__TS_exec_desc" "'$1' doesn't contain '$2'"
      ;;
    info)
      local __TS_exec_v
      into=__TS_exec_v $_Self.get verbose
      [[ "$__TS_exec_v" == "1" ]] && printf "  INFO: %s\n" "$__TS_exec_desc"
      ;;
  esac
}

# Route an assertion: execute immediately or store in the queue.
# Args: type desc [arg1 arg2 ...]
__TestSuite._route() {
  local __TS_route_type="$1" __TS_route_mode
  into=__TS_route_mode $_Self.get mode

  if [[ "$__TS_route_mode" == "immediate" ]]; then
    __TestSuite._exec "$@"
  else
    # Queue mode: store as a Map in the queue List.
    # @@ pipe-delimited args are fragile if args contain literal pipes.
    local __TS_route_map __TS_route_queue __TS_route_args="" __TS_route_arg
    into=__TS_route_map _Delegate Map
    _Delegate $__TS_route_map.setAt "type" "$__TS_route_type"
    _Delegate $__TS_route_map.setAt "desc" "$2"
    shift 2
    for __TS_route_arg in "$@"; do
      [[ -n "$__TS_route_args" ]] && __TS_route_args="$__TS_route_args|$__TS_route_arg" ||
        __TS_route_args="$__TS_route_arg"
    done
    _Delegate $__TS_route_map.setAt "args" "$__TS_route_args"
    into=__TS_route_queue $_Self.get queue
    _Delegate $__TS_route_queue.push "$__TS_route_map"
  fi
}

# ============================================================================
# Constructor
# ============================================================================

TestSuite.new() {
  local _Self="${_Self:-TestSuite}"; local _Class="${_Class:-TestSuite}"
  local __TS_new_self __TS_new_name="" __TS_new_mode="immediate"
  local __TS_new_verbose="${TESTSUITE_VERBOSE:-0}"
  local __TS_new_arg __TS_new_args

  for __TS_new_arg in "$@"; do
    case "$__TS_new_arg" in
      name=*)    __TS_new_name="${__TS_new_arg#name=}" ;;
      mode=*)    __TS_new_mode="${__TS_new_arg#mode=}" ;;
      verbose=*) __TS_new_verbose="${__TS_new_arg#verbose=}" ;;
    esac
  done

  [[ -n "$__TS_new_name" ]] || _Crash "TestSuite: name is required"
  [[ "$__TS_new_mode" == "immediate" || "$__TS_new_mode" == "queue" ]] || 
    _Crash "TestSuite: mode must be 'immediate' or 'queue', got '$__TS_new_mode'"

  __TS_new_args=( name="$__TS_new_name" mode="$__TS_new_mode" verbose="$__TS_new_verbose" 
    passed=0 failed=0 section_name="" section_start="" suite_start="$EPOCHREALTIME" queue="" )

  into=__TS_new_self __boop.new "${__TS_new_args[@]}"

  # Object is registered — safe to use method syntax now
  local _Self="$__TS_new_self"
  local __TS_new_queue
  into=__TS_new_queue _Delegate List
  $_Self.set queue "$__TS_new_queue"

  printf "=== %s ===\n" "$__TS_new_name"
  boop.pass "$__TS_new_self" ${into:-}
}

# ============================================================================
# Section management
# ============================================================================

TestSuite.section() {
  local _Self="${_Self:-$_Class}"; local _Class="${_Class:-TestSuite}"
  local __TS_sec_name="$1" __TS_sec_verbose __TS_sec_prev_start __TS_sec_mode
  into=__TS_sec_verbose    $_Self.get verbose
  into=__TS_sec_prev_start $_Self.get section_start

  # Print elapsed time for the section that just ended, if verbose + immediate
  if [[ -n "$__TS_sec_prev_start" && "$__TS_sec_verbose" == "1" ]]; then
    into=__TS_sec_mode $_Self.get mode
    [[ "$__TS_sec_mode" == "immediate" ]] && \
      printf "  [%.3fs]\n" "$(( ${EPOCHREALTIME//.} - ${__TS_sec_prev_start//.} ))e-6"
  fi

  [[ "$__TS_sec_verbose" == "1" ]] && printf "\n--- %s ---\n" "$__TS_sec_name"
  $_Self.set section_name "$__TS_sec_name"
  $_Self.set section_start "$EPOCHREALTIME"
}

# ============================================================================
# Public assertion methods
# ============================================================================

TestSuite.assert_eq()       { local _Self="${_Self:-$_Class}"; local _Class="${_Class:-TestSuite}"; __TestSuite._route eq       "$@"; }
TestSuite.assert_ne()       { local _Self="${_Self:-$_Class}"; local _Class="${_Class:-TestSuite}"; __TestSuite._route ne       "$@"; }
TestSuite.assert_ok()       { local _Self="${_Self:-$_Class}"; local _Class="${_Class:-TestSuite}"; __TestSuite._route ok       "$@"; }
TestSuite.assert_fail()     { local _Self="${_Self:-$_Class}"; local _Class="${_Class:-TestSuite}"; __TestSuite._route fail     "$@"; }
TestSuite.assert_match()    { local _Self="${_Self:-$_Class}"; local _Class="${_Class:-TestSuite}"; __TestSuite._route match    "$@"; }
TestSuite.assert_contains() { local _Self="${_Self:-$_Class}"; local _Class="${_Class:-TestSuite}"; __TestSuite._route contains "$@"; }

TestSuite.info() {
  local _Self="${_Self:-$_Class}"; local _Class="${_Class:-TestSuite}"
  local __TS_info_v
  into=__TS_info_v $_Self.get verbose
  [[ "$__TS_info_v" == "1" ]] && printf "  INFO: %s\n" "$1"
}

# ============================================================================
# Queue execution (queue mode only)
# ============================================================================

TestSuite.run() {
  local _Self="${_Self:-$_Class}"; local _Class="${_Class:-TestSuite}"
  local __TS_run_queue __TS_run_len
  into=__TS_run_queue $_Self.get queue
  into=__TS_run_len _Delegate $__TS_run_queue.length

  local -i __TS_run_i
  for (( __TS_run_i=0; __TS_run_i < __TS_run_len; __TS_run_i++ )); do
    local __TS_run_map __TS_run_type __TS_run_desc __TS_run_args_str
    into=__TS_run_map _Delegate      $__TS_run_queue.getAt $__TS_run_i
    into=__TS_run_type _Delegate     $__TS_run_map.getAt "type"
    into=__TS_run_desc _Delegate     $__TS_run_map.getAt "desc"
    into=__TS_run_args_str _Delegate $__TS_run_map.getAt "args"

    local -a __TS_run_args=()
    [[ -n "$__TS_run_args_str" ]] && IFS='|' read -ra __TS_run_args <<< "$__TS_run_args_str"

    __TestSuite._exec "$__TS_run_type" "$__TS_run_desc" "${__TS_run_args[@]}"
  done

  _Delegate $__TS_run_queue.clear

  local __TS_run_sec_start __TS_run_verbose
  into=__TS_run_sec_start $_Self.get section_start
  into=__TS_run_verbose   $_Self.get verbose
  if [[ -n "$__TS_run_sec_start" && "$__TS_run_verbose" == "1" ]]; then
    printf "  [%.3fs]\n" "$(( ${EPOCHREALTIME//.} - ${__TS_run_sec_start//.} ))e-6"
  fi
}

# ============================================================================
# Summary
# ============================================================================

TestSuite.summary() {
  local _Self="${_Self:-$_Class}"; local _Class="${_Class:-TestSuite}"
  local __TS_sum_verbose __TS_sum_mode __TS_sum_sec_start
  into=__TS_sum_verbose   $_Self.get verbose
  into=__TS_sum_mode      $_Self.get mode
  into=__TS_sum_sec_start $_Self.get section_start

  # Print final section timing if immediate + verbose
  if [[ "$__TS_sum_mode" == "immediate" && -n "$__TS_sum_sec_start" && "$__TS_sum_verbose" == "1" ]]; then
    printf "  [%.3fs]\n" "$(( ${EPOCHREALTIME//.} - ${__TS_sum_sec_start//.} ))e-6"
  fi

  local __TS_sum_name __TS_sum_p __TS_sum_f __TS_sum_start
  into=__TS_sum_name  $_Self.get name
  into=__TS_sum_p     $_Self.get passed
  into=__TS_sum_f     $_Self.get failed
  into=__TS_sum_start $_Self.get suite_start
  : "${__TS_sum_p:=0}" "${__TS_sum_f:=0}"

  printf "\n=== %s RESULTS ===\n" "$__TS_sum_name"
  printf "  Passed: %d\n" "$__TS_sum_p"
  printf "  Failed: %d\n" "$__TS_sum_f"
  printf "  Total:  %d\n" "$(( __TS_sum_p + __TS_sum_f ))"
  printf "  Time:   %.3fs\n" "$(( ${EPOCHREALTIME//.} - ${__TS_sum_start//.} ))e-6"

  if (( __TS_sum_f > 0 )); then
    printf "\n  *** %d FAILURES ***\n" "$__TS_sum_f"
    return 1
  fi
  printf "\n  All tests passed.\n"
}

# ============================================================================
# Class Declaration
# ============================================================================

boopClass TestSuite ' 
  has:name,mode,verbose,passed,failed,section_name,section_start,suite_start,queue
  public:new,section,run,summary
  public:assert_eq,assert_ne,assert_ok,assert_fail
  public:assert_match,assert_contains,info
'
