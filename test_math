#!/bin/bash
set -u

# Test suite for Math class — arbitrary precision string-based arithmetic

. boop Math

passed=0
failed=0

expect_val() {
  local __desc="$1" __expected="$2" __obj="$3"
  local __got
  into=__got $__obj.val
  if [[ "$__got" == "$__expected" ]]; then
    printf "  PASS: %s\n" "$__desc"
    (( passed++ ))
  else
    printf "  FAIL: %s expected '%s' got '%s'\n" "$__desc" "$__expected" "$__got"
    (( failed++ ))
  fi
}

expect_rc() {
  local __desc="$1" __expected="$2"; shift 2
  "$@" 2>/dev/null; local __rc=$?
  if (( __rc == __expected )); then
    printf "  PASS: %s (rc=%d)\n" "$__desc" "$__rc"
    (( passed++ ))
  else
    printf "  FAIL: %s expected rc=%d got rc=%d\n" "$__desc" "$__expected" "$__rc"
    (( failed++ ))
  fi
}

printf "=== MATH TEST SUITE ===\n"
__suite_start=$EPOCHREALTIME

# Use low precision for fast tests
__Math.setPrecision 10

# ============================================================================
# Construction
# ============================================================================

printf "\n--- Construction ---\n"

into=m1 Math 3.14
expect_val "3.14" "3.14" "$m1"

into=m2 Math 42
expect_val "integer 42" "42" "$m2"

into=m3 Math -7.5
expect_val "-7.5" "-7.5" "$m3"

into=m4 Math 0
expect_val "zero" "0" "$m4"

into=m5 Math 0.001
expect_val "0.001" "0.001" "$m5"

into=m6 Math -0
expect_val "negative zero normalizes" "0" "$m6"


# ============================================================================
# Addition
# ============================================================================

printf "\n--- Addition ---\n"

into=a1 Math 1.5
into=a2 Math 2.3
into=a3 $a1.add $a2
expect_val "1.5 + 2.3 = 3.8" "3.8" "$a3"

into=a4 $a1.add -1.5
expect_val "1.5 + (-1.5) = 0" "0" "$a4"

into=a5 Math -3.0
into=a6 Math -2.0
into=a7 $a5.add $a6
expect_val "-3 + (-2) = -5" "-5" "$a7"

into=a8 Math 999
into=a9 Math 1
into=a10 $a8.add $a9
expect_val "999 + 1 = 1000" "1000" "$a10"

into=a11 Math 0.1
into=a12 Math 0.2
into=a13 $a11.add $a12
expect_val "0.1 + 0.2 = 0.3 (exact!)" "0.3" "$a13"

# ============================================================================
# Subtraction
# ============================================================================

printf "\n--- Subtraction ---\n"

into=s1 Math 5.0
into=s2 Math 3.2
into=s3 $s1.sub $s2
expect_val "5 - 3.2 = 1.8" "1.8" "$s3"

into=s4 $s2.sub $s1
expect_val "3.2 - 5 = -1.8" "-1.8" "$s4"

into=s5 Math 100
into=s6 Math 100
into=s7 $s5.sub $s6
expect_val "100 - 100 = 0" "0" "$s7"

# ============================================================================
# Multiplication
# ============================================================================

printf "\n--- Multiplication ---\n"

into=mu1 Math 2.5
into=mu2 Math 4
into=mu3 $mu1.mul $mu2
expect_val "2.5 * 4 = 10" "10" "$mu3"

into=mu4 Math -3
into=mu5 Math 7
into=mu6 $mu4.mul $mu5
expect_val "-3 * 7 = -21" "-21" "$mu6"

into=mu7 Math 0.1
into=mu8 Math 0.1
into=mu9 $mu7.mul $mu8
expect_val "0.1 * 0.1 = 0.01" "0.01" "$mu9"

into=mu10 Math 12345
into=mu11 Math 67890
into=mu12 $mu10.mul $mu11
expect_val "12345 * 67890 = 838102050" "838102050" "$mu12"

# ============================================================================
# Division
# ============================================================================

printf "\n--- Division ---\n"

into=d1 Math 10
into=d2 Math 4
into=d3 precision=10 $d1.div $d2
into=d3v $d3.val
if [[ "$d3v" == 2.5 ]]; then
  printf "  PASS: 10 / 4 = 2.5\n"; (( passed++ ))
else
  printf "  FAIL: 10 / 4 expected 2.5 got '%s'\n" "$d3v"; (( failed++ ))
fi

into=d4 Math 1
into=d5 Math 3
into=d6 precision=10 $d4.div $d5
into=d6v $d6.val
# 1/3 = 0.3333333333...
if [[ "$d6v" == 0.333333333* ]]; then
  printf "  PASS: 1 / 3 ≈ 0.333...\n"; (( passed++ ))
else
  printf "  FAIL: 1 / 3 expected 0.333... got '%s'\n" "$d6v"; (( failed++ ))
fi

into=d7 Math 22
into=d8 Math 7
into=d9 precision=15 $d7.div $d8
into=d9v $d9.val
if [[ "$d9v" == 3.14285714* ]]; then
  printf "  PASS: 22 / 7 ≈ 3.14285714...\n"; (( passed++ ))
else
  printf "  FAIL: 22 / 7 expected 3.14285714... got '%s'\n" "$d9v"; (( failed++ ))
fi

# ============================================================================
# Comparisons
# ============================================================================

printf "\n--- Comparisons ---\n"

into=c1 Math 3.14
into=c2 Math 2.71
into=c3 Math 3.14

expect_rc "3.14 eq 3.14" 0 $c1.eq $c3
expect_rc "3.14 eq 2.71" 1 $c1.eq $c2
expect_rc "3.14 gt 2.71" 0 $c1.gt $c2
expect_rc "2.71 lt 3.14" 0 $c2.lt $c1
expect_rc "3.14 ge 3.14" 0 $c1.ge $c3
expect_rc "3.14 le 3.14" 0 $c1.le $c3

into=c4 Math -5
into=c5 Math 3
expect_rc "-5 lt 3" 0 $c4.lt $c5
expect_rc "3 gt -5" 0 $c5.gt $c4

# ============================================================================
# Utility methods
# ============================================================================

printf "\n--- Utilities ---\n"

into=u1 Math -42.5
into=u2 $u1.abs
expect_val "abs(-42.5) = 42.5" "42.5" "$u2"

into=u3 Math 7.7
into=u4 $u3.neg
expect_val "neg(7.7) = -7.7" "-7.7" "$u4"

into=u5 Math 3.14159
into=u6 $u5.toInt
if [[ "$u6" == "3" ]]; then
  printf "  PASS: toInt(3.14159) = 3\n"; (( passed++ ))
else
  printf "  FAIL: toInt(3.14159) expected 3 got '%s'\n" "$u6"; (( failed++ ))
fi


# ============================================================================
# Pi calculation — the big one
# ============================================================================

printf "\n--- Pi (10 digits) ---\n"

# Known pi to 50 digits: 3.14159265358979323846264338327950288419716939937510
__pi10_start=$EPOCHREALTIME
into=pi10 Math.pi 10
__pi10_end=$EPOCHREALTIME
into=pi10v $pi10.val
printf "  pi(10) = %s  [%s sec]\n" "$pi10v" "$(awk "BEGIN{printf \"%.3f\", $__pi10_end - $__pi10_start}")"
if [[ "$pi10v" == 3.14159265* ]]; then
  printf "  PASS: pi(10) starts with 3.14159265\n"; (( passed++ ))
else
  printf "  FAIL: pi(10) expected 3.14159265... got '%s'\n" "$pi10v"; (( failed++ ))
fi

printf "\n--- Pi (20 digits) ---\n"

__pi20_start=$EPOCHREALTIME
into=pi20 Math.pi 20
__pi20_end=$EPOCHREALTIME
into=pi20v $pi20.val
printf "  pi(20) = %s  [%s sec]\n" "$pi20v" "$(awk "BEGIN{printf \"%.3f\", $__pi20_end - $__pi20_start}")"
if [[ "$pi20v" == 3.141592653589793238* ]]; then
  printf "  PASS: pi(20) starts with 3.141592653589793238\n"; (( passed++ ))
else
  printf "  FAIL: pi(20) expected 3.141592653589793238... got '%s'\n" "$pi20v"; (( failed++ ))
fi

printf "\n--- Pi (50 digits) ---\n"

__pi50_start=$EPOCHREALTIME
into=pi50 Math.pi 50
__pi50_end=$EPOCHREALTIME
into=pi50v $pi50.val
printf "  pi(50) = %s  [%s sec]\n" "$pi50v" "$(awk "BEGIN{printf \"%.3f\", $__pi50_end - $__pi50_start}")"
# Known: 3.14159265358979323846264338327950288419716939937510
if [[ "$pi50v" == 3.141592653589793238462643383279502884197169399375* ]]; then
  printf "  PASS: pi(50) matches known value\n"; (( passed++ ))
else
  printf "  FAIL: pi(50) doesn't match known value\n"; (( failed++ ))
fi

# ============================================================================
# Square — loop test
# ============================================================================

printf "\n--- Square (loop) ---\n"

for __sq_x in 1 2 3 4 5; do
  into=__sq_m Math $__sq_x
  into=__sq_r $__sq_m.square
  into=__sq_v $__sq_r.val
  expect_val "$__sq_x² = $(( __sq_x * __sq_x ))" "$(( __sq_x * __sq_x ))" "$__sq_r"
done

# ============================================================================
# Full-word instance methods (backward compat + new names)
# ============================================================================

printf "\n--- Full-word instance methods ---\n"

into=fw1 Math 10
into=fw2 Math 3

into=fw3 $fw1.subtract $fw2
expect_val "10.subtract(3) = 7" "7" "$fw3"

into=fw4 $fw1.multiply $fw2
expect_val "10.multiply(3) = 30" "30" "$fw4"

into=fw5 $fw1.divide $fw2
into=fw5v $fw5.val
if [[ "$fw5v" == 3.333333333* ]]; then
  printf "  PASS: 10.divide(3) ≈ 3.333...\n"; (( passed++ ))
else
  printf "  FAIL: 10.divide(3) expected 3.333... got '%s'\n" "$fw5v"; (( failed++ ))
fi

# ============================================================================
# Static API — class-level functions returning plain value strings
# ============================================================================

printf "\n--- Static API ---\n"

expect_str() {
  local __desc="$1" __expected="$2" __got="$3"
  if [[ "$__got" == "$__expected" ]]; then
    printf "  PASS: %s\n" "$__desc"
    (( passed++ ))
  else
    printf "  FAIL: %s expected '%s' got '%s'\n" "$__desc" "$__expected" "$__got"
    (( failed++ ))
  fi
}

into=sa1 Math.add 1.5 2.3
expect_str "Math.add 1.5 2.3 = 3.8" "3.8" "$sa1"

into=sa2 Math.subtract 10 3.5
expect_str "Math.subtract 10 3.5 = 6.5" "6.5" "$sa2"

into=sa3 Math.multiply 2.5 4
expect_str "Math.multiply 2.5 4 = 10" "10" "$sa3"

into=sa4 Math.divide 10 4
expect_str "Math.divide 10 4 = 2.5" "2.5" "$sa4"

into=sa5 Math.square 7
expect_str "Math.square 7 = 49" "49" "$sa5"

into=sa6 Math.abs -42.5
expect_str "Math.abs -42.5 = 42.5" "42.5" "$sa6"

into=sa7 Math.neg 3.14
expect_str "Math.neg 3.14 = -3.14" "-3.14" "$sa7"

# ============================================================================
# Symbol aliases
# ============================================================================

printf "\n--- Symbol aliases ---\n"

into=sy1 Math.+ 1.5 2.3
expect_str "Math.+ 1.5 2.3 = 3.8" "3.8" "$sy1"

into=sy2 Math.- 10 3.5
expect_str "Math.- 10 3.5 = 6.5" "6.5" "$sy2"

into=sy3 Math.x 2.5 4
expect_str "Math.x 2.5 4 = 10" "10" "$sy3"

into=sy4 Math./ 10 4
expect_str "Math./ 10 4 = 2.5" "2.5" "$sy4"

# ============================================================================
# Math.DO (infix) — spaced, packed, mixed, negatives
# ============================================================================

printf "\n--- Math.DO (infix) ---\n"

into=do1 Math.DO 1.5 + 2.3
expect_str "Math.DO 1.5 + 2.3 = 3.8" "3.8" "$do1"

into=do2 Math.DO 2 + 3 x 4
expect_str "Math.DO 2 + 3 x 4 = 14 (precedence)" "14" "$do2"

into=do3 Math.DO "( 2 + 3 ) x 4"
expect_str "Math.DO (2+3) x 4 = 20 (parens)" "20" "$do3"

into=do4 Math.DO 10 - 2 - 3
expect_str "Math.DO 10 - 2 - 3 = 5 (left assoc)" "5" "$do4"

into=do5 Math.DO 100 / 4 / 5
expect_str "Math.DO 100 / 4 / 5 = 5" "5" "$do5"

into=do6 Math.DO "( 1.5 + 2.5 ) x ( 3 - 1 )"
expect_str "Math.DO (1.5+2.5)x(3-1) = 8" "8" "$do6"

# Packed expressions — no whitespace
into=do7 Math.DO "(2+3)x4"
expect_str "Math.DO packed (2+3)x4 = 20" "20" "$do7"

into=do8 Math.DO "10/2+3"
expect_str "Math.DO packed 10/2+3 = 8" "8" "$do8"

# Mixed: some quoted, some separate — "$*" flattens, precedence applies
into=do9 Math.DO "3 + 4" x 2
expect_str "Math.DO mixed '3 + 4' x 2 = 11 (precedence)" "11" "$do9"

# Negative numbers
into=do10 Math.DO "(-3)x4"
expect_str "Math.DO (-3)x4 = -12" "-12" "$do10"

into=do11 Math.DO -5 + 8
expect_str "Math.DO -5 + 8 = 3" "3" "$do11"

# ============================================================================
# Math.RPN (postfix) — separate, string, mixed
# ============================================================================

printf "\n--- Math.RPN (postfix) ---\n"

into=rp1 Math.RPN 1.5 2.3 +
expect_str "Math.RPN 1.5 2.3 + = 3.8" "3.8" "$rp1"

into=rp2 Math.RPN 3 4 + 2 x
expect_str "Math.RPN 3 4 + 2 x = 14" "14" "$rp2"

into=rp3 Math.RPN "10 3 /"
expect_str "Math.RPN 10 3 / starts with 3.33" "3.33" "${rp3:0:4}"

into=rp4 Math.RPN 5 3 - 2 x 1 +
expect_str "Math.RPN 5 3 - 2 x 1 + = 5" "5" "$rp4"

# Mixed input: some quoted, some separate
into=rp5 Math.RPN "1.5 2.5" + "3" x
expect_str "Math.RPN mixed '1.5 2.5' + '3' x = 12" "12" "$rp5"

# ============================================================================
# Static square loop (user's original request)
# ============================================================================

printf "\n--- Static square loop ---\n"

for __ssq_x in 1 2 3 4 5; do
  into=__ssq_v Math.square $__ssq_x
  expect_str "Math.square $__ssq_x = $(( __ssq_x * __ssq_x ))" "$(( __ssq_x * __ssq_x ))" "$__ssq_v"
done

# ============================================================================
# SUMMARY
# ============================================================================

printf "\n=== MATH TEST RESULTS ===\n"
__suite_end=$EPOCHREALTIME
printf "  Passed: %d\n" "$passed"
printf "  Failed: %d\n" "$failed"
printf "  Total:  %d\n" "$(( passed + failed ))"
printf "  Time:   %s sec\n" "$(awk "BEGIN{printf \"%.3f\", $__suite_end - $__suite_start}")"

if (( failed > 0 )); then
  printf "\n  *** %d FAILURES ***\n" "$failed"
  exit 1
fi

printf "\n  All tests passed.\n"
exit 0
