#!/bin/bash

# Container — virtual base class for all container types.
#
# Defines the interface contract that child classes (List, Map, Stack,
# Queue, LinkedList, etc.) must implement. This is bash's version of an
# abstract class — virtual methods crash with a clear error if a child
# forgets to override them.
#
# Architecture:
#   Container data lives in companion bash arrays, NOT in the pipe-delimited
#   descriptor. Each instance owns a global array named __bashClass_data_${self}.
#   Child constructors declare it as indexed (-ga) or associative (-gA).
#   The descriptor only holds metadata (class, parent, type).
#
# Why companion arrays instead of descriptor storage:
#   Bash arrays can't be nested inside associative arrays. Encoding a list
#   into a pipe-delimited string would require escaping delimiters inside
#   delimiters — fragile and slow. Companion arrays give us native bash
#   performance for element access while the object system handles identity,
#   dispatch, and lifecycle.
#
# Inheritance hierarchy:
#   bashClass → Container → List (indexed)
#                         → Map  (associative)
#                         → Stack, Queue, etc. (future)
#
# Virtual methods (child MUST override): get, set, delete, length, clear, has, toArray
# Provided methods (inherited, work for all): isEmpty, new, destroy, toString

# Load guard — if already registered, nothing to do
[[ -n "${__bashClass_registry[Container]+set}" ]] && return 2>/dev/null

. boop

# ============================================================================
# Container Class Descriptor
# ============================================================================

# The "type" property records the storage flavor ("indexed" or "associative")
# so toString and introspection can report it without checking the companion array.
__bashClass_registry["Container"]="|class=Container|parent=bashClass|methods=new,destroy,length,clear,has,get,set,delete,isEmpty,toArray,toString,itemAt,setAt|properties=type"

# ============================================================================
# Virtual methods — child classes MUST override these.
# Each one crashes with a message naming the actual child class ($class),
# not "Container", so the error tells you exactly which class forgot to
# implement the method. This is the closest bash gets to a pure virtual.
# ============================================================================

# Retrieve an element by key (Map) or index (List).
Container.get() {
  local -I self class
  __bashClass.crash "$class must implement 'get'"
}

# Store an element at a key (Map) or index (List).
Container.set() {
  local -I self class
  __bashClass.crash "$class must implement 'set'"
}

# Remove an element by key (Map) or index (List).
Container.delete() {
  local -I self class
  __bashClass.crash "$class must implement 'delete'"
}

# Return the number of elements in the container.
Container.length() {
  local -I self class
  __bashClass.crash "$class must implement 'length'"
}

# Remove all elements from the container.
Container.clear() {
  local -I self class
  __bashClass.crash "$class must implement 'clear'"
}

# Check if a key (Map) or index (List) exists in the container.
Container.has() {
  local -I self class
  __bashClass.crash "$class must implement 'has'"
}

# Serialize all elements to a string. Format is child-defined:
# List returns newline-delimited values, Map returns "key=value" lines.
Container.toArray() {
  local -I self class
  __bashClass.crash "$class must implement 'toArray'"
}

# ============================================================================
# Provided methods — work for all containers via delegation.
# ============================================================================

# Returns 0 (true) if container has no elements, 1 (false) otherwise.
# Delegates to the child's length implementation — works for any container
# type without knowing the storage details. Uses exit code convention
# for boolean: `$list.isEmpty && printf "nothing here"`
Container.isEmpty() {
  local -I self class
  local __Container_isEmpty_len
  into=__Container_isEmpty_len self="$self" class="$class" __bashClass.dispatch length
  (( __Container_isEmpty_len == 0 )) && return 0 || return 1
}

# Base constructor. Child classes override this to declare their companion
# array type (indexed or associative) and pass type= to the descriptor.
# The companion array is NOT created here — children own that responsibility
# because only they know whether to declare -ga or -gA.
Container.new() {
  local -I class
  : "${class:=Container}"
  local __Container_new_self
  into=__Container_new_self __bashClass.new "$@"
  __bashClass.return "$__Container_new_self" ${into:-}
}

# Destroy — clean up the companion array and remove the object from the
# registry. After this call, the object ID is invalid and any stubs/baked
# wrappers referencing it will crash on use (registry miss).
# Child classes can override to add cleanup (e.g., destroying nested
# objects in a tree structure), but should call super or replicate this.
Container.destroy() {
  local -I self class
  unset "__bashClass_data_${self}"
  unset "__bashClass_registry[$self]"
}

# Container-aware toString override. Shows class name, object ID, storage
# type, and element count. Child classes (List, Map) override this further
# to show actual contents — this version is the fallback for any container
# subclass that doesn't provide its own.
Container.toString() {
  local -I self class
  local -l prettyPrint; : "${prettyPrint:=false}"
  [[ "${1:-}" == "pretty" ]] && prettyPrint=true
  local __Container_ts_len __Container_ts_type
  into=__Container_ts_len self="$self" class="$class" __bashClass.dispatch length
  __bashClass.parse "$self" "type" __Container_ts_type

  if [[ "$prettyPrint" != "true" ]]; then
    __bashClass.return "$class($self){ type=$__Container_ts_type length=$__Container_ts_len }" ${into:-}
    return
  fi

  local __Container_ts_out
  printf -v __Container_ts_out "%s(%s) {\n  type   = %s\n  length = %s\n}" \
    "$class" "$self" "$__Container_ts_type" "$__Container_ts_len"
  __bashClass.return "$__Container_ts_out" ${into:-}
}

# ============================================================================
# Deep Traversal — itemAt / setAt (Container methods)
#
# IMPORTANT — why these methods use explicit dispatch instead of $cursor.get:
#
#   Most methods in this framework use `local -I self class` to inherit the
#   calling object's identity, then call `$self.method` or `$other.method`
#   and let the baked stubs handle dispatch. That works fine when every call
#   in the function targets the SAME object type.
#
#   Traversal methods are different. The cursor changes identity AND class
#   on every step — a List at level 0, a Map at level 1, a List again at
#   level 2. The problem is `local -I`: it makes `self` and `class`
#   inherited AND writable by callees. When we call `$cursor.get "$key"`,
#   the dispatch machinery sets `self` and `class` to the cursor's values
#   for that call — but those values LEAK BACK into our scope because
#   `local -I` doesn't create a protective copy, it creates a shared
#   binding up the call stack.
#
#   So after calling `$listCursor.get 0` (which sets class=List internally),
#   our local `class` variable is now "List". If the next cursor is a Map
#   and we call `$mapCursor.set "key" "val"`, the leaked class=List causes
#   dispatch to route to List.set instead of Map.set. List.set expects an
#   integer index, gets a string key, and crashes with "unbound variable".
#
#   The fix: we track the cursor's class explicitly in a local variable,
#   look it up from the registry after each step via __bashClass.parse,
#   and pass self= and class= as explicit environment prefixes on every
#   dispatch call. This overrides whatever `local -I` leaked and ensures
#   each step dispatches to the correct class implementation.
#
#   This is the ONLY place in the framework where this pattern is needed,
#   because it's the only place where a single function dispatches to
#   multiple different objects of potentially different classes in sequence.
# ============================================================================

# Walk nested containers by index/key path and return the leaf value.
#
# Each positional argument is a key (Map) or index (List) resolved in
# sequence. The cursor starts as this container, and each step does a
# .get to descend one level. If any intermediate resolves to empty
# (missing key, out-of-range index), returns empty string immediately —
# a read miss is not a crash.
#
# The final key's .get result is the return value. For a 2D matrix,
# two args; for a Map-of-Lists, two args; for deeper nesting, more args.
# The framework doesn't care about the mix of container types — each
# step dispatches get on whatever the cursor points to.
#
# See the block comment above for why we use explicit self=/class=
# dispatch instead of $cursor.get — `local -I` leaks class identity
# across calls, which breaks mixed-type traversal.
#
# Usage: into=val $matrix.itemAt 1 2         # matrix[1][2]
#        into=val $config.itemAt "db" "host"  # config["db"]["host"]
#        into=val $deep.itemAt 0 "key" 3 1    # four levels deep
Container.itemAt() {
  local -I self class
  local __Container_itemAt_cursor="$self" __Container_itemAt_class="$class"
  while (( $# > 1 )); do
    # Explicit self=/class= prevents local -I leak from previous iteration
    into=__Container_itemAt_cursor self="$__Container_itemAt_cursor" class="$__Container_itemAt_class" __bashClass.dispatch get "$1"
    [[ -n "$__Container_itemAt_cursor" ]] || { __bashClass.return "" ${into:-}; return; }
    # Cursor changed — resolve its actual class from the registry
    __bashClass.parse "$__Container_itemAt_cursor" "class" __Container_itemAt_class
    shift
  done
  # Final get — same explicit dispatch pattern
  self="$__Container_itemAt_cursor" class="$__Container_itemAt_class" into=__Container_itemAt_cursor __bashClass.dispatch get "$1"
  __bashClass.return "$__Container_itemAt_cursor" ${into:-}
}

# Walk nested containers by index/key path and set the leaf value.
#
# First argument is the value to write. Remaining arguments are the
# traversal path — all but the last key are resolved via .get (same
# as itemAt), then the last key is passed to .set on the penultimate
# container.
#
# Crashes if any intermediate resolves to empty — a write to a missing
# path is a logic error, not a silent no-op. If you're not sure the
# path exists, check with itemAt first.
#
# Same explicit self=/class= dispatch as itemAt — see the block comment
# above itemAt for the full explanation of the local -I leak hazard.
#
# Usage: $matrix.setAt "99" 1 2              # matrix[1][2] = "99"
#        $config.setAt "newhost" "db" "host"  # config["db"]["host"] = "newhost"
Container.setAt() {
  local -I self class
  local __Container_setAt_val="$1"; shift
  local __Container_setAt_cursor="$self" __Container_setAt_class="$class"
  while (( $# > 1 )); do
    # Explicit self=/class= prevents local -I leak from previous iteration
    into=__Container_setAt_cursor self="$__Container_setAt_cursor" class="$__Container_setAt_class" __bashClass.dispatch get "$1"
    [[ -n "$__Container_setAt_cursor" ]] || \
      __bashClass.crash "setAt: missing intermediate at '$1'"
    # Cursor changed — resolve its actual class from the registry
    __bashClass.parse "$__Container_setAt_cursor" "class" __Container_setAt_class
    shift
  done
  # Final set — explicit dispatch to the correct class at the leaf
  self="$__Container_setAt_cursor" class="$__Container_setAt_class" __bashClass.dispatch set "$1" "$__Container_setAt_val"
}

# ============================================================================
# Deep Traversal — itemFrom / setOn (bashClass augmentation)
#
# These methods are registered on bashClass so ALL objects can use them,
# but they only exist when Container is loaded. This is runtime augmentation:
# loading Container adds container-awareness to the entire object system.
#
# itemFrom starts by reading a named property from the object's descriptor
# (a bashClass .get via __bashClass.parse, not a Container .get), then
# walks the resulting container with the remaining keys — same loop as
# itemAt.
#
# setOn does the same walk but writes at the leaf.
#
# These methods use the same explicit self=/class= dispatch pattern as
# itemAt/setAt. See the block comment above itemAt for the full
# explanation of the local -I leak hazard that makes this necessary.
# The short version: when a function dispatches to multiple different
# objects in sequence, `local -I` leaks the class identity from one
# call into the next, causing dispatch to route to the wrong class.
# Explicit self=/class= on each dispatch call prevents this.
# ============================================================================

# Read a value from a container stored in a named property.
#
# First argument is the property name on this object (resolved via
# __bashClass.parse on the descriptor — NOT a Container .get). The
# property's value is expected to be a container object ID. Remaining
# arguments are the traversal path into that container, resolved the
# same way as itemAt.
#
# Returns empty if the property is empty or any intermediate is missing.
#
# Usage: into=val $cube.itemFrom tags 0        # cube.tags → List → get 0
#        into=val $cube.itemFrom tags 2 "name"  # cube.tags → List → Map → get "name"
__bashClass.itemFrom() {
  local -I self class
  local __itemFrom_cursor __itemFrom_class
  # First step: read the named property from the descriptor (bashClass get)
  __bashClass.parse "$self" "$1" __itemFrom_cursor
  [[ -n "$__itemFrom_cursor" ]] || { __bashClass.return "" ${into:-}; return; }
  # Resolve the container's class for explicit dispatch
  __bashClass.parse "$__itemFrom_cursor" "class" __itemFrom_class
  shift
  while (( $# > 1 )); do
    # Explicit self=/class= prevents local -I leak from previous iteration
    into=__itemFrom_cursor self="$__itemFrom_cursor" class="$__itemFrom_class" __bashClass.dispatch get "$1"
    [[ -n "$__itemFrom_cursor" ]] || { __bashClass.return "" ${into:-}; return; }
    # Cursor changed — resolve its actual class from the registry
    __bashClass.parse "$__itemFrom_cursor" "class" __itemFrom_class
    shift
  done
  # Final get — same explicit dispatch pattern
  self="$__itemFrom_cursor" class="$__itemFrom_class" into=__itemFrom_cursor __bashClass.dispatch get "$1"
  __bashClass.return "$__itemFrom_cursor" ${into:-}
}

# Write a value into a container stored in a named property.
#
# First argument is the property name (resolved via __bashClass.parse
# on the descriptor). Second argument is the value to write. Remaining
# arguments are the traversal path — same walk as itemFrom, but the
# last key gets a .set.
#
# Crashes if the property is empty or any intermediate is missing.
#
# Same explicit self=/class= dispatch as itemFrom — see the block
# comment above itemAt for the full explanation.
#
# Usage: $cube.setOn tags "urgent" 0            # cube.tags → List → set 0 "urgent"
#        $cube.setOn tags "newval" 2 "name"      # cube.tags → List → Map → set "name" "newval"
__bashClass.setOn() {
  local -I self class
  local __setOn_cursor __setOn_class
  # First step: read the named property from the descriptor (bashClass get)
  __bashClass.parse "$self" "$1" __setOn_cursor
  [[ -n "$__setOn_cursor" ]] || __bashClass.crash "setOn: property '$1' is empty"
  # Resolve the container's class for explicit dispatch
  __bashClass.parse "$__setOn_cursor" "class" __setOn_class
  shift
  local __setOn_val="$1"; shift
  while (( $# > 1 )); do
    # Explicit self=/class= prevents local -I leak from previous iteration
    into=__setOn_cursor self="$__setOn_cursor" class="$__setOn_class" __bashClass.dispatch get "$1"
    [[ -n "$__setOn_cursor" ]] || \
      __bashClass.crash "setOn: missing intermediate at '$1'"
    # Cursor changed — resolve its actual class from the registry
    __bashClass.parse "$__setOn_cursor" "class" __setOn_class
    shift
  done
  # Final set — explicit dispatch to the correct class at the leaf
  self="$__setOn_cursor" class="$__setOn_class" __bashClass.dispatch set "$1" "$__setOn_val"
}

# ============================================================================
# Register Methods & Finalize
# ============================================================================

# Container's own methods
__bashClass.registerMethod Container itemAt Container.itemAt
__bashClass.registerMethod Container setAt Container.setAt
__bashClass.registerMethod Container get Container.get
__bashClass.registerMethod Container set Container.set
__bashClass.registerMethod Container delete Container.delete
__bashClass.registerMethod Container length Container.length
__bashClass.registerMethod Container clear Container.clear
__bashClass.registerMethod Container has Container.has
__bashClass.registerMethod Container toArray Container.toArray
__bashClass.registerMethod Container isEmpty Container.isEmpty
__bashClass.registerMethod Container new Container.new
__bashClass.registerMethod Container destroy Container.destroy
__bashClass.registerMethod Container toString Container.toString
__bashClass.registerClass Container

# Augment bashClass with container-aware traversal methods.
# These are registered on bashClass so every object (Container or not)
# can traverse containers stored in its properties. The functions are
# defined above as __bashClass.itemFrom and __bashClass.setOn.
# The bashClass methods= descriptor is updated so new objects created
# after Container loads get stubs for these methods automatically.
__bashClass.registerMethod bashClass itemFrom __bashClass.itemFrom
__bashClass.registerMethod bashClass setOn __bashClass.setOn

# Append to bashClass's methods list so stubAll picks them up
__bashClass_registry["bashClass"]="${__bashClass_registry["bashClass"]/|methods=/|methods=itemFrom,setOn,}"
