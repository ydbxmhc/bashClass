#!/bin/bash

# Container — virtual base class for all container types.
#
# Defines the interface contract that child classes (List, Map, Stack,
# Queue, LinkedList, etc.) must implement. This is bash's version of an
# abstract class — virtual methods crash with a clear error if a child
# forgets to override them.
#
# Architecture:
#   Container data lives in companion bash arrays, NOT in the pipe-delimited
#   descriptor. Each instance owns a global array named __bashClass_data_${self}.
#   Child constructors declare it as indexed (-ga) or associative (-gA).
#   The descriptor only holds metadata (class, parent, type).
#
# Why companion arrays instead of descriptor storage:
#   Bash arrays can't be nested inside associative arrays. Encoding a list
#   into a pipe-delimited string would require escaping delimiters inside
#   delimiters — fragile and slow. Companion arrays give us native bash
#   performance for element access while the object system handles identity,
#   dispatch, and lifecycle.
#
# Inheritance hierarchy:
#   bashClass → Container → List (indexed)
#                         → Map  (associative)
#                         → Stack, Queue, etc. (future)
#
# Iterator (companion class, defined in this file):
#   bashClass → Iterator
#   Iterator is a standalone cursor object that holds a reference to a
#   Container and a position. It is NOT a Container subclass — it doesn't
#   hold data and doesn't fulfill the Container contract. It exists because
#   of Container and is useless without one.
#
#   Every Container gets lazy iterator delegation: calling $list.next or
#   $map.hasNext auto-creates an internal Iterator on first use and
#   forwards to it. For independent cursors, create Iterators explicitly:
#     into=iter Iterator target="$list" target_class="List"
#
#   Subclasses that don't want iterators call $self.noIterators in their
#   constructor to wall off all iterator methods with a clear error.
#
# Virtual methods (child MUST override): get, set, delete, length, clear, has, toArray
# Provided methods (inherited, work for all): isEmpty, new, destroy, toString
# Iterator delegation (lazy): next, prev, hasNext, hasPrev, current, iterIndex, iterReset

# Load guard — if already registered, nothing to do
[[ -n "${__bashClass_registry[Container]+set}" ]] && return 2>/dev/null

. boop

# ============================================================================
# Container Class Descriptor
# ============================================================================

__bashClass_registry["Container"]="|class=Container|parent=bashClass|methods=new,destroy,length,clear,has,get,set,delete,isEmpty,toArray,toString,itemAt,setAt,each,iterator,next,prev,hasNext,hasPrev,current,iterIndex,iterReset,noIterators|properties=type"

# ============================================================================
# Virtual methods — child classes MUST override these.
# Each one crashes with a message naming the actual child class ($class),
# not "Container", so the error tells you exactly which class forgot to
# implement the method. This is the closest bash gets to a pure virtual.
# ============================================================================

Container.get() {
  local -I _Self _Class
  __bashClass.crash "$_Class must implement 'get'"
}

Container.set() {
  local -I _Self _Class
  __bashClass.crash "$_Class must implement 'set'"
}

Container.delete() {
  local -I _Self _Class
  __bashClass.crash "$_Class must implement 'delete'"
}

Container.length() {
  local -I _Self _Class
  __bashClass.crash "$_Class must implement 'length'"
}

Container.clear() {
  local -I _Self _Class
  __bashClass.crash "$_Class must implement 'clear'"
}

Container.has() {
  local -I _Self _Class
  __bashClass.crash "$_Class must implement 'has'"
}

Container.toArray() {
  local -I _Self _Class
  __bashClass.crash "$_Class must implement 'toArray'"
}

Container.each() {
  local -I _Self _Class
  __bashClass.crash "$_Class must implement 'each'"
}

# ============================================================================
# Provided methods — work for all containers via delegation.
# ============================================================================

Container.isEmpty() {
  local -I _Self _Class
  local __Container_isEmpty_len
  into=__Container_isEmpty_len _Self="$_Self" _Class="$_Class" __bashClass.dispatch length
  (( __Container_isEmpty_len == 0 )) && return 0 || return 1
}

# ============================================================================
# Iterator delegation — lazy auto-creation of internal Iterator.
#
# Each Container instance can have an implicit Iterator stored in its
# _iterator descriptor property. The first call to any delegation method
# (next, prev, hasNext, etc.) creates the Iterator if it doesn't exist,
# then forwards the call. This gives every container $list.next syntax
# with zero cost if never used.
#
# For independent cursors, create Iterators explicitly via:
#   into=iter Iterator target="$list" target_class="List"
# ============================================================================

# Internal helper — ensure the lazy iterator exists, store its ID in $3.
# Uses __bashClass.set (descriptor property) not Container.set (data storage).
__Container._ensureIterator() {
  local __cei_self="$1" __cei_class="$2" __cei_target="$3"
  local __cei_iter
  __bashClass.parse "$__cei_self" "_iterator" __cei_iter
  if [[ -z "$__cei_iter" ]]; then
    into=__cei_iter Iterator target="$__cei_self" target_class="$__cei_class"
    # Store in descriptor, not in container data
    local __cei_encoded
    __bashClass.encode "$__cei_iter" __cei_encoded
    local __cei_desc="${__bashClass_registry[$__cei_self]:-}"
    __bashClass_registry[$__cei_self]="$__cei_desc|_iterator=$__cei_encoded"
  fi
  local -n __cei_ref="$__cei_target"
  __cei_ref="$__cei_iter"
}

# Create an explicit Iterator over this container.
# Returns a new Iterator object every time — independent from the
# lazy internal one. Callers manage its lifecycle.
#
# Usage: into=iter $list.iterator
#        while $iter.hasNext; do
#          into=val $iter.next
#        done
Container.iterator() {
  local -I _Self _Class
  local __Container_iter_obj
  into=__Container_iter_obj Iterator target="$_Self" target_class="$_Class"
  __bashClass.return "$__Container_iter_obj" ${into:-}
}

# Advance the internal iterator and return the next value.
Container.next() {
  local -I _Self _Class
  local __Container_next_iter
  __Container._ensureIterator "$_Self" "$_Class" __Container_next_iter
  into=__Container_next_val _Self="$__Container_next_iter" _Class=Iterator __bashClass.dispatch next
  __bashClass.return "$__Container_next_val" ${into:-}
}

# Move the internal iterator backward and return the value.
Container.prev() {
  local -I _Self _Class
  local __Container_prev_iter
  __Container._ensureIterator "$_Self" "$_Class" __Container_prev_iter
  into=__Container_prev_val _Self="$__Container_prev_iter" _Class=Iterator __bashClass.dispatch prev
  __bashClass.return "$__Container_prev_val" ${into:-}
}

# Check if the internal iterator has more elements ahead.
Container.hasNext() {
  local -I _Self _Class
  local __Container_hn_iter
  __Container._ensureIterator "$_Self" "$_Class" __Container_hn_iter
  _Self="$__Container_hn_iter" _Class=Iterator __bashClass.dispatch hasNext
}

# Check if the internal iterator has elements behind.
Container.hasPrev() {
  local -I _Self _Class
  local __Container_hp_iter
  __Container._ensureIterator "$_Self" "$_Class" __Container_hp_iter
  _Self="$__Container_hp_iter" _Class=Iterator __bashClass.dispatch hasPrev
}

# Return the value at the internal iterator's current position.
Container.current() {
  local -I _Self _Class
  local __Container_cur_iter
  __Container._ensureIterator "$_Self" "$_Class" __Container_cur_iter
  into=__Container_cur_val _Self="$__Container_cur_iter" _Class=Iterator __bashClass.dispatch current
  __bashClass.return "$__Container_cur_val" ${into:-}
}

# Return the key/index at the internal iterator's current position.
Container.iterIndex() {
  local -I _Self _Class
  local __Container_idx_iter
  __Container._ensureIterator "$_Self" "$_Class" __Container_idx_iter
  into=__Container_idx_val _Self="$__Container_idx_iter" _Class=Iterator __bashClass.dispatch index
  __bashClass.return "$__Container_idx_val" ${into:-}
}

# Reset the internal iterator to before the first element.
Container.iterReset() {
  local -I _Self _Class
  local __Container_rst_iter
  __Container._ensureIterator "$_Self" "$_Class" __Container_rst_iter
  _Self="$__Container_rst_iter" _Class=Iterator __bashClass.dispatch reset
}

# Disable all iterator methods on this instance. Call from a subclass
# constructor to opt out of iterator support entirely.
#
# Usage (in a subclass constructor):
#   $_Self.noIterators
Container.noIterators() {
  local -I _Self _Class
  local __noi_method
  for __noi_method in iterator next prev hasNext hasPrev current iterIndex iterReset; do
    eval "$_Self.$__noi_method() { __bashClass.crash '$_Class does not support iterators'; }"
  done
}

# ============================================================================
# Constructor / Destructor / toString
# ============================================================================

Container.new() {
  local -I _Class
  : "${_Class:=Container}"
  local __Container_new_self
  into=__Container_new_self __bashClass.new "$@"
  __bashClass.return "$__Container_new_self" ${into:-}
}

Container.destroy() {
  local -I _Self _Class
  unset "__bashClass_data_${_Self}"
  unset "__bashClass_registry[$_Self]"
}

Container.toString() {
  local -I _Self _Class
  local -l prettyPrint; : "${prettyPrint:=false}"
  [[ "${1:-}" == "pretty" ]] && prettyPrint=true
  local __Container_ts_len __Container_ts_type
  into=__Container_ts_len _Self="$_Self" _Class="$_Class" __bashClass.dispatch length
  __bashClass.parse "$_Self" "type" __Container_ts_type

  if [[ "$prettyPrint" != "true" ]]; then
    __bashClass.return "$_Class($_Self){ type=$__Container_ts_type length=$__Container_ts_len }" ${into:-}
    return
  fi

  local __Container_ts_out
  printf -v __Container_ts_out "%s(%s) {\n  type   = %s\n  length = %s\n}" \
    "$_Class" "$_Self" "$__Container_ts_type" "$__Container_ts_len"
  __bashClass.return "$__Container_ts_out" ${into:-}
}

# ============================================================================
# Deep Traversal — itemAt / setAt
#
# IMPORTANT — why these methods use explicit dispatch instead of $cursor.get:
#
#   Traversal methods dispatch to multiple different objects of potentially
#   different classes in sequence. `local -I` leaks class identity across
#   calls, so we track the cursor's class explicitly and pass _Self=/_Class=
#   as environment prefixes on every dispatch call.
# ============================================================================

Container.itemAt() {
  local -I _Self _Class
  local __Container_itemAt_cursor="$_Self" __Container_itemAt_class="$_Class"
  while (( $# > 1 )); do
    into=__Container_itemAt_cursor _Self="$__Container_itemAt_cursor" _Class="$__Container_itemAt_class" __bashClass.dispatch get "$1"
    [[ -n "$__Container_itemAt_cursor" ]] || { __bashClass.return "" ${into:-}; return; }
    __bashClass.parse "$__Container_itemAt_cursor" "class" __Container_itemAt_class
    shift
  done
  _Self="$__Container_itemAt_cursor" _Class="$__Container_itemAt_class" into=__Container_itemAt_cursor __bashClass.dispatch get "$1"
  __bashClass.return "$__Container_itemAt_cursor" ${into:-}
}

Container.setAt() {
  local -I _Self _Class
  local __Container_setAt_val="$1"; shift
  local __Container_setAt_cursor="$_Self" __Container_setAt_class="$_Class"
  while (( $# > 1 )); do
    into=__Container_setAt_cursor _Self="$__Container_setAt_cursor" _Class="$__Container_setAt_class" __bashClass.dispatch get "$1"
    [[ -n "$__Container_setAt_cursor" ]] || \
      __bashClass.crash "setAt: missing intermediate at '$1'"
    __bashClass.parse "$__Container_setAt_cursor" "class" __Container_setAt_class
    shift
  done
  _Self="$__Container_setAt_cursor" _Class="$__Container_setAt_class" __bashClass.dispatch set "$1" "$__Container_setAt_val"
}

# ============================================================================
# Deep Traversal — itemFrom / setOn (bashClass augmentation)
#
# Registered on bashClass so ALL objects can use them. Loading Container
# adds container-awareness to the entire object system.
# ============================================================================

__bashClass.itemFrom() {
  local -I _Self _Class
  local __itemFrom_cursor __itemFrom_class
  __bashClass.parse "$_Self" "$1" __itemFrom_cursor
  [[ -n "$__itemFrom_cursor" ]] || { __bashClass.return "" ${into:-}; return; }
  __bashClass.parse "$__itemFrom_cursor" "class" __itemFrom_class
  shift
  while (( $# > 1 )); do
    into=__itemFrom_cursor _Self="$__itemFrom_cursor" _Class="$__itemFrom_class" __bashClass.dispatch get "$1"
    [[ -n "$__itemFrom_cursor" ]] || { __bashClass.return "" ${into:-}; return; }
    __bashClass.parse "$__itemFrom_cursor" "class" __itemFrom_class
    shift
  done
  _Self="$__itemFrom_cursor" _Class="$__itemFrom_class" into=__itemFrom_cursor __bashClass.dispatch get "$1"
  __bashClass.return "$__itemFrom_cursor" ${into:-}
}

__bashClass.setOn() {
  local -I _Self _Class
  local __setOn_cursor __setOn_class
  __bashClass.parse "$_Self" "$1" __setOn_cursor
  [[ -n "$__setOn_cursor" ]] || __bashClass.crash "setOn: property '$1' is empty"
  __bashClass.parse "$__setOn_cursor" "class" __setOn_class
  shift
  local __setOn_val="$1"; shift
  while (( $# > 1 )); do
    into=__setOn_cursor _Self="$__setOn_cursor" _Class="$__setOn_class" __bashClass.dispatch get "$1"
    [[ -n "$__setOn_cursor" ]] || \
      __bashClass.crash "setOn: missing intermediate at '$1'"
    __bashClass.parse "$__setOn_cursor" "class" __setOn_class
    shift
  done
  _Self="$__setOn_cursor" _Class="$__setOn_class" __bashClass.dispatch set "$1" "$__setOn_val"
}

# ============================================================================
# Iterator — companion class (bashClass → Iterator)
#
# Stateful cursor for traversing Container subclasses. Holds a reference
# to a container (target) and a position. NOT a Container subclass — it
# doesn't hold data and doesn't fulfill the Container contract.
#
# Defined here because Iterator is useless without Container and Container
# benefits from having it always available. No separate file to load.
#
# Position semantics:
#   -1 = before first element (initial state)
#   0..length-1 = on an element
#
# For List: walks elements in index order (0, 1, 2, ...).
# For Map: snapshots the ordered key list at creation time and walks
#   keys in insertion order. Mutations to the Map after creation don't
#   affect the snapshot — predictable traversal over live-view.
#
# Usage (explicit):
#   into=iter Iterator target="$list" target_class="List"
#   while $iter.hasNext; do
#     into=val $iter.next
#     into=idx $iter.index
#   done
#
# Usage (via Container delegation — lazy, auto-created):
#   while $list.hasNext; do
#     into=val $list.next
#   done
# ============================================================================

__bashClass_registry["Iterator"]="|class=Iterator|parent=bashClass|methods=new,hasNext,hasPrev,next,prev,current,index,reset|properties=target,target_class"

# Constructor — creates an Iterator bound to a container.
# Required args: target=<objectID> target_class=<className>
Iterator.new() {
  local -I _Class
  : "${_Class:=Iterator}"

  local __Iter_new_target="" __Iter_new_tclass=""
  local __Iter_new_arg
  for __Iter_new_arg in "$@"; do
    case "$__Iter_new_arg" in
      target=*)       __Iter_new_target="${__Iter_new_arg#target=}" ;;
      target_class=*) __Iter_new_tclass="${__Iter_new_arg#target_class=}" ;;
    esac
  done

  [[ -n "$__Iter_new_target" ]] || __bashClass.crash "Iterator: target is required"
  [[ -n "$__Iter_new_tclass" ]] || __bashClass.crash "Iterator: target_class is required"

  local __Iter_new_self
  into=__Iter_new_self __bashClass.new target="$__Iter_new_target" target_class="$__Iter_new_tclass" position=-1

  # For Map targets, snapshot the ordered key list
  if [[ "$__Iter_new_tclass" == "Map" ]]; then
    declare -ga "__bashClass_iterkeys_${__Iter_new_self}"
    local -n __Iter_new_keys="__bashClass_keys_${__Iter_new_target}"
    local -n __Iter_new_snap="__bashClass_iterkeys_${__Iter_new_self}"
    if [[ -n "${!__Iter_new_keys[@]}" ]] && (( ${#__Iter_new_keys[@]} > 0 )); then
      __Iter_new_snap=("${__Iter_new_keys[@]}")
    fi
  fi

  __bashClass.return "$__Iter_new_self" ${into:-}
}

# Internal helper — get the length of the target container into $2.
__Iterator._targetLen() {
  local __itl_self="$1"
  local __itl_target __itl_tclass
  __bashClass.parse "$__itl_self" "target" __itl_target
  __bashClass.parse "$__itl_self" "target_class" __itl_tclass
  local -n __itl_out="$2"

  if [[ "$__itl_tclass" == "Map" ]]; then
    local -n __itl_snap="__bashClass_iterkeys_${__itl_self}"
    if [[ -n "${!__itl_snap[@]}" ]]; then
      __itl_out=${#__itl_snap[@]}
    else
      __itl_out=0
    fi
  else
    local -n __itl_arr="__bashClass_data_${__itl_target}"
    if [[ -n "${!__itl_arr[@]}" ]]; then
      __itl_out=${#__itl_arr[@]}
    else
      __itl_out=0
    fi
  fi
}

Iterator.hasNext() {
  local -I _Self _Class
  local __Iter_hn_pos
  __bashClass.parse "$_Self" "position" __Iter_hn_pos
  : "${__Iter_hn_pos:=-1}"
  local -i __Iter_hn_len
  __Iterator._targetLen "$_Self" __Iter_hn_len
  (( __Iter_hn_pos + 1 < __Iter_hn_len )) && return 0 || return 1
}

Iterator.hasPrev() {
  local -I _Self _Class
  local __Iter_hp_pos
  __bashClass.parse "$_Self" "position" __Iter_hp_pos
  : "${__Iter_hp_pos:=-1}"
  (( __Iter_hp_pos > 0 )) && return 0 || return 1
}

Iterator.next() {
  local -I _Self _Class
  local __Iter_next_pos
  __bashClass.parse "$_Self" "position" __Iter_next_pos
  : "${__Iter_next_pos:=-1}"
  local -i __Iter_next_len
  __Iterator._targetLen "$_Self" __Iter_next_len

  (( __Iter_next_pos + 1 < __Iter_next_len )) || \
    __bashClass.crash "Iterator: no more elements (next)"

  (( __Iter_next_pos++ ))
  _Self="$_Self" _Class=Iterator __bashClass.dispatch set position "$__Iter_next_pos"

  local __Iter_next_target __Iter_next_tclass
  __bashClass.parse "$_Self" "target" __Iter_next_target
  __bashClass.parse "$_Self" "target_class" __Iter_next_tclass

  if [[ "$__Iter_next_tclass" == "Map" ]]; then
    local -n __Iter_next_snap="__bashClass_iterkeys_${_Self}"
    local __Iter_next_key="${__Iter_next_snap[$__Iter_next_pos]}"
    local -n __Iter_next_data="__bashClass_data_${__Iter_next_target}"
    __bashClass.return "${__Iter_next_data[$__Iter_next_key]:-}" ${into:-}
  else
    local -n __Iter_next_arr="__bashClass_data_${__Iter_next_target}"
    __bashClass.return "${__Iter_next_arr[$__Iter_next_pos]}" ${into:-}
  fi
}

Iterator.prev() {
  local -I _Self _Class
  local __Iter_prev_pos
  __bashClass.parse "$_Self" "position" __Iter_prev_pos
  : "${__Iter_prev_pos:=-1}"

  (( __Iter_prev_pos > 0 )) || \
    __bashClass.crash "Iterator: no previous element (prev)"

  (( __Iter_prev_pos-- ))
  _Self="$_Self" _Class=Iterator __bashClass.dispatch set position "$__Iter_prev_pos"

  local __Iter_prev_target __Iter_prev_tclass
  __bashClass.parse "$_Self" "target" __Iter_prev_target
  __bashClass.parse "$_Self" "target_class" __Iter_prev_tclass

  if [[ "$__Iter_prev_tclass" == "Map" ]]; then
    local -n __Iter_prev_snap="__bashClass_iterkeys_${_Self}"
    local __Iter_prev_key="${__Iter_prev_snap[$__Iter_prev_pos]}"
    local -n __Iter_prev_data="__bashClass_data_${__Iter_prev_target}"
    __bashClass.return "${__Iter_prev_data[$__Iter_prev_key]:-}" ${into:-}
  else
    local -n __Iter_prev_arr="__bashClass_data_${__Iter_prev_target}"
    __bashClass.return "${__Iter_prev_arr[$__Iter_prev_pos]}" ${into:-}
  fi
}

Iterator.current() {
  local -I _Self _Class
  local __Iter_cur_pos
  __bashClass.parse "$_Self" "position" __Iter_cur_pos
  : "${__Iter_cur_pos:=-1}"
  local -i __Iter_cur_len
  __Iterator._targetLen "$_Self" __Iter_cur_len

  (( __Iter_cur_pos >= 0 && __Iter_cur_pos < __Iter_cur_len )) || \
    __bashClass.crash "Iterator: cursor not on an element"

  local __Iter_cur_target __Iter_cur_tclass
  __bashClass.parse "$_Self" "target" __Iter_cur_target
  __bashClass.parse "$_Self" "target_class" __Iter_cur_tclass

  if [[ "$__Iter_cur_tclass" == "Map" ]]; then
    local -n __Iter_cur_snap="__bashClass_iterkeys_${_Self}"
    local __Iter_cur_key="${__Iter_cur_snap[$__Iter_cur_pos]}"
    local -n __Iter_cur_data="__bashClass_data_${__Iter_cur_target}"
    __bashClass.return "${__Iter_cur_data[$__Iter_cur_key]:-}" ${into:-}
  else
    local -n __Iter_cur_arr="__bashClass_data_${__Iter_cur_target}"
    __bashClass.return "${__Iter_cur_arr[$__Iter_cur_pos]}" ${into:-}
  fi
}

Iterator.index() {
  local -I _Self _Class
  local __Iter_idx_pos
  __bashClass.parse "$_Self" "position" __Iter_idx_pos
  : "${__Iter_idx_pos:=-1}"
  local -i __Iter_idx_len
  __Iterator._targetLen "$_Self" __Iter_idx_len

  (( __Iter_idx_pos >= 0 && __Iter_idx_pos < __Iter_idx_len )) || \
    __bashClass.crash "Iterator: cursor not on an element"

  local __Iter_idx_tclass
  __bashClass.parse "$_Self" "target_class" __Iter_idx_tclass

  if [[ "$__Iter_idx_tclass" == "Map" ]]; then
    local -n __Iter_idx_snap="__bashClass_iterkeys_${_Self}"
    __bashClass.return "${__Iter_idx_snap[$__Iter_idx_pos]}" ${into:-}
  else
    __bashClass.return "$__Iter_idx_pos" ${into:-}
  fi
}

Iterator.reset() {
  local -I _Self _Class
  _Self="$_Self" _Class=Iterator __bashClass.dispatch set position "-1"
}

